def data_home() -> Path:
    base = os.environ.get("XDG_DATA_HOME") or os.path.expanduser("~/.local/share")
    return Path(base) / "sakar"

def config_home() -> Path:
    base = os.environ.get("XDG_CONFIG_HOME") or os.path.expanduser("~/.config")
    return Path(base) / "sakar"

def state_home() -> Path:
    base = os.environ.get("XDG_STATE_HOME") or os.path.expanduser("~/.local/state")
    return Path(base) / "sakar"

def runtime_home() -> Path:
    base = os.environ.get("XDG_RUNTIME_DIR")
    return Path(base) / "sakar" if base else data_home()

def sock_path() -> str:
    return str(runtime_home() / "sakar.sock")

def mitm_confdir() -> Path:
    return data_home() / "mitmproxy"

def ca_cert_path() -> Path:
    return mitm_confdir() / "mitmproxy-ca-cert.pem"

def deny_file() -> Path:
    return config_home() / "deny"

def allow_file() -> Path:
    return config_home() / "allow"

def _ensure_dirs() -> None:
    for p in (data_home(), config_home(), runtime_home(), mitm_confdir(), state_home()):
        p.mkdir(parents=True, exist_ok=True)

