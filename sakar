# ════════════════════════════════════════════════════════════════════════════
#  Frame encode/decode (one frame type: RELAY)
# ════════════════════════════════════════════════════════════════════════════

FRAME_RELAY = 1

# Max ancillary FDs accepted per recvmsg (CMSG space sizing) and the muxed-socket
# limits, kept in sync between the send and receive sides.
MAX_FDS_PER_MSG = 16
MAX_FRAME_BUFFER = 1 << 20   # 1 MiB cap on buffered-but-unparsed frame bytes
RECV_CHUNK = 65536           # bytes per recvmsg from the muxed channel

def encode_frame(ftype: int, payload: bytes = b"") -> bytes:
    """Encode one typed frame: [total-len:4 BE][type:1][payload]. total-len counts the
    type byte + payload. Module-level + pure so it is unit-testable without a socket."""
    return struct.pack("!I", 1 + len(payload)) + bytes([ftype & 0xFF]) + payload

def decode_frames(buf: bytes) -> "tuple[list, bytes]":
    """Decode as many whole frames as `buf` holds. Returns (frames, remainder) where
    frames is [(ftype, payload)] and remainder is the trailing partial frame."""
    out = []
    i = 0
    n = len(buf)
    while n - i >= 4:
        (tot,) = struct.unpack("!I", buf[i:i + 4])
        if n - (i + 4) < tot:
            break
        ftype = buf[i + 4]
        payload = buf[i + 5:i + 4 + tot]
        out.append((ftype, payload))
        i += 4 + tot
    return out, buf[i:]

# ════════════════════════════════════════════════════════════════════════════
#  Synthetic DNS — stable 127/8 IPs for proxy-unaware clients
# ════════════════════════════════════════════════════════════════════════════

class SyntheticDNS:
    """Allocates stable synthetic 127/8 IPv4 addresses for domains and reverses them.

    Pool: 127.0.0.0/8 minus the two reserved rendezvous IPs (127.0.0.1 = inner proxy
    listener, 127.0.0.53 = this resolver) and the broadcast-ish 127.0.0.0. Same domain
    always maps to the same IP (dedup, so a chatty resolver can't exhaust the pool);
    pool exhaustion raises so the caller can answer SERVFAIL."""

    _LO_NET = 0x7F000000
    _LO_BCAST = 0x7FFFFFFF
    _RESERVED = frozenset({0x7F000000, 0x7F000001, 0x7F000035})  # .0, proxy .1, dns .53

    def __init__(self):
        self._lock = threading.Lock()
        self._by_domain: dict[str, str] = {}
        self._by_ip: dict[str, str] = {}
        self._next = self._LO_NET + 2

    def ip_for(self, domain: str) -> str:
        """Stable synthetic IP for `domain`. Raises RuntimeError on pool exhaustion."""
        domain = domain.lower().rstrip(".")
        with self._lock:
            ip = self._by_domain.get(domain)
            if ip is not None:
                return ip
            n = self._next
            while n < self._LO_BCAST:
                if n not in self._RESERVED:
                    ipstr = socket.inet_ntoa(struct.pack("!I", n))
                    self._next = n + 1
                    self._by_domain[domain] = ipstr
                    self._by_ip[ipstr] = domain
                    return ipstr
                n += 1
            raise RuntimeError("synthetic 127/8 pool exhausted")

    def domain_for(self, ip: str) -> "str | None":
        """Reverse lookup for the forwarders; None if `ip` was never handed out."""
        return self._by_ip.get(ip)


_DNS_QTYPE_A = 1
_DNS_QTYPE_AAAA = 28


def _dns_parse_question(pkt: bytes) -> "tuple[int, str, int] | None":
    """Return (txid, qname, qtype) for the first question, or None if malformed."""
    try:
        if len(pkt) < 12:
            return None
        txid, _flags, qdcount = struct.unpack("!HHH", pkt[:6])
        if qdcount < 1:
            return None
        pos = 12
        labels = []
        while True:
            if pos >= len(pkt):
                return None
            ln = pkt[pos]; pos += 1
            if ln == 0:
                break
            if ln & 0xC0:
                return None
            if pos + ln > len(pkt):
                return None
            labels.append(pkt[pos:pos + ln].decode("latin-1"))
            pos += ln
        if pos + 4 > len(pkt):
            return None
        qtype, _qclass = struct.unpack("!HH", pkt[pos:pos + 4])
        return txid, ".".join(labels), qtype
    except (struct.error, UnicodeError, IndexError):
        return None


def _dns_build_response(pkt: bytes, txid: int, *, rcode: int = 0,
                        a_ip: "str | None" = None, ttl: int = 30) -> bytes:
    """Build a response echoing the query's question section."""
    pos = 12
    while pos < len(pkt) and pkt[pos] != 0:
        pos += 1 + pkt[pos]
    qend = pos + 1 + 4
    question = pkt[12:qend]
    ancount = 1 if a_ip is not None else 0
    rd = pkt[2] & 0x01 if len(pkt) > 2 else 0
    # DNS header flags: QR=1 (response) | AA=1 (authoritative), the request's RD bit
    # echoed back (rd << 8), and the rcode in the low nibble.
    QR, AA = 0x8000, 0x0400
    flags = QR | AA | (rd << 8) | (rcode & 0x0F)
    header = struct.pack("!HHHHHH", txid, flags, 1, ancount, 0, 0)
    out = header + question
    if a_ip is not None:
        out += struct.pack("!HHHIH", 0xC00C, _DNS_QTYPE_A, 1, ttl, 4)
        out += socket.inet_aton(a_ip)
    return out


def _dns_handle_packet(pkt: bytes, dns: SyntheticDNS) -> "bytes | None":
    """Pure function: query bytes → response bytes (or None to drop malformed packet)."""
    q = _dns_parse_question(pkt)
    if q is None:
        return None
    txid, qname, qtype = q
    if qtype == _DNS_QTYPE_A:
        if not qname:
            return _dns_build_response(pkt, txid, rcode=0)
        try:
            ip = dns.ip_for(qname)
        except RuntimeError:
            return _dns_build_response(pkt, txid, rcode=2)
        return _dns_build_response(pkt, txid, a_ip=ip)
    return _dns_build_response(pkt, txid, rcode=0)

# ════════════════════════════════════════════════════════════════════════════
#  Process identity — what's behind a connection, for the approval prompt
# ════════════════════════════════════════════════════════════════════════════

def read_peer_ident(pid: int) -> dict:
    """Best-effort {exe, argv} of the in-box process `pid`, read from /proc.

    The in-box runner shares the box's PID namespace, so it can read the connecting
    process's /proc directly to label the connection in the approval prompt (e.g.
    "curl https://…"). Never raises; absent fields come back empty."""
    info = {"exe": "", "argv": []}
    try:
        with open(f"/proc/{pid}/cmdline", "rb") as f:
            info["argv"] = [p.decode("utf-8", "surrogateescape")
                            for p in f.read().split(b"\x00") if p]
    except OSError: pass
    try: info["exe"] = os.readlink(f"/proc/{pid}/exe")
    except OSError: pass
    return info

# ════════════════════════════════════════════════════════════════════════════
#  Policy: deny/allow wildcard files + interactive prompt
# ════════════════════════════════════════════════════════════════════════════

def _load_patterns(path: Path) -> list[str]:
    """Load wildcard patterns from a file; ignore #-comments and blank lines."""
    patterns = []
    try:
        for line in path.read_text().splitlines():
            line = line.split("#", 1)[0].strip()
            if line:
                patterns.append(line.lower())
    except OSError:
        pass
    return patterns

def _matches_any(host: str, patterns: list[str]) -> bool:
    h = host.lower()
    return any(fnmatch.fnmatch(h, p) for p in patterns)

def _append_to_file(path: Path, line: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with open(path, "a") as f:
        f.write(line + "\n")

def _notify(title: str, body: str) -> None:
    """Best-effort desktop notification — swallow all errors."""
    try:
        if sys.platform == "darwin":
            subprocess.run(
                ["osascript", "-e",
                 f'display notification "{body}" with title "{title}"'],
                timeout=2, capture_output=True)
        else:
            subprocess.run(["notify-send", title, body],
                           timeout=2, capture_output=True)
    except Exception:
        pass


class Policy:
    """File-based allow/deny policy with interactive terminal prompt."""

    def __init__(self):
        self._lock = asyncio.Lock()

    def _reload(self) -> "tuple[list[str], list[str]]":
        return _load_patterns(deny_file()), _load_patterns(allow_file())

    def precheck(self, host: str) -> "str | None":
        """Quick file-only check (no prompt). Returns 'deny', 'allow', or None (prompt)."""
        deny_pats, allow_pats = self._reload()
        if _matches_any(host, deny_pats):
            return "deny"
        if _matches_any(host, allow_pats):
            return "allow"
        return None

    async def decide(self, box_id: str, host: str, port: int, scheme: str,
                     url: str = "", proc: "dict | None" = None) -> dict:
        """Full policy decision: file check then optional interactive prompt."""
        deny_pats, allow_pats = self._reload()
        if _matches_any(host, deny_pats):
            return {"action": "deny"}
        if _matches_any(host, allow_pats):
            return {"action": "allow"}

        # Unknown host — prompt (or fail closed if non-interactive)
        if not sys.stdin.isatty():
            return {"action": "deny"}

        loop = asyncio.get_running_loop()

        def _prompt() -> str:
            exe = (proc or {}).get("exe", "?")
            argv = (proc or {}).get("argv", [])
            short_argv = " ".join(argv[:4]) if argv else ""
            dest_str = f"{scheme}://{host}:{port}"
            if url:
                dest_str += f"  ({url})"
            _notify(f"sakar [box {box_id}]", f"Allow {dest_str}?")
            print(f"\n[box {box_id}] Connection request", file=sys.stderr)
            print(f"  process: {exe}  {short_argv}", file=sys.stderr)
            print(f"  dest:    {dest_str}", file=sys.stderr)
            print("  [y]es once / [n]o once / [a]llow+save / [d]eny+save [n]: ",
                  end="", flush=True, file=sys.stderr)
            try:
                ans = input().strip().lower()
            except EOFError:
                ans = ""
            return ans

        async with self._lock:
            ans = await loop.run_in_executor(None, _prompt)

        if ans == "y":
            return {"action": "allow"}
        elif ans == "a":
            _append_to_file(allow_file(), host.lower())
            return {"action": "allow"}
        elif ans == "d":
            _append_to_file(deny_file(), host.lower())
            return {"action": "deny"}
        else:
            # "n", empty, or anything else → deny (fail closed)
            return {"action": "deny"}

# ════════════════════════════════════════════════════════════════════════════
#  Mitmproxy contextvars (per-connection)
# ════════════════════════════════════════════════════════════════════════════

# Mitmproxy invokes its addon hooks (request/response/http_connect) with only the
# flow; there is no way to thread this connection's box id, requester provenance, and
# intended destination through those signatures. We stash them in contextvars set just
# before handle_client(). Each relayed connection runs in its own task, so the values
# stay isolated per connection.
_CURRENT_BOX_ID: "contextvars.ContextVar[str]" = contextvars.ContextVar(
    "sakar_box_id", default="")
_CURRENT_PROV: "contextvars.ContextVar[dict]" = contextvars.ContextVar(
    "sakar_prov", default={})
_CURRENT_DEST: "contextvars.ContextVar[tuple | None]" = contextvars.ContextVar(
    "sakar_dest", default=None)

# ════════════════════════════════════════════════════════════════════════════
#  GatingAddon — gate each connection through Policy
# ════════════════════════════════════════════════════════════════════════════

class _GatingAddon:
    """Mitmproxy addon: gate each connection via Policy; log to stdout."""

    def __init__(self, policy: Policy):
        self.policy = policy

    def _normalize_direct_host(self, flow) -> bool:
        dest = _CURRENT_DEST.get()
        if dest is None:
            return True
        host, port, _scheme = dest
        if not host:
            return False
        if flow.request.host != host:
            flow.request.host = host
        return True

    def _deny(self, flow):
        from mitmproxy import http
        flow.metadata["sakar_denied"] = True
        flow.response = http.Response.make(
            403, b"sakar: denied\n", {"Content-Type": "text/plain"})

    async def _gate(self, flow, scheme: str, url: str = "") -> None:
        res = await self.policy.decide(
            _CURRENT_BOX_ID.get(), flow.request.host, flow.request.port, scheme, url,
            proc=_CURRENT_PROV.get())
        if res.get("action") != "allow":
            self._deny(flow)

    async def http_connect(self, flow):
        if not self._normalize_direct_host(flow):
            self._deny(flow); return
        flow.metadata["sakar_connect_gated"] = True
        await self._gate(flow, "https")

    async def request(self, flow):
        if not self._normalize_direct_host(flow):
            self._deny(flow)
            return
        url = flow.request.pretty_url
        if flow.request.scheme == "http":
            await self._gate(flow, "http", url)
        elif flow.metadata.get("sakar_connect_gated"):
            # Already gated at CONNECT; only enforce deny at URL level (no double-prompt).
            if self.policy.precheck(flow.request.host) == "deny":
                self._deny(flow)
        else:
            # Direct https (reverse mode, no CONNECT): gate once here.
            await self._gate(flow, "https", url)

    def response(self, flow):
        req, resp = flow.request, flow.response
        denied = bool(flow.metadata.get("sakar_denied"))
        action = "deny" if denied else "allow"
        box_id = _CURRENT_BOX_ID.get()
        status = resp.status_code if resp else 0
        resp_len = len(resp.content or b"") if resp else 0
        print(f"[box {box_id}] {action} {req.method} {req.pretty_url} {status} {resp_len}b",
              flush=True)

    def error(self, flow):
        box_id = _CURRENT_BOX_ID.get()
        print(f"[box {box_id}] error {flow.request.pretty_url if flow.request else '?'}",
              flush=True)

# ════════════════════════════════════════════════════════════════════════════
#  ProxyEngine — drive one mitmproxy session per relayed connection
# ════════════════════════════════════════════════════════════════════════════

class ProxyEngine:
    """Drive one mitmproxy connection per passed FD."""

    def __init__(self, policy: Policy,
                 loop: asyncio.AbstractEventLoop, flows_path: str):
        self.policy = policy
        self.loop = loop
        self._master = None
        self._opts = None
        self._mode = None
        self._reverse_cache: dict = {}
        self._ready = False
        try:
            from mitmproxy import options as moptions, addons, hooks as mhooks
            from mitmproxy.master import Master
            from mitmproxy.proxy import mode_specs
            opts = moptions.Options()
            master = Master(opts, event_loop=loop)
            master.addons.add(*addons.default_addons())
            master.addons.add(_GatingAddon(policy))
            opts.update(confdir=str(mitm_confdir()), server=False,
                        save_stream_file=flows_path)
            master.addons.trigger(mhooks.ConfigureHook(set(opts.keys())))
            self._master = master
            self._opts = opts
            self._mode = mode_specs.ProxyMode.parse("regular")
            self._ready = True
        except Exception as e:
            print(f"sakar: mitmproxy unavailable: {e}", file=sys.stderr)

    @property
    def ready(self) -> bool:
        return self._ready

    def _reverse_mode(self, scheme: str, host: str, port: int):
        from mitmproxy.proxy import mode_specs
        key = f"reverse:{scheme}://{host}:{port}"
        m = self._reverse_cache.get(key)
        if m is None:
            m = mode_specs.ProxyMode.parse(key)
            self._reverse_cache[key] = m
        return m

    async def handle_fd(self, fd: int, box_id: str, *, kind: str = "proxy",
                        dest: "tuple | None" = None) -> None:
        if not self._ready:
            try: os.close(fd)
            except OSError: pass
            return
        if kind == "direct" and (not dest or not dest[0]):
            try: os.close(fd)
            except OSError: pass
            return
        from mitmproxy.proxy.mode_servers import ProxyConnectionHandler
        from mitmproxy.proxy import layers

        sock = socket.socket(fileno=fd)
        sock.setblocking(False)
        try:
            reader, writer = await asyncio.open_connection(sock=sock)
        except OSError:
            try: sock.close()
            except OSError: pass
            return

        _CURRENT_BOX_ID.set(box_id)
        _CURRENT_DEST.set(dest)
        # kind="proxy": from a proxy-aware client (HTTP CONNECT / absolute-URI on the
        # in-box :8080 proxy) — mitmproxy runs in regular HttpProxy mode and learns the
        # destination from the request. kind="direct": from a catch-all-intercepted
        # connection (proxy-unaware client that dialed a synthetic IP) where we already
        # know host/port/scheme, so mitmproxy runs in ReverseProxy mode toward that dest.
        if kind == "direct":
            host, port, scheme = dest
            mode = self._reverse_mode(scheme, host, port)
            handler = ProxyConnectionHandler(
                self._master, reader, writer, self._opts, mode)
            handler.layer = layers.modes.ReverseProxy(handler.layer.context)
        else:
            handler = ProxyConnectionHandler(
                self._master, reader, writer, self._opts, self._mode)
            handler.layer = layers.modes.HttpProxy(handler.layer.context)
        try:
            await handler.handle_client()
        except Exception:
            pass
        finally:
            try: writer.close()
            except Exception: pass

# ════════════════════════════════════════════════════════════════════════════
#  Relay frame parsing
# ════════════════════════════════════════════════════════════════════════════

def _parse_relay_meta(payload: bytes) -> "tuple[str, tuple | None, dict]":
    """Parse a RELAY frame's meta JSON → (kind, dest, proc). `kind` is 'proxy' (the
    client named the destination, regular proxy) or 'direct' (catch-all already knows
    host/port/scheme, reverse proxy). `proc` is the connecting process's {exe, argv},
    read box-side by the runner, shown in the approval prompt."""
    kind, dest, proc = "proxy", None, {}
    if payload:
        try:
            meta = json.loads(payload.decode())
            if isinstance(meta, dict):
                if isinstance(meta.get("proc"), dict):
                    proc = meta["proc"]
                if meta.get("kind") == "direct":
                    kind = "direct"
                    dest = (str(meta.get("host", "")), int(meta.get("port", 0)),
                            str(meta.get("scheme", "https")))
        except (ValueError, TypeError, UnicodeDecodeError):
            kind, dest, proc = "proxy", None, {}
    return kind, dest, proc


async def relay_handle_fds(engine: ProxyEngine, box_id: str, fds: list,
                           payload: bytes) -> None:
    """Gate one caught connection — receive side of a RELAY frame. `fds` is the single
    relayed connection FD; the box is untrusted, so close any extras it slipped in."""
    if not fds:
        return
    for extra in fds[1:]:
        try: os.close(extra)
        except OSError: pass
    kind, dest, proc = _parse_relay_meta(payload)
    _CURRENT_PROV.set(proc)
    _CURRENT_DEST.set(dest)
    await engine.handle_fd(fds[0], box_id, kind=kind, dest=dest)

# ════════════════════════════════════════════════════════════════════════════
#  CA generation
# ════════════════════════════════════════════════════════════════════════════

# Canonical OS CA-bundle locations across distros. For each that exists, sakar binds
# an AUGMENTED copy (these roots + our proxy CA) over it inside the box, so clients
# that read the OS trust store trust the proxy with no per-tool configuration.
SYSTEM_CA_FILES = (
    "/etc/ssl/certs/ca-certificates.crt",
    "/etc/pki/tls/certs/ca-bundle.crt",
    "/etc/pki/ca-trust/extracted/pem/tls-ca-bundle.pem",
    "/etc/ssl/cert.pem",
    "/etc/ssl/ca-bundle.pem",
)

def primary_ca_path() -> "str | None":
    """First OS CA bundle that exists (what the in-box CA-bundle env vars point at)."""
    for f in SYSTEM_CA_FILES:
        if Path(f).is_file(): return f
    return None

def _augment_bundle(system_pem: bytes, ca_pem: bytes) -> bytes:
    """A CA bundle = the OS roots followed by our proxy CA, so a client validating
    against it trusts both real sites and the proxy's minted certs. Each block is
    stripped so the END of one PEM and the BEGIN of the next sit on their own lines."""
    return system_pem.strip() + b"\n" + ca_pem.strip() + b"\n"

def ensure_ca_cert() -> "Path | None":
    """Generate the mitmproxy CA cert if not already present.

    Uses mitmproxy.certs.CertStore.from_store() directly — no subprocess,
    no event loop required. Works in the uv-script env where mitmdump is not
    in PATH.
    """
    _ca = ca_cert_path()
    if _ca.exists(): return _ca
    _cd = mitm_confdir()
    _cd.mkdir(parents=True, exist_ok=True)
    try:
        from mitmproxy.certs import CertStore
        CertStore.from_store(_cd, "mitmproxy", 2048)
    except Exception as e:
        print(f"sakar: ensure_ca_cert: error generating CA: {e}", file=sys.stderr)
    if not _ca.exists():
        print("sakar: ensure_ca_cert: CA cert still not present after init",
              file=sys.stderr)
        return None
    return _ca

# ════════════════════════════════════════════════════════════════════════════
#  Runner-mode detection (ambient caps vs. user namespace)
# ════════════════════════════════════════════════════════════════════════════

def find_self() -> str:
    return os.path.abspath(sys.argv[0])

_BWRAP_HELP = None
def bwrap_supports(flag: str) -> bool:
    global _BWRAP_HELP
    if _BWRAP_HELP is None:
        try:
            r = subprocess.run(["bwrap", "--help"], capture_output=True,
                               text=True, timeout=5)
            _BWRAP_HELP = r.stdout + r.stderr
        except Exception:
            _BWRAP_HELP = ""
    return flag in _BWRAP_HELP

def _capeff_has_caps(capeff_hex: str) -> bool:
    try:
        bits = int(capeff_hex, 16)
    except (ValueError, TypeError):
        return False
    CAP_NET_ADMIN = 12
    CAP_SYS_ADMIN = 21
    return bool(bits & (1 << CAP_SYS_ADMIN)) and bool(bits & (1 << CAP_NET_ADMIN))

def _have_ambient_caps() -> bool:
    try:
        with open("/proc/self/status") as f:
            for line in f:
                if line.startswith("CapEff:"):
                    return _capeff_has_caps(line.split(":", 1)[1].strip())
    except OSError:
        return False
    return False

_USERNS_RUNNER_WORKS = None
def _userns_runner_works() -> bool:
    global _USERNS_RUNNER_WORKS
    if _USERNS_RUNNER_WORKS is not None:
        return _USERNS_RUNNER_WORKS
    try:
        r = subprocess.run(
            ["bwrap", "--unshare-user", "--unshare-net", "--dev-bind", "/", "/",
             "--cap-add", "CAP_SYS_ADMIN", "--cap-add", "CAP_NET_ADMIN",
             "--", "/bin/true"],
            capture_output=True, timeout=15)
        _USERNS_RUNNER_WORKS = (r.returncode == 0)
    except Exception:
        _USERNS_RUNNER_WORKS = False
    return _USERNS_RUNNER_WORKS

# ════════════════════════════════════════════════════════════════════════════
#  Server: control socket + box registry + mitmproxy
# ════════════════════════════════════════════════════════════════════════════

class Server:
    """Accept box connections, register them, serve RELAY frames to ProxyEngine."""

    def __init__(self):
        self._boxes: dict[str, dict] = {}   # box_id -> {prov, counters}
        self._box_counter = 0
        self._policy = Policy()
        self._engine: "ProxyEngine | None" = None
        self._loop: "asyncio.AbstractEventLoop | None" = None
        self._sock: "socket.socket | None" = None
        self._flows_path: str = ""

    async def start(self, flows_path: str) -> None:
        self._loop = asyncio.get_running_loop()
        self._flows_path = flows_path

        if not ca_cert_path().exists():
            print("sakar: CA cert not found; generating...", file=sys.stderr)
            if ensure_ca_cert() is None:
                print("sakar: FATAL: cannot generate CA cert; is mitmproxy installed?",
                      file=sys.stderr)
                sys.exit(1)

        self._engine = ProxyEngine(self._policy, self._loop, flows_path)
        if not self._engine.ready:
            print("sakar: FATAL: mitmproxy engine failed to start", file=sys.stderr)
            sys.exit(1)

        sp = sock_path()
        try: os.unlink(sp)
        except FileNotFoundError: pass
        self._sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        self._sock.bind(sp)
        os.chmod(sp, 0o600)
        self._sock.listen(128)
        self._sock.setblocking(False)

        print(f"sakar: listening on {sp}", flush=True)
        print(f"sakar: flows → {flows_path}", flush=True)
        print(f"sakar: CA cert → {ca_cert_path()}", flush=True)

        await self._accept_loop()

    async def _accept_loop(self) -> None:
        while True:
            try:
                conn, _ = await self._loop.sock_accept(self._sock)
            except (OSError, asyncio.CancelledError):
                break
            asyncio.create_task(self._handle(conn))

    async def _recvmsg_ready(self, conn: socket.socket) -> "tuple[bytes, list]":
        """Await readability then ONE non-blocking recvmsg.

        recvmsg (not recv) so we receive the SCM_RIGHTS connection FDs that ride
        alongside each RELAY frame's bytes."""
        while True:
            try:
                data, anc, _flags, _addr = conn.recvmsg(
                    RECV_CHUNK, socket.CMSG_SPACE(4 * MAX_FDS_PER_MSG))
                return data, anc
            except (BlockingIOError, InterruptedError):
                pass
            fut = self._loop.create_future()
            fd = conn.fileno()
            self._loop.add_reader(fd, lambda: fut.done() or fut.set_result(None))
            try:
                await fut
            finally:
                try: self._loop.remove_reader(fd)
                except (OSError, ValueError): pass

    async def _handle(self, conn: socket.socket) -> None:
        # Control phase: newline-JSON only (ping / register), no ancillary FDs — so a
        # plain async read suffices. On register the SAME connection becomes the box's
        # muxed channel, served by _serve_box, where the relayed connection FDs arrive.
        conn.setblocking(False)
        buf = b""
        try:
            while True:
                if b"\n" in buf:
                    line, buf = buf.split(b"\n", 1)
                    if line.strip():
                        reply, box_id = await self._dispatch(line)
                        if reply is not None:
                            try:
                                await self._loop.run_in_executor(
                                    None, self._send_reply, conn, reply)
                            except OSError:
                                pass
                            if box_id and reply.get("ok"):
                                await self._serve_box(conn, box_id, buf)
                                return
                    continue
                more = await self._loop.sock_recv(conn, 4096)
                if not more:
                    break
                if len(buf) + len(more) > MAX_FRAME_BUFFER:
                    break
                buf += more
        except (OSError, asyncio.CancelledError):
            pass
        finally:
            try: conn.close()
            except OSError: pass

    @staticmethod
    def _send_reply(conn: socket.socket, reply: dict) -> None:
        payload = (json.dumps(reply) + "\n").encode()
        conn.setblocking(True)
        try:
            conn.sendall(payload)
        finally:
            conn.setblocking(False)

    async def _dispatch(self, line: bytes) -> "tuple[dict | None, str | None]":
        """Returns (reply, box_id_if_register)."""
        try:
            msg = json.loads(line.decode())
        except json.JSONDecodeError:
            return None, None
        t = msg.get("type")
        if t == "ping":
            return {"ok": True}, None
        elif t == "register":
            self._box_counter += 1
            box_id = str(self._box_counter)
            cmd = msg.get("cmd") if isinstance(msg.get("cmd"), list) else []
            self._boxes[box_id] = {"cmd": cmd}
            print(f"[box {box_id}] started  {' '.join(cmd)}", flush=True)
            return {"ok": True, "box_id": box_id}, box_id
        return None, None

    async def _serve_box(self, conn: socket.socket, box_id: str,
                         leftover: bytes) -> None:
        """Serve the box's muxed channel: read RELAY frames, schedule engine tasks."""
        pending_fds: list = []
        buf = leftover
        try:
            while True:
                try:
                    data, anc = await self._recvmsg_ready(conn)
                except OSError:
                    break
                if not data and not anc:
                    break   # EOF: box exited
                for lvl, typ, adata in anc:
                    if lvl == socket.SOL_SOCKET and typ == socket.SCM_RIGHTS:
                        a = array.array("i"); a.frombytes(adata)
                        pending_fds.append(a.tolist())
                buf += data
                frames, buf = decode_frames(buf)
                for ftype, payload in frames:
                    if ftype == FRAME_RELAY:
                        fds = pending_fds.pop(0) if pending_fds else []
                        asyncio.create_task(
                            relay_handle_fds(self._engine, box_id, fds, payload))
                if len(buf) > MAX_FRAME_BUFFER:
                    break
        except (OSError, asyncio.CancelledError):
            pass
        finally:
            # Any connection FDs received but not yet matched to a RELAY frame (e.g.
            # on EOF mid-frame or buffer overflow) would otherwise leak; close them.
            for leftover_fds in pending_fds:
                for fd in leftover_fds:
                    try: os.close(fd)
                    except OSError: pass
            self._boxes.pop(box_id, None)
            print(f"[box {box_id}] exited", flush=True)

# ════════════════════════════════════════════════════════════════════════════
#  Shared child-process supervision (used by both run_inner and cmd_run)
# ════════════════════════════════════════════════════════════════════════════

def _controlling_tty_fd() -> "int | None":
    """The first of stdin/stdout/stderr that is a tty, or None if none is."""
    return next((fd for fd in (0, 1, 2) if os.isatty(fd)), None)

def _forward_signals_to_pgrp(pid: int) -> None:
    """Install SIGTERM/SIGINT handlers that forward to the child's process group.

    Both the launcher (cmd_run) and the in-box runner (run_inner) put the child in
    its own process group and want a signal aimed at us to take the whole group down,
    falling back to a single-process terminate() if the group kill fails."""
    def _sig(_s, _f):
        try:
            os.killpg(pid, signal.SIGTERM)
        except OSError:
            try: os.kill(pid, signal.SIGTERM)
            except OSError: pass
    signal.signal(signal.SIGTERM, _sig)
    signal.signal(signal.SIGINT, _sig)


@contextlib.contextmanager
def _terminal_foreground_guard(tty_fd: "int | None"):
    """Save the terminal's foreground process group and SIGTTOU disposition on entry,
    restore both on exit.

    Both cmd_run and run_inner put the child in its own process group; while it runs
    the child (run_inner) or bwrap (cmd_run) may become the terminal's foreground
    group. On teardown we must hand the terminal back to whoever held it before, and
    we ignore SIGTTOU meanwhile so our own tcsetpgrp calls don't stop us. Yields the
    saved foreground pgrp (or None) so callers that reassign it can read the original."""
    old_fg = None
    old_ttou = None
    if tty_fd is not None:
        old_ttou = signal.signal(signal.SIGTTOU, signal.SIG_IGN)
        try: old_fg = os.tcgetpgrp(tty_fd)
        except OSError: old_fg = None
    try:
        yield old_fg
    finally:
        if tty_fd is not None and old_fg is not None:
            try: os.tcsetpgrp(tty_fd, old_fg)
            except OSError: pass
        if old_ttou is not None:
            try: signal.signal(signal.SIGTTOU, old_ttou)
            except (OSError, ValueError): pass


# ════════════════════════════════════════════════════════════════════════════
#  Inner runner (in-box pid-1 — spawned by bwrap from cmd_run)
# ════════════════════════════════════════════════════════════════════════════

def run_inner(conn_fd: int, cmd: list) -> int:
    """In-box pid-1-ish process. Sets up network forwarders, then execs cmd."""
    stop = threading.Event()
    dns = SyntheticDNS()

    # The box has no route to the internet; its only egress is this one muxed unix
    # socket to the server. Rather than copy bytes in-box (and re-implement TLS/HTTP),
    # each forwarder hands the raw accepted connection FD to the server over SCM_RIGHTS
    # so the server's mitmproxy drives the connection host-side. All connections share
    # this single socket, each framed as a RELAY carrying its FD(s).
    chan = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM, fileno=conn_fd)
    chan_lock = threading.Lock()

    def _close_channel() -> None:
        """Shut down + close the muxed socket. The half-close is the teardown signal:
        the server sees EOF on this connection and tears the box down."""
        try: chan.shutdown(socket.SHUT_RDWR)
        except OSError: pass
        try: chan.close()
        except OSError: pass

    def _send_frame(ftype: int, payload: bytes, fds: "list | None" = None) -> None:
        frame = encode_frame(ftype, payload)
        try:
            with chan_lock:
                if fds:
                    chan.sendmsg([frame],
                                 [(socket.SOL_SOCKET, socket.SCM_RIGHTS,
                                   array.array("i", fds).tobytes())])
                else:
                    chan.sendall(frame)
        except OSError:
            pass

    def _peer_ident(conn: socket.socket) -> dict:
        """{exe, argv} of the in-box process that opened `conn`, for the prompt.

        SO_PEERCRED gives the kernel's view of the peer's pid in our (the box's) PID
        namespace; we read its /proc directly — same namespace, no translation needed.
        {} if the peer is already gone."""
        try:
            creds = conn.getsockopt(socket.SOL_SOCKET, socket.SO_PEERCRED,
                                    struct.calcsize("3i"))
            pid, _uid, _gid = struct.unpack("3i", creds)
        except OSError:
            return {}
        return read_peer_ident(pid) if pid > 0 else {}

    def forward_one(conn: socket.socket, meta: "dict | None" = None) -> None:
        """Hand the raw connection FD to the server as a RELAY frame. The meta JSON
        carries the connection's kind/destination plus the connecting process's
        {exe, argv} (read here, box-side) so the server can name it in the prompt."""
        meta = dict(meta) if meta else {"kind": "proxy"}
        meta["proc"] = _peer_ident(conn)
        try:
            _send_frame(FRAME_RELAY, json.dumps(meta).encode(), fds=[conn.fileno()])
        finally:
            conn.close()

    def _tcp_accept_loop(bind_ip: str, port: int, on_conn) -> None:
        """Bind a TCP listener and hand each accepted connection to on_conn on its own
        daemon thread, until `stop` is set. Shared by the proxy listener and the
        catch-all listeners (they differ only in bind address and per-conn handler)."""
        srv = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        srv.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        try:
            srv.bind((bind_ip, port))
            srv.listen(64)
        except OSError as e:
            print(f"sakar(inner): cannot listen :{port}: {e}", file=sys.stderr)
            return
        srv.settimeout(0.5)
        while not stop.is_set():
            try:
                conn, _ = srv.accept()
            except socket.timeout:
                continue
            except OSError:
                break
            threading.Thread(target=on_conn, args=(conn,), daemon=True).start()
        srv.close()

    def dns_server() -> None:
        srv = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        srv.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        try:
            srv.bind((INNER_DNS_ADDR, INNER_DNS_PORT))
        except OSError as e:
            print(f"sakar(inner): cannot bind DNS: {e}", file=sys.stderr)
            return
        srv.settimeout(0.5)
        while not stop.is_set():
            try:
                pkt, addr = srv.recvfrom(4096)
            except socket.timeout:
                continue
            except OSError:
                break
            try:
                resp = _dns_handle_packet(pkt, dns)
                if resp is not None:
                    srv.sendto(resp, addr)
            except OSError:
                pass
        srv.close()

    def _handle_catch_all(conn: socket.socket, port: int, scheme: str) -> None:
        try:
            dest_ip = conn.getsockname()[0]
        except OSError:
            conn.close(); return
        # Reverse the synthetic IP the resolver handed out back to its domain. A
        # 127/8 dest we never handed out means the client dialed an address we did
        # not authorize (e.g. a hardcoded direct IP); we fail closed and refuse it
        # rather than guess a destination.
        domain = dns.domain_for(dest_ip)
        if domain is None:
            conn.close(); return
        forward_one(conn, {"kind": "direct", "host": domain,
                           "port": port, "scheme": scheme})

    def catch_all(port: int, scheme: str) -> None:
        _tcp_accept_loop("0.0.0.0", port,
                         lambda conn: _handle_catch_all(conn, port, scheme))

    # Always run the network forwarders (sakar boxes are always networked).
    # Proxy listener on 127.0.0.1:8080 forwards each connection as-is (proxy-aware);
    # the catch-all listeners reverse the synthetic dest IP first (proxy-unaware).
    threading.Thread(
        target=lambda: _tcp_accept_loop("127.0.0.1", INNER_PROXY_PORT, forward_one),
        daemon=True).start()
    threading.Thread(target=dns_server, daemon=True).start()
    threading.Thread(target=catch_all,
                     args=(INNER_HTTP_PORT, "http"), daemon=True).start()
    threading.Thread(target=catch_all,
                     args=(INNER_HTTPS_PORT, "https"), daemon=True).start()

    # Run the command as a child process (NOT os.execvp — that would replace this
    # process and kill the forwarder threads, which must stay alive while the child
    # runs). This --inner process stays alive as pid-1 until the child exits, then
    # signals teardown by closing the muxed connection.
    try:
        proc = subprocess.Popen(cmd, preexec_fn=os.setpgrp)
    except FileNotFoundError:
        print(f"sakar(inner): command not found: {cmd[0]}", file=sys.stderr)
        stop.set()
        _close_channel()
        os._exit(127)
    except OSError as e:
        print(f"sakar(inner): exec failed: {e}", file=sys.stderr)
        stop.set()
        _close_channel()
        os._exit(1)

    tty_fd = _controlling_tty_fd()
    with _terminal_foreground_guard(tty_fd):
        try: os.setpgid(proc.pid, proc.pid)
        except OSError: pass
        if tty_fd is not None:
            # Hand the terminal foreground to the child so it can read stdin / get
            # job-control signals. (The launcher does NOT do this — it stays
            # foreground itself.)
            try: os.tcsetpgrp(tty_fd, proc.pid)
            except OSError: pass

        _forward_signals_to_pgrp(proc.pid)

        try:
            code = proc.wait()
        except KeyboardInterrupt:
            proc.terminate()
            code = proc.wait()

        stop.set()

    # Close the muxed connection: EOF → server sees box exited → teardown.
    _close_channel()

    # Hard-exit: --inner is pid-1 in the box. Daemon threads may still be in
    # blocking calls; normal interpreter shutdown races them. We've done cleanup.
    try: sys.stdout.flush()
    except Exception: pass
    try: sys.stderr.flush()
    except Exception: pass
    os._exit(code or 0)

# ════════════════════════════════════════════════════════════════════════════
#  cmd_run: `sakar -- CMD [ARGS...]`
# ════════════════════════════════════════════════════════════════════════════

def cmd_run(cmd: list) -> int:
    """Connect to the running sakar server and run CMD in an intercepted netns."""
    if not cmd:
        print("sakar: no command given", file=sys.stderr); return 2

    sp = sock_path()

    # Fail fast if server not running.
    try:
        with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as s:
            s.settimeout(2.0)
            s.connect(sp)
            ping = (json.dumps({"type": "ping"}) + "\n").encode()
            s.sendall(ping)
            line = s.makefile("rb").readline()
            ack = json.loads(line.decode()) if line.strip() else None
            if not ack or not ack.get("ok"):
                raise OSError("bad ping reply")
    except (OSError, json.JSONDecodeError):
        print(f"sakar: server not running.\n"
              f"  Start sakar first:  sakar\n"
              f"  (expected socket: {sp})", file=sys.stderr)
        return 3

    # Open ONE persistent connection for the register handshake + muxed channel.
    srv_conn = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    try:
        srv_conn.settimeout(30)
        srv_conn.connect(sp)
        # Register names the box by the command it runs (for the server's log); the
        # per-connection prompts name the actual connecting process, read box-side.
        payload = (json.dumps({"type": "register", "cmd": list(cmd)}) + "\n").encode()
        srv_conn.sendall(payload)
        buf = b""
        while b"\n" not in buf:
            chunk = srv_conn.recv(1)
            if not chunk:
                break
            buf += chunk
        line = buf.split(b"\n", 1)[0]
        ack = json.loads(line.decode()) if line.strip() else None
        if not ack or not ack.get("ok"):
            srv_conn.close()
            print("sakar: register failed", file=sys.stderr)
            return 1
        box_id = ack.get("box_id", "?")
        srv_conn.settimeout(None)
    except (OSError, json.JSONDecodeError) as e:
        try: srv_conn.close()
        except OSError: pass
        print(f"sakar: connection failed: {e}", file=sys.stderr)
        return 1

    _ca = ca_cert_path()
    if not _ca.exists():
        srv_conn.close()
        print("sakar: CA cert not found (is the server running and initialized?)",
              file=sys.stderr)
        return 1

    # Write a temp resolv.conf pointing to our synthetic DNS resolver.
    resolv_tmp = tempfile.NamedTemporaryFile(
        prefix="sakar-resolv-", suffix=".conf", delete=False, mode="w")
    resolv_tmp.write(f"nameserver {INNER_DNS_ADDR}\n")
    resolv_tmp.close()
    resolv_tmp_path = resolv_tmp.name

    # Build an augmented CA bundle (OS roots + our proxy CA) for every distinct OS
    # trust-store file that exists; bound over those paths below so clients that read
    # the OS store trust the proxy without any env var. One temp per distinct bundle
    # (deduped by realpath so a symlinked path isn't bound twice); cleaned up in finally.
    ca_pem = _ca.read_bytes()
    ca_bundle_binds: list = []      # (in-box target path, host temp file)
    ca_bundle_tmps: list = []       # temp files to unlink on exit
    _seen_ca: set = set()
    for _f in SYSTEM_CA_FILES:
        try:
            if not Path(_f).is_file():
                continue
            _rp = os.path.realpath(_f)
            if _rp in _seen_ca:
                continue
            _seen_ca.add(_rp)
            _tf = tempfile.NamedTemporaryFile(prefix="sakar-cabundle-",
                                              suffix=".pem", delete=False)
            _tf.write(_augment_bundle(Path(_rp).read_bytes(), ca_pem))
            _tf.close()
            ca_bundle_tmps.append(_tf.name)
            ca_bundle_binds.append((_rp, _tf.name))
        except OSError:
            continue
    ca_env_target = primary_ca_path() or str(_ca)   # in-box: now augmented

    tty_fd = _controlling_tty_fd()
    launched = False
    code = 1

    with _terminal_foreground_guard(tty_fd):
      try:
        conn_fd = srv_conn.fileno()
        os.set_inheritable(conn_fd, True)
        popen_pass_fds: tuple = (conn_fd,)

        # ── runner mode ───────────────────────────────────────────────────
        # Need CAP_SYS_ADMIN (unshare) + CAP_NET_ADMIN (loopback) + CAP_NET_BIND_SERVICE
        # (bind privileged ports 53/80/443 inside the box's netns).
        _force_userns = os.environ.get("SAKAR_FORCE_USERNS") == "1"
        if not _force_userns and _have_ambient_caps():
            _runner_mode = "ambient"
        elif _userns_runner_works():
            _runner_mode = "userns"
        else:
            print(
                "sakar: cannot create the runner sandbox.\n"
                "  No ambient CAP_SYS_ADMIN/CAP_NET_ADMIN and unprivileged user\n"
                "  namespaces are unavailable. To fix, either enable unprivileged\n"
                "  user namespaces (sysctl kernel.unprivileged_userns_clone=1, or\n"
                "  on Debian/Ubuntu kernel.apparmor_restrict_unprivileged_userns=0)\n"
                "  or run sakar with ambient CAP_SYS_ADMIN+CAP_NET_ADMIN.",
                file=sys.stderr)
            return 4

        unshare_args = ["--unshare-pid", "--unshare-ipc", "--unshare-uts",
                        "--unshare-net"]
        if _runner_mode == "userns":
            unshare_args.append("--unshare-user")

        # Caps: ambient keeps SYS_ADMIN+NET_ADMIN+NET_BIND_SERVICE; userns drops ALL
        # + adds only NET_BIND_SERVICE (the in-box forwarders need it for ports 53/80/443).
        if _runner_mode == "userns":
            cap_args = ["--cap-drop", "ALL", "--cap-add", "CAP_NET_BIND_SERVICE"]
        else:
            cap_args = ["--cap-drop", "ALL",
                        "--cap-add", "CAP_SYS_ADMIN",
                        "--cap-add", "CAP_NET_ADMIN",
                        "--cap-add", "CAP_NET_BIND_SERVICE"]

        # sakar leaves the filesystem alone — passthrough root (--dev-bind / /).
        # sakar's job is network isolation only, not filesystem isolation.
        bind_root_args = ["--dev-bind", "/", "/"]

        args = ["bwrap",
                *bind_root_args,
                "--proc", "/proc", "--dev", "/dev",
                "--ro-bind-try", "/sys", "/sys",
                "--tmpfs", "/tmp", "--tmpfs", "/run",
                # Point /etc/resolv.conf at our synthetic DNS resolver.
                "--ro-bind", resolv_tmp_path, "/etc/resolv.conf",
                *unshare_args,
                *cap_args, "--die-with-parent",
                "--chdir", os.getcwd()]

        if bwrap_supports("--as-pid-1"):
            args += ["--as-pid-1"]

        # Make in-box clients trust the proxy's CA, three complementary ways so we
        # don't depend on any one tool's convention:
        #   (a) bind the bare CA at its own path (NODE_EXTRA_CA_CERTS points there);
        #   (b) bind the augmented OS bundles over the OS trust store, so anything
        #       reading /etc/ssl/... trusts the proxy with no env var; and
        #   (c) point the common CA-bundle env vars at the (now-augmented) OS bundle.
        # (Tools with their own store — Java cacerts, NSS — read none of these and are
        # out of scope, as they were under any file-based scheme.)
        args += ["--ro-bind", str(_ca), str(_ca)]
        for _rp, _tmp in ca_bundle_binds:
            args += ["--ro-bind", _tmp, _rp]
        proxy = f"http://127.0.0.1:{INNER_PROXY_PORT}"
        for var in ("http_proxy", "https_proxy", "HTTP_PROXY", "HTTPS_PROXY"):
            args += ["--setenv", var, proxy]
        for var in ("REQUESTS_CA_BUNDLE", "SSL_CERT_FILE",
                    "CURL_CA_BUNDLE", "GIT_SSL_CAINFO"):
            args += ["--setenv", var, ca_env_target]
        args += ["--setenv", "NODE_EXTRA_CA_CERTS", str(_ca)]

        args += ["--", sys.executable, find_self(), "--inner",
                 "--conn-fd", str(conn_fd), "--", *cmd]

        proc = subprocess.Popen(args, preexec_fn=os.setpgrp,
                                pass_fds=popen_pass_fds)
        launched = True
        # Close OUR copy — --inner is now the sole holder; its exit → EOF → teardown.
        try: srv_conn.close()
        except OSError: pass
        try: os.setpgid(proc.pid, proc.pid)
        except OSError: pass

        _forward_signals_to_pgrp(proc.pid)

        code = proc.wait()
      finally:
        try: os.unlink(resolv_tmp_path)
        except OSError: pass
        for _t in ca_bundle_tmps:
            try: os.unlink(_t)
            except OSError: pass
        if not launched:
            try: srv_conn.close()
            except OSError: pass

    print(f"sakar: [box {box_id}] exited ({code if launched else 1}).",
          file=sys.stderr)
    return (code or 0) if launched else 1

# ════════════════════════════════════════════════════════════════════════════
#  main() dispatch
# ════════════════════════════════════════════════════════════════════════════

_USAGE = """\
sakar — network-intercepting sandbox

Usage:
  sakar                   start the server (foreground; Ctrl-C to stop)
  sakar -- CMD [ARGS...]  run CMD in an intercepted network namespace
  sakar -h / --help       show this help

The server must be running before `sakar -- CMD` is used. The server writes
captured flows to ~/.local/state/sakar/flows-YYYYMMDD-HHMMSS.mitm (openable
with `mitmproxy -r FILE`).

Policy files (one domain wildcard per line, # comments ignored):
  allow: ~/.config/sakar/allow
  deny:  ~/.config/sakar/deny
"""

def main() -> int:
    args = sys.argv[1:]

    if not args:
        # Server mode.
        _ensure_dirs()
        ts = datetime.now().strftime("%Y%m%d-%H%M%S")
        flows_path = str(state_home() / f"flows-{ts}.mitm")
        server = Server()
        try:
            asyncio.run(server.start(flows_path))
        except KeyboardInterrupt:
            print("\nsakar: server stopped.", file=sys.stderr)
        return 0

    if args[0] in ("-h", "--help"):
        print(_USAGE)
        return 0

    if args[0] == "--inner":
        # In-box pid-1 runner.
        # Usage: --inner --conn-fd N -- CMD...
        remaining = args[1:]
        conn_fd = -1
        cmd: list = []
        i = 0
        while i < len(remaining):
            if remaining[i] == "--conn-fd" and i + 1 < len(remaining):
                conn_fd = int(remaining[i + 1])
                i += 2
            elif remaining[i] == "--":
                cmd = remaining[i + 1:]
                break
            else:
                i += 1
        if conn_fd < 0 or not cmd:
            print("sakar --inner: usage: --inner --conn-fd N -- CMD...",
                  file=sys.stderr)
            return 2
        return run_inner(conn_fd, cmd) or 0

    if args[0] == "--":
        # Runner mode: sakar -- CMD [ARGS...]
        cmd = args[1:]
        if not cmd:
            print("sakar: no command after --", file=sys.stderr)
            return 2
        return cmd_run(cmd)

    print(f"sakar: unrecognized argument: {args[0]!r}\n{_USAGE}", file=sys.stderr)
    return 2


if __name__ == "__main__":
    sys.exit(main())
