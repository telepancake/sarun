#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#   "openai>=1.30",
# ]
# ///
"""
oaita — a tiny, resumable OpenAI chat client backed by a folder of turn files.

A SESSION is a named folder under ``$XDG_STATE_HOME/oaita/<name>/`` (fallback
``~/.local/state/oaita/<name>/``). There is NO database, NO JSON, NO hidden
state — the entire conversation context is just the FILES in that folder.

Each file is the raw text of ONE conversation turn (nothing wrapping it). The
FILENAME encodes ordering, identity, provenance and meta:

    NNNN[-turnid[-from]].<flags>.<type>

  • ``NNNN`` — a zero-padded (width 4) integer that orders turns like BASIC line
    numbers. Files are sorted ALPHABETICALLY, and the zero-padding makes the
    alphabetical order identical to the numeric order.
  • optional ``-turnid`` — ``[a-z0-9]+``; the turn-id — a stable identifier
    injected into the sent context so the model can reference individual turns.
  • optional ``-from`` — a session name: the sender that POSTED this turn into
    the folder (cross-context writes only; absent for the session's own turns).
  • optional ``.<flags>`` — single-char turn meta: ``p`` partial (needs
    extension), ``i`` no-header (suppress the injected id line), ``c`` tool
    call (assistant turn holding a tool-call envelope).
  • ``<type>`` — the extension IS the turn type, mapped to an OpenAI chat role:
    ``.system`` / ``.user`` / ``.assistant`` (also ``.developer`` / ``.tool``).
    A file whose name does not match the grammar is NOT a turn and is ignored.

Turns are numbered on a STEP-10 grid (0010, 0020, 0030 …) so the trailing zero
leaves room to hand-insert 0011–0019 later. The next generated turn's number is
``(highest existing) + 10`` (or ``0010`` if the session has none). Existing
numbers are preserved — the client never renumbers files you placed by hand.

The ``gen`` command is ONE model generation, persisted:

  • If the LAST turn is a PARTIAL assistant turn (the ``p`` flag), that file is
    the write target and is (re)generated IN PLACE; the prompt is every turn
    EXCEPT that last one. This is what makes an interrupted ``gen`` resumable.
  • Otherwise a NEW ``NNNN-<id>.p.assistant`` turn is appended (highest+10);
    the prompt is ALL existing turns. A CLEAN assistant tail is a finished
    answer — gen after it appends a further turn, it never rewrites it.

The reply is streamed (``stream=True``) and written INCREMENTALLY to the
``p``-flagged target (write+flush per delta) while echoing live to stdout; an
interrupt mid-stream leaves the partial text on disk WITH the ``p`` flag for
the next ``gen`` to resume from. On clean completion the ``p`` flag is dropped
(rename). If the model answers with tool call(s) instead, each call is
persisted as a ``c``-flagged assistant turn holding a small JSON envelope
(``{"tool": ..., "arguments": ...}``) — and gen STOPS without evaluating them.

The ``call`` command evaluates ONE unanswered tool call (the first, in the
trailing call/result block — pairing is positional): an ``act`` call is
stitched into its persistent inner sub-agent session (seed user turn posted
with ``from=<outer>``), the inner session is ``gen``'d as a leaf, and the
answer comes back as a ``.tool`` result turn posted with ``from=<inner>`` — so
the model can target that sender for follow-ups.

The ``run`` command is the run-to-completion loop: evaluate pending calls
(``call``), otherwise generate (``gen``), until the tail is a clean assistant
turn. The primitives stay one-step; ``run`` is the only driver.

Turn-id metadata is INJECTED into the sent context (never written to files):
every message's content is prefixed with ``{"turn-id": "<id>"}\\n`` so the
model can reference turns by their stable slug-ids. Files on disk always hold
raw content only — the header is synthesised at send time from the filename. If
the model echoes such a header back atop its reply, it is stripped before the
turn is stored (and a valid, unique id the model chose is adopted as the slug).

Name stitching: a session name is letters and digits only, and a dot-stitched
spec ``a.b.c`` means inference happens in ``c`` (the reply is written there)
while ``a`` then ``b`` are PREPENDED to the context. This is composition, not
hierarchy — next round the caller may write ``c.d.a`` — and is how
sub-conversations, reusable "skills", and system prompts are mixed in. Every
referenced session is loaded and slug-assigned, turn-ids stay unique across the
whole stitched context, and only the target (last) segment is ever written.

The model name comes from ``--model`` or ``$OAITA_MODEL``. The base URL / api
key come from ``--base-url`` / ``--api-key`` or, when unset, the SDK's
``OPENAI_BASE_URL`` / ``OPENAI_API_KEY`` env vars (the SDK only ever contacts
the configured base_url — no phone-home).

    oaita gen <name> [--model M] [--base-url URL] [--api-key KEY]
                     [--tool-context NAME] [--capabilities TEXT]

Tool calling is ALWAYS on. The registry is: ``act`` (delegate to a sub-agent),
``shell`` (run a script in the session's sandbox box), ``inspect`` (list the
structure at a path), ``delete`` (roll back / collapse this context, or drop a
spent sub-agent session). Each ``act`` call is a re-addressable recursive
sub-agent that is itself TOOL-CAPABLE and run to completion one depth deeper
(continue it later via ``follow_up`` or by targeting the result's ``from``
sender). Delegation is capped at ``MAX_DEPTH`` — past it ``act`` returns
"too deep". Intended for tool-capable models only.

    oaita gen  <name> [--model M] [--base-url URL] [--api-key KEY]
                      [--capabilities TEXT]
    oaita call <name> [--tool-context NAME] [...]
    oaita run  <name> [--max-steps N] [...]
    oaita add  [name] [--type ROLE] [--id TURNID] [--from NAME]
                      [--flags FLAGS] [--number N]      (stdin → turn file)

Sections:
    1 · Imports & session paths
    2 · Turn model (filename grammar, ordering, numbering)
    3 · Turn-id generation & slug assignment
    4 · Client / config layer
    4b · Tool calling: the `act` meta-tool + streamed tool-call assembly
    5 · gen / call / run: the one-step primitives + the driver loop
    6 · CLI (argparse) & entry points
    7 · TODO
    8 · __main__
"""

from __future__ import annotations

# ════════════════════════════════════════════════════════════════════════════
#  1 · Imports & session paths
# ════════════════════════════════════════════════════════════════════════════
import argparse
import hashlib
import json
import os
import re
import secrets
import shlex
import shutil
import string
import sys
from dataclasses import dataclass, replace
from pathlib import Path

import openai

# Roles a turn-file extension may map to. The extension IS the role name.
TURN_TYPES = ("system", "developer", "user", "assistant", "tool")

# Numbering grid: zero-padded width, and the step between generated turns.
NUM_WIDTH = 4
NUM_STEP = 10


def state_home() -> Path:
    """Root of all oaita state: ``$XDG_STATE_HOME/oaita`` (fallback ~/.local)."""
    xdg = os.environ.get("XDG_STATE_HOME")
    base = Path(xdg) if xdg else Path.home() / ".local" / "state"
    return base / "oaita"


def session_dir(name: str) -> Path:
    """The folder holding one named session's turn files."""
    return state_home() / name


# A session name is letters and digits ONLY — so the '.' that stitches names
# together (see parse_stitch) is always an unambiguous separator, never part of
# a name.
_NAME_RE = re.compile(r"^[A-Za-z0-9]+$")


def validate_session_name(name: str) -> str:
    """Return ``name`` if it is a valid session name, else raise ``SystemExit``."""
    if not _NAME_RE.match(name):
        raise SystemExit(
            f"oaita: invalid session name {name!r} — names may contain only "
            f"letters and digits (the '.' in a stitch spec separates names)")
    return name


def parse_stitch(spec: str) -> list[str]:
    """Split a dot-stitched name spec into its segment names, in order.

    ``"a.b.c"`` → ``["a", "b", "c"]``: inference happens in the LAST segment
    (``c``), while the earlier segments (``a``, ``b``) are PREPENDED to the
    context. This is composition, NOT hierarchy — the caller may write the same
    names in any order next round (``"c.d.a"``). A bare ``"a"`` is a one-segment
    spec (a single session). Every segment must be a valid session name, and a
    session may not appear more than once (that would duplicate its turn-ids).
    """
    segments = spec.split(".")
    for seg in segments:
        validate_session_name(seg)
    if len(set(segments)) != len(segments):
        raise SystemExit(
            f"oaita: a session may not appear more than once in a stitch "
            f"spec: {spec!r}")
    return segments


# ════════════════════════════════════════════════════════════════════════════
#  2 · Turn model (filename grammar, ordering, numbering)
# ════════════════════════════════════════════════════════════════════════════
# Grammar:  NNNN[-turnid[-from]].<flags>.<type>
#   NNNN   — one or more digits (zero-padded in practice).
#   turnid — optional turn-id, [a-z0-9]+ (no dash: '-' separates the fields).
#   from   — optional sender, a session name ([A-Za-z0-9]+): the session that
#            WROTE this turn into the folder. Absent for the session's own
#            turns; present exactly when call/run machinery posted it
#            cross-context. `from` implies a turnid (positional 2nd field).
#   flags  — optional dotted segment of single-char turn meta:
#              p — partial: needs extension (e.g. interrupted stream, no EOS);
#              i — no turn-id header: suppress header injection for this turn;
#              c — tool call: an assistant turn holding a tool-call envelope.
#   type   — one of TURN_TYPES (the extension), and nothing after it.
_FLAG_CHARS = "pic"
_TURN_RE = re.compile(
    r"^(?P<num>\d+)"
    r"(?:-(?P<turnid>[a-z0-9]+)(?:-(?P<sender>[A-Za-z0-9]+))?)?"
    r"(?:\.(?P<flags>[" + _FLAG_CHARS + r"]+))?"
    r"\.(?P<type>" + "|".join(TURN_TYPES) + r")$"
)


@dataclass(frozen=True)
class Turn:
    """One parsed turn file. ``path`` is the file; ``content`` is read lazily."""
    number: int
    slug: str | None
    type: str
    path: Path
    sender: str | None = None
    flags: str = ""

    @property
    def role(self) -> str:
        """The OpenAI chat role for this turn (identical to its type)."""
        return self.type

    def read(self) -> str:
        """The raw file text — exactly the turn content, nothing stripped."""
        return self.path.read_text(encoding="utf-8")

    def message(self, *, inject_id: bool = True) -> dict:
        """The OpenAI chat message ``{"role": ..., "content": ...}``.

        When ``inject_id`` is True (the default for API sends) the content is
        prefixed with the turn-id meta line::

            {"turn-id": "<slug>"}\\n<raw text>

        plus a ``"from"`` key when the filename carries a sender — so the model
        sees who posted the turn and can target that sender in its commands.
        The ``i`` flag suppresses the header for this turn entirely. Files on
        disk never hold the header — it is synthesised here from the filename.
        Pass ``inject_id=False`` to get the raw content.
        """
        raw = self.read()
        if inject_id and self.slug is not None and "i" not in self.flags:
            hdr: dict = {"turn-id": self.slug}
            if self.sender is not None:
                hdr["from"] = self.sender
            content = json.dumps(hdr) + "\n" + raw
        else:
            content = raw
        return {"role": self.role, "content": content}


def parse_turn(path: Path) -> Turn | None:
    """Parse one filename into a Turn, or None if it is not a turn file."""
    mo = _TURN_RE.match(path.name)
    if mo is None:
        return None
    return Turn(
        number=int(mo.group("num")),
        slug=mo.group("turnid"),
        type=mo.group("type"),
        path=path,
        sender=mo.group("sender"),
        flags=mo.group("flags") or "",
    )


def load_turns(name: str) -> list[Turn]:
    """All turn files of a session, in turn order.

    Files are sorted ALPHABETICALLY by filename; zero-padding makes that order
    identical to numeric order. Non-conforming files are ignored. A missing
    session folder simply yields an empty list.
    """
    folder = session_dir(name)
    if not folder.is_dir():
        return []
    turns = []
    for path in sorted(folder.iterdir(), key=lambda p: p.name):
        if not path.is_file():
            continue
        turn = parse_turn(path)
        if turn is not None:
            turns.append(turn)
    return turns


def next_number(turns: list[Turn]) -> int:
    """The number for the next appended turn: highest existing + STEP (or STEP)."""
    if not turns:
        return NUM_STEP
    return max(t.number for t in turns) + NUM_STEP


def turn_filename(number: int, type: str, slug: str | None = None,
                  sender: str | None = None, flags: str = "") -> str:
    """Render ``NNNN[-turnid[-from]].<flags>.<type>`` on the zero-padded grid.

    ``sender`` requires ``slug`` (the grammar's 2nd dash-field is always the
    turn-id, so a sender cannot be encoded without one).
    """
    if sender and not slug:
        raise ValueError("turn_filename: sender requires a turn-id slug")
    stem = f"{number:0{NUM_WIDTH}d}"
    if slug:
        stem += f"-{slug}"
    if sender:
        stem += f"-{sender}"
    if flags:
        stem += f".{flags}"
    return f"{stem}.{type}"


# ════════════════════════════════════════════════════════════════════════════
#  3 · Turn-id generation & slug assignment
# ════════════════════════════════════════════════════════════════════════════
# Turn-ids are 5 lowercase ASCII letters chosen via the `secrets` module.
# Rationale: exactly reproducible by the model (it can re-state "xqvmb" in
# a reply), visually distinct from the zero-padded NNNN line numbers (no
# digits), and collision probability is negligible (26^5 = 11 878 576 for
# sessions whose turn counts fit in a hand).
#   TODO: revisit the turn-id form for LLM-friendliness —
#     • token efficiency: 5 lower-ascii chars may span 1–3 tokens; consider
#       numeric ids (fewer tokens, but harder to distinguish from NNNN),
#       base32 (uppercase noise), CJK / emoji (compact but hard to type), or
#       4-char ids (smaller space, fewer tokens).
#     • exact-reproduction reliability: letters-only IDs are simpler for a
#       model to reproduce verbatim than mixed alphanumeric.
#     • KV-cache note: re-sending a freshly generated turn with its prepended
#       id-header diverges from the generation-time KV cache, so the tail is
#       recomputed each gen. This is accepted cost on local inference; could
#       later be avoided by emitting the id-header DURING generation (so the
#       cached context already contains it).
_ID_CHARS = string.ascii_lowercase
_ID_LEN = 5


def _id_from_hash(material: str) -> str:
    """Map arbitrary seed material to one candidate id (5 chars of _ID_CHARS)."""
    v = int.from_bytes(
        hashlib.blake2b(material.encode(), digest_size=8).digest(), "big")
    chars = []
    for _ in range(_ID_LEN):
        v, r = divmod(v, len(_ID_CHARS))
        chars.append(_ID_CHARS[r])
    return "".join(chars)


def new_turn_id(existing: set[str], slot: str | None = None) -> str:
    """Generate a fresh unique 5-char lowercase turn-id not already in ``existing``.

    Normal mode uses ``secrets.choice`` (unpredictability is overkill for ids
    but avoids predictable alphabetical sequences).

    Deterministic mode: when ``$OAITA_ID_SEED`` is set AND ``slot`` is given,
    the id is ``hash(seed:slot:probe)``. ``slot`` is the turn's stable
    coordinate — ``"<session>/<NNNN>"`` — so the same folder state under the
    same seed always yields the same ids, which is what lets expect-style tests
    pin exact filenames in their assertions.

    Either way, uniqueness comes from probing against ``existing`` (open
    addressing — the deterministic path bumps the probe counter, the random
    path redraws), never from improbability. The id length only governs probe
    count, and the namespace (26^5) is far larger than any real session.
    """
    seed = os.environ.get("OAITA_ID_SEED")
    if seed is not None and slot is not None:
        probe = 0
        while True:
            candidate = _id_from_hash(f"{seed}:{slot}:{probe}")
            if candidate not in existing:
                return candidate
            probe += 1
    while True:
        candidate = "".join(secrets.choice(_ID_CHARS) for _ in range(_ID_LEN))
        if candidate not in existing:
            return candidate


def assign_slugs(turns: list[Turn],
                 existing_slugs: set[str] | None = None) -> list[Turn]:
    """Ensure every turn has a slug, renaming slug-less files on disk in place.

    Turns that already have a slug keep it unchanged — user-authored labels are
    the turn-ids verbatim. For turns without a slug a fresh unique id is
    generated, the file is renamed (``Path.rename``), and the in-memory Turn is
    updated to reflect the new path and slug.

    ``existing_slugs`` is an optional SHARED set of ids to avoid (mutated in
    place as ids are assigned). Passing one lets a stitched generation keep
    turn-ids unique across SEVERAL sessions; when omitted the set is derived
    from ``turns`` alone (single-session behaviour).

    Returns the updated list (same order; ``frozen=True`` dataclasses replaced
    via ``dataclasses.replace``).
    """
    if existing_slugs is None:
        existing_slugs = {t.slug for t in turns if t.slug is not None}
    updated: list[Turn] = []
    for turn in turns:
        if turn.slug is not None:
            # Already has a slug — keep it, but make sure the shared set knows.
            existing_slugs.add(turn.slug)
            updated.append(turn)
        else:
            # Generate a fresh id, rename the file, update the in-memory turn.
            # Slot = session/NNNN, the turn's stable coordinate (deterministic mode).
            new_id = new_turn_id(
                existing_slugs, slot=f"{turn.path.parent.name}/{turn.number}")
            existing_slugs.add(new_id)
            # A slug-less turn cannot carry a sender (grammar); keep its flags.
            new_name = turn_filename(turn.number, turn.type, new_id,
                                     flags=turn.flags)
            new_path = turn.path.parent / new_name
            turn.path.rename(new_path)
            updated.append(replace(turn, slug=new_id, path=new_path))
    return updated


def check_unique_turn_ids(turns: list[Turn]) -> None:
    """Raise ``SystemExit`` if two turns in the sent context share a turn-id.

    Turn-ids must be unique across the WHOLE stitched context so the model can
    reference any turn unambiguously. New ids are drawn collision-free, so this
    only ever fires on pre-existing duplicates (e.g. two hand-authored turns
    with the same slug, possibly in different stitched sessions).
    """
    seen: dict[str, Path] = {}
    for t in turns:
        if t.slug in seen:
            raise SystemExit(
                f"oaita: turn-id collision {t.slug!r} — used by both "
                f"{seen[t.slug]} and {t.path}; rename one of the turns")
        seen[t.slug] = t.path


# A model that sees every turn begin with a {"turn-id": "..."} header tends to
# imitate it and emit one at the top of its own reply. We strip that mimic so
# the stored turn stays raw — and, for a newly appended turn, adopt the id the
# model chose when it is a valid, session-unique slug. Parsing is deliberately
# SLOPPY: tolerate ' or " quotes, turn-id / turn_id, inner whitespace, and a
# missing trailing newline.
_EMITTED_ID_RE = re.compile(
    r"""^\s*\{\s*['"]turn[-_ ]?id['"]\s*:\s*['"](?P<id>[^'"]*)['"]\s*"""
    r"""(?:,\s*['"]from['"]\s*:\s*['"][^'"]*['"]\s*)?"""
    r"""\}[ \t]*(?:\r?\n|$)""",
    re.IGNORECASE,
)
# An id we are willing to adopt from the model: must fit the turnid grammar
# field ([a-z0-9], no dash — dash separates filename fields), length-bounded.
# A model-imitated "from" is NEVER adopted: sender identity is harness-assigned
# provenance, not a label the model may choose (it is matched above only to be
# stripped).
_ADOPTABLE_SLUG_RE = re.compile(r"^[a-z0-9]{1,64}$")


def strip_emitted_turn_id(content: str) -> tuple[str | None, str]:
    """Sloppily strip a leading ``{"turn-id": "..."}`` header the model imitated.

    Returns ``(emitted_id, body)``. If ``content`` does not start with a
    turn-id-looking header, returns ``(None, content)`` unchanged. Otherwise the
    header line and its trailing newline are removed from ``body``, and
    ``emitted_id`` is the captured value verbatim (it may be empty or not
    slug-valid — the caller decides whether to adopt it).
    """
    mo = _EMITTED_ID_RE.match(content)
    if mo is None:
        return None, content
    return mo.group("id"), content[mo.end():]


# ════════════════════════════════════════════════════════════════════════════
#  4 · Client / config layer
# ════════════════════════════════════════════════════════════════════════════
def make_client(
    base_url: str | None = None,
    api_key: str | None = None,
    max_retries: int = 2,
    timeout: float = 60.0,
) -> openai.OpenAI:
    """Return a configured ``openai.OpenAI`` client.

    When ``base_url`` / ``api_key`` are None the SDK reads ``OPENAI_BASE_URL`` /
    ``OPENAI_API_KEY`` from the environment. The SDK only ever contacts the
    configured ``base_url`` — there is no phone-home to real OpenAI.
    """
    kwargs: dict = {"max_retries": max_retries, "timeout": timeout}
    if base_url is not None:
        kwargs["base_url"] = base_url
    if api_key is not None:
        kwargs["api_key"] = api_key
    return openai.OpenAI(**kwargs)


def resolve_model(model: str | None) -> str:
    """The model name from ``--model`` or ``$OAITA_MODEL``; error if neither."""
    chosen = model or os.environ.get("OAITA_MODEL")
    if not chosen:
        raise SystemExit(
            "oaita: no model set — pass --model NAME or set $OAITA_MODEL")
    return chosen


# ════════════════════════════════════════════════════════════════════════════
#  4b · Tool calling: the `act` meta-tool + streamed tool-call assembly
# ════════════════════════════════════════════════════════════════════════════
# Tool calling in oaita is RECURSIVE SUB-AGENTS, not real execution. The
# user-facing context is given exactly ONE tool — `act` — and when the model
# "calls" it, oaita does not run anything external: `evaluate_call` stitches
# the call into a separate, persistent inner session and `gen`s THAT to produce
# the result, which is posted back as the tool result (from=<inner session>).
# Because each inner context is just a session addressed by its turn-id, every
# `act` call is a re-addressable sub-agent (continue it later via `follow_up`
# or by targeting the result's sender). Always on; gen persists calls, `call`
# evaluates them, `run` loops.
META_TOOL_NAME = "act"

# The capabilities blurb embedded verbatim in the `act` description; override
# per call via generate(..., capabilities=...).
DEFAULT_CAPABILITIES = "general assistance (shell, inspect, delegation)"

# Delegation depth: a top-level conversation is depth 0; each `act` sub-agent
# is one deeper. At MAX_DEPTH the `act` tool stays VISIBLE but refuses with a
# flat "too deep" — the model is told delegation exists, just exhausted, so it
# does the work itself rather than spinning. Override via $OAITA_MAX_DEPTH.
MAX_DEPTH = int(os.environ.get("OAITA_MAX_DEPTH") or 3)


def meta_tool(capabilities: str, *, exhausted: bool = False) -> dict:
    """Build the OpenAI tool/function schema for the ``act`` meta-tool.

    The model uses its capabilities by DESCRIBING what it wants: a
    natural-language ``request`` plus any ``data`` to operate on. Setting
    ``follow_up`` to a previous ``act`` call's turn-id continues that sub-agent
    instead of starting a fresh one. ``capabilities`` is embedded verbatim into
    the description so the model knows what it can ask for.

    ``exhausted`` (at the depth cap) swaps in flatter, less-encouraging text:
    the tool is still offered, but a call will come back "too deep".
    """
    if exhausted:
        description = (
            "Delegation depth is exhausted here. You can still call this, but "
            "it will return 'too deep' — so just do the task yourself.")
    else:
        description = (
            "Use your capabilities by describing what you want. Put a "
            "natural-language description in `request` and any data in `data`. "
            f"Your capabilities: {capabilities}. To follow up on an earlier "
            "result, set `follow_up` to that call's turn-id.")
    return {
        "type": "function",
        "function": {
            "name": META_TOOL_NAME,
            "description": description,
            "parameters": {
                "type": "object",
                "properties": {
                    "request": {
                        "type": "string",
                        "description": "Natural-language description of what "
                                       "you want done.",
                    },
                    "data": {
                        "type": "string",
                        "description": "Any data or payload the request "
                                       "operates on.",
                    },
                    "follow_up": {
                        "type": "string",
                        "description": "Turn-id of a previous `act` call to "
                                       "continue as a follow-up.",
                    },
                },
                "required": ["request"],
            },
        },
    }


# ── Tool registry ─────────────────────────────────────────────────────────────
# Each tool is one declarative row, two-faced:
#   outward — the function schema the provider sees (name/description/params);
#   inward  — how `evaluate_call` runs it, tagged by run_location:
#     "in-box"  — runs against the conversation's sarun box (arbitrary scripts
#                 are ONLY ever this kind);
#     "manager" — operates ON the box itself (apply/discard… — fixed,
#                 parameterized templates, never free-form). Not wired yet.
@dataclass(frozen=True)
class ToolSpec:
    """One registry row: the outward schema + the inward run-location meta."""
    name: str
    description: str
    parameters: dict
    run_location: str = "in-box"

    def schema(self) -> dict:
        """The OpenAI tools-array entry for this row."""
        return {"type": "function",
                "function": {"name": self.name,
                             "description": self.description,
                             "parameters": self.parameters}}


def tool_registry(capabilities: str | None = None,
                  depth: int = 0) -> dict[str, ToolSpec]:
    """The v1 tool rows: ``act``, ``shell``, ``inspect``, ``delete``.

    ``depth`` (this context's delegation depth) flattens ``act`` to its
    exhausted form at ``MAX_DEPTH`` — the row stays so the model still sees
    the capability, but a call returns "too deep".
    """
    caps = capabilities if capabilities is not None else DEFAULT_CAPABILITIES
    act = meta_tool(caps, exhausted=depth >= MAX_DEPTH)["function"]
    return {
        META_TOOL_NAME: ToolSpec(
            name=META_TOOL_NAME,
            description=act["description"],
            parameters=act["parameters"],
        ),
        "shell": ToolSpec(
            name="shell",
            description=(
                "Run a shell script in this conversation's persistent sandbox "
                "box. The script is executed with `sh -c`; stdout/stderr are "
                "captured and returned, followed by a summary of any file "
                "changes the run staged in the box (changes stay STAGED until "
                "resolved — they do not touch the host)."),
            parameters={
                "type": "object",
                "properties": {
                    "script": {
                        "type": "string",
                        "description": "The shell script to run (no shebang).",
                    },
                },
                "required": ["script"],
            },
        ),
        "inspect": ToolSpec(
            name="inspect",
            description=(
                "List the structure of the thing at `path`: a directory's "
                "entries (name + kind). A huge listing is summarized to fit. "
                "Read a specific entry by inspecting its deeper path."),
            parameters={
                "type": "object",
                "properties": {
                    "path": {
                        "type": "string",
                        "description": "Filesystem path to inspect.",
                    },
                },
                "required": ["path"],
            },
        ),
        "apply": ToolSpec(
            name="apply",
            description=(
                "APPLY a sub-agent's staged changes: fold everything its "
                "sandbox box accumulated (files, session edits) into this "
                "plane, then remove the box. `target` is the sub-agent id "
                "(the from-sender of its result turn). Review the change "
                "summary first — applying is the commit."),
            parameters={
                "type": "object",
                "properties": {
                    "target": {
                        "type": "string",
                        "description": "Sub-agent session id whose box to "
                                       "apply.",
                    },
                },
                "required": ["target"],
            },
            run_location="manager",
        ),
        "reject": ToolSpec(
            name="reject",
            description=(
                "REJECT a sub-agent's staged changes: discard everything its "
                "sandbox box accumulated and remove the box. `target` is the "
                "sub-agent id (the from-sender of its result turn). Its "
                "result text stays in this conversation; only the staged "
                "changes vanish."),
            parameters={
                "type": "object",
                "properties": {
                    "target": {
                        "type": "string",
                        "description": "Sub-agent session id whose box to "
                                       "discard.",
                    },
                },
                "required": ["target"],
            },
            run_location="manager",
        ),
        "delete": ToolSpec(
            name="delete",
            description=(
                "Tidy your own context. Give a `turn-id` to ROLL BACK: every "
                "turn from it onward is removed; if you also give `annotation` "
                "text, one clean assistant turn with that text replaces them — "
                "collapsing a messy string of attempts into the result. Give "
                "a `session` name instead to delete a finished sub-agent "
                "session entirely."),
            parameters={
                "type": "object",
                "properties": {
                    "turn_id": {
                        "type": "string",
                        "description": "Turn-id to roll back to (inclusive).",
                    },
                    "annotation": {
                        "type": "string",
                        "description": "Replacement assistant-turn text for a "
                                       "rollback.",
                    },
                    "session": {
                        "type": "string",
                        "description": "A sub-agent session name to delete "
                                       "wholesale (instead of a rollback).",
                    },
                },
                "required": [],
            },
        ),
    }


def registry_tools(capabilities: str | None = None,
                   depth: int = 0) -> list[dict]:
    """The outward tools array for the API (all registry rows at ``depth``)."""
    return [spec.schema()
            for spec in tool_registry(capabilities, depth).values()]


# ── Executors — where `shell` scripts actually run ───────────────────────────
@dataclass
class ExecResult:
    """What a shell run came back with: captured output, a human-readable
    change summary ('' when the run touched no files), and the exit code."""
    output: str
    changes: str = ""
    exit_code: int = 0


def summarize_patch(patch: str) -> str:
    """A terse, model-facing summary of a unified diff: per-file +/- counts."""
    files: list[tuple[str, int, int]] = []
    name, plus, minus = None, 0, 0
    for line in patch.splitlines():
        if line.startswith("+++ "):
            if name is not None:
                files.append((name, plus, minus))
            name = line[4:].split("\t")[0]
            name = name[2:] if name.startswith(("a/", "b/")) else name
            plus = minus = 0
        elif line.startswith("+") and not line.startswith("+++"):
            plus += 1
        elif line.startswith("-") and not line.startswith("---"):
            minus += 1
    if name is not None:
        files.append((name, plus, minus))
    if not files:
        return ""
    lines = [f"{n}: +{p} -{m}" for n, p, m in files]
    return f"{len(files)} file(s) changed (staged in the box):\n" + \
        "\n".join(lines)


def box_name(target_seg: str) -> str:
    """The sarun box a session's shell runs share: ``OAITA-<SESSION>``.

    One persistent box per session segment: follow-up shell calls land in the
    same box (sarun reruns a named box), so state accumulates until the box's
    changes are applied or discarded. The prefix keeps the box a valid sarun
    NAME (CAPS, starts with a letter) for any session name.
    """
    return f"OAITA-{target_seg.upper()}"


class SarunExecutor:
    """Run scripts in a sarun box via the sarun CLI; changes via ``patch``.

    Requires a running sarun UI (sarun's own requirement). Output is whatever
    the runner echoed (sarun captures and re-echoes the box's stdout/stderr);
    the change summary is computed from ``sarun <box> patch``.
    """

    def __init__(self, sarun=None):
        if sarun is None:
            sibling = Path(__file__).resolve().parent / "sarun"
            sarun = str(sibling) if sibling.exists() else "sarun"
        # A string is the executable; a sequence is a full argv prefix (e.g.
        # ["/deps/python", "/path/sarun"] to skip per-call uv resolution).
        self._argv = [sarun] if isinstance(sarun, str) else list(sarun)

    def run_script(self, script: str, box: str) -> ExecResult:
        import subprocess
        proc = subprocess.run(
            [*self._argv, box, "--", "sh", "-c", script],
            capture_output=True, text=True)
        output = proc.stdout + (("\n" + proc.stderr) if proc.stderr else "")
        patch = subprocess.run(
            [*self._argv, box, "patch"], capture_output=True, text=True)
        changes = summarize_patch(patch.stdout) if patch.returncode == 0 else ""
        return ExecResult(output=output.strip("\n"), changes=changes,
                          exit_code=proc.returncode)

    def discard_box(self, box: str) -> str:
        """Discard a box's staged changes and remove it. Returns CLI output."""
        import subprocess
        r = subprocess.run([*self._argv, box, "discard"],
                           capture_output=True, text=True)
        return (r.stdout + r.stderr).strip() or f"discarded box {box}"

    def apply_box(self, box: str) -> str:
        """Apply a box's staged changes to its parent plane, remove the box."""
        import subprocess
        r = subprocess.run([*self._argv, box, "apply"],
                           capture_output=True, text=True)
        return (r.stdout + r.stderr).strip() or f"applied box {box}"


class LocalExecutor:
    """NO SANDBOX, NO GATE: scripts run directly on the host via ``sh -c``.

    A testing / no-sarun stand-in (select with ``$OAITA_EXECUTOR=local``).
    Every write is immediately live — there is nothing staged, so apply and
    reject are no-ops that say so. The transactional gate lives in sarun
    boxes; this class exists so the rest of oaita can be exercised without
    one, not as a safe substitute.
    """

    def run_script(self, script: str, box: str) -> ExecResult:
        import subprocess
        proc = subprocess.run(["sh", "-c", script],
                              capture_output=True, text=True)
        output = proc.stdout + (("\n" + proc.stderr) if proc.stderr else "")
        return ExecResult(output=output.strip("\n"), changes="",
                          exit_code=proc.returncode)

    def discard_box(self, box: str) -> str:
        return (f"no sandbox: {box} was never staged — its writes are "
                f"already live and cannot be discarded")

    def apply_box(self, box: str) -> str:
        return f"no sandbox: {box} had nothing staged — writes were live"


# The absolute path of THIS oaita — what act scripts invoke inside a box (the
# box overlays the host filesystem, so the same path resolves in-box).
OAITA_PATH = Path(__file__).resolve()


def act_script(stitch_spec: str, innerid: str, depth: int) -> str:
    """The in-box script one ``act`` call runs.

    Runs the sub-agent to completion (its stream is on disk; stdout noise is
    dropped) and then prints the FINAL turn through the box's staged view via
    ``oaita tail`` — a sub-agent that collapsed itself with ``delete`` streams
    nothing, so the on-disk tail is the only truthful answer channel. Depth
    rides ``$OAITA_DEPTH`` so the sub-agent's own ``act`` knows how deep it is.
    """
    # $OAITA_CMD overrides how the sub-process invokes oaita (e.g. a
    # deps-equipped interpreter in tests, skipping per-spawn uv resolution);
    # default is this file's own path (the box overlays the host, so the uv
    # shebang resolves in-box too).
    oaita = os.environ.get("OAITA_CMD") or shlex.quote(str(OAITA_PATH))
    return (f"OAITA_DEPTH={depth} {oaita} run {stitch_spec} "
            f">/dev/null 2>&1 && {oaita} tail {innerid}")


def render_act_result(r: ExecResult) -> str:
    """The model-facing text of one act run's ``.tool`` result turn.

    The sub-agent's final turn (read through the box), then the box's staged
    change summary — a REPORT of staged state, never an application of it.
    The caller resolves the box with apply/reject.
    """
    parts = []
    if r.exit_code != 0:
        parts.append(f"(sub-agent run exited {r.exit_code})")
    parts.append(r.output)
    if r.changes:
        parts.append(r.changes)
    return "\n".join(p for p in parts if p != "")


def render_shell_result(r: ExecResult) -> str:
    """The model-facing text of one shell run's ``.tool`` result turn."""
    parts = [f"exit {r.exit_code}", r.output]
    parts.append(r.changes if r.changes else "[no file changes]")
    return "\n".join(p for p in parts if p != "")


# ── inspect — structure of the thing at a path ───────────────────────────────
INSPECT_MAX_ENTRIES = 200          # past this, summarize instead of enumerate


def _entry_kind(p: Path) -> str:
    if p.is_symlink():
        return "symlink"
    if p.is_dir():
        return "dir"
    if p.is_file():
        return "file"
    return "other"


def inspect_path(path: str) -> str:
    """List the structure at ``path``. v1: a directory's entries (name + kind).

    A listing larger than ``INSPECT_MAX_ENTRIES`` is SUMMARIZED to per-kind
    counts (the degenerate-case fuse — "15086 files" beats dumping them); the
    model digs into any subpath with another inspect. A regular file reports
    its size (structural decode lands later); a missing path is an error.
    """
    p = Path(path).expanduser()
    if not p.exists():
        return f"error: no such path {path!r}"
    if p.is_dir():
        entries = sorted(p.iterdir(), key=lambda q: q.name)
        if len(entries) > INSPECT_MAX_ENTRIES:
            counts: dict[str, int] = {}
            for e in entries:
                counts[_entry_kind(e)] = counts.get(_entry_kind(e), 0) + 1
            summary = ", ".join(f"{n} {k}(s)" for k, n in sorted(counts.items()))
            return f"{path} (summarized — {len(entries)} entries): {summary}"
        lines = [f"{_entry_kind(e)}\t{e.name}" for e in entries]
        return f"{path} ({len(entries)} entries):\n" + "\n".join(lines)
    return f"{path}: file, {p.stat().st_size} bytes"


# ── delete — roll back / collapse, or drop a finished sub-agent session ──────
def apply_delete(target_seg: str, *, turn_id: str | None = None,
                 annotation: str | None = None,
                 session: str | None = None,
                 executor=None) -> str:
    """Apply a ``delete`` call to ``target_seg``; return a model-facing summary.

    ROLLBACK (``turn_id``): every turn from that id onward (by grid number) is
    removed, and if ``annotation`` is given a single clean assistant turn with
    that text replaces them — collapsing a messy string of attempts into the
    kept result. (Attachment dirs of the removed turns go too.)

    SESSION (``session``): delete that sub-agent session's folder wholesale and
    discard its sandbox box. For tidying re-addressable sub-agents once their
    result is banked.
    """
    if session is not None:
        if not _NAME_RE.match(session):
            return f"error: invalid session name {session!r}"
        folder = session_dir(session)
        if not folder.is_dir():
            return f"error: no session {session!r} to delete"
        shutil.rmtree(folder, ignore_errors=True)
        if executor is not None and hasattr(executor, "discard_box"):
            executor.discard_box(box_name(session))
        return f"deleted session {session!r}"

    if turn_id is None:
        return "error: delete needs a turn_id (rollback) or session (drop)"
    turns = load_turns(target_seg)
    match = next((t for t in turns if t.slug == turn_id), None)
    if match is None:
        return f"error: no turn {turn_id!r} in this context"
    removed = [t for t in turns if t.number >= match.number]
    for t in removed:
        t.path.unlink(missing_ok=True)
        att = t.path.parent / t.path.name.split(".")[0]
        if att.is_dir():
            shutil.rmtree(att, ignore_errors=True)
    note = ""
    if annotation:
        kept = load_turns(target_seg)
        slug = new_turn_id({t.slug for t in kept if t.slug},
                           slot=f"{target_seg}/{match.number}")
        append_raw_turn(target_seg, "assistant", annotation, slug=slug)
        note = f"; collapsed into assistant turn {slug!r}"
    return f"rolled back {len(removed)} turn(s) from {turn_id!r}{note}"


@dataclass
class AssembledResponse:
    """The assembled result of consuming a streaming chat-completion response.

    Mirrors ``oaita_fakeclient.assemble_stream`` (replicated here so oaita stays
    self-contained — it does NOT import the fake client at runtime). Tool-call
    fragments are accumulated per ``index`` into a list of ``_AssembledToolCall``
    objects exposing ``.id``, ``.name`` and ``.arguments``.
    """
    content: str = ""
    tool_calls: list = None
    finish_reason: str | None = None

    def __post_init__(self):
        if self.tool_calls is None:
            self.tool_calls = []


@dataclass
class _AssembledToolCall:
    """One reassembled tool call: function ``name``, ``arguments`` str, ``id``."""
    id: str | None
    name: str | None
    arguments: str


def stream_to_file(stream, target: Path, echo) -> AssembledResponse:
    """Stream a chat-completion reply to ``target`` while collecting tool calls.

    Content deltas are written to ``target`` and flushed PER DELTA (so an
    interrupt mid-stream leaves resumable partial text on disk) and echoed live
    via ``echo``. Tool-call fragments are accumulated by ``index`` in the SAME
    pass — you learn a reply is a tool call from ``delta.tool_calls`` as it
    arrives, with no need to buffer the whole thing. Returns the assembled
    response; ``target`` already holds the streamed content on return (empty for
    a pure tool call).
    """
    content_parts: list[str] = []
    tc_acc: dict[int, dict] = {}
    finish_reason: str | None = None

    with open(target, "w", encoding="utf-8") as f:
        f.truncate(0)
        for chunk in stream:
            if not chunk.choices:
                continue
            choice = chunk.choices[0]
            delta = choice.delta
            if delta.content:
                f.write(delta.content)
                f.flush()
                echo(delta.content)
                content_parts.append(delta.content)
            if delta.tool_calls:
                for tc_delta in delta.tool_calls:
                    acc = tc_acc.setdefault(
                        tc_delta.index, {"id": None, "name": None, "arguments": ""})
                    if tc_delta.id:
                        acc["id"] = tc_delta.id
                    fn = tc_delta.function
                    if fn:
                        if fn.name:
                            acc["name"] = fn.name
                        if fn.arguments:
                            acc["arguments"] += fn.arguments
            if choice.finish_reason:
                finish_reason = choice.finish_reason

    tool_calls = [
        _AssembledToolCall(
            id=tc_acc[i]["id"], name=tc_acc[i]["name"],
            arguments=tc_acc[i]["arguments"])
        for i in sorted(tc_acc)
    ]
    return AssembledResponse(
        content="".join(content_parts),
        tool_calls=tool_calls,
        finish_reason=finish_reason,
    )


# ════════════════════════════════════════════════════════════════════════════
#  5 · gen / call / run: the one-step primitives + the driver loop
# ════════════════════════════════════════════════════════════════════════════
def plan_generation(turns: list[Turn], folder: Path, existing_slugs: set[str]):
    """Decide the prompt turns and the write-target path for a generation.

    Returns ``(prompt_turns, target_path, is_regenerate)``:
      • If the last turn is a PARTIAL assistant turn (``p`` flag) → regenerate
        it in place; the prompt is every turn EXCEPT that last one. The tail is
        guaranteed to already have a slug (``assign_slugs`` was called first).
      • Otherwise → append a new ``NNNN-<id>.p.assistant`` turn (highest+10);
        the prompt is ALL existing turns. A clean assistant tail is a finished
        answer and is never rewritten.

    Either way the target carries the ``p`` flag while it streams; the flag is
    dropped (rename) when the generation completes cleanly, so an interrupt
    leaves a ``p``-marked partial for the next gen to resume.

    ``existing_slugs`` is the current set of known slugs; a new id is drawn
    from outside it and added to the set in place.
    """
    if turns and turns[-1].type == "assistant" and "p" in turns[-1].flags:
        return turns[:-1], turns[-1].path, True
    number = next_number(turns)
    new_id = new_turn_id(existing_slugs, slot=f"{folder.name}/{number}")
    existing_slugs.add(new_id)
    target = folder / turn_filename(number, "assistant", new_id, flags="p")
    return turns, target, False


@dataclass
class _PreparedContext:
    """The slug-assigned, stitched context for one outer generation pass.

    Produced by ``prepare_context``; consumed by both the non-tooled stream and
    the tooled loop so the load → assign-slugs → stitch → uniqueness pipeline is
    written exactly once.
    """
    segments: list[str]
    target_seg: str
    target_folder: Path
    existing_slugs: set[str]
    prompt_turns: list[Turn]
    target: Path
    is_regenerate: bool
    messages: list[dict]


def prepare_context(name: str) -> _PreparedContext:
    """Build the per-pass context for ``name`` (the shared front half of gen).

    Parses the dot-stitched spec, loads every segment, assigns slugs across all
    of them from one shared id set (renaming slug-less files on disk), picks the
    write target / regenerate-in-place decision for the LAST segment, enforces
    turn-id uniqueness across the whole sent context, and builds the messages
    list with per-turn id-headers injected. Raises ``SystemExit`` on an invalid
    name or an empty stitched context.

    The tooled loop re-runs this every iteration because the session changes on
    disk between passes (call + result turns are appended).
    """
    segments = parse_stitch(name)
    target_seg = segments[-1]
    target_folder = session_dir(target_seg)

    existing_slugs: set[str] = set()
    seg_turns: dict[str, list[Turn]] = {}
    for seg in segments:
        seg_turns[seg] = load_turns(seg)
        existing_slugs |= {t.slug for t in seg_turns[seg] if t.slug is not None}
    for seg in segments:
        seg_turns[seg] = assign_slugs(seg_turns[seg], existing_slugs)

    tgt_turns = seg_turns[target_seg]
    prompt_tail, target, is_regenerate = plan_generation(
        tgt_turns, target_folder, existing_slugs)
    prepended = [t for seg in segments[:-1] for t in seg_turns[seg]]
    prompt_turns = prepended + prompt_tail

    if not prompt_turns:
        raise SystemExit(
            f"oaita: nothing to generate from for {name!r} — no turns across "
            f"the stitched context")

    check_unique_turn_ids(prompt_turns)
    messages = build_messages(prompt_turns)
    return _PreparedContext(
        segments=segments,
        target_seg=target_seg,
        target_folder=target_folder,
        existing_slugs=existing_slugs,
        prompt_turns=prompt_turns,
        target=target,
        is_regenerate=is_regenerate,
        messages=messages,
    )


def append_raw_turn(name: str, type: str, content: str,
                    slug: str | None = None, sender: str | None = None,
                    flags: str = "") -> Path:
    """Append a raw turn of ``type`` (role) + ``content`` to session ``name``.

    Numbers it via the session's own ``next_number`` (highest+10), writes the
    raw text verbatim (no id-header — headers are injected only at send time),
    and returns the written path. ``slug`` becomes the turn-id when given (the
    caller is responsible for its uniqueness); ``sender`` records WHO posted
    the turn (cross-context writes only — requires ``slug``); ``flags`` are
    the single-char turn meta. Creates the folder if new.

    This is the shared write primitive for tool-call turns, tool-result turns,
    and inner sub-agent seed turns.
    """
    folder = session_dir(name)
    folder.mkdir(parents=True, exist_ok=True)
    number = next_number(load_turns(name))
    path = folder / turn_filename(number, type, slug, sender=sender, flags=flags)
    path.write_text(content, encoding="utf-8")
    return path


def build_messages(turns: list[Turn]) -> list[dict]:
    """The OpenAI messages array for a turn sequence — NATIVE tool-call form.

    Plain (free-prose) turns pass through ``Turn.message()`` and get the
    id-header. A ``c``-flagged call turn that HAS a paired result is lifted
    into the provider's native shape — an assistant message carrying
    ``tool_calls`` with id ``call_<turn-id>`` and NO content — and its
    ``.tool`` result gets the matching ``tool_call_id`` and a RAW payload (no
    injected header: call/result messages live inside template-special
    regions where models expect pure payloads; their turn-id rides the native
    tool_call_id channel instead). This is SEND-TIME ONLY: files keep the
    envelope. Without it the model keeps seeing envelope-JSON-as-content and
    starts WRITING envelope JSON as content instead of emitting native
    tool-call tokens.

    Pairing is positional per maximal call/result block (same rule as
    ``pending_calls``). An UNANSWERED call inside the history (possible in a
    prepended stitched segment) stays in narrative form — an assistant
    ``tool_calls`` message with no result would be rejected by strict
    providers. A stray ``.tool`` turn with no preceding call self-pairs on its
    own turn-id.
    """
    # Pass 1: positional pairing inside each maximal (c-call | tool) block.
    call_of_result: dict[int, Turn] = {}     # index of tool turn -> call turn
    answered: set[int] = set()               # indices of c-turns with a result
    block_calls: list[tuple[int, Turn]] = []
    block_results: list[int] = []

    def flush_block():
        for k, ridx in enumerate(block_results):
            if k < len(block_calls):
                cidx, cturn = block_calls[k]
                call_of_result[ridx] = cturn
                answered.add(cidx)
        block_calls.clear()
        block_results.clear()

    for i, t in enumerate(turns):
        if t.type == "assistant" and "c" in t.flags:
            block_calls.append((i, t))
        elif t.type == "tool":
            block_results.append(i)
        else:
            flush_block()
    flush_block()

    # Pass 2: build the messages. ID-HEADERS GO ON FREE-PROSE TURNS ONLY:
    # call and result messages live in template-special regions (tool-call /
    # tool-response token wrapping; models are trained on PURE payloads
    # there), so they carry no injected header — their turn-id rides the
    # NATIVE id channel instead (tool_call_id = call_<turn-id>, which is also
    # everything follow_up needs). A result's from-sender stays filename-only
    # (harness/UI-visible, not on the wire).
    msgs: list[dict] = []
    for i, t in enumerate(turns):
        if i in answered:
            tool, args = _parse_call_envelope(t.read())
            msgs.append({
                "role": "assistant",
                "content": None,
                "tool_calls": [{
                    "id": f"call_{t.slug}",
                    "type": "function",
                    "function": {"name": tool, "arguments": args},
                }],
            })
        elif t.type == "tool":
            m = t.message(inject_id=False)
            paired = call_of_result.get(i)
            m["tool_call_id"] = f"call_{(paired or t).slug}"
            msgs.append(m)
        else:
            msgs.append(t.message())
    return msgs


def pending_calls(turns: list[Turn]) -> list[Turn]:
    """The UNANSWERED tool-call turns in the trailing call/result block.

    The trailing block is the maximal run of ``c``-flagged assistant turns and
    ``.tool`` result turns at the end of the session. Pairing is POSITIONAL:
    the k-th result in the block answers the k-th call (parallel calls are
    written in order and their results are appended in order). Anything before
    the block is settled history and never re-examined.
    """
    block: list[Turn] = []
    for t in reversed(turns):
        if t.type == "tool" or (t.type == "assistant" and "c" in t.flags):
            block.append(t)
        else:
            break
    block.reverse()
    calls = [t for t in block if t.type == "assistant"]
    n_results = sum(1 for t in block if t.type == "tool")
    return calls[n_results:]


# Replayed calls carry their turn-id as tool_call_id = call_<turn-id>, so a
# model following the convention emits e.g. call_fetchinfo for its NEXT call —
# the tool-blob analogue of imitating the prose id-header. Adopt such an id
# (strip the call_ prefix) when it looks like one of OURS: starts with a
# letter, >=4 chars, [a-z0-9], unique. Provider/template junk (call_0,
# call_1, random uppercase blobs) fails the gate and a fresh id is minted.
_ADOPTABLE_CALL_ID_RE = re.compile(r"^[a-z][a-z0-9]{3,63}$")


def adopt_call_id(wire_id: str | None, taken: set[str]) -> str | None:
    """The turn-id extracted from a model-emitted tool_call id, if adoptable."""
    if not wire_id:
        return None
    cand = wire_id[5:] if wire_id.startswith("call_") else wire_id
    if _ADOPTABLE_CALL_ID_RE.match(cand) and cand not in taken:
        return cand
    return None


def _call_envelope(name: str | None, arguments: str) -> str:
    """Render one wire tool call as the raw content of a ``c``-flagged turn.

    ``{"tool": <name>, "arguments": <parsed-or-raw>}`` — arguments are embedded
    as a JSON object when they parse (model-readable on the next gen), else as
    the verbatim string. The provider's ``tool_call.id`` is deliberately NOT
    kept: the turn-id system replaces it (pairing is positional).
    """
    try:
        args = json.loads(arguments)
    except (ValueError, TypeError):
        args = None
    if not isinstance(args, (dict, list)):
        args = arguments
    return json.dumps({"tool": name or META_TOOL_NAME, "arguments": args})


def _parse_call_envelope(content: str) -> tuple[str, str]:
    """Parse a call turn's content back into ``(tool_name, arguments_str)``.

    Tolerant: content that is not a ``{"tool": ...}`` envelope (hand-authored
    call turns, junk) is treated as an ``act`` request verbatim.
    """
    try:
        obj = json.loads(content)
    except (ValueError, TypeError):
        obj = None
    if not isinstance(obj, dict) or "tool" not in obj:
        return META_TOOL_NAME, content
    args = obj.get("arguments")
    if isinstance(args, dict):
        args = json.dumps(args)
    elif not isinstance(args, str):
        args = ""
    return str(obj["tool"]), args


def add_turn(
    name: str,
    *,
    type: str = "user",
    slug: str | None = None,
    sender: str | None = None,
    flags: str = "",
    number: int | None = None,
    source=None,
) -> Path:
    """Add ONE turn to session ``name``, content streamed from ``source``.

    The convenience entry the ``add`` subcommand wraps: everything defaults —
    next grid number, a fresh generated turn-id, type ``user`` — and everything
    can be overridden. ``source`` is a binary file object (default: stdin);
    its bytes are copied to the turn file unbuffered, so a slow interactive
    stdin appears in the file as it is typed. ``name`` may be a stitch spec;
    the turn is added to the LAST segment (where gen would write).

    Validates the pieces against the filename grammar (turnid ``[a-z0-9]+``,
    sender a session name, flags from the known set) and refuses to overwrite
    an existing file. Returns the written path.
    """
    target_seg = parse_stitch(name)[-1]
    if type not in TURN_TYPES:
        raise SystemExit(f"oaita: invalid turn type {type!r} — "
                         f"one of {', '.join(TURN_TYPES)}")
    if slug is not None and not re.fullmatch(r"[a-z0-9]+", slug):
        raise SystemExit(f"oaita: invalid turn-id {slug!r} — [a-z0-9]+ only")
    if sender is not None and not _NAME_RE.match(sender):
        raise SystemExit(f"oaita: invalid sender {sender!r} — a session name")
    if any(ch not in _FLAG_CHARS for ch in flags):
        raise SystemExit(f"oaita: invalid flags {flags!r} — "
                         f"chars from {_FLAG_CHARS!r}")
    folder = session_dir(target_seg)
    folder.mkdir(parents=True, exist_ok=True)
    turns = load_turns(target_seg)
    if number is None:
        number = next_number(turns)
    if slug is None:
        slug = new_turn_id({t.slug for t in turns if t.slug},
                           slot=f"{target_seg}/{number}")
    path = folder / turn_filename(number, type, slug, sender=sender,
                                  flags=flags)
    if path.exists():
        raise SystemExit(f"oaita: {path} already exists")
    if source is None:
        source = sys.stdin.buffer
    # Unbuffered copy: each read lands in the file immediately, so the session
    # folder is live even while an interactive stdin is still being typed.
    with open(path, "wb", buffering=0) as f:
        while True:
            chunk = source.read(1 << 16)
            if not chunk:
                break
            f.write(chunk)
    return path


def generate(
    name: str,
    *,
    model: str,
    base_url: str | None = None,
    api_key: str | None = None,
    client: openai.OpenAI | None = None,
    echo=None,
    tools: list | None = None,
    capabilities: str | None = None,
    depth: int = 0,
) -> list[Path]:
    """ONE model generation for ``name``, persisted. Nothing more.

    ``name`` is a session name, or a dot-stitched spec ``"a.b.c"``: inference
    happens in the LAST segment (and its file is written there), while the
    earlier segments are prepended to the context in order. Every referenced
    session is loaded and slug-assigned; only the target segment is written.

    The reply is streamed to a ``p``-flagged target file (flushed per delta, so
    an interrupt leaves a resumable partial) and echoed live via ``echo``
    (defaults to stdout). On clean completion the ``p`` flag is dropped; an
    imitated id-header is stripped, and on an appended turn a valid unique id
    the model chose is adopted as the slug.

    TOOL CALLING is always on (``tools=None`` → the single ``act`` meta-tool;
    ``capabilities`` overrides the blurb; ``tools=[]`` → a leaf that can only
    answer). If the model answers with tool call(s), each is PERSISTED as a
    ``c``-flagged assistant turn holding its envelope — and gen STOPS without
    evaluating anything. Evaluation is ``evaluate_call`` / ``oaita call``;
    looping is ``run_to_completion`` / ``oaita run``. gen REFUSES to run while
    an unanswered call is pending (the context would mislead the model).

    Returns the turn files this step wrote, in order. Raises ``SystemExit`` on
    an invalid name or an empty stitched context — no empty files are created.
    """
    model = resolve_model(model)
    if client is None:
        client = make_client(base_url=base_url, api_key=api_key)
    if echo is None:
        def echo(text: str):
            sys.stdout.write(text)
            sys.stdout.flush()

    # The normal context carries the registry tools for THIS depth (act flips
    # to its "too deep" form at MAX_DEPTH). tools=[] forces a tool-free leaf
    # (used for a deliberately non-acting context); tools=<list> overrides.
    if tools is None:
        tools = registry_tools(capabilities, depth)
    tools_param = tools or None

    target_seg = parse_stitch(name)[-1]
    if pending_calls(load_turns(target_seg)):
        raise SystemExit(
            f"oaita: {target_seg!r} has an unanswered tool call — evaluate it "
            f"first (`oaita call {name}`), or drive with `oaita run {name}`")

    # ONE main-model generation per `gen` (no agent loop anywhere in here).
    ctx = prepare_context(name)
    ctx.target_folder.mkdir(parents=True, exist_ok=True)
    stream = client.chat.completions.create(
        model=model, messages=ctx.messages, tools=tools_param, stream=True)
    resp = stream_to_file(stream, ctx.target, echo)

    if not resp.tool_calls:
        # Plain reply: the streamed content is the final answer, already on disk.
        return [_finalize_answer(ctx.target, ctx)]

    # The model called tool(s): persist each call as a c-flagged assistant turn
    # (the envelope is the turn's raw content), then STOP. Nothing is evaluated
    # here — `call` does that, one call at a time.
    produced: list[Path] = []
    # NARRATION: a reply may carry prose AND tool calls (a running tally before
    # the next step). Keep it — finalize the streamed content as its own clean
    # assistant turn, so the commentary survives instead of being overwritten
    # by the envelope. The c-turns are then all appended after it. (Empty
    # narration → the first call repurposes the streamed target, as before.)
    repurpose = ctx.target
    if resp.content.strip():
        produced.append(_finalize_answer(ctx.target, ctx))
        repurpose = None
    for i, call in enumerate(resp.tool_calls):
        envelope = _call_envelope(call.name, call.arguments)
        if repurpose is not None and i == 0:
            # Repurpose the just-streamed (empty) target turn: write the
            # envelope, rename p→c. A model-chosen call_<id> in our shape is
            # adopted as the slug (the tool-blob analogue of prose header
            # adoption), else the minted slug stays.
            tgt = parse_turn(repurpose)
            repurpose.write_text(envelope, encoding="utf-8")
            slug = adopt_call_id(call.id, ctx.existing_slugs - {tgt.slug}) \
                or tgt.slug
            cpath = repurpose.parent / turn_filename(
                tgt.number, "assistant", slug, sender=tgt.sender, flags="c")
            if cpath != repurpose:
                repurpose.rename(cpath)
        else:
            # Append a fresh c-flagged turn (parallel call, or narration kept).
            cur = load_turns(target_seg)
            taken = {t.slug for t in cur if t.slug} | ctx.existing_slugs
            slug = adopt_call_id(call.id, taken) or new_turn_id(
                taken, slot=f"{target_seg}/{next_number(cur)}")
            cpath = append_raw_turn(
                target_seg, "assistant", envelope, slug=slug, flags="c")
        produced.append(cpath)
    return produced


def evaluate_call(
    name: str,
    *,
    model: str,
    base_url: str | None = None,
    api_key: str | None = None,
    client: openai.OpenAI | None = None,
    echo=None,
    tool_context: str | None = None,
    executor=None,
    depth: int = 0,
) -> list[Path]:
    """Evaluate the FIRST unanswered tool call of ``name``'s target segment.

    ONE call per invocation — repetition is ``run_to_completion``'s job.

    ``act``: the inner sub-agent session is the call's turn-id (or the call's
    ``follow_up`` target); the request is posted into it as a user turn with
    ``from=<outer segment>``, and the sub-agent runs as ``oaita run`` — a
    PROCESS IN A BOX (``OAITA-<innerid>``), one depth deeper via
    ``$OAITA_DEPTH``, tool-capable, never an in-process recursion. ALL its
    writes (own turns, edits to any session, file changes) STAGE in that box.
    The ``.tool`` result (``from=<inner session>``) is a REPORT read through
    the staged view — the sub-agent's final turn via ``oaita tail`` plus the
    change summary; reporting commits nothing. The caller resolves the box
    with ``apply`` / ``reject``. At ``MAX_DEPTH`` ``act`` refuses "too deep".

    ``shell``: the script runs via ``executor`` in the session's persistent
    box (``box_name(target_seg)``); the result turn is the captured output +
    staged-change summary. No executor configured → an error-text result.

    ``apply`` / ``reject`` (manager-level): fold or discard a sub-agent's
    staged box — the ONLY gate; nothing ever auto-applies.

    ``inspect``: list the structure at a path. ``delete``: roll back / collapse
    this context, or drop a sub-agent session. Both are harness-native and act
    on ``target_seg`` directly.

    An unknown tool name also yields an error-text result turn (the loop keeps
    moving; the model sees the error). Returns the written result turn
    ``[path]``. Raises ``SystemExit`` when no call is pending.
    """
    model = resolve_model(model)
    if client is None:
        client = make_client(base_url=base_url, api_key=api_key)
    segments = parse_stitch(name)
    target_seg = segments[-1]

    # Slug pool spans the whole stitch so a result id cannot collide with a
    # prepended segment's id (the next gen enforces uniqueness across them).
    pool: set[str] = set()
    for seg in segments:
        pool |= {t.slug for t in load_turns(seg) if t.slug}
    turns = assign_slugs(load_turns(target_seg), pool)

    pend = pending_calls(turns)
    if not pend:
        raise SystemExit(f"oaita: no unanswered tool call in {target_seg!r}")
    call_turn = pend[0]
    tool, arguments = _parse_call_envelope(call_turn.read())

    sender: str | None = None
    rolled_back = False
    if tool == "shell":
        script = _parse_shell_arguments(arguments)
        if executor is None:
            result = ("error: no executor configured — shell needs sarun "
                      "(its UI running); the script was NOT run")
        else:
            result = render_shell_result(
                executor.run_script(script, box=box_name(target_seg)))
    elif tool == "inspect":
        result = inspect_path(_parse_inspect_arguments(arguments))
    elif tool == "delete":
        tid, annotation, sess = _parse_delete_arguments(arguments)
        # A self-rollback removes the delete CALL turn itself, so it does NOT
        # produce a paired .tool result — the rewritten context IS the answer.
        rolled_back = sess is None and tid is not None
        result = apply_delete(target_seg, turn_id=tid, annotation=annotation,
                              session=sess, executor=executor)
        if rolled_back:
            return []
    elif tool in ("apply", "reject"):
        # Manager-level: resolve a sub-agent's STAGED box — the only place
        # its accumulated writes (files AND session edits) become real or
        # vanish. Always caller-driven; nothing ever auto-applies.
        target = _parse_target_argument(arguments)
        if target is None:
            result = f"error: {tool} needs a target sub-agent id"
        elif executor is None:
            result = "error: no executor configured — nothing is staged"
        elif tool == "apply":
            result = executor.apply_box(box_name(target))
        else:
            result = executor.discard_box(box_name(target))
    elif tool != META_TOOL_NAME:
        known = ", ".join(repr(k) for k in tool_registry())
        result = f"error: unknown tool {tool!r} — available: {known}"
    elif depth >= MAX_DEPTH:
        result = ("too deep: delegation depth is exhausted — do this "
                  "yourself rather than delegating further")
    else:
        request, data, follow_up = _parse_act_arguments(arguments)
        # New call → the inner session IS this turn's id; follow_up continues
        # the referenced existing sub-agent instead.
        innerid = follow_up if (follow_up and _NAME_RE.match(follow_up)) \
            else call_turn.slug
        inner_user = request if not data else f"{request}\n\n{data}"
        inner_cur = load_turns(innerid)
        inner_slug = new_turn_id({t.slug for t in inner_cur if t.slug},
                                 slot=f"{innerid}/{next_number(inner_cur)}")
        append_raw_turn(innerid, "user", inner_user,
                        slug=inner_slug, sender=target_seg)
        if executor is None:
            result = ("error: no executor configured — act runs the "
                      "sub-agent in a sandbox box; nothing was run")
        else:
            # The sub-agent is a PROCESS IN A BOX, never an in-process
            # recursion: `oaita run` inside box OAITA-<innerid>, where ALL
            # its writes — its own turns, edits to ANY session, file changes
            # — stage until this caller applies or rejects the box. The
            # result below is a REPORT read through the staged view (the
            # sub-agent's final turn via `oaita tail`, + change summary);
            # reporting commits nothing.
            stitch_spec = f"{tool_context}.{innerid}" if tool_context \
                else innerid
            r = executor.run_script(
                act_script(stitch_spec, innerid, depth + 1),
                box=box_name(innerid))
            result = render_act_result(r)
            sender = innerid

    cur = load_turns(target_seg)
    pool |= {t.slug for t in cur if t.slug}
    slug = new_turn_id(pool, slot=f"{target_seg}/{next_number(cur)}")
    return [append_raw_turn(target_seg, "tool", result,
                            slug=slug, sender=sender)]


def run_to_completion(
    name: str,
    *,
    model: str,
    base_url: str | None = None,
    api_key: str | None = None,
    client: openai.OpenAI | None = None,
    echo=None,
    tool_context: str | None = None,
    capabilities: str | None = None,
    executor=None,
    max_steps: int = 32,
    depth: int = 0,
) -> list[Path]:
    """Drive ``name`` until its tail is a CLEAN assistant turn (the answer).

    Each step is one primitive: an unanswered call → ``evaluate_call``;
    otherwise (no clean assistant tail yet, or a partial one) → ``generate``.
    The primitives stay one-step and individually re-runnable; this loop is
    the only driver. Already-settled contexts return immediately ([]).
    ``depth`` is this context's delegation depth (sub-agents run deeper).

    Bounded by ``max_steps`` (raises ``SystemExit`` when exceeded — partial
    progress is all on disk, a later run resumes exactly where it stopped).
    """
    model = resolve_model(model)
    if client is None:
        client = make_client(base_url=base_url, api_key=api_key)
    target_seg = parse_stitch(name)[-1]
    produced: list[Path] = []
    for _ in range(max_steps):
        turns = load_turns(target_seg)
        if pending_calls(turns):
            produced += evaluate_call(name, model=model, client=client,
                                      echo=echo, tool_context=tool_context,
                                      executor=executor, depth=depth)
            continue
        if (turns and turns[-1].type == "assistant"
                and "p" not in turns[-1].flags and "c" not in turns[-1].flags):
            return produced
        produced += generate(name, model=model, client=client, echo=echo,
                             capabilities=capabilities, depth=depth)
    raise SystemExit(
        f"oaita: run {name!r} did not settle within {max_steps} steps — "
        f"progress is on disk; run again to continue")


def _finalize_answer(target: Path, ctx: _PreparedContext) -> Path:
    """Finalise a streamed FINAL answer already written to ``target``.

    The reply's content is on disk (streamed there by ``stream_to_file``).
    Strip an id-header the model imitated atop it (keeping the file raw); on an
    appended turn adopt a valid, unique id the model chose as the slug. Either
    way drop the ``p`` (streaming/partial) flag — the turn is now complete.
    Returns the final (possibly renamed) path.
    """
    body = target.read_text(encoding="utf-8")
    emitted_id, stripped = strip_emitted_turn_id(body)
    if emitted_id is not None:
        target.write_text(stripped, encoding="utf-8")
    tgt = parse_turn(target)
    slug = tgt.slug
    if (emitted_id is not None and not ctx.is_regenerate
            and _ADOPTABLE_SLUG_RE.match(emitted_id)
            and emitted_id not in (ctx.existing_slugs - {tgt.slug})):
        slug = emitted_id
    final = target.parent / turn_filename(
        tgt.number, tgt.type, slug, sender=tgt.sender,
        flags=tgt.flags.replace("p", ""))
    if final != target:
        target.rename(final)
    return final


def _parse_shell_arguments(arguments: str) -> str:
    """Parse a ``shell`` call's arguments into the script text.

    Tolerant like ``_parse_act_arguments``: a missing/dirty arguments string
    (or one without a usable ``script``) is treated as the script verbatim.
    """
    try:
        obj = json.loads(arguments)
    except (ValueError, TypeError):
        obj = None
    if isinstance(obj, dict):
        script = obj.get("script")
        if isinstance(script, str) and script:
            return script
    return arguments


def _parse_inspect_arguments(arguments: str) -> str:
    """Parse an ``inspect`` call into the path (tolerant — raw text if dirty)."""
    try:
        obj = json.loads(arguments)
    except (ValueError, TypeError):
        obj = None
    if isinstance(obj, dict) and isinstance(obj.get("path"), str):
        return obj["path"]
    return arguments.strip()


def _parse_target_argument(arguments: str) -> str | None:
    """Parse an ``apply``/``reject`` call into the target sub-agent id."""
    try:
        obj = json.loads(arguments)
    except (ValueError, TypeError):
        obj = None
    if isinstance(obj, dict) and isinstance(obj.get("target"), str) \
            and obj["target"]:
        return obj["target"]
    return arguments.strip() or None


def _parse_delete_arguments(arguments: str):
    """Parse a ``delete`` call into (turn_id, annotation, session)."""
    try:
        obj = json.loads(arguments)
    except (ValueError, TypeError):
        obj = None
    if not isinstance(obj, dict):
        return None, None, None
    def s(key):
        v = obj.get(key)
        return v if isinstance(v, str) and v else None
    return s("turn_id"), s("annotation"), s("session")


def _parse_act_arguments(arguments: str) -> tuple[str, str | None, str | None]:
    """Parse an ``act`` call's ``arguments`` JSON into (request, data, follow_up).

    Tolerates a missing/dirty arguments string: on a JSON parse failure (or a
    non-object payload) the WHOLE arguments string is treated as the ``request``,
    with no ``data`` / ``follow_up``.
    """
    try:
        obj = json.loads(arguments)
    except (ValueError, TypeError):
        obj = None
    if not isinstance(obj, dict):
        return arguments, None, None
    request = obj.get("request")
    if not isinstance(request, str) or not request:
        # Missing/empty request → fall back to the raw arguments text.
        request = arguments
    data = obj.get("data")
    data = data if isinstance(data, str) and data else None
    follow_up = obj.get("follow_up")
    follow_up = follow_up if isinstance(follow_up, str) and follow_up else None
    return request, data, follow_up


# ════════════════════════════════════════════════════════════════════════════
#  6 · CLI (argparse) & entry points
# ════════════════════════════════════════════════════════════════════════════
def build_parser() -> argparse.ArgumentParser:
    """Build the argparse CLI. Structured so new subcommands drop in trivially."""
    parser = argparse.ArgumentParser(
        prog="oaita",
        description="A resumable OpenAI chat client backed by a folder of "
                    "turn files.",
    )
    sub = parser.add_subparsers(dest="command", required=True)

    def common(p, tool_ctx=False, caps=False):
        p.add_argument(
            "name",
            help="session name, or a dot-stitched spec 'a.b.c' — act on the "
                 "last segment; earlier segments are prepended as context")
        p.add_argument("--model", default=None,
                       help="model name (else $OAITA_MODEL)")
        p.add_argument("--base-url", default=None,
                       help="OpenAI base URL (else $OPENAI_BASE_URL)")
        p.add_argument("--api-key", default=None,
                       help="API key (else $OPENAI_API_KEY)")
        if tool_ctx:
            p.add_argument(
                "--tool-context", default=None, metavar="NAME",
                help="session of fixed tool descriptions stitched before each "
                     "inner sub-agent context")
            p.add_argument(
                "--sarun", default=None, metavar="PATH",
                help="sarun executable for the shell tool (default: the "
                     "sibling ./sarun, else 'sarun' on PATH)")
            p.add_argument(
                "--no-sandbox", action="store_true",
                help="run with NO shell executor (shell calls return an "
                     "error result instead of executing)")
        if caps:
            p.add_argument(
                "--capabilities", default=None, metavar="TEXT",
                help="capabilities blurb embedded in the `act` tool "
                     "description (overrides the default)")

    gen = sub.add_parser(
        "gen", help="ONE model generation (a reply, or persisted tool calls)")
    common(gen, caps=True)
    gen.set_defaults(func=_cmd_gen)

    call = sub.add_parser(
        "call", help="evaluate the first unanswered tool call (one call)")
    common(call, tool_ctx=True)
    call.set_defaults(func=_cmd_call)

    run = sub.add_parser(
        "run", help="drive gen/call until the tail is a clean assistant turn")
    common(run, tool_ctx=True, caps=True)
    run.add_argument("--max-steps", type=int, default=32, metavar="N",
                     help="abort (progress kept on disk) after N steps")
    run.set_defaults(func=_cmd_run)

    tail = sub.add_parser(
        "tail", help="print the LAST turn's raw content (the settled answer)")
    tail.add_argument("name", help="session name (or stitch spec — reads the "
                                   "last segment)")
    tail.set_defaults(func=_cmd_tail)

    add = sub.add_parser(
        "add", help="add one turn to a session, content copied from stdin")
    add.add_argument(
        "name", nargs="?", default=None,
        help="session name (or stitch spec — the turn goes to the last "
             "segment); default $OAITA_SESSION, else 'default'")
    add.add_argument("--type", default="user", metavar="ROLE",
                     help="turn type / role (default: user)")
    add.add_argument("--id", dest="slug", default=None, metavar="TURNID",
                     help="turn-id ([a-z0-9]+; default: generated)")
    add.add_argument("--from", dest="sender", default=None, metavar="NAME",
                     help="sender session name (default: none — own turn)")
    add.add_argument("--flags", default="", metavar="FLAGS",
                     help="turn flags, e.g. 'p' or 'i' (default: none)")
    add.add_argument("--number", type=int, default=None, metavar="N",
                     help="grid number (default: highest+10)")
    add.set_defaults(func=_cmd_add)
    return parser


def _report(produced) -> int:
    """Shared tail for the subcommand handlers: newline + written-files list."""
    # The reply was already echoed live; finish the line for a clean terminal.
    sys.stdout.write("\n")
    sys.stdout.flush()
    for path in produced:
        print(f"oaita: wrote {path}", file=sys.stderr)
    return 0


def _cmd_gen(args) -> int:
    """Handler for ``oaita gen``."""
    return _report(generate(
        args.name, model=args.model, base_url=args.base_url,
        api_key=args.api_key, capabilities=args.capabilities,
        depth=_depth_from_env()))


def _executor_from(args):
    """The executor the CLI selects: --no-sandbox → None (error-result mode);
    $OAITA_EXECUTOR=local → LocalExecutor (UNGATED — testing); else sarun."""
    if args.no_sandbox:
        return None
    if os.environ.get("OAITA_EXECUTOR") == "local":
        return LocalExecutor()
    return SarunExecutor(args.sarun)


def _depth_from_env() -> int:
    """This process's delegation depth (act scripts export $OAITA_DEPTH)."""
    try:
        return int(os.environ.get("OAITA_DEPTH") or 0)
    except ValueError:
        return 0


def _cmd_call(args) -> int:
    """Handler for ``oaita call``."""
    return _report(evaluate_call(
        args.name, model=args.model, base_url=args.base_url,
        api_key=args.api_key, tool_context=args.tool_context,
        executor=_executor_from(args), depth=_depth_from_env()))


def _cmd_run(args) -> int:
    """Handler for ``oaita run``."""
    return _report(run_to_completion(
        args.name, model=args.model, base_url=args.base_url,
        api_key=args.api_key, tool_context=args.tool_context,
        capabilities=args.capabilities, max_steps=args.max_steps,
        executor=_executor_from(args), depth=_depth_from_env()))


def _cmd_tail(args) -> int:
    """Handler for ``oaita tail``: last turn's raw content on stdout."""
    target_seg = parse_stitch(args.name)[-1]
    turns = load_turns(target_seg)
    if not turns:
        print(f"oaita: no turns in {target_seg!r}", file=sys.stderr)
        return 1
    sys.stdout.write(turns[-1].read())
    return 0


def _cmd_add(args) -> int:
    """Handler for ``oaita add``: stdin → one turn file; path on stdout."""
    name = args.name or os.environ.get("OAITA_SESSION") or "default"
    path = add_turn(name, type=args.type, slug=args.slug, sender=args.sender,
                    flags=args.flags, number=args.number)
    print(path)
    return 0


def main(argv=None) -> int:
    """CLI entry point. Returns a process exit code."""
    parser = build_parser()
    args = parser.parse_args(argv)
    return args.func(args)


