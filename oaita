#  6 · CLI (argparse) & entry points
# ════════════════════════════════════════════════════════════════════════════
def build_parser() -> argparse.ArgumentParser:
    """Build the argparse CLI. Structured so new subcommands drop in trivially."""
    parser = argparse.ArgumentParser(
        prog="oaita",
        description="A resumable OpenAI chat client backed by a folder of "
                    "turn files.",
    )
    sub = parser.add_subparsers(dest="command", required=True)

    gen = sub.add_parser(
        "gen", help="generate the assistant reply for a session")
    gen.add_argument(
        "name",
        help="session name, or a dot-stitched spec 'a.b.c' — infer in the last "
             "segment; earlier segments are prepended as context")
    gen.add_argument("--model", default=None,
                     help="model name (else $OAITA_MODEL)")
    gen.add_argument("--base-url", default=None,
                     help="OpenAI base URL (else $OPENAI_BASE_URL)")
    gen.add_argument("--api-key", default=None,
                     help="API key (else $OPENAI_API_KEY)")
    gen.add_argument(
        "--tool-context", default=None, metavar="NAME",
        help="session of fixed tool descriptions stitched before each "
             "per-call inner sub-agent context")
    gen.add_argument(
        "--capabilities", default=None, metavar="TEXT",
        help="capabilities blurb embedded in the `act` tool description "
             "(overrides the default)")
    gen.set_defaults(func=_cmd_gen)
    return parser


def _cmd_gen(args) -> int:
    """Handler for ``oaita gen``."""
    produced = generate(
        args.name,
        model=args.model,
        base_url=args.base_url,
        api_key=args.api_key,
        tool_context=args.tool_context,
        capabilities=args.capabilities,
    )
    # The reply was already echoed live; finish the line for a clean terminal.
    sys.stdout.write("\n")
    sys.stdout.flush()
    for path in produced:
        print(f"oaita: wrote {path}", file=sys.stderr)
    return 0


def main(argv=None) -> int:
    """CLI entry point. Returns a process exit code."""
    parser = build_parser()
    args = parser.parse_args(argv)
    return args.func(args)


