<mediawiki xmlns="http://www.mediawiki.org/xml/export-0.11/"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://www.mediawiki.org/xml/export-0.11/ http://www.mediawiki.org/xml/export-0.11.xsd"
           version="0.11"
           xml:lang="en">
  <siteinfo>
    <sitename>TestWiki</sitename>
    <dbname>testwiki</dbname>
    <base>https://test.example.org/wiki/Main_Page</base>
    <generator>MediaWiki Content File Export 0.3.12</generator>
    <case>first-letter</case>
    <namespaces>
      <namespace key="0" case="first-letter" />
      <namespace key="1" case="first-letter">Talk</namespace>
      <namespace key="10" case="first-letter">Template</namespace>
    </namespaces>
  </siteinfo>
  <!-- Page 1: a redirect -->
  <page>
    <title>Old Title</title>
    <ns>0</ns>
    <id>1</id>
    <redirect title="New Title" />
    <revision>
      <id>100</id>
      <timestamp>2024-01-01T00:00:00Z</timestamp>
      <contributor>
        <username>Alice</username>
        <id>10</id>
      </contributor>
      <comment>created redirect</comment>
      <origin>100</origin>
      <model>wikitext</model>
      <format>text/x-wiki</format>
      <text bytes="22" sha1="qrstuvwxyzabcdefghij1234567890a" xml:space="preserve">#REDIRECT [[New Title]]</text>
      <sha1>qrstuvwxyzabcdefghij1234567890a</sha1>
    </revision>
  </page>
  <!-- Page 2: two revisions, both visible -->
  <page>
    <title>New Title</title>
    <ns>0</ns>
    <id>2</id>
    <revision>
      <id>200</id>
      <timestamp>2024-01-02T00:00:00Z</timestamp>
      <contributor>
        <username>Alice</username>
        <id>10</id>
      </contributor>
      <minor />
      <comment>first revision</comment>
      <origin>200</origin>
      <model>wikitext</model>
      <format>text/x-wiki</format>
      <text bytes="11" sha1="abcdefghijklmnopqrstuvwxyz01234" xml:space="preserve">hello world</text>
      <sha1>abcdefghijklmnopqrstuvwxyz01234</sha1>
    </revision>
    <revision>
      <id>201</id>
      <parentid>200</parentid>
      <timestamp>2024-01-03T00:00:00Z</timestamp>
      <contributor>
        <username>Bob</username>
        <id>11</id>
      </contributor>
      <comment>expanded</comment>
      <origin>201</origin>
      <model>wikitext</model>
      <format>text/x-wiki</format>
      <text bytes="23" sha1="bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb" xml:space="preserve">hello world, expanded.</text>
      <sha1>bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb</sha1>
    </revision>
  </page>
  <!-- Page 3: one revision with RevisionDelete'd text -->
  <page>
    <title>Suspicious Page</title>
    <ns>0</ns>
    <id>3</id>
    <revision>
      <id>300</id>
      <timestamp>2024-01-04T00:00:00Z</timestamp>
      <contributor>
        <username>Carol</username>
        <id>12</id>
      </contributor>
      <comment>questionable edit</comment>
      <origin>300</origin>
      <model>wikitext</model>
      <format>text/x-wiki</format>
      <text deleted="deleted" />
      <sha1>ccccccccccccccccccccccccccccccc</sha1>
    </revision>
  </page>
</mediawiki>
