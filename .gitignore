__pycache__/
*.pyc
.claude/
# Top-level symlink created by `make engine[-musl]` pointing at the build artifact.
/sarun
# Scratch dir for `sarun run -b -C <dir> -- make` smoke tests when iterating
# on box-mode kati behavior (see kati corpus runner work).
/.corpus-staging/

# Repository-local bootstrap tools. scripts/with-tools.sh installs uv and
# rustup here when the host does not already provide them, without touching
# shell startup files or requiring a global rustup default.
/.tools/

# Guard against stray cargo prototypes left at the repo root by subagents
# (the real manifest is engine/Cargo.toml). Keeps the worktree clean.
/Cargo.toml
/Cargo.lock
/src/
/target/

# Assembled at build time by `make vendor` (scripts/vendor.py) from
# engine/vendor.toml pins + engine/vendor-patches/ series. Never commit.
/engine/vendor/
/engine/.vendor-cache/

# Manual cellulose/Chromium capture outputs (not test fixtures).
/cellulose/netlog.json
/cellulose/out.txt
