__pycache__/
*.pyc
.claude/
# Top-level symlink created by `make engine[-musl]` pointing at the build artifact.
/sarun
# Scratch dir for `sarun run -b -C <dir> -- make` smoke tests when iterating
# on box-mode kati behavior (see kati corpus runner work).
/.corpus-staging/

# Guard against stray cargo prototypes left at the repo root by subagents
# (the real manifest is engine/Cargo.toml). Keeps the worktree clean.
/Cargo.toml
/Cargo.lock
/src/
/target/
# wasm blob build output (engine/wasm/blobs is its own cargo crate)
/engine/wasm/blobs/target/
/engine/wasm/asyncify-demo/target/
/engine/wasm/asyncify-demo/run.wasm
/engine/wasm/host/target/
/engine/wasm/mmap-demo/target/
/engine/wasm/heap-demo/guest/target/
/engine/wasm/heap-demo/host/target/
