+/*
+ * MikroTik's e500 kernels use `mtspr 1023,r0` as a private hypercall.
+ * Hypercall 16 is hv_yield; success is returned by clearing CR0.SO before
+ * the following bnslr.  Leave other values unsuccessful.
+ */
+void spr_write_mikrotik_hypercall(DisasContext *ctx, int sprn, int gprn)
+{
+    TCGLabel *done = gen_new_label();
+
+    tcg_gen_brcondi_tl(TCG_COND_NE, cpu_gpr[gprn], 16, done);
+    tcg_gen_andi_i32(cpu_crf[0], cpu_crf[0], ~CRF_SO);
+    gen_set_label(done);
+}
