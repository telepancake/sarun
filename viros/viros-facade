#!/usr/bin/env bash
set -euo pipefail

# Stable runner-facing entry point for the live Linux-inferior facade.  Keep
# Python selection here so Sarun never falls back to /usr/bin/python or a user
# virtual environment when it starts a debugger session.
root=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)
python="$root/tools/python/managed/bin/python3"
if [[ ! -x $python ]]; then
    printf '%s\n' \
        'viros-facade: managed Python is missing; run ./viros.sh download first' >&2
    exit 2
fi

exec env \
    PYTHONPATH="$root" \
    PYTHONNOUSERSITE=1 \
    PYTHONSAFEPATH=1 \
    "$python" -m inferiors.sarun_provider "$@"
