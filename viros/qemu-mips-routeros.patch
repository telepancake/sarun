 {
-    if ((ms->smp.cpus > 1) && cpu_type_supports_cps_smp(ms->cpu_type)) {
+    /* MT7621 exposes its coherence manager even when only one virtual
+     * processor is active.  Keep CPS/CM present for deterministic debug. */
+    if (cpu_type_supports_cps_smp(ms->cpu_type)) {
         create_cps(ms, s, cbus_irq, i8259_irq);
     } else {
         create_cpu_without_cps(ms, s, cbus_irq, i8259_irq);
@@ -1085,6 +1075,8 @@ void mips_malta_init(MachineState *machine)
     MemoryRegion *system_memory = get_system_memory();
     MemoryRegion *ram_low_preio = g_new(MemoryRegion, 1);
     MemoryRegion *ram_low_postio;
+    MemoryRegion *rb_uart = g_new(MemoryRegion, 1);
+    MemoryRegion *mmips_uart = g_new(MemoryRegion, 1);
     MemoryRegion *bios, *bios_copy = g_new(MemoryRegion, 1);
     const size_t smbus_eeprom_size = 8 * 256;
     uint8_t *smbus_eeprom_buf = g_malloc0(smbus_eeprom_size);
@@ -1120,6 +1112,24 @@ void mips_malta_init(MachineState *machine)
                              machine->ram, 0, MIN(ram_size, 256 * MiB));
     memory_region_add_subregion(system_memory, 0, ram_low_preio);

+    /* RouterOS smips board=vm still emits panic text through the AR9330
+     * polling UART.  A RAM-backed status/data word is enough for the kernel:
+     * bit 9 means ready and character writes preserve it. */
+    memory_region_init_ram(rb_uart, NULL, "mikrotik.rb-uart", 0x1000,
+                           &error_fatal);
+    memory_region_add_subregion_overlap(system_memory, 0x18020000,
+                                        rb_uart, 10);
+    stl_be_p(memory_region_get_ram_ptr(rb_uart), 0x200);
+
+    /* MMIPS uses the MT7621 UART at 0x1e000c00.  It overlaps Malta's
+     * pflash window, so place a small polling-compatible register page
+     * above it.  LSR bits 5 and 6 keep early printk from stalling. */
+    memory_region_init_ram(mmips_uart, NULL, "mikrotik.mmips-uart", 0x1000,
+                           &error_fatal);
+    memory_region_add_subregion_overlap(system_memory, 0x1e000c00,
+                                        mmips_uart, 10);
+    *((uint8_t *)memory_region_get_ram_ptr(mmips_uart) + 0x14) = 0x60;
+
     /* alias for post IO hole access, if there is enough RAM */
     if (ram_size > 512 * MiB) {
         ram_low_postio = g_new(MemoryRegion, 1);
