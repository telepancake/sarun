- *   T05core:{id};
+ * Include both the topology core and the protocol thread.  A CPS-backed
+ * single-vCPU machine can number its visible CPU from one, and debuggers
+ * otherwise have to infer the current thread from a separate query.
@@ -673,3 +674,6 @@ void gdb_build_stop_packet(GString *buf, CPUState *cs)
     g_string_printf(buf,
-                    "T%02xcore:%02x;", GDB_SIGNAL_TRAP, gdb_get_cpu_index(cs));
+                    "T%02xcore:%02x;thread:",
+                    GDB_SIGNAL_TRAP, gdb_get_cpu_index(cs));
+    gdb_append_thread_id(cs, buf);
+    g_string_append_c(buf, ';');
