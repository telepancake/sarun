Date: Sat, 04 Jul 2026 17:53:06 +0000
Subject: [PATCH] uniq: entry takes logical env; knobs from the shell

---
diff --git a/src/uniq.rs b/src/uniq.rs
index 8ffde9f..6a6d7c0 100644
--- a/src/uniq.rs
+++ b/src/uniq.rs
@@ -56,6 +56,20 @@ struct Uniq {
     slice_stop: Option<usize>,
     ignore_case: bool,
     zero_terminated: bool,
+    /// Whether the effective locale is C/POSIX, computed once from the shell's
+    /// LOGICAL environment (not the engine process's env) when the `Uniq` is
+    /// built. Governs byte- vs character-counting for `-w`/`--check-chars`.
+    is_c_locale: bool,
+}
+
+/// Look up `key` in the shell's LOGICAL environment snapshot (the vars the
+/// brush shell has `export`ed), returning its value if present. Replaces the
+/// process-env reads (`std::env::var_os`) so a knob set with `export` in the
+/// box shell — not one inherited by the engine process — takes effect.
+fn env_get<'a>(env: &'a [(OsString, OsString)], key: &str) -> Option<&'a OsStr> {
+    env.iter()
+        .find(|(k, _)| k == OsStr::new(key))
+        .map(|(_, v)| v.as_os_str())
 }
 
 #[derive(Default)]
@@ -72,6 +86,21 @@ macro_rules! write_line_terminator {
     };
 }
 
+/// Whether the effective locale (from the shell's LOGICAL env) is C/POSIX.
+/// The first non-empty of `LC_ALL`, `LC_CTYPE`, `LANG` decides; absent/empty
+/// throughout means C (GNU's default), so behavior with the vars unset is
+/// identical to the previous process-env read.
+fn is_c_locale(env: &[(OsString, OsString)]) -> bool {
+    for key in ["LC_ALL", "LC_CTYPE", "LANG"] {
+        if let Some(v) = env_get(env, key) {
+            if !v.is_empty() {
+                return v == "C" || v == "POSIX";
+            }
+        }
+    }
+    true
+}
+
 impl Uniq {
     pub fn write_uniq(&self, mut reader: impl BufRead, mut writer: impl Write) -> UResult<()> {
         let mut first_line_printed = false;
@@ -187,17 +216,6 @@ impl Uniq {
         }
     }
 
-    fn is_c_locale() -> bool {
-        for key in ["LC_ALL", "LC_CTYPE", "LANG"] {
-            if let Some(v) = std::env::var_os(key) {
-                if !v.is_empty() {
-                    return v == "C" || v == "POSIX";
-                }
-            }
-        }
-        true
-    }
-
