index 0000000..7872f70
--- /dev/null
+++ b/src/lib/mods/logical_env.rs
@@ -0,0 +1,67 @@
+// This file is part of the uutils coreutils package.
+//
+// For the full copyright and license information, please view the LICENSE
+// file that was distributed with this source code.
+
+//! A thread-local *logical environment* seam for the in-process builtins.
+//!
+//! When several uutils utilities run as in-process brush builtins inside one
+//! long-lived engine process, the shell's exported variables (set with
+//! `export`, `unset`, or a `VAR=v cmd` prefix) live only in the shell's own
+//! logical environment — they are NOT installed into the engine process's real
+//! `environ`. So uucore's *runtime* env reads (`LANG`/`LC_*` for localization,
+//! `VERSION_CONTROL`/`SIMPLE_BACKUP_SUFFIX` for backups, `_POSIX2_VERSION`,
+//! `NO_COLOR`/`TERM`, …) must consult that logical environment, not
+//! `std::env::var_os`.
+//!
+//! The engine installs a snapshot of the shell's exported vars into this
+//! thread-local at the top of each builtin's worker thread (before
+//! localization and the util body run), then clears it. A standalone uutils
+//! binary never installs an override, so [`get`] falls straight through to
+//! `std::env::var_os` and behavior is byte-for-byte unchanged.
+
+use std::ffi::{OsStr, OsString};
+
+thread_local! {
+    // `None` => no override installed on this thread: fall back to the real
+    // process environment (standalone binaries, and any engine thread that
+    // hasn't been seeded). `Some(vec)` => the shell's logical exported env.
+    static OVERRIDE: std::cell::RefCell<Option<Vec<(OsString, OsString)>>> =
+        const { std::cell::RefCell::new(None) };
+}
+
+/// Install the logical environment for the current thread. Replaces any
+/// previously-installed override. Call once at the top of a builtin's worker
+/// thread, before localization setup and the util body.
+pub fn set_logical_env(env: Vec<(OsString, OsString)>) {
+    OVERRIDE.with(|slot| *slot.borrow_mut() = Some(env));
+}
+
+/// Remove any logical-environment override on the current thread, restoring
+/// the fall-through-to-`std::env` behavior.
+pub fn clear() {
+    OVERRIDE.with(|slot| *slot.borrow_mut() = None);
+}
+
+/// Look up `key` in the logical environment for the current thread.
+///
+/// If an override is installed, the lookup is served entirely from it (a key
+/// absent from the snapshot reads as unset — the shell did not export it, so a
+/// forked child would not see it either). If no override is installed, falls
+/// back to `std::env::var_os`.
+pub fn get<K: AsRef<OsStr>>(key: K) -> Option<OsString> {
+    let key = key.as_ref();
+    OVERRIDE.with(|slot| match &*slot.borrow() {
+        Some(env) => env
+            .iter()
+            .find(|(k, _)| k.as_os_str() == key)
+            .map(|(_, v)| v.clone()),
+        None => std::env::var_os(key),
+    })
+}
+
+/// Convenience: like [`get`] but yields a `String`, mirroring the common
+/// `std::env::var(k).ok()` shape (non-UTF-8 values read as absent).
+pub fn get_string<K: AsRef<OsStr>>(key: K) -> Option<String> {
+    get(key).and_then(|v| v.into_string().ok())
+}
