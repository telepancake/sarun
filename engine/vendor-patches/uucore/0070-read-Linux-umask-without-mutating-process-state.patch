From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: sarun <noreply@sarun>
Date: Fri, 17 Jul 2026 23:50:00 +0000
Subject: [PATCH] read Linux umask without mutating process state

---
diff --git a/src/lib/features/mode.rs b/src/lib/features/mode.rs
--- a/src/lib/features/mode.rs
+++ b/src/lib/features/mode.rs
@@ -171,10 +171,22 @@ pub fn parse(mode_string: &str, considering_dir: bool, umask: u32) -> Result<u32
 }

 pub fn get_umask() -> u32 {
-    // There's no portable way to read the umask without changing it.
-    // We have to replace it and then quickly set it back, hopefully before
-    // some other thread is affected.
-    // On modern Linux kernels the current umask could instead be read
-    // from /proc/self/status. But that's a lot of work.
-    #[cfg(unix)]
+    // Linux exposes the process umask without mutating it. This matters for an
+    // in-process shell running several coreutils concurrently: the traditional
+    // umask(0); umask(old) probe races and can permanently leave the shared
+    // process mask at zero.
+    #[cfg(any(target_os = "linux", target_os = "android"))]
+    {
+        std::fs::read_to_string("/proc/self/status")
+            .ok()
+            .and_then(|status| {
+                status.lines().find_map(|line| {
+                    line.strip_prefix("Umask:")
+                        .and_then(|value| u32::from_str_radix(value.trim(), 8).ok())
+                })
+            })
+            .unwrap_or(0o022)
+    }
+
+    #[cfg(all(unix, not(any(target_os = "linux", target_os = "android"))))]
     {
         use nix::sys::stat::{Mode, umask};
