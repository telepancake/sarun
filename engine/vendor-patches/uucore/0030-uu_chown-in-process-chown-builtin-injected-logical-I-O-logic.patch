         let path = root.as_ref();
         let Some(meta) = self.obtain_meta(path, self.dereference) else {
             if self.verbosity.level == VerbosityLevel::Verbose {
-                println!(
+                perms_out!(
                     "failed to change ownership of {} to {}",
                     path.quote(),
                     self.raw_owner
@@ -685,9 +736,9 @@ impl ChownExecutor {
