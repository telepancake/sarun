-struct ZcReader<'a>(Reader<'a>);
+enum MessageReader<'a> {
+    Virtio(Reader<'a>),
+    Fuse(std::io::Cursor<&'a [u8]>),
+}
+
+impl Read for MessageReader<'_> {
+    fn read(&mut self, buffer: &mut [u8]) -> io::Result<usize> {
+        match self {
+            Self::Virtio(reader) => reader.read(buffer),
+            Self::Fuse(reader) => reader.read(buffer),
+        }
+    }
+}
+
+impl MessageReader<'_> {
+    fn read_obj<T: ByteValued>(&mut self) -> io::Result<T> {
+        let mut value = std::mem::MaybeUninit::<T>::uninit();
+        // SAFETY: ByteValued permits every initialized byte pattern.
+        let bytes =
+            unsafe { std::slice::from_raw_parts_mut(value.as_mut_ptr().cast(), size_of::<T>()) };
+        self.read_exact(bytes)?;
+        // SAFETY: read_exact initialized the complete ByteValued object.
+        Ok(unsafe { value.assume_init() })
+    }
+
+    fn write_to_file_at(
+        &mut self,
+        file: &File,
+        mut count: usize,
+        mut offset: u64,
+        flags: Option<oslib::WritevFlags>,
+    ) -> io::Result<usize> {
+        if let Self::Virtio(reader) = self {
+            return reader.write_to_file_at(file, count, offset, flags);
+        }
+        let original = count;
+        let mut buffer = vec![0; count.min(64 * 1024)];
+        while count > 0 {
+            let chunk = count.min(buffer.len());
+            let read = self.read(&mut buffer[..chunk])?;
+            if read == 0 {
+                break;
+            }
+            let mut consumed = 0;
+            while consumed < read {
+                let written = file.write_at(&buffer[consumed..read], offset)?;
+                if written == 0 {
+                    return Err(io::Error::from(io::ErrorKind::WriteZero));
+                }
+                consumed += written;
+                offset = offset
+                    .checked_add(written as u64)
+                    .ok_or_else(|| io::Error::other("write offset overflow"))?;
+                count -= written;
+            }
+        }
+        Ok(original - count)
+    }
+}
+
+struct FuseWriter<'a> {
+    buffer: &'a mut [u8],
+    written: usize,
+}
+
+enum MessageWriter<'a> {
+    Virtio(Writer<'a>),
+    Fuse(FuseWriter<'a>),
+}
+
+impl Write for MessageWriter<'_> {
+    fn write(&mut self, data: &[u8]) -> io::Result<usize> {
+        match self {
+            Self::Virtio(writer) => writer.write(data),
+            Self::Fuse(writer) => {
+                let available = writer.buffer.len().saturating_sub(writer.written);
+                let count = available.min(data.len());
+                writer.buffer[writer.written..writer.written + count]
+                    .copy_from_slice(&data[..count]);
+                writer.written += count;
+                Ok(count)
+            }
+        }
+    }
+
+    fn flush(&mut self) -> io::Result<()> {
+        match self {
+            Self::Virtio(writer) => writer.flush(),
+            Self::Fuse(_) => Ok(()),
+        }
+    }
+}
+
+impl<'a> MessageWriter<'a> {
+    fn available_bytes(&self) -> usize {
+        match self {
+            Self::Virtio(writer) => writer.available_bytes(),
+            Self::Fuse(writer) => writer.buffer.len().saturating_sub(writer.written),
+        }
+    }
+
+    fn split_at(&mut self, offset: usize) -> io::Result<MessageWriter<'a>> {
+        match self {
+            Self::Virtio(writer) => writer
+                .split_at(offset)
+                .map(Self::Virtio)
+                .map_err(io::Error::other),
+            Self::Fuse(writer) => {
+                if writer.written != 0 || offset > writer.buffer.len() {
+                    return Err(io::Error::from_raw_os_error(libc::EINVAL));
+                }
+                let buffer = std::mem::replace(&mut writer.buffer, &mut []);
+                let (head, tail) = buffer.split_at_mut(offset);
+                writer.buffer = head;
+                Ok(Self::Fuse(FuseWriter {
+                    buffer: tail,
+                    written: 0,
+                }))
+            }
+        }
+    }
+
+    fn bytes_written(&self) -> usize {
+        match self {
+            Self::Virtio(writer) => writer.bytes_written(),
+            Self::Fuse(writer) => writer.written,
+        }
+    }
+
+    fn read_from_file_at(
+        &mut self,
+        file: &File,
+        mut count: usize,
+        mut offset: u64,
+        flags: Option<oslib::ReadvFlags>,
+    ) -> io::Result<usize> {
+        if let Self::Virtio(writer) = self {
+            return writer.read_from_file_at(file, count, offset, flags);
+        }
+        let original = count;
+        let mut buffer = vec![0; count.min(64 * 1024)];
+        while count > 0 {
+            let chunk = count.min(buffer.len());
+            let read = file.read_at(&mut buffer[..chunk], offset)?;
+            if read == 0 {
+                break;
+            }
+            self.write_all(&buffer[..read])?;
+            offset = offset
+                .checked_add(read as u64)
+                .ok_or_else(|| io::Error::other("read offset overflow"))?;
+            count -= read;
+        }
+        Ok(original - count)
+    }
+}
