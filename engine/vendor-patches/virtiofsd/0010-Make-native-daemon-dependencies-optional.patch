diff --git a/src/capabilities.rs b/src/capabilities.rs
new file mode 100644
index 0000000..1a91928
--- /dev/null
+++ b/src/capabilities.rs
@@ -0,0 +1,113 @@
+// SPDX-License-Identifier: BSD-3-Clause
+
+//! Minimal Linux capability operations needed by the filesystem library.
+//!
+//! The standalone daemon retains libcap-ng for its broader policy handling.
+//! Library users only need to toggle effective bits while impersonating a
+//! request, so they should not be forced to link a native daemon dependency.
+
+use std::io;
+
+const LINUX_CAPABILITY_VERSION_3: u32 = 0x2008_0522;
+const CAP_DAC_OVERRIDE: u32 = 1;
+const CAP_FSETID: u32 = 4;
+
+#[repr(C)]
+struct Header {
+    version: u32,
+    pid: i32,
+}
+
+#[repr(C)]
+#[derive(Clone, Copy, Default)]
+struct Data {
+    effective: u32,
+    permitted: u32,
+    inheritable: u32,
+}
+
+fn number(name: &str) -> io::Result<u32> {
+    match name {
+        "DAC_OVERRIDE" => Ok(CAP_DAC_OVERRIDE),
+        "FSETID" => Ok(CAP_FSETID),
+        _ => Err(io::Error::new(
+            io::ErrorKind::InvalidInput,
+            format!("unknown Linux capability {name}"),
+        )),
+    }
+}
+
+fn read() -> io::Result<[Data; 2]> {
+    let mut header = Header {
+        version: LINUX_CAPABILITY_VERSION_3,
+        pid: 0,
+    };
+    let mut data = [Data::default(); 2];
+    let result = unsafe {
+        libc::syscall(
+            libc::SYS_capget,
+            &mut header as *mut Header,
+            data.as_mut_ptr(),
+        )
+    };
+    if result < 0 {
+        Err(io::Error::last_os_error())
+    } else {
+        Ok(data)
+    }
+}
+
+fn write(data: &[Data; 2]) -> io::Result<()> {
+    let mut header = Header {
+        version: LINUX_CAPABILITY_VERSION_3,
+        pid: 0,
+    };
+    let result = unsafe {
+        libc::syscall(
+            libc::SYS_capset,
+            &mut header as *mut Header,
+            data.as_ptr(),
+        )
+    };
+    if result < 0 {
+        Err(io::Error::last_os_error())
+    } else {
+        Ok(())
+    }
+}
+
+fn location(capability: u32) -> (usize, u32) {
+    ((capability / 32) as usize, 1u32 << (capability % 32))
+}
+
+pub fn effective(name: &str) -> io::Result<bool> {
+    let (word, mask) = location(number(name)?);
+    Ok(read()?[word].effective & mask != 0)
+}
+
+pub fn set_effective(name: &str, enabled: bool) -> io::Result<()> {
+    let (word, mask) = location(number(name)?);
+    let mut data = read()?;
+    if enabled {
+        data[word].effective |= mask;
+    } else {
+        data[word].effective &= !mask;
+    }
+    write(&data)
+}
+
+pub fn clear_all() -> io::Result<()> {
+    write(&[Data::default(); 2])
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn known_capabilities_have_stable_linux_numbers() {
+        assert_eq!(number("DAC_OVERRIDE").unwrap(), 1);
+        assert_eq!(number("FSETID").unwrap(), 4);
+        assert!(number("NOT_A_CAPABILITY").is_err());
+    }
+}
