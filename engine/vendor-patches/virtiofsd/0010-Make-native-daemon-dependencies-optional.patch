From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: sarun <noreply@sarun>
Date: Thu, 16 Jul 2026 20:14:53 +0000
Subject: [PATCH] Make native daemon dependencies optional

Keep the transport, server, passthrough filesystem, and vhost-user library usable from a fully static musl embedder without libcap-ng. The library's two effective-capability operations use Linux capget/capset directly; the standalone daemon retains its existing libcap-ng feature.

---
diff --git a/Cargo.toml b/Cargo.toml
index bc29928..c6e71d5 100644
--- a/Cargo.toml
+++ b/Cargo.toml
@@ -28,7 +28,13 @@ license = "Apache-2.0 AND BSD-3-Clause"
 repository = "https://gitlab.com/virtio-fs/virtiofsd"
 
 [features]
-default = ["seccomp"]
+default = ["daemon", "seccomp"]
+daemon = [
+    "dep:capng",
+    "dep:clap",
+    "dep:env_logger",
+    "dep:syslog",
+]
 seccomp = ["dep:libseccomp-sys"]
 xen = [
     "vhost-user-backend/xen",
@@ -43,7 +49,7 @@ path = "src/lib.rs"
 [[bin]]
 name = "virtiofsd"
 path = "src/main.rs"
-required-features = ["seccomp"]
+required-features = ["daemon", "seccomp"]
 
 [dependencies.bitflags]
 version = "1.2"
@@ -53,13 +59,16 @@ version = "0.7"
 
 [dependencies.capng]
 version = "0.2.2"
+optional = true
 
 [dependencies.clap]
 version = "4"
 features = ["derive"]
+optional = true
 
 [dependencies.env_logger]
 version = "0.8.4"
+optional = true
 
 [dependencies.futures]
 version = "0.3"
@@ -85,6 +94,7 @@ features = ["derive"]
 
 [dependencies.syslog]
 version = "6.1"
+optional = true
 
 [dependencies.vhost]
 version = "0.16"
