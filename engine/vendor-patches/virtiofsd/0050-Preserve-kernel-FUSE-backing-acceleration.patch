From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: sarun <noreply@sarun>
Date: Fri, 17 Jul 2026 00:53:22 +0000
Subject: [PATCH] Preserve kernel FUSE backing acceleration

Expose backing-file eligibility through the shared filesystem contract while keeping backing registration, IDs, and release ioctls inside the raw /dev/fuse transport. Mask the host-only capability from virtio-fs connections.

---
diff --git a/src/filesystem.rs b/src/filesystem.rs
index 066cf4d..3d797dc 100644
--- a/src/filesystem.rs
+++ b/src/filesystem.rs
@@ -535,6 +535,14 @@ pub trait FileSystem {
         Ok((None, OpenOptions::empty()))
     }
 
+    /// Duplicate the host file for an open handle that returned
+    /// [`OpenOptions::PASSTHROUGH`]. The ordinary `/dev/fuse` transport uses
+    /// this file only to create a kernel backing registration. Other
+    /// transports never call this method.
+    fn backing_file(&self, handle: Self::Handle) -> io::Result<Option<File>> {
+        Ok(None)
+    }
+
     /// Create and open a file.
     ///
     /// If the file does not already exist, the file system should create it with the specified
