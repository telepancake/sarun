+/// Host-kernel acceleration owned by an ordinary `/dev/fuse` transport.
+/// Filesystem policy chooses eligible handles; this interface only registers
+/// and retires their backing file descriptors on the mounted connection.
+pub trait FuseBacking: Send + Sync {
+    fn register(&self, handle: u64, file: &File) -> io::Result<u32>;
+    fn release(&self, handle: u64);
+}
+
