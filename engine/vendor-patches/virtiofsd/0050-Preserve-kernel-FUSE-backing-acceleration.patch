+    #[derive(Default)]
+    struct RawBacking {
+        registered: AtomicU64,
+        released: AtomicU64,
+    }
+
+    impl FuseBacking for RawBacking {
+        fn register(&self, handle: u64, _file: &File) -> io::Result<u32> {
+            self.registered.store(handle, Ordering::Relaxed);
+            Ok(41)
+        }
