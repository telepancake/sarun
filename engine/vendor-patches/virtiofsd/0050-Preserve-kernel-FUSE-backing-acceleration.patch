@@ -76,6 +76,10 @@ const FOPEN_NOFLUSH: u32 = 1 << 5;
 /// Allow concurrent direct writes on the same inode
 const FOPEN_PARALLEL_DIRECT_WRITES: u32 = 1 << 6;
 
+/// The kernel accesses a backing file registered by the `/dev/fuse`
+/// transport instead of forwarding reads to userspace.
+const FOPEN_PASSTHROUGH: u32 = 1 << 7;
+
 bitflags! {
     /// Options controlling the behavior of files opened by the server in response
     /// to an open or create request.
@@ -87,6 +91,7 @@ bitflags! {
         const STREAM = FOPEN_CACHE_DIR;
         const NOFLUSH = FOPEN_NOFLUSH;
         const PARALLEL_DIRECT_WRITES = FOPEN_PARALLEL_DIRECT_WRITES;
+        const PASSTHROUGH = FOPEN_PASSTHROUGH;
     }
 }
 
@@ -204,6 +209,9 @@ const CREATE_SUPP_GROUP: u64 = 1 << 34;
 /// Relax restrictions in FOPEN_DIRECT_IO mode to allow shared mmap.
 const DIRECT_IO_ALLOW_MMAP: u64 = 1 << 36;
 
+/// Kernel FUSE supports backing-file passthrough registrations.
+const PASSTHROUGH: u64 = 1 << 37;
+
 /// We need this for idmapped mounts support
 const ALLOW_IDMAP: u64 = 1 << 40;
 
@@ -461,6 +469,10 @@ bitflags! {
         /// Allow shared mmap'ing of files in DIRECT_IO.
         const DIRECT_IO_ALLOW_MMAP = DIRECT_IO_ALLOW_MMAP;
 
+        /// The `/dev/fuse` transport may register backing files for eligible
+        /// read-only opens. This is never enabled for virtio-fs transport.
+        const PASSTHROUGH = PASSTHROUGH;
+
         /// Indicates if idmapped mounts are allowed for virtiofs.
         const ALLOW_IDMAP = ALLOW_IDMAP;
     }
@@ -1074,7 +1086,8 @@ pub struct InitOut {
     pub max_pages: u16,
     pub map_alignment: u16,
     pub flags2: u32,
-    pub unused: [u32; 7],
+    pub max_stack_depth: u32,
+    pub unused: [u32; 6],
 }
 unsafe impl ByteValued for InitOut {}
 
diff --git a/src/server.rs b/src/server.rs
