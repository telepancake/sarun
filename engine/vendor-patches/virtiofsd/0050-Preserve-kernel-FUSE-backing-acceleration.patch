+    #[test]
+    fn raw_fuse_backing_registration_is_transport_owned() {
+        let backing = RawBacking::default();
+        let server = Server::new(RawTestFs);
+        let open_header = InHeader {
+            len: (size_of::<InHeader>() + size_of::<OpenIn>()) as u32,
+            opcode: Opcode::Open as u32,
+            unique: 88,
+            nodeid: 9,
+            ..Default::default()
+        };
+        let mut request = open_header.as_slice().to_vec();
+        request.extend_from_slice(OpenIn::default().as_slice());
+        let mut response = [0; 128];
+        let count = server
+            .handle_fuse_message_with_backing(&request, &mut response, &backing)
+            .unwrap();
+        assert_eq!(count, size_of::<OutHeader>() + size_of::<OpenOut>());
+        let opened = unsafe {
+            std::ptr::read_unaligned(
+                response
+                    .as_ptr()
+                    .add(size_of::<OutHeader>())
+                    .cast::<OpenOut>(),
+            )
+        };
+        assert_eq!((opened.fh, opened.padding), (7, 41));
+        assert_eq!(opened.open_flags, OpenOptions::PASSTHROUGH.bits());
+        assert_eq!(backing.registered.load(Ordering::Relaxed), 7);
+
+        let release_header = InHeader {
+            len: (size_of::<InHeader>() + size_of::<ReleaseIn>()) as u32,
+            opcode: Opcode::Release as u32,
+            unique: 89,
+            nodeid: 9,
+            ..Default::default()
+        };
+        let mut release = release_header.as_slice().to_vec();
+        release.extend_from_slice(
+            ReleaseIn {
+                fh: 7,
+                ..Default::default()
+            }
+            .as_slice(),
+        );
+        server
+            .handle_fuse_message_with_backing(&release, &mut response, &backing)
+            .unwrap();
+        assert_eq!(backing.released.load(Ordering::Relaxed), 7);
+    }
