         Server {
@@ -263,7 +271,12 @@ impl<F: FileSystem + Sync> Server<F> {
 
     #[allow(clippy::cognitive_complexity)]
     pub fn handle_message<T>(&self, r: Reader, w: Writer, vu_req: Option<&mut T>) -> Result<usize> {
-        self.handle_message_inner(MessageReader::Virtio(r), MessageWriter::Virtio(w), vu_req)
+        self.handle_message_inner(
+            MessageReader::Virtio(r),
+            MessageWriter::Virtio(w),
+            vu_req,
+            None,
+        )
     }
 
     /// Decode one ordinary kernel FUSE request through the same opcode path as
