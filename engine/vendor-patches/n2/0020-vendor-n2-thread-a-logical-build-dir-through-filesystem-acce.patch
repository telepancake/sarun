-    Ok(match std::fs::metadata(path) {
+    Ok(match std::fs::metadata(resolve_cwd(path)) {
         Ok(meta) => MTime::Stamp(meta.modified().unwrap()),
         Err(err) => {
             if err.kind() == std::io::ErrorKind::NotFound {
