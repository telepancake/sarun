From: sarun <noreply@sarun>
Date: Sat, 04 Jul 2026 16:47:26 +0000
Subject: [PATCH] sort: entry takes logical cwd; join relative paths (operands, -o, -T, --files0-from)

---
diff --git a/src/buffer_hint.rs b/src/buffer_hint.rs
index d5baf9e..ad95cd3 100644
--- a/src/buffer_hint.rs
+++ b/src/buffer_hint.rs
@@ -29,7 +29,10 @@ fn file_size_hint(files: &[OsString]) -> Option<usize> {
             continue;
         }
 
-        let Ok(metadata) = std::fs::metadata(file) else {
+        // Stat at the cwd-resolved path so the size heuristic sees the real
+        // file (the process is never chdir'd to the shell's logical cwd).
+        let Ok(metadata) = std::fs::metadata(crate::resolve_logical(std::path::Path::new(file)))
+        else {
             continue;
         };
 
