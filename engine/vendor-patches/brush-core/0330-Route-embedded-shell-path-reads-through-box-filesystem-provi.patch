diff --git a/src/vfs.rs b/src/vfs.rs
new file mode 100644
index 0000000..194fac1
--- /dev/null
+++ b/src/vfs.rs
@@ -0,0 +1,174 @@
+//! Backend-neutral, read-only filesystem access for shell evaluation.
+//!
+//! File descriptors and mutations intentionally remain outside this interface. An
+//! embedder can therefore route metadata-heavy shell operations to its own filesystem
+//! without accidentally letting a virtual descriptor escape to an external process.
+
+use std::{
+    ffi::OsString,
+    io,
+    path::{Path, PathBuf},
+};
+
+use crate::sys::fs::PathExt as _;
+
+/// The filesystem object kind returned by [`BoxVfs`].
+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+pub enum VfsFileType {
+    File,
+    Directory,
+    Symlink,
+    Other,
+}
+
+/// Backend-neutral metadata. This deliberately does not expose
+/// [`std::fs::Metadata`], whose methods would tie callers to the host filesystem.
+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+pub struct VfsMetadata {
+    pub file_type: VfsFileType,
+    pub len: u64,
+}
+
+impl VfsMetadata {
+    #[must_use]
+    pub const fn is_file(self) -> bool {
+        matches!(self.file_type, VfsFileType::File)
+    }
+
+    #[must_use]
+    pub const fn is_dir(self) -> bool {
+        matches!(self.file_type, VfsFileType::Directory)
+    }
+
+    #[must_use]
+    pub const fn is_symlink(self) -> bool {
+        matches!(self.file_type, VfsFileType::Symlink)
+    }
+}
+
+/// A directory entry whose name remains an `OsString`, including non-UTF-8 names.
+#[derive(Clone, Debug, Eq, PartialEq)]
+pub struct VfsDirEntry {
+    pub path: PathBuf,
+    pub file_name: OsString,
+    pub file_type: VfsFileType,
+}
+
+/// Access check requested from a filesystem provider.
+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+pub enum VfsAccess {
+    Read,
+    Write,
+    Execute,
+}
+
+/// Read-only filesystem operations that are safe to use without exporting a host fd.
+///
+/// Providers must not silently fall back to `std::fs` for provider-owned paths. Every
+/// method is explicit so tests can use a backend that fails on any unexpected operation.
+pub trait BoxVfs: Send + Sync + 'static {
+    /// Metadata while following the final symlink.
+    fn metadata(&self, path: &Path) -> io::Result<VfsMetadata>;
+
+    /// Metadata without following the final symlink.
+    fn symlink_metadata(&self, path: &Path) -> io::Result<VfsMetadata>;
+
+    fn read_dir(&self, path: &Path) -> io::Result<Vec<VfsDirEntry>>;
+
+    fn read_link(&self, path: &Path) -> io::Result<PathBuf>;
+
+    /// Read a complete regular file without exposing a descriptor to the caller.
+    fn read(&self, path: &Path) -> io::Result<Vec<u8>>;
+
+    fn access(&self, path: &Path, access: VfsAccess) -> io::Result<()>;
+}
+
+/// Default provider retaining ordinary Brush behavior.
+#[derive(Debug, Default)]
+pub struct NativeBoxVfs;
+
+fn file_type(file_type: std::fs::FileType) -> VfsFileType {
+    if file_type.is_file() {
+        VfsFileType::File
+    } else if file_type.is_dir() {
+        VfsFileType::Directory
+    } else if file_type.is_symlink() {
+        VfsFileType::Symlink
+    } else {
+        VfsFileType::Other
+    }
+}
+
+fn metadata(metadata: std::fs::Metadata) -> VfsMetadata {
+    VfsMetadata {
+        file_type: file_type(metadata.file_type()),
+        len: metadata.len(),
+    }
+}
+
+impl BoxVfs for NativeBoxVfs {
+    fn metadata(&self, path: &Path) -> io::Result<VfsMetadata> {
+        std::fs::metadata(path).map(metadata)
+    }
+
+    fn symlink_metadata(&self, path: &Path) -> io::Result<VfsMetadata> {
+        std::fs::symlink_metadata(path).map(metadata)
+    }
+
+    fn read_dir(&self, path: &Path) -> io::Result<Vec<VfsDirEntry>> {
+        std::fs::read_dir(path)?
+            .map(|entry| {
+                let entry = entry?;
+                Ok(VfsDirEntry {
+                    path: entry.path(),
+                    file_name: entry.file_name(),
+                    file_type: file_type(entry.file_type()?),
+                })
+            })
+            .collect()
+    }
+
+    fn read_link(&self, path: &Path) -> io::Result<PathBuf> {
+        std::fs::read_link(path)
+    }
+
+    fn read(&self, path: &Path) -> io::Result<Vec<u8>> {
+        std::fs::read(path)
+    }
+
+    fn access(&self, path: &Path, access: VfsAccess) -> io::Result<()> {
+        let allowed = match access {
+            VfsAccess::Read => path.readable(),
+            VfsAccess::Write => path.writable(),
+            VfsAccess::Execute => path.executable(),
+        };
+        if allowed {
+            Ok(())
+        } else {
+            Err(io::Error::from(io::ErrorKind::PermissionDenied))
+        }
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn native_provider_preserves_raw_directory_names_and_file_kinds() -> io::Result<()> {
+        let scratch = tempfile::tempdir()?;
+        std::fs::write(scratch.path().join("plain"), b"contents")?;
+        std::fs::create_dir(scratch.path().join("directory"))?;
+
+        let fs = NativeBoxVfs;
+        let mut entries = fs.read_dir(scratch.path())?;
+        entries.sort_by(|a, b| a.file_name.cmp(&b.file_name));
+
+        assert_eq!(entries[0].file_name, OsString::from("directory"));
+        assert_eq!(entries[0].file_type, VfsFileType::Directory);
+        assert_eq!(entries[1].file_name, OsString::from("plain"));
+        assert_eq!(entries[1].file_type, VfsFileType::File);
+        assert_eq!(fs.read(&entries[1].path)?, b"contents");
+        Ok(())
+    }
+}
