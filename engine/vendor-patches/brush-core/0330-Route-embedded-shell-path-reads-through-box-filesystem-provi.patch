+#[cfg(test)]
+mod tests {
+    use std::{
+        collections::HashMap,
+        io,
+        path::{Path, PathBuf},
+        sync::{Arc, Mutex},
+    };
+
+    use crate::vfs::{BoxVfs, VfsAccess, VfsDirEntry, VfsFileType, VfsMetadata};
+
+    #[derive(Default)]
+    struct StrictMockVfs {
+        metadata: HashMap<PathBuf, VfsMetadata>,
+        files: HashMap<PathBuf, Vec<u8>>,
+        executable: Vec<PathBuf>,
+        calls: Mutex<Vec<(&'static str, PathBuf)>>,
+    }
+
+    impl StrictMockVfs {
+        fn unsupported(&self, operation: &'static str, path: &Path) -> io::Error {
+            self.calls
+                .lock()
+                .unwrap()
+                .push((operation, path.to_owned()));
+            io::Error::new(io::ErrorKind::Unsupported, operation)
+        }
+    }
+
+    impl BoxVfs for StrictMockVfs {
+        fn metadata(&self, path: &Path) -> io::Result<VfsMetadata> {
+            self.calls
+                .lock()
+                .unwrap()
+                .push(("metadata", path.to_owned()));
+            self.metadata
+                .get(path)
+                .copied()
+                .ok_or_else(|| io::Error::from(io::ErrorKind::NotFound))
+        }
+
+        fn symlink_metadata(&self, path: &Path) -> io::Result<VfsMetadata> {
+            Err(self.unsupported("symlink_metadata", path))
+        }
+
+        fn read_dir(&self, path: &Path) -> io::Result<Vec<VfsDirEntry>> {
+            Err(self.unsupported("read_dir", path))
+        }
+
+        fn read_link(&self, path: &Path) -> io::Result<PathBuf> {
+            Err(self.unsupported("read_link", path))
+        }
+
+        fn read(&self, path: &Path) -> io::Result<Vec<u8>> {
+            self.calls.lock().unwrap().push(("read", path.to_owned()));
+            self.files
+                .get(path)
+                .cloned()
+                .ok_or_else(|| io::Error::from(io::ErrorKind::NotFound))
+        }
+
+        fn access(&self, path: &Path, access: VfsAccess) -> io::Result<()> {
+            self.calls.lock().unwrap().push(("access", path.to_owned()));
+            if access == VfsAccess::Execute && self.executable.iter().any(|p| p == path) {
+                Ok(())
+            } else {
+                Err(io::Error::from(io::ErrorKind::PermissionDenied))
+            }
+        }
+    }
+
+    #[tokio::test]
+    async fn cwd_validation_uses_provider_and_provider_is_clone_shared() {
+        let virtual_dir = PathBuf::from("/not-on-the-host/provider-cwd");
+        let provider = Arc::new(StrictMockVfs {
+            metadata: HashMap::from([(
+                virtual_dir.clone(),
+                VfsMetadata {
+                    file_type: VfsFileType::Directory,
+                    len: 0,
+                },
+            )]),
+            executable: vec![virtual_dir.clone()],
+            ..StrictMockVfs::default()
+        });
+        let provider_handle: Arc<dyn BoxVfs> = provider.clone();
+        let mut shell = crate::Shell::builder()
+            .box_vfs(provider_handle)
+            .build()
+            .await
+            .unwrap();
+
+        shell.set_working_dir(&virtual_dir).unwrap();
+        let cloned = shell.clone();
+        let shell_vfs = shell.box_vfs_handle();
+        let cloned_vfs = cloned.box_vfs_handle();
+
+        assert_eq!(shell.working_dir(), virtual_dir);
+        assert!(Arc::ptr_eq(&shell_vfs, &cloned_vfs));
+        assert_eq!(
+            provider.calls.lock().unwrap().as_slice(),
+            &[("metadata", virtual_dir.clone()), ("access", virtual_dir)]
+        );
+    }
+
+    #[tokio::test]
+    async fn path_lookup_uses_provider_without_native_fallback() {
+        let executable = PathBuf::from("/provider-only/bin/tool");
+        let provider = Arc::new(StrictMockVfs {
+            executable: vec![executable.clone()],
+            ..StrictMockVfs::default()
+        });
+        let mut shell = crate::Shell::builder().build().await.unwrap();
+        shell.set_box_vfs(provider.clone());
+        shell
+            .env_mut()
+            .set_global("PATH", crate::ShellVariable::new("/provider-only/bin"))
+            .unwrap();
+
+        assert_eq!(
+            shell.find_first_executable_in_path("tool"),
+            Some(executable.clone())
+        );
+        assert_eq!(
+            provider.calls.lock().unwrap().as_slice(),
+            &[("access", executable)]
+        );
+    }
+
+    #[tokio::test]
+    async fn sourced_script_bytes_use_provider_without_native_fallback() {
+        let virtual_script = PathBuf::from("/provider-only/profile.sh");
+        let provider = Arc::new(StrictMockVfs {
+            files: HashMap::from([(virtual_script.clone(), b"provider_value=typed\n".to_vec())]),
+            ..StrictMockVfs::default()
+        });
+        let provider_handle: Arc<dyn BoxVfs> = provider.clone();
+        let mut shell = crate::Shell::builder()
+            .box_vfs(provider_handle)
+            .build()
+            .await
+            .unwrap();
+        let params = shell.default_exec_params();
+
+        shell
+            .source_script(&virtual_script, std::iter::empty::<String>(), &params)
+            .await
+            .unwrap();
+
+        assert_eq!(shell.env_str("provider_value").as_deref(), Some("typed"));
+        assert_eq!(
+            provider.calls.lock().unwrap().as_slice(),
+            &[("read", virtual_script)]
+        );
+    }
+}
