From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: sarun <noreply@sarun>
Date: Mon, 06 Jul 2026 14:59:33 +0000
Subject: [PATCH] brush-core: /dev/fd/N from process substitution is a REAL fd

---
diff --git a/src/interp.rs b/src/interp.rs
index 86b5cc4..e336f7e 100644
--- a/src/interp.rs
+++ b/src/interp.rs
@@ -2198,17 +2198,39 @@ fn setup_process_substitution(
         }
     });
 
-    // Starting at 63 (a.k.a. 64-1)--and decrementing--look for an
-    // available fd.
-    let mut candidate_fd_num = 63;
-    while params.open_files.contains_fd(candidate_fd_num) {
-        candidate_fd_num -= 1;
-        if candidate_fd_num == 0 {
-            return error::unimp("no available file descriptors");
+    // sarun: the fd number handed out as /dev/fd/<N> must be a REAL
+    // process fd, not just a virtual open_files slot. External children
+    // get virtual fds dup2'd at spawn, but the in-process builtins
+    // (cat/uu_* run on a thread, no fork) open the /dev/fd path against
+    // the REAL fd table — with a virtual-only number, `cat <(echo hi)`
+    // died with "/dev/fd/63: No such file or directory". Pin the pipe
+    // end at a real fd >= 63 via F_DUPFD and advertise THAT number;
+    // the pinned duplicate lives inside the OpenFile, so dropping the
+    // substitution closes it.
+    {
+        use std::os::fd::AsRawFd;
+        use std::os::fd::FromRawFd;
+        let raw = target_file.try_clone_to_owned()?;
+        let mut min = 63;
+        loop {
+            let real = unsafe { libc::fcntl(raw.as_raw_fd(),
+                                            libc::F_DUPFD, min) };
+            if real < 0 {
+                return Err(std::io::Error::last_os_error().into());
+            }
+            if !params.open_files.contains_fd(real) {
+                let pinned = unsafe { std::os::fd::OwnedFd::from_raw_fd(real) };
+                return Ok((real, std::fs::File::from(pinned).into()));
+            }
+            // Real number collides with an existing VIRTUAL slot —
+            // advertising it would alias two different files. Try above.
+            unsafe { libc::close(real) };
+            min = real + 1;
+            if min > 1000 {
+                return error::unimp("no available file descriptors");
+            }
         }
     }
-
-    Ok((candidate_fd_num, target_file))
 }
 
 fn setup_open_file_with_contents(contents: &str) -> Result<OpenFile, error::Error> {
