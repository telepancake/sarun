-fn argv_with_prefix(input: &CommandProbeInput, prefix: Option<&str>) -> Vec<String> {
+fn argv_with_prefix(input: &BuiltinParserInput, prefix: Option<&str>) -> Vec<String> {
     let mut argv = Vec::with_capacity(input.before.len() + input.after.len() + 1);
     argv.extend(input.before.iter().cloned());
     if let Some(prefix) = prefix.filter(|prefix| !prefix.is_empty() || !input.suffix.is_empty()) {
