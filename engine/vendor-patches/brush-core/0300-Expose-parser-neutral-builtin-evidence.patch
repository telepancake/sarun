 fn typed_parse_status<T: Command>(
-    input: &CommandProbeInput,
+    input: &BuiltinParserInput,
     prefix: Option<&str>,
     command: &clap::Command,
-) -> (CommandParseStatus, Vec<CommandArgumentEvidence>) {
+) -> (BuiltinParseStatus, Vec<ParserArgumentEvidence>) {
     match T::new(argv_with_prefix(input, prefix)) {
-        Ok(_) => (CommandParseStatus::Complete, Vec::new()),
+        Ok(_) => (BuiltinParseStatus::Complete, Vec::new()),
         Err(error)
             if incomplete_error(&error, prefix.unwrap_or_default(), input.suffix.as_str()) =>
         {
             (
-                CommandParseStatus::Incomplete,
+                BuiltinParseStatus::Incomplete,
                 expected_arguments(command, &error),
             )
         }
-        Err(error) => (CommandParseStatus::Rejected(error.kind()), Vec::new()),
+        Err(error) => (
+            BuiltinParseStatus::Rejected(parser_diagnostic(&error)),
+            Vec::new(),
+        ),
+    }
+}
+
+fn parser_diagnostic(error: &clap::Error) -> ParserDiagnostic {
+    use clap::error::ErrorKind;
+
+    let code = match error.kind() {
+        ErrorKind::InvalidValue | ErrorKind::ValueValidation => "invalid_value",
+        ErrorKind::UnknownArgument | ErrorKind::InvalidSubcommand => "unknown_argument",
+        ErrorKind::TooManyValues => "too_many_values",
+        ErrorKind::ArgumentConflict => "argument_conflict",
+        ErrorKind::MissingRequiredArgument | ErrorKind::MissingSubcommand => "missing_argument",
+        _ => "invalid_invocation",
+    };
+    ParserDiagnostic {
+        code: code.into(),
+        message: error.to_string(),
     }
 }
 
