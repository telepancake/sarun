From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: sarun <noreply@sarun>
Date: Sat, 04 Jul 2026 21:06:44 +0000
Subject: [PATCH] document logical-env ordering contract for prepare_uutil_runtime

---
diff --git a/src/lib.rs b/src/lib.rs
index 5171f18..dff1d9a 100644
--- a/src/lib.rs
+++ b/src/lib.rs
@@ -58,6 +58,14 @@ use std::ffi::OsString;
     reason = "only called by adapters generated by the `register!` macro; with no coreutils.* features enabled, no adapter exists"
 )]
 fn prepare_uutil_runtime(util_crate_name: &str) {
+    // ORDERING CONTRACT (sarun): the caller must have already installed the
+    // shell's logical environment for this thread
+    // (`uucore::logical_env::set_logical_env`) BEFORE calling this. Localization
+    // setup below reads `LANG`/`LC_*` through `uucore::logical_env::get`, so the
+    // shell's exported locale knobs only reach the Fluent bundle if the override
+    // is in place first. The engine's `run_coreutil_localized` guarantees this;
+    // the `register!` adapter path (standalone bundled dispatch) installs no
+    // override, so `get` falls through to the process env as upstream expects.
     uucore::panic::preserve_inherited_sigpipe();
     uucore::panic::mute_sigpipe_panic();
     let localization_name = uucore::get_canonical_util_name(util_crate_name);
