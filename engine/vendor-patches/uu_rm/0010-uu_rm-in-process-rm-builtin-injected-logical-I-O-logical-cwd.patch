+/// `println!` to the logical stdout buffer (`RM_OUT`) in logical mode, else the
+/// real stdout. Replaces upstream's `println!` for verbose output.
+macro_rules! rm_println {
+    ($($args:tt)+) => {{
+        use std::io::Write as _;
+        if $crate::rm_logical() {
+            $crate::RM_OUT.with(|b| { let _ = writeln!(b.borrow_mut(), $($args)+); });
+        } else {
+            let _ = writeln!(std::io::stdout(), $($args)+);
+        }
+    }};
+}
