+// ── Injected-I/O plumbing for the in-process brush builtin ───────────────────
+//
+// FILESYSTEM template, mirroring uu_cp: [`rm_main`] resolves every relative
+// operand against the shell's LOGICAL cwd (the process is never `chdir`'d) and
+// routes ALL stdio to the shell's logical streams — including interactive
+// prompts (`rm -i`), which must read the shell's logical stdin, NEVER the
+// engine's real fd 0 (a stray read there corrupts a control channel/pipe). Runs
+// on a FRESH worker thread per call (the engine's `run_coreutil_localized`), so
+// these thread-locals are per-instance: `RM_OUT` buffers verbose output,
+// `RM_ERR` diagnostics + prompt text, `RM_IN` the logical stdin line source,
+// `RM_LOGICAL` flags that the logical entry installed them. The crate-local
+// `show_error!` / `prompt_yes!` macros below SHADOW uucore's, and the verbose
+// `println!` sites target `RM_OUT`. Standalone [`uumain`] leaves `RM_LOGICAL`
+// false, so prompts/`is_terminal` fall back to the real process streams.
+thread_local! {
+    static RM_OUT: std::cell::RefCell<Vec<u8>> = const { std::cell::RefCell::new(Vec::new()) };
+    static RM_ERR: std::cell::RefCell<Vec<u8>> = const { std::cell::RefCell::new(Vec::new()) };
+    static RM_IN: std::cell::RefCell<Option<Box<dyn BufRead>>> = const { std::cell::RefCell::new(None) };
+    static RM_LOGICAL: std::cell::Cell<bool> = const { std::cell::Cell::new(false) };
+}
+
+/// True when the standard streams are the shell's logical streams ([`rm_main`]),
+/// false for the standalone binary ([`uumain`]).
+fn rm_logical() -> bool {
+    RM_LOGICAL.with(std::cell::Cell::get)
+}
+
+/// Whether the (logical or real) stdin is a terminal. In-process there is no
+/// controlling tty, so the logical stdin is never a terminal.
+fn rm_stdin_is_terminal() -> bool {
+    if rm_logical() { false } else { stdin().is_terminal() }
+}
+
+/// Shadows [`uucore::show_error!`]: writes `<util_name>: <msg>` to the logical
+/// stderr buffer when in logical mode, else to the real fd 2.
+macro_rules! show_error {
+    ($($args:tt)+) => {{
+        use std::io::Write as _;
+        if $crate::rm_logical() {
+            $crate::RM_ERR.with(|b| {
+                let mut b = b.borrow_mut();
+                let _ = write!(b, "{}: ", uucore::util_name());
+                let _ = writeln!(b, $($args)+);
+            });
+        } else {
+            let mut e = std::io::stderr().lock();
+            let _ = write!(e, "{}: ", uucore::util_name());
+            let _ = writeln!(e, $($args)+);
+        }
+    }};
+}
+
+/// Shadows [`uucore::prompt_yes!`]: in logical mode the prompt text goes to the
+/// logical stderr buffer and the y/N answer is read from the logical stdin
+/// (`RM_IN`) — never the engine's fd 0; EOF / no input is treated as "no",
+/// matching GNU's behavior on a closed stdin. Falls back to the real streams
+/// for the standalone binary.
+macro_rules! prompt_yes {
+    ($($args:tt)+) => {{
+        if $crate::rm_logical() {
+            use std::io::Write as _;
+            $crate::RM_ERR.with(|b| {
+                let mut b = b.borrow_mut();
+                let _ = write!(b, "{}: ", uucore::util_name());
+                let _ = write!(b, $($args)+);
+                let _ = write!(b, " ");
+            });
+            $crate::RM_IN.with(|cell| {
+                let mut s = String::new();
+                match cell.borrow_mut().as_mut() {
+                    Some(r) => matches!(r.read_line(&mut s), Ok(n) if n > 0 && matches!(s.chars().next(), Some('y' | 'Y'))),
+                    None => false,
+                }
+            })
+        } else {
+            uucore::prompt_yes!($($args)+)
+        }
+    }};
+}
 
