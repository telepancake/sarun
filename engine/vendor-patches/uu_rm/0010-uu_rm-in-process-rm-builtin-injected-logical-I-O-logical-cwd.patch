+/// Logical entry point for the in-process brush `rm` builtin.
+///
+/// Mirrors [`uumain`] but (1) resolves every relative file operand against the
+/// shell's LOGICAL `cwd` (the process is never `chdir`'d), and (2) routes all
+/// stdio through the shell's logical streams: verbose output to `out`,
+/// diagnostics + prompts to `err`, and `rm -i` answers read from `stdin` — never
+/// the engine's fd 0. The deferred error status surfaces as the returned value.
+pub fn rm_main(
+    args: impl uucore::Args,
+    cwd: &Path,
+    out: &mut dyn Write,
+    err: &mut dyn Write,
+    stdin_src: Box<dyn BufRead>,
+) -> UResult<()> {
+    RM_OUT.with(|b| b.borrow_mut().clear());
+    RM_ERR.with(|b| b.borrow_mut().clear());
+    RM_IN.with(|c| *c.borrow_mut() = Some(stdin_src));
+    RM_LOGICAL.with(|c| c.set(true));
+
+    let result = run(args, Some(cwd));
+
+    RM_LOGICAL.with(|c| c.set(false));
+    RM_IN.with(|c| *c.borrow_mut() = None);
+    let produced_out = RM_OUT.with(|b| std::mem::take(&mut *b.borrow_mut()));
+    let produced_err = RM_ERR.with(|b| std::mem::take(&mut *b.borrow_mut()));
+    let _ = out.write_all(&produced_out);
+    let _ = out.flush();
+    let _ = err.write_all(&produced_err);
+    let _ = err.flush();
+    result
+}
+
 #[uucore::main]
 pub fn uumain(args: impl uucore::Args) -> UResult<()> {
+    run(args, None)
+}
+
