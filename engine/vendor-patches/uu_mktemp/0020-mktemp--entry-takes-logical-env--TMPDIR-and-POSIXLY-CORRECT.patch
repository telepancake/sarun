 /// Shared body of [`mktemp_main`] and [`uumain`]. When `cwd` is `Some`, a
 /// relative target directory is rooted at the shell's logical cwd for creation
 /// (the printed name stays template-relative); when `None` (standalone) creation
 /// is against the process cwd, as upstream. The created name is written to `out`.
-fn run(args: impl uucore::Args, cwd: Option<&Path>, out: &mut dyn std::io::Write) -> UResult<()> {
+fn run(
+    args: impl uucore::Args,
+    cwd: Option<&Path>,
+    env: &[(OsString, OsString)],
+    out: &mut dyn std::io::Write,
+) -> UResult<()> {
     let args: Vec<_> = args.collect();
     let matches = match uu_app().try_get_matches_from(&args) {
         Ok(m) => m,
@@ -423,9 +437,9 @@ fn run(args: impl uucore::Args, cwd: Option<&Path>, out: &mut dyn std::io::Write
 
     // Parse command-line options into a format suitable for the
     // application logic.
-    let options = Options::from(&matches);
+    let options = Options::from(&matches, env, cwd);
 
-    if env::var_os("POSIXLY_CORRECT").is_some() {
+    if env_get(env, "POSIXLY_CORRECT").is_some() {
         // If POSIXLY_CORRECT was set, template MUST be the last argument.
         if matches.contains_id(ARG_TEMPLATE) {
             // Template argument was provided, check if was the last one.
@@ -669,11 +683,32 @@ fn exec(
     Ok(path)
 }
 
-/// Reads from `TMPDIR_ENV_VAR` but defaults to /tmp if value is set to empty string.
-fn get_tmpdir_env_or_default() -> PathBuf {
-    match env::var_os(TMPDIR_ENV_VAR) {
-        Some(val) if val.is_empty() => PathBuf::from(FALLBACK_TMPDIR),
-        _ => env::temp_dir(),
+/// Look a key up in a logical-env snapshot (`export`ed vars from the brush shell).
+fn env_get<'a>(env: &'a [(OsString, OsString)], key: &str) -> Option<&'a OsStr> {
+    env.iter()
+        .find(|(k, _)| k.as_os_str() == OsStr::new(key))
+        .map(|(_, v)| v.as_os_str())
+}
+
+/// Root a directory path against the shell's logical `cwd` when it is relative
+/// (the process is never `chdir`'d there). `cwd` is `None` on the standalone
+/// bridge, where a relative value is left as-is (resolved against the process
+/// cwd at creation, exactly as upstream).
+fn join_logical(path: &Path, cwd: Option<&Path>) -> PathBuf {
+    match cwd {
+        Some(c) if path.is_relative() => c.join(path),
+        _ => path.to_owned(),
+    }
+}
+
+/// The temp-directory default from the LOGICAL env: `$TMPDIR` if set and
+/// non-empty (a relative value rooted at the logical `cwd`), else `/tmp`. This
+/// replaces the pair `env::var_os(TMPDIR)` / `env::temp_dir()`, both of which
+/// read the engine process's own env.
+fn get_tmpdir_env_or_default(env: &[(OsString, OsString)], cwd: Option<&Path>) -> PathBuf {
+    match env_get(env, TMPDIR_ENV_VAR) {
+        Some(val) if !val.is_empty() => join_logical(Path::new(val), cwd),
+        _ => PathBuf::from(FALLBACK_TMPDIR),
     }
 }
 
