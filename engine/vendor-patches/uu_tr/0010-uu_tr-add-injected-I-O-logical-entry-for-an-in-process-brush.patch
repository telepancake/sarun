+        let (out, err, code) = run(&["a-z", "A-Z"], b"Hello, World!\n");
+        assert_eq!(out, b"HELLO, WORLD!\n");
+        assert!(err.is_empty(), "stderr: {err:?}");
+        assert_eq!(code, 0);
+    }
+
+    #[test]
