+    /// In-memory, no-fd path: drive the public `head` entry with `out` = a
+    /// `Vec<u8>` and `stdin` = a byte slice, both fd-less (out_fd/stdin_fd =
+    /// None). This is the exact shape a pipeline hands when `head` is fed by
+    /// another in-process builtin and its output is captured to memory: no raw
+    /// descriptor exists on either end, so the seek path is skipped and bytes
+    /// flow through the trait objects. Proves the port is correct without any
+    /// process-global stdio.
+    #[test]
+    #[allow(clippy::cognitive_complexity)]
+    fn test_head_in_memory_no_fd() {
+        fn run(argv: &[&str], input: &[u8]) -> Vec<u8> {
+            let mut src: &[u8] = input;
+            let mut out: Vec<u8> = Vec::new();
+            let args = std::iter::once(OsString::from("head"))
+                .chain(argv.iter().map(OsString::from));
+            head(args, &mut out, None, &mut src, None).unwrap();
+            out
+        }
+
+        let input: &[u8] = b"l1\nl2\nl3\nl4\nl5\nl6\nl7\nl8\nl9\nl10\nl11\nl12\n";
+
+        // Default: first 10 lines.
+        assert_eq!(run(&[], input), b"l1\nl2\nl3\nl4\nl5\nl6\nl7\nl8\nl9\nl10\n");
+        // -n 2
+        assert_eq!(run(&["-n", "2"], input), b"l1\nl2\n");
+        // -c 5
+        assert_eq!(run(&["-c", "5"], input), b"l1\nl2");
+        // -n -2 (all but last 2 lines)
+        assert_eq!(run(&["-n", "-2"], b"a\nb\nc\nd\ne\n"), b"a\nb\nc\n");
+        // -c -3 (all but last 3 bytes)
+        assert_eq!(run(&["-c", "-3"], b"abcdef"), b"abc");
+        // empty input
+        assert_eq!(run(&[], b""), b"");
+        // no trailing newline, -n 2
+        assert_eq!(run(&["-n", "2"], b"a\nb\nc"), b"a\nb\n");
     }
 
