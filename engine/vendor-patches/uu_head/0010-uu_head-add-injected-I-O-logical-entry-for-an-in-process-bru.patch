-pub fn uumain(args: impl uucore::Args) -> UResult<()> {
+/// Logical entry point for the bundled `head` builtin.
+///
+/// Unlike upstream's `uumain`, this never touches the process's own stdio: it
+/// drives `head` against the shell's logical output sink (`out`) and logical
+/// input source (`stdin`, with its backing descriptor `stdin_fd` when one
+/// exists). `head` has no splice/`copy_file_range` fast path, so `out_fd` is
+/// accepted only for signature parity with `cat` and is unused; `stdin_fd` is
+/// genuinely needed — when present, the stdin path dups it to a seekable
+/// `File` and preserves the shared offset exactly as GNU/uutils do, and when
+/// absent it copies straight through the in-memory reader. Holds no
+/// process-global state, so a pipeline stage can take it concurrently.
+pub fn head(
+    args: impl uucore::Args,
+    out: &mut dyn Write,
+    out_fd: Option<BorrowedFd<'_>>,
+    stdin: &mut dyn Read,
+    stdin_fd: Option<BorrowedFd<'_>>,
+) -> UResult<()> {
+    // `head` has no fd-to-fd fast path; the output descriptor is irrelevant.
+    let _ = out_fd;
     let args: Vec<_> = arg_iterate(args)?.collect();
     let matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;
     let options = HeadOptions::get_from(&matches).map_err(HeadError::MatchOption)?;
-    uu_head(&options)
+    uu_head(&options, out, stdin, stdin_fd)
+}
+
+/// Descriptor-based entry point for the standalone `head` binary and the
+/// `--invoke-bundled` subprocess dispatcher.
+///
+/// In those contexts the process's own fd 0/1 *are* the intended input and
+/// output, so this is a thin bridge that hands them to [`head`]. The in-process
+/// brush builtin must NOT route through here — it calls [`head`] directly with
+/// the shell's logical sink/source (and their backing fds, when any), so it
+/// never touches process-global stdio.
+#[uucore::main]
+pub fn uumain(args: impl uucore::Args) -> UResult<()> {
+    let stdout = io::stdout();
+    let mut out = stdout.lock();
+    let stdin = io::stdin();
+    let mut input = stdin.lock();
+    // SAFETY: fd 0 and fd 1 are the process's standard streams, open and valid
+    // for the whole duration of this call.
+    let out_fd = Some(unsafe { BorrowedFd::borrow_raw(1) });
+    let in_fd = Some(unsafe { BorrowedFd::borrow_raw(0) });
+    head(args, &mut out, out_fd, &mut input, in_fd)
 }
 
