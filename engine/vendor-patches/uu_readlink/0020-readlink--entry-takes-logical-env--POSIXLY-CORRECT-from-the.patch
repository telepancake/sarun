From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: sarun <noreply@sarun>
Date: Sat, 04 Jul 2026 17:47:11 +0000
Subject: [PATCH] readlink: entry takes logical env; POSIXLY_CORRECT from the shell

---
diff --git a/src/readlink.rs b/src/readlink.rs
index 888217f..5f54a8d 100644
--- a/src/readlink.rs
+++ b/src/readlink.rs
@@ -6,7 +6,6 @@
 // spell-checker:ignore (ToDO) errno
 
 use clap::{Arg, ArgAction, Command};
-use std::env;
 use std::ffi::OsString;
 use std::fs;
 use std::io::Write;
@@ -57,6 +56,17 @@ const OPT_ZERO: &str = "zero";
 
 const ARG_FILES: &str = "files";
 
+/// Look up `key` in the call's LOGICAL environment (the shell's exported vars),
+/// never the engine process's environment. `Some("")` for a set-but-empty value
+/// vs `None` when unset — the same distinction as `env::var_os`. The standalone
+/// binary passes a snapshot of the process environment, so behavior there is
+/// unchanged.
+fn env_get<'a>(env: &'a [(OsString, OsString)], key: &str) -> Option<&'a std::ffi::OsStr> {
+    env.iter()
+        .find(|(k, _)| k == key)
+        .map(|(_, v)| v.as_os_str())
+}
+
 /// Logical entry point for the in-process brush `readlink` builtin.
 ///
 /// Mirrors [`uumain`] but (1) resolves every relative operand against the
@@ -65,11 +75,12 @@ const ARG_FILES: &str = "files";
 pub fn readlink(
     args: impl uucore::Args,
     cwd: &Path,
+    env: &[(OsString, OsString)],
     out: &mut dyn Write,
     err: &mut dyn Write,
 ) -> UResult<()> {
     RL_ERR.with(|b| b.borrow_mut().clear());
-    let result = run(args, Some(cwd), out);
+    let result = run(args, Some(cwd), env, out);
     let produced_err = RL_ERR.with(|b| std::mem::take(&mut *b.borrow_mut()));
     let _ = out.flush();
     let _ = err.write_all(&produced_err);
@@ -81,7 +92,9 @@ pub fn readlink(
 pub fn uumain(args: impl uucore::Args) -> UResult<()> {
     RL_ERR.with(|b| b.borrow_mut().clear());
     let mut out = std::io::stdout();
-    let result = run(args, None, &mut out);
+    // Standalone binary: resolve POSIXLY_CORRECT against the process environment.
+    let env: Vec<(OsString, OsString)> = std::env::vars_os().collect();
+    let result = run(args, None, &env, &mut out);
     let produced_err = RL_ERR.with(|b| std::mem::take(&mut *b.borrow_mut()));
     let _ = std::io::stderr().write_all(&produced_err);
     result
@@ -90,12 +103,18 @@ pub fn uumain(args: impl uucore::Args) -> UResult<()> {
 /// Shared body of [`readlink`] and [`uumain`]. When `cwd` is `Some`, relative
 /// operands are rooted at the shell's logical cwd; when `None` (standalone) they
 /// resolve against the process cwd, as upstream.
-fn run(args: impl uucore::Args, cwd: Option<&Path>, out: &mut dyn Write) -> UResult<()> {
+fn run(
+    args: impl uucore::Args,
+    cwd: Option<&Path>,
+    env: &[(OsString, OsString)],
+    out: &mut dyn Write,
+) -> UResult<()> {
     let matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;
 
     let mut no_trailing_delimiter = matches.get_flag(OPT_NO_NEWLINE);
     let use_zero = matches.get_flag(OPT_ZERO);
-    let verbose = matches.get_flag(OPT_VERBOSE) || env::var("POSIXLY_CORRECT").is_ok();
+    // POSIXLY_CORRECT read from the shell's LOGICAL env, not the process env.
+    let verbose = matches.get_flag(OPT_VERBOSE) || env_get(env, "POSIXLY_CORRECT").is_some();
 
     // GNU readlink -f/-e/-m follows symlinks first and then applies `..` (physical resolution).
     // ResolveMode::Logical collapses `..` before following links, which yields the opposite order,
