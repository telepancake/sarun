From: sarun <noreply@sarun>
Date: Sat, 04 Jul 2026 16:41:35 +0000
Subject: [PATCH] wc: entry takes logical cwd; join relative file and files0-from operands

---
diff --git a/src/wc.rs b/src/wc.rs
index 68700b1..1ce6897 100644
--- a/src/wc.rs
+++ b/src/wc.rs
@@ -134,6 +134,34 @@ mod options {
 static ARG_FILES: &str = "files";
 static STDIN_REPR: &str = "-";
 
+thread_local! {
+    /// The call's logical cwd. A relative FILE operand — and a `--files0-from=F`
+    /// value, and every relative path read FROM F — is rooted here for OPEN
+    /// (the process is never `chdir`'d). Empty => the standalone binary, which
+    /// resolves operands against the process cwd. Set by [`wc`], cleared after.
+    static WC_CWD: std::cell::RefCell<PathBuf> = const { std::cell::RefCell::new(PathBuf::new()) };
+}
+
+/// Root a relative operand at the call's logical cwd ([`WC_CWD`]) for OPEN only.
+/// Absolute operands are returned unchanged; an empty cwd (standalone binary)
+/// leaves the operand as given. The stdin sentinel (`-`) never reaches here.
+/// Display/error text keeps the operand as the user wrote it — this join is
+/// applied strictly at the `File::open`/`metadata` sites, not to the stored
+/// `Input::Path`.
+fn logical_join(path: &Path) -> PathBuf {
+    if path.is_absolute() {
+        return path.to_path_buf();
+    }
+    WC_CWD.with(|c| {
+        let base = c.borrow();
+        if base.as_os_str().is_empty() {
+            path.to_path_buf()
+        } else {
+            base.join(path)
+        }
+    })
+}
+
 /// Supported inputs.
 #[derive(Debug)]
 enum Inputs<'a> {
