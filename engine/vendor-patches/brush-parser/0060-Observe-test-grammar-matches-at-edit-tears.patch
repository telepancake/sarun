 /// Parses a test command expression.
 ///
 /// # Arguments
 ///
 /// * `input` - The test command expression to parse, in string form.
 pub fn parse<S: AsRef<str>>(input: &[S]) -> Result<ast::TestExpr, error::TestCommandParseError> {
-    let expr =
-        test_command::full_expression(&input.iter().map(AsRef::as_ref).collect::<Vec<&str>>())?;
+    let words = input
+        .iter()
+        .map(|word| InputWord {
+            text: word.as_ref(),
+            tear: false,
+            prefix: "",
+            suffix: "",
+            recorder: None,
+        })
+        .collect::<Vec<_>>();
+    parse_words(&words)
+}
+
+/// Runs the ordinary test-expression parser with one rich edit tear.
+///
+/// Literal and operand evidence is recorded at the PEG grammar's real match
+/// sites. Literal candidates are retained only when replacing the tear word
+/// makes that same parser accept the complete expression.
+pub fn probe(input: &ProbeInput) -> ProbeObservation {
+    let recorder = RefCell::new(Recorder::default());
+    let tear_text = format!("{}{}", input.prefix, input.suffix);
+    let mut surfaces = Vec::with_capacity(input.before.len() + input.after.len() + 1);
+    surfaces.extend(input.before.iter().map(String::as_str));
+    surfaces.push(tear_text.as_str());
+    surfaces.extend(input.after.iter().map(String::as_str));
+    let tear_index = input.before.len();
+    let words = surfaces
+        .iter()
+        .enumerate()
+        .map(|(index, text)| InputWord {
+            text,
+            tear: index == tear_index,
+            prefix: input.prefix.as_str(),
+            suffix: input.suffix.as_str(),
+            recorder: Some(&recorder),
+        })
+        .collect::<Vec<_>>();
+    let parsed = parse_words(&words);
+    let diagnostic = parsed.as_ref().err().map(ToString::to_string);
+
+    let mut recorded = recorder.into_inner();
+    recorded
+        .arguments
+        .sort_by_key(|argument| format!("{argument:?}"));
+    recorded.arguments.dedup();
 
-    Ok(expr)
+    let mut literal_continuations = recorded
+        .literals
+        .into_iter()
+        .filter_map(|literal| {
+            let mut candidate = surfaces
+                .iter()
+                .map(|word| (*word).to_owned())
+                .collect::<Vec<_>>();
+            candidate[tear_index] = literal.expected.to_owned();
+            parse(&candidate).ok().map(|_| LiteralContinuation {
+                literal: literal.replacement_prefix,
+            })
+        })
+        .collect::<Vec<_>>();
+    literal_continuations.sort_by(|left, right| left.literal.cmp(&right.literal));
+    literal_continuations.dedup();
+
+    ProbeObservation {
+        accepted: parsed.is_ok(),
+        arguments: recorded.arguments,
+        literal_continuations,
+        diagnostic,
+    }
 }
 
