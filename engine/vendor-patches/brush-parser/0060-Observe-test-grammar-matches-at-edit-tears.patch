 //! Parser for shell test commands.
 
+use std::cell::RefCell;
+
 use crate::{ast, error};
 
+/// Input to an observational parse at an edit tear.
+#[derive(Clone, Debug, Default, PartialEq, Eq)]
+pub struct ProbeInput {
+    pub before: Vec<String>,
+    pub prefix: String,
+    pub suffix: String,
+    pub after: Vec<String>,
+}
+
+/// The semantic role in which the ordinary parser matched the tear word.
+#[derive(Clone, Debug, PartialEq, Eq)]
+pub enum TearArgument {
+    Literal,
+    FilesystemPath,
+    FilesystemFile,
+    FilesystemDirectory,
+    FilesystemExecutable,
+    ShellVariable,
+    ShellOption,
+    FileDescriptor,
+    Integer,
+    Text,
+}
+
+/// One literal terminal matched by the ordinary grammar at the tear.
+#[derive(Clone, Debug, PartialEq, Eq)]
+pub struct LiteralContinuation {
+    /// Replacement prefix before the unchanged suffix to the right of the tear.
+    pub literal: String,
+}
+
+/// Result of probing the execution parser.
+#[derive(Clone, Debug, PartialEq, Eq)]
+pub struct ProbeObservation {
+    pub accepted: bool,
+    pub arguments: Vec<TearArgument>,
+    pub literal_continuations: Vec<LiteralContinuation>,
+    pub diagnostic: Option<String>,
+}
+
+#[derive(Clone, Debug)]
+struct RecordedLiteral {
+    expected: &'static str,
+    replacement_prefix: String,
+}
+
+#[derive(Default)]
+struct Recorder {
+    arguments: Vec<TearArgument>,
+    literals: Vec<RecordedLiteral>,
+}
+
+#[derive(Clone, Copy)]
+struct InputWord<'a> {
+    text: &'a str,
+    tear: bool,
+    prefix: &'a str,
+    suffix: &'a str,
+    recorder: Option<&'a RefCell<Recorder>>,
+}
+
+impl InputWord<'_> {
+    fn matches_literal(&self, expected: &'static str) -> bool {
+        if self.tear
+            && let Some(replacement_prefix) = expected.strip_suffix(self.suffix)
+            && replacement_prefix.starts_with(self.prefix)
+            && let Some(recorder) = self.recorder
+        {
+            recorder.borrow_mut().literals.push(RecordedLiteral {
+                expected,
+                replacement_prefix: replacement_prefix.to_owned(),
+            });
+        }
+        self.text == expected
+    }
+
+    fn record_argument(self, argument: TearArgument) {
+        if self.tear
+            && let Some(recorder) = self.recorder
+        {
+            recorder.borrow_mut().arguments.push(argument);
+        }
+    }
+}
+
+fn unary_argument(operator: &ast::UnaryPredicate) -> TearArgument {
+    match operator {
+        ast::UnaryPredicate::FileExistsAndIsRegularFile => TearArgument::FilesystemFile,
+        ast::UnaryPredicate::FileExistsAndIsDir => TearArgument::FilesystemDirectory,
+        ast::UnaryPredicate::FileExistsAndIsExecutable => TearArgument::FilesystemExecutable,
+        ast::UnaryPredicate::FileExists
+        | ast::UnaryPredicate::FileExistsAndIsBlockSpecialFile
+        | ast::UnaryPredicate::FileExistsAndIsCharSpecialFile
+        | ast::UnaryPredicate::FileExistsAndIsSetgid
+        | ast::UnaryPredicate::FileExistsAndIsSymlink
+        | ast::UnaryPredicate::FileExistsAndHasStickyBit
+        | ast::UnaryPredicate::FileExistsAndIsFifo
+        | ast::UnaryPredicate::FileExistsAndIsReadable
+        | ast::UnaryPredicate::FileExistsAndIsNotZeroLength
+        | ast::UnaryPredicate::FileExistsAndIsSetuid
+        | ast::UnaryPredicate::FileExistsAndIsWritable
+        | ast::UnaryPredicate::FileExistsAndOwnedByEffectiveGroupId
+        | ast::UnaryPredicate::FileExistsAndModifiedSinceLastRead
+        | ast::UnaryPredicate::FileExistsAndOwnedByEffectiveUserId
+        | ast::UnaryPredicate::FileExistsAndIsSocket => TearArgument::FilesystemPath,
+        ast::UnaryPredicate::ShellVariableIsSetAndAssigned
+        | ast::UnaryPredicate::ShellVariableIsSetAndNameRef => TearArgument::ShellVariable,
+        ast::UnaryPredicate::ShellOptionEnabled => TearArgument::ShellOption,
+        ast::UnaryPredicate::FdIsOpenTerminal => TearArgument::FileDescriptor,
+        ast::UnaryPredicate::StringHasZeroLength | ast::UnaryPredicate::StringHasNonZeroLength => {
+            TearArgument::Text
+        }
+    }
+}
+
+fn binary_argument(operator: &ast::BinaryPredicate) -> TearArgument {
+    match operator {
+        ast::BinaryPredicate::FilesReferToSameDeviceAndInodeNumbers
+        | ast::BinaryPredicate::LeftFileIsNewerOrExistsWhenRightDoesNot
+        | ast::BinaryPredicate::LeftFileIsOlderOrDoesNotExistWhenRightDoes => {
+            TearArgument::FilesystemPath
+        }
+        ast::BinaryPredicate::ArithmeticEqualTo
+        | ast::BinaryPredicate::ArithmeticNotEqualTo
+        | ast::BinaryPredicate::ArithmeticLessThan
+        | ast::BinaryPredicate::ArithmeticLessThanOrEqualTo
+        | ast::BinaryPredicate::ArithmeticGreaterThan
+        | ast::BinaryPredicate::ArithmeticGreaterThanOrEqualTo => TearArgument::Integer,
+        ast::BinaryPredicate::StringExactlyMatchesPattern
+        | ast::BinaryPredicate::StringDoesNotExactlyMatchPattern
+        | ast::BinaryPredicate::StringMatchesRegex
+        | ast::BinaryPredicate::StringExactlyMatchesString
+        | ast::BinaryPredicate::StringDoesNotExactlyMatchString
+        | ast::BinaryPredicate::StringContainsSubstring
+        | ast::BinaryPredicate::LeftSortsBeforeRight
+        | ast::BinaryPredicate::LeftSortsAfterRight => TearArgument::Text,
+    }
+}
+
+fn parse_words(input: &[InputWord<'_>]) -> Result<ast::TestExpr, error::TestCommandParseError> {
+    Ok(test_command::full_expression(input)?)
+}
