+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn probe_records_unary_operand_at_the_real_match_site() {
+        let observation = probe(&ProbeInput {
+            before: vec!["-f".into()],
+            prefix: "./c".into(),
+            suffix: String::new(),
+            after: Vec::new(),
+        });
+        assert!(observation.accepted);
+        assert_eq!(observation.arguments, vec![TearArgument::FilesystemFile]);
+    }
+
+    #[test]
+    fn probe_records_only_parser_viable_literal_continuations() {
+        let observation = probe(&ProbeInput {
+            before: vec!["left".into()],
+            prefix: "-e".into(),
+            suffix: String::new(),
+            after: vec!["right".into()],
+        });
+        assert!(!observation.accepted);
+        assert_eq!(
+            observation.literal_continuations,
+            vec![
+                LiteralContinuation {
+                    literal: "-ef".into()
+                },
+                LiteralContinuation {
+                    literal: "-eq".into()
+                }
+            ]
+        );
+    }
+
+    #[test]
+    fn probe_preserves_suffix_compatibility() {
+        let observation = probe(&ProbeInput {
+            before: vec!["left".into()],
+            prefix: "-".into(),
+            suffix: "q".into(),
+            after: vec!["right".into()],
+        });
+        assert_eq!(
+            observation.literal_continuations,
+            vec![LiteralContinuation {
+                literal: "-e".into()
+            }]
+        );
+    }
+}
