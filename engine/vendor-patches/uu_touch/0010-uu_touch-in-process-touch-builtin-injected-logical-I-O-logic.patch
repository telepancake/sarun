 use crate::error::TouchError;
 
+// ── Injected-I/O plumbing for the in-process brush builtin ───────────────────
+//
+// FILESYSTEM template, mirroring uu_cp: [`touch_main`] resolves every relative
+// path operand (and a `-r`/`--reference` value) against the shell's LOGICAL cwd
+// (the process is never `chdir`'d) and routes diagnostics to the shell's logical
+// stderr. touch reads no stdin and (on Unix) writes no stdout. Runs on a FRESH
+// worker thread per call (the engine's `run_coreutil_localized`), so these
+// thread-locals are per-instance: `TOUCH_ERR` buffers diagnostics, `TOUCH_EXIT`
+// the deferred exit code. The crate-local `show!` macro below SHADOWS uucore's
+// (which writes fd 2 + the process-global exit code), recording the code into
+// `TOUCH_EXIT`. Standalone [`uumain`] drains the buffer to real stderr.
+thread_local! {
+    static TOUCH_ERR: std::cell::RefCell<Vec<u8>> = const { std::cell::RefCell::new(Vec::new()) };
+    static TOUCH_EXIT: std::cell::Cell<i32> = const { std::cell::Cell::new(0) };
+}
+
+/// Shadows [`uucore::show!`]: records the error's code into [`TOUCH_EXIT`] and
+/// writes `<util_name>: <err>` to the logical stderr buffer (never fd 2).
+macro_rules! show {
+    ($err:expr) => {{
+        #[allow(unused_imports)]
+        use uucore::error::UError as _;
+        use std::io::Write as _;
+        let e = $err;
+        $crate::TOUCH_EXIT.with(|c| c.set(e.code()));
+        $crate::TOUCH_ERR.with(|b| {
+            let _ = writeln!(b.borrow_mut(), "{}: {e}", uucore::util_name());
+        });
+    }};
+}
+
