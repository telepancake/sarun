+/// Logical entry point for the in-process brush `touch` builtin.
+///
+/// Mirrors [`uumain`] but (1) resolves every relative path operand and the
+/// `-r`/`--reference` value against the shell's LOGICAL `cwd` (the process is
+/// never `chdir`'d), and (2) routes diagnostics to `err` (never fd 2). touch
+/// reads no stdin. The deferred error status surfaces as the returned value.
+pub fn touch_main(
+    args: impl uucore::Args,
+    cwd: &Path,
+    _out: &mut dyn std::io::Write,
+    err: &mut dyn std::io::Write,
+) -> UResult<()> {
+    TOUCH_ERR.with(|b| b.borrow_mut().clear());
+    TOUCH_EXIT.with(|c| c.set(0));
+
+    let result = run(args, Some(cwd));
+
+    let produced = TOUCH_ERR.with(|b| std::mem::take(&mut *b.borrow_mut()));
+    let _ = err.write_all(&produced);
+    let _ = err.flush();
+
+    let deferred = TOUCH_EXIT.with(std::cell::Cell::get);
+    match result {
+        Ok(()) if deferred != 0 => Err(USimpleError::new(deferred, String::new())),
+        other => other,
+    }
+}
+
 #[uucore::main]
 pub fn uumain(args: impl uucore::Args) -> UResult<()> {
+    TOUCH_ERR.with(|b| b.borrow_mut().clear());
+    TOUCH_EXIT.with(|c| c.set(0));
+
+    let result = run(args, None);
+
+    let produced = TOUCH_ERR.with(|b| std::mem::take(&mut *b.borrow_mut()));
+    let _ = std::io::Write::write_all(&mut std::io::stderr(), &produced);
+
+    let deferred = TOUCH_EXIT.with(std::cell::Cell::get);
+    match result {
+        Ok(()) if deferred != 0 => Err(USimpleError::new(deferred, String::new())),
+        other => other,
+    }
+}
+
