Subject: [PATCH] touch: honor logical TZ for -d/-t date parsing without mutating process TZ

---
diff --git a/src/touch.rs b/src/touch.rs
index 1703964..9d544d3 100644
--- a/src/touch.rs
+++ b/src/touch.rs
@@ -174,9 +174,41 @@ fn timestamp_to_filetime(ts: Timestamp) -> FileTime {
     FileTime::from_system_time(SystemTime::from(ts))
 }
 
-fn filetime_to_zoned(ft: &FileTime) -> Option<Zoned> {
+fn filetime_to_zoned(ft: &FileTime, tz: &TimeZone) -> Option<Zoned> {
     let ts = Timestamp::new(ft.unix_seconds(), ft.nanoseconds() as i32).ok()?;
-    Some(Zoned::new(ts, TimeZone::system()))
+    Some(Zoned::new(ts, tz.clone()))
+}
+
+/// Resolve the LOGICAL timezone for date parsing.
+///
+/// A box shell's `export TZ=…` must steer `touch -d`/`-t` the way it steers a
+/// real `touch` child — but the process (the engine) is shared across concurrent
+/// pipelines, so we must NOT mutate the process TZ (`set_var`/`tzset`). Instead
+/// we read `TZ` from the shell's LOGICAL env snapshot (`env`) and resolve it to a
+/// `jiff::tz::TimeZone` locally, leaving the process global untouched.
+///
+/// Honored forms: an IANA name (`Asia/Tokyo`, `UTC`, resolved against the
+/// system zoneinfo, optional leading `:`), a POSIX TZ string (`JST-9`,
+/// `EST5EDT`), and empty `TZ` (POSIX: UTC). When `TZ` is unset, or set to a
+/// value that resolves to neither, we fall back to `TimeZone::system()` — the
+/// process's own local zone, i.e. today's behavior. The standalone binary passes
+/// an env snapshot of the real process env, so it is unaffected.
+fn logical_timezone(env: &[(OsString, OsString)]) -> TimeZone {
+    let Some(tz) = env_get(env, "TZ") else {
+        return TimeZone::system();
+    };
+    let spec = tz.to_string_lossy();
+    let spec = spec.strip_prefix(':').unwrap_or(&spec);
+    if spec.is_empty() {
+        return TimeZone::UTC;
+    }
+    if let Ok(z) = TimeZone::get(spec) {
+        return z;
+    }
+    if let Ok(z) = TimeZone::posix(spec) {
+        return z;
+    }
+    TimeZone::system()
 }
 
 /// Whether all characters in the string are digits.
