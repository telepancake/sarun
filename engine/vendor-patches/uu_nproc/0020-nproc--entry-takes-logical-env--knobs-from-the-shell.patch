From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: sarun <noreply@sarun>
Date: Sat, 04 Jul 2026 17:53:06 +0000
Subject: [PATCH] nproc: entry takes logical env; knobs from the shell

---
diff --git a/src/nproc.rs b/src/nproc.rs
index 427b851..58a96e6 100644
--- a/src/nproc.rs
+++ b/src/nproc.rs
@@ -6,8 +6,9 @@
 // spell-checker:ignore (ToDO) NPROCESSORS nprocs numstr sysconf
 
 use clap::{Arg, ArgAction, Command};
+use std::ffi::{OsStr, OsString};
 use std::io::{Write, stdout};
-use std::{env, thread};
+use std::thread;
 use uucore::display::Quotable;
 use uucore::error::{UResult, USimpleError};
 use uucore::format_usage;
@@ -16,11 +17,22 @@ use uucore::translate;
 static OPT_ALL: &str = "all";
 static OPT_IGNORE: &str = "ignore";
 
+/// Look up `key` in the shell's LOGICAL environment snapshot (the vars the
+/// brush shell has `export`ed), returning its value if present. Replaces the
+/// process-env reads (`std::env::var`) so the OpenMP knobs (`OMP_THREAD_LIMIT`,
+/// `OMP_NUM_THREADS`) set with `export` in the box shell — not ones inherited by
+/// the engine process — take effect. Behavior with the vars absent is identical.
+fn env_get<'a>(env: &'a [(OsString, OsString)], key: &str) -> Option<&'a OsStr> {
+    env.iter()
+        .find(|(k, _)| k == OsStr::new(key))
+        .map(|(_, v)| v.as_os_str())
+}
+
 /// Compute the CPU count to report, applying the `--all`/`--ignore` flags and the
 /// OpenMP env-var overrides. Factored out of `uumain` so the standalone binary
 /// and the in-process [`nproc_main`] share identical logic; only the output sink
 /// differs.
-fn count_cores(matches: &clap::ArgMatches) -> UResult<usize> {
+fn count_cores(matches: &clap::ArgMatches, env: &[(OsString, OsString)]) -> UResult<usize> {
     let ignore = match matches.get_one::<String>(OPT_IGNORE) {
         Some(numstr) => match numstr.trim().parse::<usize>() {
             Ok(num) => num,
@@ -34,27 +46,27 @@ fn count_cores(matches: &clap::ArgMatches) -> UResult<usize> {
         None => 0,
     };
 
-    let limit = match env::var("OMP_THREAD_LIMIT") {
+    let limit = match env_get(env, "OMP_THREAD_LIMIT").and_then(OsStr::to_str) {
         // Uses the OpenMP variable to limit the number of threads
         // If the parsing fails, returns the max size (so, no impact)
         // If OMP_THREAD_LIMIT=0, rejects the value
-        Ok(threads) => match threads.parse() {
+        Some(threads) => match threads.parse() {
             Ok(0) | Err(_) => usize::MAX,
             Ok(n) => n,
         },
-        // the variable 'OMP_THREAD_LIMIT' doesn't exist
+        // the variable 'OMP_THREAD_LIMIT' doesn't exist (or isn't Unicode)
         // fallback to the max
-        Err(_) => usize::MAX,
+        None => usize::MAX,
     };
 
     let mut cores = if matches.get_flag(OPT_ALL) {
         num_cpus_all()
     } else {
         // OMP_NUM_THREADS doesn't have an impact on --all
-        match env::var("OMP_NUM_THREADS") {
+        match env_get(env, "OMP_NUM_THREADS").and_then(OsStr::to_str) {
             // Uses the OpenMP variable to force the number of threads
             // If the parsing fails, returns the number of CPU
-            Ok(threads) => {
+            Some(threads) => {
                 // In some cases, OMP_NUM_THREADS can be "x,y,z"
                 // In this case, only take the first one (like GNU)
                 // If OMP_NUM_THREADS=0, rejects the value
@@ -66,9 +78,9 @@ fn count_cores(matches: &clap::ArgMatches) -> UResult<usize> {
                     },
                 }
             }
-            // the variable 'OMP_NUM_THREADS' doesn't exist
+            // the variable 'OMP_NUM_THREADS' doesn't exist (or isn't Unicode)
             // fallback to the regular CPU detection
-            Err(_) => available_parallelism(),
+            None => available_parallelism(),
         }
     };
 
@@ -85,15 +97,18 @@ fn count_cores(matches: &clap::ArgMatches) -> UResult<usize> {
 ///
 /// `nproc` reads no stdin; it computes the CPU count and writes `"{cores}\n"` to
 /// the injected `out` sink — never the process's global stdout. `err` is accepted
-/// for the engine's uniform `(args, out, err)` entry shape; nproc emits no
+/// `env` is the shell's LOGICAL environment snapshot, from which the OpenMP
+/// knobs are read (never the engine process's env). `err` is accepted for the
+/// engine's uniform `(args, env, out, err)` entry shape; nproc emits no
 /// diagnostics of its own (failures are returned).
 pub fn nproc_main(
     args: impl uucore::Args,
+    env: &[(OsString, OsString)],
     out: &mut dyn Write,
     _err: &mut dyn Write,
 ) -> UResult<()> {
     let matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;
-    let cores = count_cores(&matches)?;
+    let cores = count_cores(&matches, env)?;
     out.write_all(format!("{cores}\n").as_bytes())
         .map_err(|e| USimpleError::new(1, e.to_string()))?;
     Ok(())
@@ -102,7 +117,10 @@ pub fn nproc_main(
 #[uucore::main(no_signals)]
 pub fn uumain(args: impl uucore::Args) -> UResult<()> {
     let matches = uucore::clap_localization::handle_clap_result(uu_app(), args)?;
-    let cores = count_cores(&matches)?;
+    // Standalone binary: the OpenMP knobs come from the process environment,
+    // exactly as upstream read them directly.
+    let env: Vec<(OsString, OsString)> = std::env::vars_os().collect();
+    let cores = count_cores(&matches, &env)?;
     //discard error about stdout flush
     stdout()
         .lock()
