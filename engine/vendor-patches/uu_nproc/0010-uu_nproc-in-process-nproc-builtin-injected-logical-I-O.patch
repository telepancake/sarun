+++ b/src/nproc.rs
@@ -16,10 +16,11 @@ use uucore::translate;
 static OPT_ALL: &str = "all";
 static OPT_IGNORE: &str = "ignore";
 
-#[uucore::main(no_signals)]
-pub fn uumain(args: impl uucore::Args) -> UResult<()> {
