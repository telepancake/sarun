+// ── Injected-I/O plumbing for the in-process brush builtin ───────────────────
+//
+// FILESYSTEM template, mirroring uu_cp: [`mv_main`] resolves every relative
+// operand AND the `-t`/`--target-directory` value against the shell's LOGICAL
+// cwd (the process is never `chdir`'d) and routes ALL stdio to the shell's
+// logical streams — including the interactive overwrite prompt (`mv -i`), which
+// reads the shell's logical stdin, NEVER the engine's fd 0. Runs on a FRESH
+// worker thread per call (the engine's `run_coreutil_localized`), so these
+// thread-locals are per-instance: `MV_OUT` buffers verbose/debug output,
+// `MV_ERR` diagnostics + prompt text, `MV_IN` the logical stdin line source,
+// `MV_EXIT` the deferred exit code, `MV_LOGICAL` flags the logical entry. The
+// crate-local `show!` / `prompt_yes!` / `mv_println!` macros and the
+// `set_exit_code` / `mv_stdin_is_terminal` shims below SHADOW the process-global
+// originals. Standalone [`uumain`] leaves `MV_LOGICAL` false, so everything
+// falls back to the real process streams.
+thread_local! {
+    static MV_OUT: std::cell::RefCell<Vec<u8>> = const { std::cell::RefCell::new(Vec::new()) };
+    static MV_ERR: std::cell::RefCell<Vec<u8>> = const { std::cell::RefCell::new(Vec::new()) };
+    static MV_IN: std::cell::RefCell<Option<Box<dyn io::BufRead>>> = const { std::cell::RefCell::new(None) };
+    static MV_EXIT: std::cell::Cell<i32> = const { std::cell::Cell::new(0) };
+    static MV_LOGICAL: std::cell::Cell<bool> = const { std::cell::Cell::new(false) };
+}
+
+/// True when the standard streams are the shell's logical streams ([`mv_main`]).
+pub(crate) fn mv_logical() -> bool {
+    MV_LOGICAL.with(std::cell::Cell::get)
+}
+
+/// In-process there is no controlling tty, so the logical stdin is never one.
+fn mv_stdin_is_terminal() -> bool {
+    if mv_logical() { false } else { io::stdin().is_terminal() }
+}
+
+/// Route the deferred exit code into [`MV_EXIT`] (logical) or uucore's
+/// process-global `EXIT_CODE` (standalone).
+fn set_exit_code(code: i32) {
+    if mv_logical() {
+        MV_EXIT.with(|c| c.set(code));
+    } else {
+        uucore::error::set_exit_code(code);
+    }
+}
+
+/// Append a line to the logical stdout buffer (`MV_OUT`) or real stdout.
+/// Replaces upstream's verbose/debug `println!`.
+macro_rules! mv_println {
+    ($($args:tt)+) => {{
+        use std::io::Write as _;
+        if $crate::mv_logical() {
+            $crate::MV_OUT.with(|b| { let _ = writeln!(b.borrow_mut(), $($args)+); });
+        } else {
+            let _ = writeln!(std::io::stdout(), $($args)+);
+        }
+    }};
+}
+
+/// Append a line to the logical stderr buffer (`MV_ERR`) or real stderr.
+/// Replaces upstream's raw `eprintln!` (the `hardlink` module's verbose
+/// warnings, which carry no util-name prefix).
+macro_rules! mv_eprintln {
+    ($($args:tt)+) => {{
+        use std::io::Write as _;
+        if $crate::mv_logical() {
+            $crate::MV_ERR.with(|b| { let _ = writeln!(b.borrow_mut(), $($args)+); });
+        } else {
+            let _ = writeln!(std::io::stderr(), $($args)+);
+        }
+    }};
+}
+pub(crate) use mv_eprintln;
+
+/// Shadows [`uucore::show!`]: in logical mode records the error's code into
+/// [`MV_EXIT`] and writes `<util_name>: <err>` to the logical stderr buffer;
+/// otherwise defers to uucore's `show!`.
+macro_rules! show {
+    ($err:expr) => {{
+        #[allow(unused_imports)]
+        use uucore::error::UError as _;
+        if $crate::mv_logical() {
+            use std::io::Write as _;
+            let e = $err;
+            $crate::MV_EXIT.with(|c| c.set(e.code()));
+            $crate::MV_ERR.with(|b| {
+                let _ = writeln!(b.borrow_mut(), "{}: {e}", uucore::util_name());
+            });
+        } else {
+            uucore::show!($err);
+        }
+    }};
+}
+
+/// Shadows [`uucore::prompt_yes!`]: in logical mode the prompt text goes to the
+/// logical stderr buffer and the y/N answer is read from the logical stdin
+/// (`MV_IN`) — never the engine's fd 0; EOF / no input is treated as "no".
+macro_rules! prompt_yes {
+    ($($args:tt)+) => {{
+        if $crate::mv_logical() {
+            use std::io::Write as _;
+            $crate::MV_ERR.with(|b| {
+                let mut b = b.borrow_mut();
+                let _ = write!(b, "{}: ", uucore::util_name());
+                let _ = write!(b, $($args)+);
+                let _ = write!(b, " ");
+            });
+            $crate::MV_IN.with(|cell| {
+                use std::io::BufRead as _;
+                let mut s = String::new();
+                match cell.borrow_mut().as_mut() {
+                    Some(r) => matches!(r.read_line(&mut s), Ok(n) if n > 0 && matches!(s.chars().next(), Some('y' | 'Y'))),
+                    None => false,
+                }
+            })
+        } else {
+            uucore::prompt_yes!($($args)+)
+        }
+    }};
+}
 
