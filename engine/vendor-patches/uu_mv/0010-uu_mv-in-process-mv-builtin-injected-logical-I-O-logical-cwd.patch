+/// Logical entry point for the in-process brush `mv` builtin.
+///
+/// Mirrors [`uumain`] but (1) resolves every relative file operand and the
+/// `-t`/`--target-directory` value against the shell's LOGICAL `cwd` (the
+/// process is never `chdir`'d), and (2) routes all stdio through the shell's
+/// logical streams: verbose/debug output to `out`, diagnostics + the `-i`
+/// overwrite prompt to `err`, the prompt answer read from `stdin` — never the
+/// engine's fd 0. The deferred error status surfaces as the returned value.
+pub fn mv_main(
+    args: impl uucore::Args,
+    cwd: &Path,
+    out: &mut dyn io::Write,
+    err: &mut dyn io::Write,
+    stdin_src: Box<dyn io::BufRead>,
+) -> UResult<()> {
+    MV_OUT.with(|b| b.borrow_mut().clear());
+    MV_ERR.with(|b| b.borrow_mut().clear());
+    MV_EXIT.with(|c| c.set(0));
+    MV_IN.with(|c| *c.borrow_mut() = Some(stdin_src));
+    MV_LOGICAL.with(|c| c.set(true));
+
+    let result = run(args, Some(cwd));
+
+    MV_LOGICAL.with(|c| c.set(false));
+    MV_IN.with(|c| *c.borrow_mut() = None);
+    let produced_out = MV_OUT.with(|b| std::mem::take(&mut *b.borrow_mut()));
+    let produced_err = MV_ERR.with(|b| std::mem::take(&mut *b.borrow_mut()));
+    let _ = out.write_all(&produced_out);
+    let _ = out.flush();
+    let _ = err.write_all(&produced_err);
+    let _ = err.flush();
+
+    let deferred = MV_EXIT.with(std::cell::Cell::get);
+    match result {
+        Ok(()) if deferred != 0 => Err(USimpleError::new(deferred, String::new())),
+        other => other,
+    }
+}
+
 #[uucore::main]
 pub fn uumain(args: impl uucore::Args) -> UResult<()> {
+    run(args, None)
+}
+
