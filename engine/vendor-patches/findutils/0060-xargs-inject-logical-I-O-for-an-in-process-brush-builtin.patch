+/// Entry point with injected logical I/O, for an in-process embedder (the sarun
+/// brush builtin). Identical to `xargs_main` except all of xargs's own input
+/// and diagnostic/echo output go through `io` (the shell's logical
+/// stdin/stdout/stderr) instead of the process's real fd 0/1/2.
+#[must_use]
+pub fn xargs_main_with_io(args: &[&str], io: &dyn XargsIo) -> i32 {
