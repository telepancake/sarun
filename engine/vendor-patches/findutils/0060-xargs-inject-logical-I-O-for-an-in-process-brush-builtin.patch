+/// Injected logical I/O for an in-process embedder.
+///
+/// Upstream xargs reads its items from the process's real `stdin` and writes
+/// diagnostics (`-t` traces, the mutually-exclusive warning, errors) and the
+/// no-command `echo` output to the process's real `stdout`/`stderr`. Run as an
+/// in-process brush builtin those process-global streams belong to the ENGINE
+/// (fd 0 is a control channel / a parent pipe / another box's stream; fd 1/2
+/// are the engine's), so touching them would steal or corrupt a neighbour's
+/// bytes. `XargsIo` routes xargs's OWN input/output through the shell's LOGICAL
+/// stdin/stdout/stderr instead. The commands xargs SPAWNS still inherit the
+/// process fds via `Command` — exactly as `find -exec` does — which in a box is
+/// the shell's logical fd 1/2.
+///
+/// `StandardXargsIo` reproduces the upstream behaviour (real `stdin`/`stdout`/
+/// `stderr`) for the standalone binary; the embedder supplies its own.
+pub trait XargsIo {
+    /// Bulk source for input items — replaces `io::stdin()`. Returned by value
+    /// because it is moved into the `ArgumentReader`. Only consulted when no
+    /// `-a/--arg-file` is given (a file always wins, same as upstream).
+    fn take_input(&self) -> Box<dyn Read>;
+    /// Sink for normal output (the no-command `echo` action, help/version text).
+    fn output(&self) -> &RefCell<dyn Write>;
+    /// Sink for diagnostics (`-t` command traces, warnings, errors).
+    fn error_output(&self) -> &RefCell<dyn Write>;
+}
+
+/// The dependencies used when xargs runs as the real standalone executable:
+/// the process's real `stdin`, `stdout`, and `stderr`.
+pub struct StandardXargsIo {
+    output: RefCell<io::Stdout>,
+    error_output: RefCell<io::Stderr>,
+}
+
+impl Default for StandardXargsIo {
+    fn default() -> Self {
+        Self {
+            output: RefCell::new(io::stdout()),
+            error_output: RefCell::new(io::stderr()),
+        }
+    }
+}
+
+impl XargsIo for StandardXargsIo {
+    fn take_input(&self) -> Box<dyn Read> {
+        Box::new(io::stdin())
+    }
+    fn output(&self) -> &RefCell<dyn Write> {
+        &self.output
+    }
+    fn error_output(&self) -> &RefCell<dyn Write> {
+        &self.error_output
+    }
+}
