+/// Semantic identity of a predicate whose operand names one filesystem entry.
+#[derive(Clone, Copy, Debug, Eq, PartialEq, Hash)]
+pub enum ReferencePredicateIdentity {
+    Newer {
+        candidate: FileTimestamp,
+        reference: FileTimestamp,
+    },
+    SameFile,
+}
+
+/// Parsed meaning of the mechanically encoded `-newerXY` family.
+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+pub struct NewerPredicateIdentity {
+    pub candidate: FileTimestamp,
+    /// `None` is the `Y=t` textual-time form, which has no filesystem reference.
+    pub reference: Option<FileTimestamp>,
+}
+
+/// Parse `-newer`, its GNU short spellings, and the exact `-newerXY` encoding.
+pub fn newer_predicate(surface: &str) -> Option<NewerPredicateIdentity> {
+    let (candidate, reference) = match surface {
+        "-newer" => (FileTimestamp::Modified, FileTimestamp::Modified),
+        "-anewer" => (FileTimestamp::Accessed, FileTimestamp::Modified),
+        "-cnewer" => (FileTimestamp::Changed, FileTimestamp::Modified),
+        _ => {
+            let encoded = surface.strip_prefix("-newer")?;
+            if encoded.len() != 2 || !encoded.is_ascii() {
+                return None;
+            }
+            let candidate = FileTimestamp::from_code(&encoded[0..1])?;
+            let reference = if &encoded[1..2] == "t" {
+                None
+            } else {
+                Some(FileTimestamp::from_code(&encoded[1..2])?)
+            };
+            return Some(NewerPredicateIdentity {
+                candidate,
+                reference,
+            });
+        }
+    };
+    Some(NewerPredicateIdentity {
+        candidate,
+        reference: Some(reference),
+    })
+}
+
+/// Return only predicates whose operand is an external filesystem reference.
+pub fn reference_predicate(surface: &str) -> Option<ReferencePredicateIdentity> {
+    if surface == "-samefile" {
+        return Some(ReferencePredicateIdentity::SameFile);
+    }
+    let newer = newer_predicate(surface)?;
+    Some(ReferencePredicateIdentity::Newer {
+        candidate: newer.candidate,
+        reference: newer.reference?,
+    })
+}
+
+/// Common finite predicate spellings offered by syntax assistance. Exact
+/// `-newerXY` encodings are still accepted mechanically by `newer_predicate`.
+pub static REFERENCE_PREDICATE_SPELLINGS: &[(&str, &str)] = &[
+    ("-newer", "compare modification time with a reference entry"),
+    ("-anewer", "compare access time with a reference entry's modification time"),
+    ("-cnewer", "compare status-change time with a reference entry's modification time"),
+    ("-samefile", "match the same filesystem entry as a reference path"),
+];
