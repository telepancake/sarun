+/// The logical namespace in which a matcher reference operand is interpreted.
+#[derive(Clone, Debug, Eq, PartialEq)]
+pub enum ReferenceSource {
+    LogicalCwdPath(PathBuf),
+    AbsolutePath(PathBuf),
+}
+
+/// How a command-line reference operand treats a final symbolic link.
+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+pub enum ReferenceFollow {
+    LinkItself,
+    ReferentWithLinkFallback,
+}
+
+impl ReferenceFollow {
+    pub(crate) fn from_find_follow(follow: Follow) -> Self {
+        if follow == Follow::Never {
+            Self::LinkItself
+        } else {
+            Self::ReferentWithLinkFallback
+        }
+    }
+}
+
+/// The single value a matcher needs from its reference entry.
+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+pub enum ReferenceProjection {
+    Time(matchers::time::FileTimestamp),
+    FileIdentity,
+}
+
+/// A pure unique-entry-or-fail dependency produced by the Find parser.
+#[derive(Clone, Debug, Eq, PartialEq)]
+pub struct ReferenceQuery {
+    pub source: ReferenceSource,
+    pub follow: ReferenceFollow,
+    pub projection: ReferenceProjection,
+}
+
+impl ReferenceQuery {
+    pub(crate) fn from_surface(
+        surface: &str,
+        follow: Follow,
+        projection: ReferenceProjection,
+    ) -> Self {
+        let path = PathBuf::from(surface);
+        let source = if path.is_absolute() {
+            ReferenceSource::AbsolutePath(path)
+        } else {
+            ReferenceSource::LogicalCwdPath(path)
+        };
+        Self {
+            source,
+            follow: ReferenceFollow::from_find_follow(follow),
+            projection,
+        }
+    }
+}
+
+/// Opaque, comparable identity of one filesystem entry.
+pub struct ReferenceFileIdentity(FileInformation);
+
+impl std::fmt::Debug for ReferenceFileIdentity {
+    fn fmt(&self, formatter: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
+        formatter.write_str("ReferenceFileIdentity(..)")
+    }
+}
+
+impl PartialEq for ReferenceFileIdentity {
+    fn eq(&self, other: &Self) -> bool {
+        self.0 == other.0
+    }
+}
+
+impl Eq for ReferenceFileIdentity {}
+
+impl ReferenceFileIdentity {
+    pub(crate) fn from_path(path: &Path, follow: ReferenceFollow) -> io::Result<Self> {
+        if follow == ReferenceFollow::ReferentWithLinkFallback {
+            if let Ok(info) = FileInformation::from_path(path, true) {
+                return Ok(Self(info));
+            }
+        }
+        FileInformation::from_path(path, false).map(Self)
+    }
+}
+
