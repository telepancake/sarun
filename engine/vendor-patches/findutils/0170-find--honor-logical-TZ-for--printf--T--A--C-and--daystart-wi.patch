+/// Format `time` with strftime `format`, in `offset` when `Some` (the box's
+/// LOGICAL zone) or the process local zone otherwise. The `Some` branch converts
+/// via UTC then `with_timezone(&offset)`; the wall-clock components are identical
+/// to what a `chrono::Local` in that zone would produce.
+fn format_in_zone(time: SystemTime, offset: Option<FixedOffset>, format: &str) -> String {
+    match offset {
+        Some(off) => DateTime::<Utc>::from(time)
+            .with_timezone(&off)
+            .format(format)
+            .to_string(),
+        None => DateTime::<Local>::from(time).format(format).to_string(),
+    }
+}
