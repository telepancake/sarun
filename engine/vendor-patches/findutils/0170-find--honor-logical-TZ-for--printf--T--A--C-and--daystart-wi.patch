@@ -196,6 +196,48 @@ impl MatcherIO<'_> {
     pub fn confirm(&self, prompt: &str) -> bool {
         self.deps.confirm(prompt)
     }
+
+    /// sarun: the embedder's LOGICAL `TZ` name (`Dependencies::tz`), or `None` to
+    /// fall back to the process local zone (chrono `Local`).
+    #[must_use]
+    pub fn tz(&self) -> Option<String> {
+        self.deps.tz()
+    }
+}
+
+/// sarun: resolve a LOGICAL `TZ` name to the UTC offset in effect AT `time`,
+/// as a `chrono::FixedOffset` — the seam that lets `-printf %T/%A/%C` and
+/// `-daystart` honor the box shell's `export TZ=…` without the engine process
+/// mutating its own `TZ` (racy across concurrent in-process pipelines).
+///
+/// Honored forms (via `jiff`): an IANA name (`Asia/Tokyo`, `UTC`, optional
+/// leading `:`) resolved against the system zoneinfo, a POSIX TZ string
+/// (`JST-9`, `EST5EDT`), and empty `TZ` (POSIX: UTC). Anything that resolves to
+/// none of these yields `None`, and the caller falls back to chrono `Local`
+/// (the process zone) — i.e. today's behavior. DST is handled per-`time`: the
+/// offset is looked up at that instant, so a file whose time falls in a
+/// different DST period than "now" gets its own correct offset.
+#[must_use]
+pub(crate) fn logical_offset(tz_name: &str, time: SystemTime) -> Option<chrono::FixedOffset> {
+    let spec = tz_name.strip_prefix(':').unwrap_or(tz_name);
+    let tz = if spec.is_empty() {
+        jiff::tz::TimeZone::UTC
+    } else if let Ok(z) = jiff::tz::TimeZone::get(spec) {
+        z
+    } else if let Ok(z) = jiff::tz::TimeZone::posix(spec) {
+        z
+    } else {
+        return None;
+    };
+    let ts = match time.duration_since(SystemTime::UNIX_EPOCH) {
+        Ok(d) => jiff::Timestamp::new(d.as_secs() as i64, d.subsec_nanos() as i32).ok()?,
+        Err(e) => {
+            // pre-epoch time
+            let d = e.duration();
+            jiff::Timestamp::new(-(d.as_secs() as i64), -(d.subsec_nanos() as i32)).ok()?
+        }
+    };
+    chrono::FixedOffset::east_opt(tz.to_offset(ts).seconds())
 }
 
