+
+impl FindContext for DependencyFindContext<'_> {
+    fn observe_files0(&self, query: &Files0Query) -> Result<Files0Observation, Box<dyn Error>> {
+        let mut bytes = Vec::new();
+        match &query.source {
+            Files0Source::LogicalStdin => {
+                self.dependencies
+                    .get_input()
+                    .borrow_mut()
+                    .read_to_end(&mut bytes)?;
+            }
+            Files0Source::LogicalCwdPath(path) => {
+                let path = self
+                    .dependencies
+                    .cwd()
+                    .map_or_else(|| path.clone(), |cwd| cwd.join(path));
+                let mut file = std::fs::File::open(&path).map_err(|error| {
+                    format!(
+                        "cannot open '{}' for reading: {error}",
+                        query.display_source()
+                    )
+                })?;
+                file.read_to_end(&mut bytes)?;
+            }
+            Files0Source::AbsolutePath(path) => {
+                let mut file = std::fs::File::open(path).map_err(|error| {
+                    format!(
+                        "cannot open '{}' for reading: {error}",
+                        query.display_source()
+                    )
+                })?;
+                file.read_to_end(&mut bytes)?;
+            }
+        }
+        Ok(Files0Observation {
+            query: query.clone(),
+            bytes,
+        })
+    }
+}
