+/// An external value required to turn a parsed find invocation into an
+/// executable plan. Parsing only constructs this value; it never reads it.
+#[derive(Clone, Debug, Eq, PartialEq)]
+pub struct Files0Query {
+    pub argument: usize,
+    pub source: Files0Source,
+}
+
+impl Files0Query {
+    pub(crate) fn from_argument(argument: usize, surface: &str) -> Self {
+        let source = if surface == "-" {
+            Files0Source::LogicalStdin
+        } else {
+            let path = PathBuf::from(surface);
+            if path.is_absolute() {
+                Files0Source::AbsolutePath(path)
+            } else {
+                Files0Source::LogicalCwdPath(path)
+            }
+        };
+        Self { argument, source }
+    }
+
+    fn display_source(&self) -> String {
+        match &self.source {
+            Files0Source::LogicalStdin => "(standard input)".to_string(),
+            Files0Source::LogicalCwdPath(path) | Files0Source::AbsolutePath(path) => {
+                path.to_string_lossy().into_owned()
+            }
+        }
+    }
+}
+
+/// The logical namespace in which a `-files0-from` source is interpreted.
+#[derive(Clone, Debug, Eq, PartialEq)]
+pub enum Files0Source {
+    LogicalStdin,
+    LogicalCwdPath(PathBuf),
+    AbsolutePath(PathBuf),
+}
+
+/// Immutable result of resolving one [`Files0Query`]. The query is repeated in
+/// the observation so pure replay can reject an observation for another input.
+#[derive(Clone, Debug, Eq, PartialEq)]
+pub struct Files0Observation {
+    pub query: Files0Query,
+    pub bytes: Vec<u8>,
+}
+
+/// Read-only execution context used to resolve parsed Find dependencies.
+/// This is deliberately separate from [`FindOperations`], whose methods commit
+/// mutations such as creating output files.
+pub trait FindContext {
+    fn observe_files0(&self, query: &Files0Query) -> Result<Files0Observation, Box<dyn Error>>;
+}
