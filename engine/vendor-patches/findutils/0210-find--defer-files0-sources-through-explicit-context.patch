+
+fn decode_files0_observation(
+    query: &Files0Query,
+    observation: &Files0Observation,
+) -> Result<(Vec<PathBuf>, Vec<String>, i32), Box<dyn Error>> {
+    if &observation.query != query {
+        return Err(From::from(
+            "-files0-from observation does not match its query",
+        ));
+    }
+    let mut records = observation.bytes.split(|byte| *byte == 0).collect::<Vec<_>>();
+    if records.last().is_some_and(|record| record.is_empty()) {
+        records.pop();
+    }
+
+    let mut paths = Vec::new();
+    let mut diagnostics = Vec::new();
+    for (index, record) in records.into_iter().enumerate() {
+        if record.is_empty() {
+            diagnostics.push(format!(
+                "find: '{}':{}: invalid zero-length file name",
+                query.display_source(),
+                index + 1
+            ));
+            continue;
+        }
+        #[cfg(unix)]
+        let path = PathBuf::from(OsString::from_vec(record.to_vec()));
+        #[cfg(not(unix))]
+        let path = PathBuf::from(String::from_utf8(record.to_vec()).map_err(|_| {
+            format!(
+                "{}:{}: file name is not valid UTF-8 on this platform",
+                query.display_source(),
+                index + 1
+            )
+        })?);
+        paths.push(path);
+    }
+    let exit_code = i32::from(!diagnostics.is_empty());
+    Ok((paths, diagnostics, exit_code))
+}
