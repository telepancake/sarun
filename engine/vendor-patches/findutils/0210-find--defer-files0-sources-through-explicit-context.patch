+impl ParsedInfo {
+    fn resolve(self, context: &dyn FindContext) -> Result<PreparedInfo, Box<dyn Error>> {
+        let (paths, diagnostics, initial_exit_code) = match &self.starting_points {
+            StartingPoints::Default => (vec![PathBuf::from(".")], Vec::new(), 0),
+            StartingPoints::Explicit(paths) => (paths.clone(), Vec::new(), 0),
+            StartingPoints::Files0(query) => {
