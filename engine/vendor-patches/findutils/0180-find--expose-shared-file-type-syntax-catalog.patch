@@ -0,0 +1,133 @@
+//! Immutable syntax metadata shared by find's parser and external grammar
+//! importers.
+//!
+//! Keep accepted spellings and finite value domains here. Execution consumes
+//! the same values an importer sees; this is not a second help/completion table.
+
+use super::matchers::FileType;
+
+/// Stable semantic identity of a file-type predicate.
+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+pub enum FileTypePredicateIdentity {
+    Type,
+    Xtype,
+}
+
+/// One accepted value in the `-type`/`-xtype` comma-list domain.
+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+pub struct FileTypeValue {
+    pub surface: &'static str,
+    pub identity: FileType,
+    pub description: &'static str,
+}
+
+/// Declarative syntax of a predicate whose operand is a file-type list.
+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+pub struct FileTypePredicate {
+    pub surface: &'static str,
+    pub identity: FileTypePredicateIdentity,
+    pub description: &'static str,
+    pub values: &'static [FileTypeValue],
+    pub separator: char,
+    pub values_must_be_unique: bool,
+}
+
+/// Native file types accepted by this find implementation.
+pub static NATIVE_FILE_TYPE_VALUES: &[FileTypeValue] = &[
+    FileTypeValue {
+        surface: "b",
+        identity: FileType::BlockDevice,
+        description: "block device",
+    },
+    FileTypeValue {
+        surface: "c",
+        identity: FileType::CharDevice,
+        description: "character device",
+    },
+    FileTypeValue {
+        surface: "d",
+        identity: FileType::Directory,
+        description: "directory",
+    },
+    FileTypeValue {
+        surface: "f",
+        identity: FileType::Regular,
+        description: "regular file",
+    },
+    FileTypeValue {
+        surface: "l",
+        identity: FileType::Symlink,
+        description: "symbolic link",
+    },
+    FileTypeValue {
+        surface: "p",
+        identity: FileType::Fifo,
+        description: "named pipe",
+    },
+    FileTypeValue {
+        surface: "s",
+        identity: FileType::Socket,
+        description: "socket",
+    },
+];
+
+pub const TYPE_PREDICATE: FileTypePredicate = FileTypePredicate {
+    surface: "-type",
+    identity: FileTypePredicateIdentity::Type,
+    description: "match the entry's file type",
+    values: NATIVE_FILE_TYPE_VALUES,
+    separator: ',',
+    values_must_be_unique: true,
+};
+
+pub const XTYPE_PREDICATE: FileTypePredicate = FileTypePredicate {
+    surface: "-xtype",
+    identity: FileTypePredicateIdentity::Xtype,
+    description: "match the referent type, reversing symlink following",
+    values: NATIVE_FILE_TYPE_VALUES,
+    separator: ',',
+    values_must_be_unique: true,
+};
+
+pub static FILE_TYPE_PREDICATES: &[FileTypePredicate] = &[TYPE_PREDICATE, XTYPE_PREDICATE];
+
+pub fn file_type_predicate(surface: &str) -> Option<&'static FileTypePredicate> {
+    FILE_TYPE_PREDICATES
+        .iter()
+        .find(|predicate| predicate.surface == surface)
+}
+
+pub fn file_type_value(surface: &str) -> Option<&'static FileTypeValue> {
+    NATIVE_FILE_TYPE_VALUES
+        .iter()
+        .find(|value| value.surface == surface)
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    #[cfg(target_os = "linux")]
+    fn native_linux_file_type_catalog_is_exact() {
+        assert_eq!(
+            NATIVE_FILE_TYPE_VALUES
+                .iter()
+                .map(|value| value.surface)
+                .collect::<Vec<_>>(),
+            ["b", "c", "d", "f", "l", "p", "s"]
+        );
+        assert_eq!(
+            FILE_TYPE_PREDICATES
+                .iter()
+                .map(|predicate| predicate.surface)
+                .collect::<Vec<_>>(),
+            ["-type", "-xtype"]
+        );
+        assert!(FILE_TYPE_PREDICATES.iter().all(|predicate| {
+            predicate.values == NATIVE_FILE_TYPE_VALUES
+                && predicate.separator == ','
+                && predicate.values_must_be_unique
+        }));
+    }
+}
