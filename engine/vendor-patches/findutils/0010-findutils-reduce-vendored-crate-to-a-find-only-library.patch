-impl InputProcessOptions {
-    fn new(
-        exit_if_pass_char_limit: bool,
-        max_args: Option<usize>,
-        max_lines: Option<usize>,
-        no_run_if_empty: bool,
-    ) -> Self {
-        Self {
-            exit_if_pass_char_limit,
-            max_args,
-            max_lines,
-            no_run_if_empty,
