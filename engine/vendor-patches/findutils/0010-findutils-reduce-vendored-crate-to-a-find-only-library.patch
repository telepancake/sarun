-fn main() {
-    let mut args = env::args().collect::<Vec<String>>();
-    if args.len() < 2 || args[1] == "-h" || args[1] == "--help" {
-        usage();
-    }
-    let mut config = Config {
-        destination_dir: if args[1] == "-" {
-            None
-        } else {
-            Some(args[1].clone())
-        },
-        ..Default::default()
-    };
-
-    for arg in &args[2..] {
-        if arg.starts_with("--") {
-            match arg.as_ref() {
-                "--exit_with_failure" => {
-                    config.exit_with = Some(ExitWith::Failure);
-                }
-                "--exit_with_urgent_failure" => {
