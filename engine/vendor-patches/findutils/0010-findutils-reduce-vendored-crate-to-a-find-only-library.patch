-fn validate_positive_usize(s: &str) -> Result<usize, String> {
-    match s.parse::<usize>() {
-        Ok(v) if v > 0 => Ok(v),
-        Ok(v) => Err(format!("Value must be > 0, not: {v}")),
-        Err(e) => Err(e.to_string()),
-    }
-}
