index 0000000..d78b40e
--- /dev/null
+++ b/src/find/probe.rs
@@ -0,0 +1,513 @@
+//! Effect-free argument probing through find's execution parser.
+//!
+//! This deliberately covers only starting paths and `-type`/`-xtype`. Every
+//! other expression is stopped before its parser arm can perform work and is
+//! reported as [`ProbeStatus::Unsupported`].
+
+use super::matchers::FileType;
+use super::syntax::{
+    FileTypePredicate, FileTypePredicateIdentity, FileTypeValue, FILE_TYPE_PREDICATES,
+};
+use super::{parse_args_observed, ParseObserver};
+use std::collections::HashSet;
+
+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+pub enum ProbeArgument<'a> {
+    Exact(&'a str),
+    Assist { prefix: &'a str, suffix: &'a str },
+}
+
+#[derive(Clone, Copy, Debug, Eq, PartialEq)]
+pub enum ProbeStatus {
+    Complete,
+    Incomplete,
+    Rejected,
+    Unsupported,
+}
+
+#[derive(Clone, Copy, Debug, Eq, PartialEq, Hash)]
+pub enum ArgumentIdentity {
+    StartingPath,
+    FileTypePredicate(FileTypePredicateIdentity),
+    FileTypeValue {
+        predicate: FileTypePredicateIdentity,
+        value: FileType,
+    },
+}
+
+#[derive(Clone, Debug, Eq, PartialEq)]
+pub struct ArgumentMatch {
+    pub argument: usize,
+    pub identity: ArgumentIdentity,
+}
+
+#[derive(Clone, Copy, Debug, Eq, PartialEq, Hash)]
+pub enum Expectation {
+    StartingPath,
+    FileTypePredicate,
+    FileTypeValue(FileTypePredicateIdentity),
+}
+
+#[derive(Clone, Debug, Eq, PartialEq)]
+pub struct Completion {
+    /// Text inserted at the tear; the supplied prefix and suffix stay intact.
+    pub insertion: String,
+    pub display: &'static str,
+    pub help: &'static str,
+    pub identity: ArgumentIdentity,
+    pub matches: Vec<ArgumentMatch>,
+}
+
+/// Find-owned evidence, independent of Brush, Clap, and Prolog.
+#[derive(Clone, Debug, Eq, PartialEq)]
+pub struct ProbeOutput {
+    pub status: ProbeStatus,
+    pub matches: Vec<ArgumentMatch>,
+    pub expectations: Vec<Expectation>,
+    pub completions: Vec<Completion>,
+}
+
+#[derive(Default)]
+struct Recorder {
+    matches: Vec<ArgumentMatch>,
+    expectations: Vec<(usize, Expectation)>,
+    unsupported: Option<usize>,
+}
+
+impl Recorder {
+    fn has(&self, argument: usize, identity: ArgumentIdentity) -> bool {
+        self.matches
+            .iter()
+            .any(|item| item.argument == argument && item.identity == identity)
+    }
+
+    fn expects(&self, argument: usize, expectation: Expectation) -> bool {
+        self.expectations.contains(&(argument, expectation))
+    }
+}
+
+impl ParseObserver for Recorder {
+    fn top_level_option(&mut self, argument: usize, _surface: &str) -> bool {
+        self.unsupported = Some(argument);
+        false
+    }
+
+    fn starting_path(&mut self, argument: usize, _surface: &str) {
+        self.matches.push(ArgumentMatch {
+            argument,
+            identity: ArgumentIdentity::StartingPath,
+        });
+    }
+
+    fn expression(
+        &mut self,
+        argument: usize,
+        _surface: &str,
+        file_type_predicate: Option<&FileTypePredicate>,
+    ) -> bool {
+        if file_type_predicate.is_some() {
+            true
+        } else {
+            self.unsupported = Some(argument);
+            false
+        }
+    }
+
+    fn file_type_predicate(&mut self, argument: usize, predicate: &FileTypePredicate) {
+        self.matches.push(ArgumentMatch {
+            argument,
+            identity: ArgumentIdentity::FileTypePredicate(predicate.identity),
+        });
+    }
+
+    fn file_type_operand(
+        &mut self,
+        argument: usize,
+        predicate: &FileTypePredicate,
+        _surface: &str,
+    ) {
+        self.expectations
+            .push((argument, Expectation::FileTypeValue(predicate.identity)));
+    }
+
+    fn file_type_value(
+        &mut self,
+        argument: usize,
+        predicate: &FileTypePredicate,
+        value: &FileTypeValue,
+    ) {
+        self.matches.push(ArgumentMatch {
+            argument,
+            identity: ArgumentIdentity::FileTypeValue {
+                predicate: predicate.identity,
+                value: value.identity,
+            },
+        });
+    }
+
+    fn missing_file_type_operand(&mut self, argument: usize, predicate: &FileTypePredicate) {
+        self.expectations
+            .push((argument, Expectation::FileTypeValue(predicate.identity)));
+    }
+}
+
+fn replay(arguments: &[String]) -> (bool, Recorder) {
+    let refs = arguments.iter().map(String::as_str).collect::<Vec<_>>();
+    let mut recorder = Recorder::default();
+    let accepted = parse_args_observed(&refs, &mut std::io::empty(), &mut recorder).is_ok();
+    (accepted, recorder)
+}
+
+fn unsupported() -> ProbeOutput {
+    ProbeOutput {
+        status: ProbeStatus::Unsupported,
+        matches: Vec::new(),
+        expectations: Vec::new(),
+        completions: Vec::new(),
+    }
+}
+
+fn exact(arguments: &[ProbeArgument<'_>]) -> ProbeOutput {
+    let concrete = arguments
+        .iter()
+        .map(|argument| match argument {
+            ProbeArgument::Exact(surface) => (*surface).to_owned(),
+            ProbeArgument::Assist { .. } => unreachable!(),
+        })
+        .collect::<Vec<_>>();
+    let (accepted, recorder) = replay(&concrete);
+    if recorder.unsupported.is_some() {
+        return unsupported();
+    }
+    let status = if accepted {
+        ProbeStatus::Complete
+    } else if !recorder.expectations.is_empty()
+        && recorder
+            .expectations
+            .iter()
+            .any(|(argument, _)| *argument == arguments.len())
+    {
+        ProbeStatus::Incomplete
+    } else {
+        ProbeStatus::Rejected
+    };
+    ProbeOutput {
+        status,
+        matches: recorder.matches,
+        expectations: recorder
+            .expectations
+            .into_iter()
+            .map(|(_, expectation)| expectation)
+            .collect(),
+        completions: Vec::new(),
+    }
+}
+
+fn replace_tear(arguments: &[ProbeArgument<'_>], tear: usize, replacement: &str) -> Vec<String> {
+    arguments
+        .iter()
+        .enumerate()
+        .map(|(index, argument)| match argument {
+            ProbeArgument::Exact(surface) => (*surface).to_owned(),
+            ProbeArgument::Assist { .. } if index == tear => replacement.to_owned(),
+            ProbeArgument::Assist { .. } => unreachable!(),
+        })
+        .collect()
+}
+
+fn compatible_insertion<'a>(prefix: &str, suffix: &str, complete: &'a str) -> Option<&'a str> {
+    complete
+        .strip_prefix(prefix)
+        .and_then(|rest| rest.strip_suffix(suffix))
+}
+
+fn operand_insertions(
+    prefix: &str,
+    suffix: &str,
+    predicate: &FileTypePredicate,
+) -> Vec<(String, &'static FileTypeValue)> {
+    let segment_prefix = prefix
+        .rsplit_once(predicate.separator)
+        .map_or(prefix, |(_, segment)| segment);
+    let segment_suffix = suffix
+        .split_once(predicate.separator)
+        .map_or(suffix, |(segment, _)| segment);
+    let mut candidates = Vec::new();
+    for value in predicate.values {
+        if let Some(insertion) = compatible_insertion(segment_prefix, segment_suffix, value.surface)
+        {
+            candidates.push((insertion.to_owned(), value));
+        }
+    }
+
+    // A complete list at the tear can continue with one remaining value.
+    // `type_creator` below remains the authority for uniqueness.
+    if suffix.is_empty() {
+        let parts = prefix.split(predicate.separator).collect::<Vec<_>>();
+        let complete = !parts.is_empty()
+            && parts
+                .iter()
+                .all(|part| predicate.values.iter().any(|value| value.surface == *part));
+        if complete {
+            for value in predicate.values {
+                candidates.push((format!("{}{}", predicate.separator, value.surface), value));
+            }
+        }
+    }
+    candidates
+}
+
+fn assist(arguments: &[ProbeArgument<'_>], tear: usize) -> ProbeOutput {
+    let (prefix, suffix) = match arguments[tear] {
+        ProbeArgument::Assist { prefix, suffix } => (prefix, suffix),
+        ProbeArgument::Exact(_) => unreachable!(),
+    };
+    let mut output = ProbeOutput {
+        status: ProbeStatus::Incomplete,
+        matches: Vec::new(),
+        expectations: Vec::new(),
+        completions: Vec::new(),
+    };
+    let mut proved_role = false;
+    let mut unsupported_outside_tear = false;
+    let mut seen_insertions = HashSet::new();
+
+    // Ask parse_args whether this position can be a starting path. No path
+    // catalog exists here; filesystem completion remains an external context.
+    let path_surface = if prefix.is_empty() && suffix.is_empty() {
+        ".".to_owned()
+    } else {
+        format!("{prefix}{suffix}")
+    };
+    let (_, path_recorder) = replay(&replace_tear(arguments, tear, &path_surface));
+    unsupported_outside_tear |= path_recorder
+        .unsupported
+        .is_some_and(|argument| argument != tear);
+    if path_recorder.unsupported.is_none()
+        && path_recorder.has(tear, ArgumentIdentity::StartingPath)
+    {
+        proved_role = true;
+        output.expectations.push(Expectation::StartingPath);
+        output.matches = path_recorder.matches;
+    }
+
+    // Replay each execution-owned predicate spelling. The actual expression
+    // dispatch decides whether the tear is a predicate position.
+    for predicate in FILE_TYPE_PREDICATES {
+        let (_, recorder) = replay(&replace_tear(arguments, tear, predicate.surface));
+        unsupported_outside_tear |= recorder
+            .unsupported
+            .is_some_and(|argument| argument != tear);
+        let identity = ArgumentIdentity::FileTypePredicate(predicate.identity);
+        if recorder.unsupported.is_some() || !recorder.has(tear, identity) {
+            continue;
+        }
+        proved_role = true;
+        output.expectations.push(Expectation::FileTypePredicate);
+        if output.matches.is_empty() {
+            output.matches.clone_from(&recorder.matches);
+        }
+        let Some(insertion) = compatible_insertion(prefix, suffix, predicate.surface) else {
+            continue;
+        };
+        if !seen_insertions.insert(insertion.to_owned()) {
+            continue;
+        }
+        output.completions.push(Completion {
+            insertion: insertion.to_owned(),
+            display: predicate.surface,
+            help: predicate.description,
+            identity,
+            matches: recorder.matches,
+        });
+    }
+
+    // Replay finite operand values to let the real predicate branch establish
+    // the context. Candidate lists are then replayed through type_creator,
+    // which alone decides value validity and uniqueness.
+    for predicate in FILE_TYPE_PREDICATES {
+        let representative = predicate.values[0];
+        let (_, role_recorder) = replay(&replace_tear(arguments, tear, representative.surface));
+        unsupported_outside_tear |= role_recorder
+            .unsupported
+            .is_some_and(|argument| argument != tear);
+        let expectation = Expectation::FileTypeValue(predicate.identity);
+        if role_recorder.unsupported.is_some() || !role_recorder.expects(tear, expectation) {
+            continue;
+        }
+        proved_role = true;
+        output.expectations.push(expectation);
+        if output.matches.is_empty() {
+            output.matches.clone_from(&role_recorder.matches);
+        }
+        for (insertion, value) in operand_insertions(prefix, suffix, predicate) {
+            if seen_insertions.contains(&insertion) {
+                continue;
+            }
+            let completed = format!("{prefix}{insertion}{suffix}");
+            let (accepted, recorder) = replay(&replace_tear(arguments, tear, &completed));
+            let identity = ArgumentIdentity::FileTypeValue {
+                predicate: predicate.identity,
+                value: value.identity,
+            };
+            if accepted
+                && recorder.unsupported.is_none()
+                && recorder.has(tear, identity)
+                && seen_insertions.insert(insertion.clone())
+            {
+                output.completions.push(Completion {
+                    insertion,
+                    display: value.surface,
+                    help: value.description,
+                    identity,
+                    matches: recorder.matches,
+                });
+            }
+        }
+    }
+
+    if !proved_role {
+        return unsupported();
+    }
+    if unsupported_outside_tear {
+        return unsupported();
+    }
+    output
+        .expectations
+        .sort_by_key(|expectation| match expectation {
+            Expectation::StartingPath => (0, 0),
+            Expectation::FileTypePredicate => (1, 0),
+            Expectation::FileTypeValue(FileTypePredicateIdentity::Type) => (2, 0),
+            Expectation::FileTypeValue(FileTypePredicateIdentity::Xtype) => (2, 1),
+        });
+    output.expectations.dedup();
+    output
+}
+
+/// Parse or assist Find arguments without walking the filesystem.
+///
+/// Every exact input and synthesized candidate traverses `parse_args`,
+/// `build_matcher_tree`, and, for operands, `type_creator`.
+pub fn probe(arguments: &[ProbeArgument<'_>]) -> ProbeOutput {
+    let tears = arguments
+        .iter()
+        .enumerate()
+        .filter_map(|(index, argument)| {
+            matches!(argument, ProbeArgument::Assist { .. }).then_some(index)
+        })
+        .collect::<Vec<_>>();
+    match tears.as_slice() {
+        [] => exact(arguments),
+        [tear] => assist(arguments, *tear),
+        _ => unsupported(),
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    fn exact(surface: &str) -> ProbeArgument<'_> {
+        ProbeArgument::Exact(surface)
+    }
+
+    fn tear<'a>(prefix: &'a str, suffix: &'a str) -> ProbeArgument<'a> {
+        ProbeArgument::Assist { prefix, suffix }
+    }
+
+    #[test]
+    fn exact_valid_invalid_and_missing_operand_use_execution_parser() {
+        let valid = probe(&[exact("src"), exact("-type"), exact("f,d")]);
+        assert_eq!(valid.status, ProbeStatus::Complete);
+        assert_eq!(valid.matches.len(), 4);
+
+        let invalid = probe(&[exact("."), exact("-xtype"), exact("f,f")]);
+        assert_eq!(invalid.status, ProbeStatus::Rejected);
+
+        let missing = probe(&[exact("."), exact("-type")]);
+        assert_eq!(missing.status, ProbeStatus::Incomplete);
+        assert_eq!(
+            missing.expectations,
+            [Expectation::FileTypeValue(FileTypePredicateIdentity::Type)]
+        );
+    }
+
+    #[test]
+    fn predicate_tear_preserves_prefix_and_suffix() {
+        let output = probe(&[exact("."), tear("-t", "e"), exact("f")]);
+        assert_eq!(output.completions.len(), 1);
+        assert_eq!(output.completions[0].insertion, "yp");
+        assert_eq!(output.completions[0].display, "-type");
+    }
+
+    #[test]
+    fn operand_tear_records_actual_type_creator_match() {
+        let output = probe(&[exact("."), exact("-xtype"), tear("", "")]);
+        assert_eq!(output.completions.len(), 7);
+        assert!(output.completions.iter().all(|completion| {
+            completion
+                .matches
+                .iter()
+                .any(|evidence| evidence.argument == 2 && evidence.identity == completion.identity)
+        }));
+    }
+
+    #[test]
+    fn comma_list_only_offers_remaining_unique_values() {
+        let output = probe(&[exact("."), exact("-type"), tear("f,", "")]);
+        assert_eq!(
+            output
+                .completions
+                .iter()
+                .map(|completion| completion.insertion.as_str())
+                .collect::<Vec<_>>(),
+            ["b", "c", "d", "l", "p", "s"]
+        );
+
+        let continuation = probe(&[exact("."), exact("-type"), tear("f", "")]);
+        assert!(continuation
+            .completions
+            .iter()
+            .any(|completion| completion.insertion.is_empty()));
+        assert!(continuation
+            .completions
+            .iter()
+            .any(|completion| completion.insertion == ",d"));
+        assert!(!continuation
+            .completions
+            .iter()
+            .any(|completion| completion.insertion == ",f"));
+    }
+
+    #[test]
+    fn incompatible_suffix_retains_real_expectation_without_candidates() {
+        let predicate = probe(&[exact("."), tear("-ty", "x"), exact("f")]);
+        assert_eq!(predicate.status, ProbeStatus::Incomplete);
+        assert_eq!(predicate.expectations, [Expectation::FileTypePredicate]);
+        assert!(predicate.completions.is_empty());
+
+        let value = probe(&[exact("."), exact("-type"), tear("", "x")]);
+        assert_eq!(
+            value.expectations,
+            [Expectation::FileTypeValue(FileTypePredicateIdentity::Type)]
+        );
+        assert!(value.completions.is_empty());
+    }
+
+    #[test]
+    fn unsupported_expression_is_stopped_before_its_arm() {
+        for arguments in [
+            vec![exact("."), exact("-print")],
+            vec![exact("."), exact("-name"), exact("*.rs")],
+            vec![
+                exact("."),
+                exact("-type"),
+                exact("f"),
+                exact("-fprint"),
+                exact("x"),
+            ],
+        ] {
+            assert_eq!(probe(&arguments).status, ProbeStatus::Unsupported);
+        }
+    }
+}
