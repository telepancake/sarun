+    // -P: run children concurrently through a bounded pool. Serial (max_procs
+    // == 1) keeps the original `execute` path untouched; the pool stays empty.
+    let parallel = options.max_procs > 1;
+    let mut pool = ParallelPool::new(options.max_procs);
 
     while let Some(arg) = args.next()? {
         if let Err(ExhaustedCommandSpace { arg, out_of_chars }) = current_builder.add_arg(arg) {
@@ -873,7 +974,11 @@ fn process_input(
                 return Err(XargsError::ArgumentTooLarge);
             }
             if have_pending_command {
-                result.combine(current_builder.execute(io)?);
+                if parallel {
+                    pool.dispatch(current_builder, io)?;
+                } else {
+                    result.combine(current_builder.execute(io)?);
+                }
             }
 
             current_builder = CommandBuilder::new(builder_options);
@@ -886,7 +991,15 @@ fn process_input(
     }
 
     if !options.no_run_if_empty || have_pending_command {
-        result.combine(current_builder.execute(io)?);
+        if parallel {
+            pool.dispatch(current_builder, io)?;
+        } else {
+            result.combine(current_builder.execute(io)?);
+        }
+    }
+    if parallel {
+        // Wait for every remaining child (cmd & … & wait).
+        result.combine(pool.drain()?);
     }
 
     Ok(result)
