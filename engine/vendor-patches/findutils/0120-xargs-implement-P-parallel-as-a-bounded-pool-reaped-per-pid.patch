@@ -1213,6 +1327,12 @@ fn do_xargs(args: &[&str], io: &dyn XargsIo) -> Result<CommandResult, XargsError
                     .map_or_else(|| "{}".to_string(), std::borrow::ToOwned::to_owned)
             })
