+/// Operations committed after the complete command line has parsed.
+///
+/// Keeping these out of matcher construction makes the parser safe to replay
+/// for syntax assistance: a speculative parse must never create or truncate a
+/// user's output file.
+pub trait FindOperations {
+    fn create_output(&self, path: &std::path::Path) -> io::Result<std::fs::File>;
+}
+
+struct DependencyFindOperations<'a> {
+    dependencies: &'a dyn Dependencies,
+}
+
+impl FindOperations for DependencyFindOperations<'_> {
+    fn create_output(&self, path: &std::path::Path) -> io::Result<std::fs::File> {
+        let resolved = match self.dependencies.cwd() {
+            Some(cwd) if path.is_relative() => cwd.join(path),
+            _ => path.to_path_buf(),
+        };
+        std::fs::File::create(resolved)
+    }
+}
