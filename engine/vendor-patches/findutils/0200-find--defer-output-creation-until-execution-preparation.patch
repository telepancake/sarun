index 0000000..cdcc451
--- /dev/null
+++ b/src/find/matchers/output.rs
@@ -0,0 +1,42 @@
+use std::error::Error;
+use std::fs::File;
+use std::path::{Path, PathBuf};
+
+use crate::find::FindOperations;
+
+/// An action output selected by the parser but opened only during preparation.
+pub(super) enum OutputTarget {
+    Standard,
+    Open(File),
+    Pending(PathBuf),
+}
+
+impl OutputTarget {
+    pub(super) fn from_file(file: Option<File>) -> Self {
+        file.map_or(Self::Standard, Self::Open)
+    }
+
+    pub(super) fn pending(path: impl AsRef<Path>) -> Self {
+        Self::Pending(path.as_ref().to_path_buf())
+    }
+
+    pub(super) fn prepare(
+        &mut self,
+        operations: &dyn FindOperations,
+    ) -> Result<(), Box<dyn Error>> {
+        if let Self::Pending(path) = self {
+            *self = Self::Open(operations.create_output(path)?);
+        }
+        Ok(())
+    }
+
+    pub(super) fn file(&self) -> Option<&File> {
+        match self {
+            Self::Standard => None,
+            Self::Open(file) => Some(file),
+            Self::Pending(path) => {
+                panic!("output target '{}' was not prepared", path.display())
+            }
+        }
+    }
+}
