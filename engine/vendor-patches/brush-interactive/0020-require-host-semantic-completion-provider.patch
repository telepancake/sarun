From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: sarun <noreply@sarun>
Date: Thu, 16 Jul 2026 13:00:00 +0000
Subject: [PATCH] brush-interactive: require host semantic completion provider

Make Reedline a pure presenter of completion edits derived by the host's
language relation. The constructor requires the authority; there is no optional
provider and no fallback to Brush's independent token-based completer.

---
diff --git a/src/completion_provider.rs b/src/completion_provider.rs
new file mode 100644
index 0000000..be86e22
--- /dev/null
+++ b/src/completion_provider.rs
@@ -0,0 +1,17 @@
+/// A completion already derived by the host's language relation. Byte offsets
+/// use Reedline's UTF-8 buffer coordinate system.
+#[derive(Clone, Debug, Eq, PartialEq)]
+pub struct SemanticCompletion {
+    pub insert: String,
+    pub display: String,
+    pub description: Option<String>,
+    pub replace_start: usize,
+    pub replace_end: usize,
+}
+
+/// Required semantic completion authority for an interactive input backend.
+/// The backend presents these edits and does not tokenize or reinterpret the
+/// command language itself.
+pub trait SemanticCompletionProvider: Send + Sync {
+    fn complete(&self, source: &str, cursor: usize) -> Vec<SemanticCompletion>;
+}
diff --git a/src/lib.rs b/src/lib.rs
index 5843280..5525a3c 100644
--- a/src/lib.rs
+++ b/src/lib.rs
@@ -3,6 +3,9 @@
 mod error;
 pub use error::ShellError;
 
+mod completion_provider;
+pub use completion_provider::{SemanticCompletion, SemanticCompletionProvider};
+
 mod interactive_shell;
 pub use interactive_shell::{InteractiveExecutionResult, InteractiveOptions, InteractiveShell};
 
diff --git a/src/reedline/completer.rs b/src/reedline/completer.rs
index ff95907..fb6fb4c 100644
--- a/src/reedline/completer.rs
+++ b/src/reedline/completer.rs
@@ -1,91 +1,35 @@
-use nu_ansi_term::{Color, Style};
-use std::borrow::BorrowMut;
+use std::sync::Arc;
 
-use crate::{completion, refs};
+use crate::SemanticCompletionProvider;
 
-pub(crate) struct ReedlineCompleter<SE: brush_core::ShellExtensions> {
-    pub shell: refs::ShellRef<SE>,
+pub(crate) struct ReedlineCompleter {
+    pub provider: Arc<dyn SemanticCompletionProvider>,
 }
 
-impl<SE: brush_core::ShellExtensions> reedline::Completer for ReedlineCompleter<SE> {
+impl reedline::Completer for ReedlineCompleter {
     fn complete(&mut self, line: &str, pos: usize) -> Vec<reedline::Suggestion> {
-        tokio::task::block_in_place(|| {
-            tokio::runtime::Handle::current().block_on(self.complete_async(line, pos))
-        })
-    }
-}
-
-impl<SE: brush_core::ShellExtensions> ReedlineCompleter<SE> {
-    async fn complete_async(&self, line: &str, pos: usize) -> Vec<reedline::Suggestion> {
-        let mut shell_guard = self.shell.lock().await;
-        let shell = shell_guard.borrow_mut().as_mut();
-        let completions = completion::complete_async(shell, line, pos).await;
-
-        // We're done with the shell, so drop it eagerly.
-        drop(shell_guard);
-
-        let insertion_index = completions.insertion_index;
-        let delete_count = completions.delete_count;
-        let options = completions.options;
-
-        completions
-            .candidates
+        self.provider
+            .complete(line, pos)
             .into_iter()
-            .map(|candidate| {
-                Self::to_suggestion(line, candidate, insertion_index, delete_count, &options)
+            .filter(|completion| {
+                completion.replace_start <= completion.replace_end
+                    && completion.replace_end <= line.len()
+                    && line.is_char_boundary(completion.replace_start)
+                    && line.is_char_boundary(completion.replace_end)
+            })
+            .map(|completion| reedline::Suggestion {
+                value: completion.insert,
+                description: completion.description,
+                style: None,
+                extra: None,
+                span: reedline::Span {
+                    start: completion.replace_start,
+                    end: completion.replace_end,
+                },
+                match_indices: None,
+                display_override: Some(completion.display),
+                append_whitespace: false,
             })
             .collect()
     }
-
-    #[allow(
-        clippy::string_slice,
-        reason = "all indices + counts are expected to be at char boundaries"
-    )]
-    fn to_suggestion(
-        line: &str,
-        mut candidate: String,
-        mut insertion_index: usize,
-        mut delete_count: usize,
-        options: &brush_core::completion::ProcessingOptions,
-    ) -> reedline::Suggestion {
-        let mut style = Style::new();
-
-        // Special handling for filename completions.
-        if options.treat_as_filenames {
-            if brush_core::sys::fs::ends_with_path_separator(&candidate) {
-                style = style.fg(Color::Green);
-            }
-
-            if insertion_index + delete_count <= line.len() {
-                let removed = &line[insertion_index..insertion_index + delete_count];
-                if let Some(last_sep_index) = brush_core::sys::fs::rfind_path_separator(removed) {
-                    if candidate.starts_with(removed) {
-                        candidate = candidate.split_off(last_sep_index + 1);
-                        insertion_index += last_sep_index + 1;
-                        delete_count -= last_sep_index + 1;
-                    }
-                }
-            }
-        }
-
-        // See if there's whitespace at the end.
-        let append_whitespace = candidate.ends_with(' ');
-        if append_whitespace {
-            candidate.pop();
-        }
-
-        reedline::Suggestion {
-            value: candidate,
-            description: None,
-            style: Some(style),
-            extra: None,
-            span: reedline::Span {
-                start: insertion_index,
-                end: insertion_index + delete_count,
-            },
-            match_indices: None,
-            display_override: None,
-            append_whitespace,
-        }
-    }
 }
