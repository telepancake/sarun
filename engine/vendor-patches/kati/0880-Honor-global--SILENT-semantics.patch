From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: sarun <noreply@sarun>
Date: Sat, 18 Jul 2026 15:53:48 +0000
Subject: [PATCH] Honor global .SILENT semantics

Implement prerequisite-free global .SILENT so Kbuild recipe and no-op diagnostics are actually silent, while retaining an explicit warning for target-specific .SILENT forms.

---
diff --git a/src-rs/command.rs b/src-rs/command.rs
index 98e6f42..c2d621b 100644
--- a/src-rs/command.rs
+++ b/src-rs/command.rs
@@ -289,11 +289,13 @@ impl<'a> CommandEvaluator<'a> {
     pub fn eval(&mut self, n: &Arc<Mutex<DepNode>>) -> Result<Vec<Command>> {
         let mut result: Vec<Command> = Vec::new();
         let node_cmds;
+        let target_silent;
         {
             let node = n.lock();
             self.ev.loc = node.loc.clone();
             self.ev.current_scope = node.rule_vars.clone();
             node_cmds = node.cmds.clone();
+            target_silent = self.ev.silent_targets.contains(&node.output);
         }
         self.ev.is_evaluating_command = true;
         *self.current_dep_node.lock() = Some(n.clone());
@@ -302,7 +304,9 @@ impl<'a> CommandEvaluator<'a> {
             self.ev.loc = v.loc();
             let cmds_buf = v.eval_to_buf(self.ev)?;
             let mut cmds = cmds_buf.clone();
-            let mut global_echo = !FLAGS.is_silent_mode;
+            let mut global_echo = !(
+                FLAGS.is_silent_mode || self.ev.silent || target_silent
+            );
             let mut global_ignore_error = false;
             cmds = parse_command_prefixes(cmds, &mut global_echo, &mut global_ignore_error);
             if cmds.is_empty() {
diff --git a/src-rs/dep.rs b/src-rs/dep.rs
index f87fd8a..b877251 100644
--- a/src-rs/dep.rs
+++ b/src-rs/dep.rs
@@ -618,6 +618,16 @@ impl<'a> DepBuilder<'a> {
         if self.get_rule_inputs(intern(".NOTPARALLEL")).is_some() {
             self.ev.not_parallel = true;
         }
+        // A prerequisite-free `.SILENT:` is GNU's makefile-level equivalent
+        // of `-s`; prerequisites select the individual targets whose recipes
+        // and no-op goal diagnostics are quiet.
+        if let Some((inputs, _loc)) = self.get_rule_inputs(intern(".SILENT")) {
+            if inputs.is_empty() {
+                self.ev.silent = true;
+            } else {
+                self.ev.silent_targets.extend(inputs);
+            }
+        }
         // sarun: .EXPORT_ALL_VARIABLES isn't a rule whose recipe runs —
         // it's a flag that tells make to export every variable into the
         // recipe environment. Flip the Evaluator flag if present.
@@ -639,7 +649,6 @@ impl<'a> DepBuilder<'a> {
         let real_unsupported = [
             ".IGNORE",
             ".LOW_RESOLUTION_TIME",
-            ".SILENT",
         ];
         for p in noop_for_us {
             // Touch the symbol so the rule is consumed; the "don't
diff --git a/src-rs/eval.rs b/src-rs/eval.rs
index 964efeb..f0427e8 100644
--- a/src-rs/eval.rs
+++ b/src-rs/eval.rs
@@ -267,6 +267,12 @@ pub struct Evaluator {
     /// sarun: `.NOTPARALLEL:` was seen — this make's recipes run serially
     /// even when -j / a jobserver is in effect.
     pub not_parallel: bool,
+    /// sarun: a prerequisite-free `.SILENT:` special target suppresses recipe
+    /// echo and no-op root diagnostics for this make invocation.
+    pub silent: bool,
+    /// Targets listed as prerequisites of `.SILENT`. GNU make suppresses
+    /// recipe echo and no-op goal diagnostics for exactly these targets.
+    pub silent_targets: HashSet<Symbol>,
     /// sarun: per-make GNU `-n` (dry run) / `-i` (ignore-errors). Carried on
     /// the Evaluator — NOT the process-global FLAGS — because many in-process
     /// makes share one process and only the FIRST argv installs FLAGS; a
@@ -404,6 +410,8 @@ impl Evaluator {
             rule_vars: HashMap::new(),
             vpath_patterns: Vec::new(),
             not_parallel: false,
+            silent: false,
+            silent_targets: HashSet::new(),
             dry_run: false,
             ignore_errors: false,
             goal_trace: false,
@@ -1747,9 +1755,11 @@ impl Evaluator {
             // GNU make always exports its final MAKEFLAGS value.
             if let Some(var) = self.lookup_var(makeflags)? {
                 let value = var.read().eval_to_buf(self)?;
-                if !value.is_empty() {
-                    emit_export(&mut prefix, b"MAKEFLAGS", &value);
-                }
+                // Empty is meaningful: `override MAKEFLAGS=` must overwrite
+                // any ambient value in the fresh embedded recipe shell.
+                emit_export(&mut prefix, b"MAKEFLAGS", &value);
+            } else {
+                prefix.extend_from_slice(b"unset MAKEFLAGS\n");
             }
             Ok(Bytes::from(prefix))
         })();
