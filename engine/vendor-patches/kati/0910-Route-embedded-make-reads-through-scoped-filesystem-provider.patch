+//! Read-only filesystem capability used by kati's evaluator.
+//!
+//! Standalone rkati uses the native implementation. Embedders may install a
+//! provider backed by the box filesystem so parsing and dependency discovery
+//! do not escape through raw host filesystem calls. Mutations deliberately
+//! remain outside this interface until they have a cache-coherent protocol.
+
+use std::{
+    cell::RefCell,
+    ffi::{CStr, CString, OsString},
+    io,
+    marker::PhantomData,
+    os::unix::fs::FileTypeExt,
+    path::{Path, PathBuf},
+    rc::Rc,
+    slice,
+    sync::Arc,
+    time::SystemTime,
+};
+
+#[derive(Clone, Copy, Debug, PartialEq, Eq)]
+pub enum FileKind {
+    Regular,
+    Directory,
+    Symlink,
+    Fifo,
+    Socket,
+    CharDevice,
+    BlockDevice,
+    Unknown,
+}
+
+#[derive(Clone, Debug, PartialEq, Eq)]
+pub struct Metadata {
+    pub kind: FileKind,
+    pub len: u64,
+    pub modified: SystemTime,
+}
+
+impl Metadata {
+    pub fn is_file(&self) -> bool {
+        self.kind == FileKind::Regular
+    }
+
+    pub fn is_dir(&self) -> bool {
+        self.kind == FileKind::Directory
+    }
+
+    pub fn is_symlink(&self) -> bool {
+        self.kind == FileKind::Symlink
+    }
+}
+
+#[derive(Debug)]
+pub struct DirEntry {
+    pub file_name: OsString,
+    pub path: PathBuf,
+    pub kind: FileKind,
+}
+
+/// Transport-neutral read-only view of the filesystem visible to kati.
+///
+/// Paths are already resolved against kati's logical make working directory.
+/// Providers must not reinterpret relative paths against the engine cwd.
+pub trait FileSystemProvider: Send + Sync + 'static {
+    fn metadata(&self, path: &Path) -> io::Result<Metadata>;
+    fn symlink_metadata(&self, path: &Path) -> io::Result<Metadata>;
+    fn modified(&self, path: &Path) -> io::Result<SystemTime> {
+        self.metadata(path).map(|metadata| metadata.modified)
+    }
+    fn read(&self, path: &Path) -> io::Result<Vec<u8>>;
+    fn read_link(&self, path: &Path) -> io::Result<PathBuf>;
+    fn read_dir(&self, path: &Path) -> io::Result<Vec<io::Result<DirEntry>>>;
+    fn canonicalize(&self, path: &Path) -> io::Result<PathBuf>;
+    fn glob(&self, pattern: &[u8]) -> io::Result<Vec<Vec<u8>>>;
+
+    fn exists(&self, path: &Path) -> io::Result<bool> {
+        match self.metadata(path) {
+            Ok(_) => Ok(true),
+            Err(err) if err.kind() == io::ErrorKind::NotFound => Ok(false),
+            Err(err) => Err(err),
+        }
+    }
+}
+
+#[derive(Default)]
+pub struct NativeFileSystem;
+
+fn kind(file_type: std::fs::FileType) -> FileKind {
+    if file_type.is_file() {
+        FileKind::Regular
+    } else if file_type.is_dir() {
+        FileKind::Directory
+    } else if file_type.is_symlink() {
+        FileKind::Symlink
+    } else if file_type.is_fifo() {
+        FileKind::Fifo
+    } else if file_type.is_socket() {
+        FileKind::Socket
+    } else if file_type.is_char_device() {
+        FileKind::CharDevice
+    } else if file_type.is_block_device() {
+        FileKind::BlockDevice
+    } else {
+        FileKind::Unknown
+    }
+}
+
+fn from_native(metadata: std::fs::Metadata) -> io::Result<Metadata> {
+    Ok(Metadata {
+        kind: kind(metadata.file_type()),
+        len: metadata.len(),
+        modified: metadata.modified()?,
+    })
+}
+
+impl FileSystemProvider for NativeFileSystem {
+    fn metadata(&self, path: &Path) -> io::Result<Metadata> {
+        from_native(std::fs::metadata(path)?)
+    }
+
+    fn symlink_metadata(&self, path: &Path) -> io::Result<Metadata> {
+        from_native(std::fs::symlink_metadata(path)?)
+    }
+
+    fn read(&self, path: &Path) -> io::Result<Vec<u8>> {
+        std::fs::read(path)
+    }
+
+    fn read_link(&self, path: &Path) -> io::Result<PathBuf> {
+        std::fs::read_link(path)
+    }
+
+    fn read_dir(&self, path: &Path) -> io::Result<Vec<io::Result<DirEntry>>> {
+        Ok(std::fs::read_dir(path)?
+            .map(|entry| {
+                let entry = entry?;
+                Ok(DirEntry {
+                    file_name: entry.file_name(),
+                    path: entry.path(),
+                    kind: kind(entry.file_type()?),
+                })
+            })
+            .collect())
+    }
+
+    fn canonicalize(&self, path: &Path) -> io::Result<PathBuf> {
+        std::fs::canonicalize(path)
+    }
+
+    fn glob(&self, pattern: &[u8]) -> io::Result<Vec<Vec<u8>>> {
+        native_glob(pattern)
+    }
+}
+
+thread_local! {
+    /// Provider scope follows the evaluator thread. Embedded makes can nest on
+    /// recipe worker threads and unrelated makes can overlap; a process-global
+    /// swap would let one invocation restore native I/O underneath another.
+    static FILE_SYSTEM: RefCell<Option<Arc<dyn FileSystemProvider>>> = const { RefCell::new(None) };
+}
+
+/// Restores the previously installed provider when an embedded evaluation
+/// ends, including during unwinding or an early return.
+#[must_use = "dropping the guard immediately restores the previous filesystem provider"]
+pub struct FileSystemProviderGuard {
+    previous: Option<Arc<dyn FileSystemProvider>>,
+    // A provider guard must be dropped on the thread where it was installed.
+    // This also prevents an async caller from moving the scope across workers.
+    _not_send: PhantomData<Rc<()>>,
+}
+
+impl Drop for FileSystemProviderGuard {
+    fn drop(&mut self) {
+        let previous = self.previous.take();
+        FILE_SYSTEM.with(|slot| *slot.borrow_mut() = previous);
+    }
+}
+
+/// Install kati's process-wide read-only filesystem capability for the
+/// lifetime of the returned guard. Embedders retain the guard for the complete
+/// evaluation, so panic and early-return paths cannot leak provider state.
+pub fn install_file_system_provider(
+    provider: Arc<dyn FileSystemProvider>,
+) -> FileSystemProviderGuard {
+    let previous = FILE_SYSTEM.with(|slot| slot.borrow_mut().replace(provider));
+    FileSystemProviderGuard {
+        previous,
+        _not_send: PhantomData,
+    }
+}
+
+fn provider() -> Arc<dyn FileSystemProvider> {
+    FILE_SYSTEM
+        .with(|slot| slot.borrow().clone())
+        .unwrap_or_else(|| Arc::new(NativeFileSystem))
+}
+
+/// Snapshot the current thread's explicit provider for a Kati-owned worker.
+/// Callers install the returned capability at the worker entry point; `None`
+/// deliberately means the standalone/native default.
+pub fn capture_file_system_provider() -> Option<Arc<dyn FileSystemProvider>> {
+    FILE_SYSTEM.with(|slot| slot.borrow().clone())
+}
+
+pub fn exists(path: impl AsRef<Path>) -> io::Result<bool> {
+    provider().exists(path.as_ref())
+}
+
+pub fn metadata(path: impl AsRef<Path>) -> io::Result<Metadata> {
+    provider().metadata(path.as_ref())
+}
+
+pub fn symlink_metadata(path: impl AsRef<Path>) -> io::Result<Metadata> {
+    provider().symlink_metadata(path.as_ref())
+}
+
+pub fn modified(path: impl AsRef<Path>) -> io::Result<SystemTime> {
+    provider().modified(path.as_ref())
+}
+
+pub fn read(path: impl AsRef<Path>) -> io::Result<Vec<u8>> {
+    provider().read(path.as_ref())
+}
+
+pub fn read_link(path: impl AsRef<Path>) -> io::Result<PathBuf> {
+    provider().read_link(path.as_ref())
+}
+
+pub fn read_dir(path: impl AsRef<Path>) -> io::Result<Vec<io::Result<DirEntry>>> {
+    provider().read_dir(path.as_ref())
+}
+
+pub fn canonicalize(path: impl AsRef<Path>) -> io::Result<PathBuf> {
+    provider().canonicalize(path.as_ref())
+}
+
+pub fn glob(pattern: &[u8]) -> io::Result<Vec<Vec<u8>>> {
+    provider().glob(pattern)
+}
+
+fn native_glob(pattern: &[u8]) -> io::Result<Vec<Vec<u8>>> {
+    let pattern = CString::new(pattern)
+        .map_err(|_| io::Error::new(io::ErrorKind::InvalidInput, "NUL in glob pattern"))?;
+    let mut result = Vec::new();
+    // SAFETY: all fields in glob_t permit zero initialization.
+    let mut state: libc::glob_t = unsafe { std::mem::zeroed() };
+    // SAFETY: pattern is a valid C string; state is initialized and freed below.
+    let status = unsafe { libc::glob(pattern.as_ptr(), 0, None, &mut state) };
+    if status == 0 && state.gl_pathc > 0 && !state.gl_pathv.is_null() {
+        // SAFETY: successful glob returns gl_pathc valid pointers in gl_pathv.
+        let paths = unsafe { slice::from_raw_parts(state.gl_pathv, state.gl_pathc) };
+        result.reserve_exact(state.gl_pathc);
+        for path in paths {
+            if !path.is_null() {
+                // SAFETY: libc glob returns NUL-terminated path strings.
+                let path = unsafe { CStr::from_ptr(*path) };
+                result.push(path.to_bytes().to_vec());
+            }
+        }
+    }
+    // SAFETY: state was initialized above and is no longer accessed afterwards.
+    unsafe { libc::globfree(&mut state) };
+    // Preserve kati's historical behavior: glob errors and no matches both
+    // produce an empty result; only invalid byte input fails before libc.
+    Ok(result)
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+    use std::{
+        ffi::OsStr,
+        sync::{Barrier, Mutex},
+        time::UNIX_EPOCH,
+    };
+
+    static TEST_LOCK: Mutex<()> = Mutex::new(());
+    const MOCK_PATH: &str = "/__kati_mock__/Makefile";
+
+    struct MockFileSystem;
+
+    impl FileSystemProvider for MockFileSystem {
+        fn metadata(&self, path: &Path) -> io::Result<Metadata> {
+            if path == Path::new(MOCK_PATH) {
+                return Ok(Metadata {
+                    kind: FileKind::Regular,
+                    len: 7,
+                    modified: UNIX_EPOCH,
+                });
+            }
+            panic!("unexpected native metadata access: {path:?}")
+        }
+
+        fn modified(&self, path: &Path) -> io::Result<SystemTime> {
+            if path == Path::new(MOCK_PATH) {
+                return Ok(UNIX_EPOCH);
+            }
+            panic!("unexpected native modified access: {path:?}")
+        }
+
+        fn read(&self, path: &Path) -> io::Result<Vec<u8>> {
+            if path == Path::new(MOCK_PATH) {
+                return Ok(b"all: ;\n".to_vec());
+            }
+            panic!("unexpected native read access: {path:?}")
+        }
+
+        fn symlink_metadata(&self, path: &Path) -> io::Result<Metadata> {
+            if path == Path::new("/__kati_mock__/link") {
+                return Ok(Metadata {
+                    kind: FileKind::Symlink,
+                    len: 8,
+                    modified: UNIX_EPOCH,
+                });
+            }
+            panic!("unexpected native symlink_metadata access: {path:?}")
+        }
+
+        fn read_link(&self, path: &Path) -> io::Result<PathBuf> {
+            if path == Path::new("/__kati_mock__/link") {
+                return Ok(PathBuf::from("Makefile"));
+            }
+            panic!("unexpected native read_link access: {path:?}")
+        }
+
+        fn read_dir(&self, path: &Path) -> io::Result<Vec<io::Result<DirEntry>>> {
+            if path == Path::new("/__kati_mock__") {
+                return Ok(vec![Ok(DirEntry {
+                    file_name: OsString::from("Makefile"),
+                    path: PathBuf::from(MOCK_PATH),
+                    kind: FileKind::Regular,
+                })]);
+            }
+            panic!("unexpected native read_dir access: {path:?}")
+        }
+
+        fn canonicalize(&self, path: &Path) -> io::Result<PathBuf> {
+            if path == Path::new("/__kati_mock__/./Makefile") {
+                return Ok(PathBuf::from(MOCK_PATH));
+            }
+            panic!("unexpected native canonicalize access: {path:?}")
+        }
+
+        fn glob(&self, pattern: &[u8]) -> io::Result<Vec<Vec<u8>>> {
+            if pattern == b"/__kati_mock__/*" {
+                return Ok(vec![MOCK_PATH.as_bytes().to_vec()]);
+            }
+            panic!("unexpected native glob access: {pattern:?}")
+        }
+    }
+
+    #[test]
+    fn makefile_and_timestamp_stay_behind_installed_provider() {
+        let _guard = TEST_LOCK.lock().unwrap();
+        let _provider = install_file_system_provider(Arc::new(MockFileSystem));
+        let path = Path::new(MOCK_PATH);
+
+        let makefile = crate::file::Makefile::from_file(OsStr::new("Makefile"), path).unwrap();
+        assert!(makefile.is_some());
+        assert_eq!(
+            crate::fileutil::get_timestamp(MOCK_PATH.as_bytes(), Path::new("/")).unwrap(),
+            Some(UNIX_EPOCH)
+        );
+        assert!(
+            symlink_metadata("/__kati_mock__/link")
+                .unwrap()
+                .is_symlink()
+        );
+        assert_eq!(
+            read_link("/__kati_mock__/link").unwrap(),
+            Path::new("Makefile")
+        );
+        let entries = read_dir("/__kati_mock__").unwrap();
+        assert_eq!(entries.len(), 1);
+        assert_eq!(entries.into_iter().next().unwrap().unwrap().path, path);
+        assert_eq!(canonicalize("/__kati_mock__/./Makefile").unwrap(), path);
+        crate::fileutil::clear_glob_cache();
+        let matches = crate::fileutil::glob(
+            bytes::Bytes::from_static(b"/__kati_mock__/*"),
+            Path::new("/"),
+        );
+        assert_eq!(
+            matches.as_ref().as_ref().unwrap(),
+            &[bytes::Bytes::from_static(MOCK_PATH.as_bytes())]
+        );
+        crate::fileutil::clear_glob_cache();
+    }
+
+    struct ThreadFileSystem(&'static str);
+
+    impl FileSystemProvider for ThreadFileSystem {
+        fn metadata(&self, path: &Path) -> io::Result<Metadata> {
+            assert_eq!(path, Path::new(self.0));
+            Ok(Metadata {
+                kind: FileKind::Regular,
+                len: self.0.len() as u64,
+                modified: UNIX_EPOCH,
+            })
+        }
+        fn symlink_metadata(&self, path: &Path) -> io::Result<Metadata> {
+            self.metadata(path)
+        }
+        fn modified(&self, path: &Path) -> io::Result<SystemTime> {
+            assert_eq!(path, Path::new(self.0));
+            Ok(UNIX_EPOCH)
+        }
+        fn read(&self, path: &Path) -> io::Result<Vec<u8>> {
+            assert_eq!(path, Path::new(self.0));
+            Ok(self.0.as_bytes().to_vec())
+        }
+        fn read_link(&self, path: &Path) -> io::Result<PathBuf> {
+            panic!("unexpected read_link: {path:?}")
+        }
+        fn read_dir(&self, path: &Path) -> io::Result<Vec<io::Result<DirEntry>>> {
+            panic!("unexpected read_dir: {path:?}")
+        }
+        fn canonicalize(&self, path: &Path) -> io::Result<PathBuf> {
+            assert_eq!(path, Path::new(self.0));
+            Ok(path.to_path_buf())
+        }
+        fn glob(&self, pattern: &[u8]) -> io::Result<Vec<Vec<u8>>> {
+            assert_eq!(pattern, self.0.as_bytes());
+            Ok(vec![pattern.to_vec()])
+        }
+    }
+
+    #[test]
+    fn provider_scopes_are_nested_and_thread_isolated() {
+        let barrier = Arc::new(Barrier::new(2));
+        let threads: Vec<_> = ["/__kati_thread_a__", "/__kati_thread_b__"]
+            .into_iter()
+            .map(|path| {
+                let barrier = barrier.clone();
+                std::thread::spawn(move || {
+                    let outer = install_file_system_provider(Arc::new(ThreadFileSystem(path)));
+                    barrier.wait();
+                    assert_eq!(read(path).unwrap(), path.as_bytes());
+                    {
+                        let nested_path = if path.ends_with("a__") {
+                            "/__nested_a__"
+                        } else {
+                            "/__nested_b__"
+                        };
+                        let _nested =
+                            install_file_system_provider(Arc::new(ThreadFileSystem(nested_path)));
+                        assert_eq!(read(nested_path).unwrap(), nested_path.as_bytes());
+                    }
+                    assert_eq!(read(path).unwrap(), path.as_bytes());
+                    drop(outer);
+                })
+            })
+            .collect();
+        for thread in threads {
+            thread.join().unwrap();
+        }
+    }
+}
