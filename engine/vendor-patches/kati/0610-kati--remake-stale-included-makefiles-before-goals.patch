From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: sarun <noreply@sarun>
Date: Fri, 17 Jul 2026 20:15:59 +0000
Subject: [PATCH] kati: remake stale included makefiles before goals

Treat every parsed include as a makefile target, not only missing includes. Build the include graph first, reparse only when a recipe ran, and keep dependency analysis non-destructive so up-to-date includes can proceed to the requested goals.

---
diff --git a/src-rs/dep.rs b/src-rs/dep.rs
index 8469590..f9b04cc 100644
--- a/src-rs/dep.rs
+++ b/src-rs/dep.rs
@@ -474,7 +474,10 @@ struct PickedRuleInfo {
 
 impl<'a> DepBuilder<'a> {
     fn new(ev: &'a mut Evaluator) -> Result<Self> {
-        let rule_vars = std::mem::take(&mut ev.rule_vars);
+        // Dependency analysis may run once for included makefile targets and
+        // again for the user's goals. Building a graph must therefore be a
+        // read of the parsed grammar, not a destructive drain of it.
+        let rule_vars = ev.rule_vars.clone();
         // The final value of $(VPATH), evaluated once here — GNU make also
         // uses the value in effect after reading all makefiles.
         let vpath_dirs: Vec<Bytes> = {
@@ -853,8 +856,7 @@ impl<'a> DepBuilder<'a> {
     }
 
     fn populate_rules(&mut self) -> Result<()> {
-        // TODO: Is this take necessary, or can we refactor how we pass around ev?
-        for rule in std::mem::take(&mut self.ev.rules) {
+        for rule in self.ev.rules.clone() {
             let rule = Arc::new(rule);
             if rule.outputs.is_empty() {
                 self.populate_implicit_rule(rule)?;
diff --git a/src-rs/eval.rs b/src-rs/eval.rs
index 6df5292..e972d6d 100644
--- a/src-rs/eval.rs
+++ b/src-rs/eval.rs
@@ -325,14 +325,12 @@ pub struct Evaluator {
     /// target. When a recipe exits with a non-zero status, kati
     /// removes the target's output file (mirrors GNU make).
     pub delete_on_error: bool,
-    /// sarun: required `include` directives whose file didn't exist at
-    /// parse time, paired with the source location of the directive.
-    /// The remake-the-makefile loop in main.rs checks for rules
-    /// producing these names and builds + re-parses if any apply.
-    /// (loc, filename, required) — missing `include` files queued for the
-    /// remake-the-makefile loop. `-include` files queue with required=false:
-    /// GNU remakes them too when a rule exists, but a missing one without a
-    /// rule is silently tolerated.
+    /// sarun: every file named by an `include` directive, paired with the
+    /// source location and whether the include was required. GNU make treats
+    /// parsed makefiles as build targets too: an EXISTING but stale include
+    /// must be remade and the whole makefile reparsed just like a missing one.
+    /// `-include` entries carry required=false so an absent, unproducible file
+    /// remains silently tolerated.
     pub pending_remake_includes: Vec<(Loc, OsString, bool)>,
     /// sarun: in the in-process box, exported make variables can't be staged
     /// into the process environment (`std::env::set_var`) — many makes share one
@@ -1345,6 +1343,14 @@ impl Evaluator {
                 }
 
                 {
+                    // Existing included makefiles are remake candidates too.
+                    // This is essential for generated configuration fragments:
+                    // their producer can make them stale without deleting them.
+                    self.pending_remake_includes.push((
+                        stmt.loc(),
+                        OsString::from_vec(fname.to_vec()),
+                        stmt.should_exist,
+                    ));
                     let _frame = self.enter(FrameType::Parse, fname.clone(), stmt.loc());
                     self.do_include(fname)
                         .with_context(|| format!("In file included from {}:", stmt.loc()))?;
