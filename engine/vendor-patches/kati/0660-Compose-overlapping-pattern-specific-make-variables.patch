diff --git a/src-rs/var.rs b/src-rs/var.rs
index 8c01c0b..d4d7fd0 100644
--- a/src-rs/var.rs
+++ b/src-rs/var.rs
@@ -113,6 +113,60 @@ fn is_value_empty(v: &Arc<Value>) -> bool {
 }
 
 impl Variable {
+    /// Overlay a pattern-specific `+=` assignment on a value inherited from a
+    /// less-specific matching pattern.  The evaluator stores each pattern's
+    /// scope independently, so an append parsed in `lib-%.o` cannot see the
+    /// base assignment in `%.o`; composition has to happen when those matching
+    /// scopes are applied to a concrete target.
+    fn append_pattern_assignment(&mut self, rhs: &Variable) -> bool {
+        if rhs.assign_op != Some(AssignOp::PlusEq) {
+            return false;
+        }
+
+        if let (InnerVar::Simple(left), InnerVar::Simple(right)) =
+            (&mut self.value, &rhs.value)
+        {
+            if !left.is_empty() && !right.is_empty() {
+                left.push(b' ');
+            }
+            left.extend_from_slice(right);
+            self.exported |= rhs.exported;
+            self.assign_op = Some(AssignOp::PlusEq);
+            return true;
+        }
+
+        let to_value = |v: &InnerVar| -> Option<(Arc<Value>, Bytes)> {
+            match v {
+                InnerVar::Simple(bytes) => Some((
+                    Arc::new(Value::Literal(None, Bytes::copy_from_slice(bytes))),
+                    Bytes::copy_from_slice(bytes),
+                )),
+                InnerVar::Recursive { v, orig } => Some((v.clone(), orig.clone())),
+                _ => None,
+            }
+        };
+        let Some((left, left_raw)) = to_value(&self.value) else { return false };
+        let Some((right, right_raw)) = to_value(&rhs.value) else { return false };
+        let mut pieces = vec![left];
+        if !left_raw.is_empty() && !right_raw.is_empty() {
+            pieces.push(Arc::new(Value::Literal(None, Bytes::from_static(b" "))));
+        }
+        pieces.push(right);
+        let mut raw = Vec::with_capacity(left_raw.len() + right_raw.len() + 1);
+        raw.extend_from_slice(&left_raw);
+        if !left_raw.is_empty() && !right_raw.is_empty() {
+            raw.push(b' ');
+        }
+        raw.extend_from_slice(&right_raw);
+        self.value = InnerVar::Recursive {
+            v: Arc::new(Value::List(None, pieces)),
+            orig: Bytes::from(raw),
+        };
+        self.exported |= rhs.exported;
+        self.assign_op = Some(AssignOp::PlusEq);
+        true
+    }
+
     pub fn loc(&self) -> &Option<Loc> {
         &self.loc
     }
@@ -547,6 +601,26 @@ impl Vars {
             to.insert(*sym, var.clone());
         }
     }
+
+    /// Apply a more-specific pattern scope over an accumulated less-specific
+    /// one, preserving `+=` as composition instead of plain replacement.
+    pub fn merge_pattern_from(&self, vars: &Vars) {
+        let incoming: Vec<(Symbol, Var)> = vars
+            .0
+            .lock()
+            .iter()
+            .map(|(sym, var)| (*sym, var.clone()))
+            .collect();
+        for (sym, var) in incoming {
+            let existing = self.0.lock().get(&sym).cloned();
+            if let Some(existing) = existing
+                && existing.write().append_pattern_assignment(&var.read())
+            {
+                continue;
+            }
+            self.0.lock().insert(sym, var);
+        }
+    }
 }
 
