 src-rs/fileutil.rs | 42 ++++++++++++++++++++++++++++++++++++------
 src-rs/func.rs     |  2 +-
 src-rs/regen.rs    |  4 +++-
 4 files changed, 41 insertions(+), 9 deletions(-)

