+++ b/src-rs/func.rs
@@ -555,12 +555,7 @@ fn eval_func(args: &[Arc<Value>], ev: &mut Evaluator, _out: &mut dyn BufMut) ->
         );
     }
     let stmts = parse_buf(&text, ev.loc.clone().unwrap_or_default())?;
-    let stmts = stmts.lock();
-    for stmt in stmts.iter() {
-        log!("{:?}", stmt);
-        stmt.eval(ev)?;
-    }
-    Ok(())
+    ev.eval_stmts(&stmts)
 }
 
