index 1f33ff7..2418792 100644
--- a/src-rs/eval.rs
+++ b/src-rs/eval.rs
@@ -646,8 +646,11 @@ impl Evaluator {
                 let shell = self.get_shell()?;
                 let shellflag = self.get_shell_flag();
                 let box_prefix = self.box_export_prefix.clone();
+                let cwd = std::os::unix::ffi::OsStrExt::as_bytes(
+                    self.working_dir.as_os_str()).to_vec();
                 let (_exit, output, _fc) =
-                    crate::func::shell_func_impl(&shell, shellflag, &cmd_buf, &loc, &box_prefix)?;
+                    crate::func::shell_func_impl(&shell, shellflag, &cmd_buf, &loc,
+                                                 &box_prefix, &cwd)?;
                 result = Variable::with_simple_string(
                     output,
                     origin,
diff --git a/src-rs/exec.rs b/src-rs/exec.rs
index 80f8aa4..32aaeaf 100644
--- a/src-rs/exec.rs
+++ b/src-rs/exec.rs
@@ -292,7 +292,7 @@ fn run_node_commands(
             {
                 (code == 0, o, code)
             } else {
-                match run_command(shell, shellflag, &run_input, RedirectStderr::Stdout) {
+                match run_command(shell, shellflag, &run_input, &cwd, RedirectStderr::Stdout) {
                     Ok((status, o)) => (status.success(), o, status.code().unwrap_or(1)),
                     Err(e) => (false, format!("{e}\n").into_bytes(), 1),
                 }
