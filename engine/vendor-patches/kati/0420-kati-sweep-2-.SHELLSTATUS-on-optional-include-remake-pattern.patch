diff --git a/testcase/sarun_sweep2_intermediate.mk b/testcase/sarun_sweep2_intermediate.mk
new file mode 100644
index 0000000..254fdb4
--- /dev/null
+++ b/testcase/sarun_sweep2_intermediate.mk
@@ -0,0 +1,11 @@
+# Sweep 2: implicit-rule chains — the intermediate file is built through
+# a two-step %-rule chain (.z <- %.y <- %.x); .PRECIOUS keeps it.
+.PRECIOUS: %.y
+all: thing.z
+	@echo have=[$(wildcard thing.y)]
+%.z: %.y
+	@cp $< $@
+%.y: %.x
+	@echo mid > $@
+thing.x:
+	@touch $@
