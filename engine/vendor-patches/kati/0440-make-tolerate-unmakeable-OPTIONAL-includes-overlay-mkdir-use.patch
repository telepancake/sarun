-            kati::exec::exec(nodes, &mut ev)?;
+            let required: std::collections::HashSet<Symbol> = remake_targets
+                .iter().filter(|(_, req)| *req).map(|(s, _)| *s).collect();
+            let (req_nodes, opt_nodes): (Vec<_>, Vec<_>) = nodes
