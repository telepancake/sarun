diff --git a/testcase/sarun_optional_include_failing_recipe.mk b/testcase/sarun_optional_include_failing_recipe.mk
new file mode 100644
index 0000000..b21131b
--- /dev/null
+++ b/testcase/sarun_optional_include_failing_recipe.mk
@@ -0,0 +1,6 @@
+# An optional include whose remake RECIPE fails: GNU proceeds without it.
+all:
+	@echo ran-after-fail
+-include blah2
+blah2:
+	@false
diff --git a/testcase/sarun_optional_include_no_rule_at_all.mk b/testcase/sarun_optional_include_no_rule_at_all.mk
new file mode 100644
index 0000000..be267a2
--- /dev/null
+++ b/testcase/sarun_optional_include_no_rule_at_all.mk
@@ -0,0 +1,5 @@
+# `-include blah` with NO producer anywhere must be silently tolerated —
+# a regression once made it fatal ("No rule to make target 'blah'").
+all:
+	@echo ran-no-producer
+-include blah
diff --git a/testcase/sarun_optional_include_unpickable_rule.mk b/testcase/sarun_optional_include_unpickable_rule.mk
new file mode 100644
index 0000000..6fa9108
--- /dev/null
+++ b/testcase/sarun_optional_include_unpickable_rule.mk
@@ -0,0 +1,8 @@
+# An optional include whose rule exists but whose PREREQUISITE has no rule:
+# GNU tolerates this too (no error, build proceeds) — the remake attempt
+# simply doesn't happen.
+all:
+	@echo ran-unpickable
+-include gen.dep
+gen.dep: missing-src
+	@cp missing-src $@
