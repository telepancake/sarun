diff --git a/src-rs/flags.rs b/src-rs/flags.rs
index 1faf9b8..e94a1ed 100644
--- a/src-rs/flags.rs
+++ b/src-rs/flags.rs
@@ -69,6 +69,26 @@ pub struct Flags {
     pub generate_empty_ninja: bool,
     pub is_dry_run: bool,
     pub is_silent_mode: bool,
+    /// -i / --ignore-errors (GNU): treat every recipe line as if it were
+    /// '-'-prefixed — failures are reported "(ignored)" and the build goes
+    /// on. NOT upstream kati's `-i` (which meant dry run): sarun runs kati
+    /// AS `make`, so argv must carry GNU make semantics — a vendor build
+    /// invoking `$(MAKE) -i -C dir` expects ignore-errors, and the old
+    /// mapping silently turned those sub-makes into dry-run NOPs.
+    pub is_ignore_errors: bool,
+    /// --trace (GNU): print, for every considered target, whether its recipe
+    /// runs or is skipped and WHY (up to date / no commands / out of date).
+    /// sarun's rendering is a diagnosis aid, not byte-parity with GNU's.
+    pub is_trace: bool,
+    /// -B / --always-make (GNU): consider every target out of date and
+    /// rebuild it. Vendor drivers use it as "force rebuild"; refusing it
+    /// made those sub-makes exit 2 instantly — an invisible nop under a
+    /// driver that ignores sub-make status.
+    pub is_always_make: bool,
+    /// -q / --question (GNU): run nothing, print nothing; exit 0 if the
+    /// goals are up to date, 1 if anything would be rebuilt. Used in
+    /// driver-script guards (`if make -q; then skip; fi`).
+    pub is_question: bool,
     /// -k / --keep-going: on a recipe failure, keep building targets that
     /// don't depend on the failed one; exit non-zero at the end.
     pub is_keep_going: bool,
@@ -268,6 +288,13 @@ impl Flags {
                 self.is_silent_mode = true;
             } else if tok == b"-k" || tok == b"--keep-going" {
                 self.is_keep_going = true;
+            } else if tok == b"-i" || tok == b"--ignore-errors" {
+                self.is_ignore_errors = true;
+            } else if tok == b"-n" || tok == b"--just-print"
+                   || tok == b"--dry-run" || tok == b"--recon" {
+                self.is_dry_run = true;
+            } else if tok == b"--trace" {
+                self.is_trace = true;
             } else if !tok.starts_with(b"-") && tok.contains(&b'=') {
                 let var = Bytes::from(tok.to_vec());
                 if !self.cl_vars.contains(&var) {
@@ -283,6 +310,10 @@ impl Flags {
                         b'R' => self.no_builtin_variables = true,
                         b's' => self.is_silent_mode = true,
                         b'k' => self.is_keep_going = true,
+                        b'i' => self.is_ignore_errors = true,
+                        b'n' => self.is_dry_run = true,
+                        b'B' => self.is_always_make = true,
+                        b'q' => self.is_question = true,
                         _ => {}
                     }
                 }
@@ -309,11 +340,32 @@ impl Flags {
                     should_propagate = false;
                 }
                 b"-c" => flags.is_syntax_check_only = true,
-                b"-i" => flags.is_dry_run = true,
+                // sarun: GNU make argv semantics, NOT upstream kati's. kati's
+                // own CLI used `-i` for dry run; running kati AS `make` that
+                // mapping silently turned every `$(MAKE) -i -C dir` (a vendor
+                // staple: ignore-errors) into a dry-run NOP, and made `-n`
+                // BUILD FOR REAL. Crosswire undone:
+                b"-i" | b"--ignore-errors" => flags.is_ignore_errors = true,
+                b"-n" | b"--just-print" | b"--dry-run" | b"--recon" => {
+                    flags.is_dry_run = true
+                }
+                b"--trace" => flags.is_trace = true,
+                b"-B" | b"--always-make" => flags.is_always_make = true,
+                b"-q" | b"--question" => flags.is_question = true,
+                // -l/--load-average/--max-load: advisory load limiting; the
+                // slip pool already bounds system-wide parallelism, so accept
+                // and ignore. The limit argument is attached-only (getopt
+                // optional_argument): `-l2.5`, `--load-average=2.5`; a
+                // detached number is a goal, exactly as in GNU make.
+                b"-l" | b"--load-average" | b"--max-load" => {}
+                t if t.starts_with(b"-l")
+                    && t[2..].iter().all(|b| b.is_ascii_digit() || *b == b'.') => {}
+                t if t.starts_with(b"--load-average=")
+                    || t.starts_with(b"--max-load=") => {}
                 b"-s" => flags.is_silent_mode = true,
                 b"-r" => flags.no_builtin_rules = true,
                 b"-R" => flags.no_builtin_variables = true,
-                b"-w" | b"-n" => {} // accepted, semantically no-op in kati
+                b"-w" => {} // accepted, semantically no-op in kati
                 b"-k" | b"--keep-going" => flags.is_keep_going = true,
                 // sarun: GNU make's long forms of -w/its inverse. The kernel's
                 // top Makefile passes --no-print-directory to every sub-make
diff --git a/testcase/sarun_flag_B_always_make.mk b/testcase/sarun_flag_B_always_make.mk
new file mode 100644
index 0000000..eeb9a77
--- /dev/null
+++ b/testcase/sarun_flag_B_always_make.mk
@@ -0,0 +1,9 @@
+# GNU -B (--always-make): rebuild even when up to date. kati refused -B
+# outright — the sub-make exited 2 instantly having built nothing, which a
+# driver with unchecked status reads as "make -C = nop".
+$(shell printf 'out:\n\t@echo REBUILT\n\t@touch out\n' > child.mk)
+
+test:
+	@$(MAKE) --no-print-directory -f child.mk out
+	@$(MAKE) --no-print-directory -f child.mk out
+	@$(MAKE) --no-print-directory -f child.mk -B out
diff --git a/testcase/sarun_flag_i_ignore_errors.mk b/testcase/sarun_flag_i_ignore_errors.mk
new file mode 100644
index 0000000..00b3eb3
--- /dev/null
+++ b/testcase/sarun_flag_i_ignore_errors.mk
@@ -0,0 +1,10 @@
+# GNU -i (--ignore-errors): every recipe line behaves '-'-prefixed — the
+# failing step is reported ignored and the build CONTINUES, exit 0. Under
+# kati's upstream CLI mapping, -i meant dry run: a vendor build's
+# `$(MAKE) -i -C dir` silently became a NOP. stderr is dropped so the diff
+# compares only the markers (the "(ignored)" line formats differ).
+$(shell printf 'all: a b\na:\n\t@echo step-a\n\t@false\nb:\n\t@echo step-b\n' > child.mk)
+
+test:
+	@$(MAKE) --no-print-directory -f child.mk -i 2>/dev/null
+	@echo "rc=$$?"
diff --git a/testcase/sarun_flag_n_dry_run.mk b/testcase/sarun_flag_n_dry_run.mk
new file mode 100644
index 0000000..572427a
--- /dev/null
+++ b/testcase/sarun_flag_n_dry_run.mk
@@ -0,0 +1,9 @@
+# GNU -n (dry run): sub-make prints every command line — INCLUDING
+# @-silenced ones — and executes NOTHING. kati's upstream CLI parked -n as
+# a no-op (and used -i for dry run), so `make -n` BUILT FOR REAL when kati
+# runs as `make`. The follow-up `test -f` pins that no file was created.
+$(shell printf 'built.txt:\n\t@echo quiet-step\n\ttouch built.txt\n' > child.mk)
+
+test:
+	@$(MAKE) --no-print-directory -f child.mk -n built.txt
+	@test -f built.txt && echo "DRY-RUN-VIOLATED" || echo "dry-run-clean"
diff --git a/testcase/sarun_flag_q_question.mk b/testcase/sarun_flag_q_question.mk
new file mode 100644
index 0000000..634fe37
--- /dev/null
+++ b/testcase/sarun_flag_q_question.mk
@@ -0,0 +1,10 @@
+# GNU -q (--question): run nothing, print nothing; exit 1 when the goals
+# need rebuilding, 0 when up to date. Driver scripts use it as a guard
+# (`if make -q; then skip; fi`).
+$(shell printf 'out: ; @echo BUILT; touch out\n' > child.mk)
+
+test:
+	@$(MAKE) --no-print-directory -f child.mk -q out; echo "stale rc=$$?"
+	@$(MAKE) --no-print-directory -f child.mk out
+	@$(MAKE) --no-print-directory -f child.mk -q out; echo "fresh rc=$$?"
+	@test -f out && echo "built once" || echo "NEVER BUILT"
