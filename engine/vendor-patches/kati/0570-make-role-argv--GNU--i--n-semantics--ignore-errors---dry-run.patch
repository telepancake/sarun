@@ -536,17 +553,40 @@ list of the rule for '{output}' at {loc}"));
             }
         }
         if output_ts >= latest && !is_phony {
+            if self.trace || FLAGS.is_trace {
+                emit_recipe_err(&format!(
+                    "--trace: '{output}': skip — up to date \
+(target {output_ts:?} >= newest prerequisite {latest:?})"));
+            }
             return Ok((output_ts, None));
         }
         let (commands, exports) = self.eval_node_commands(&n)?;
         if commands.is_empty() {
+            if self.trace || FLAGS.is_trace {
+                emit_recipe_err(&format!(
+                    "--trace: '{output}': skip — rule has no commands \
+(phony={is_phony}, exists={})", !matches!(output_ts, ExecStatus::Timestamp(None))));
+            }
             return Ok((output_ts, None));
         }
+        if self.trace || FLAGS.is_trace {
+            let why = if matches!(output_ts, ExecStatus::Timestamp(None)) {
+                "target does not exist".to_string()
