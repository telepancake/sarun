-        if FLAGS.is_dry_run {
+        if dry_run {
             continue;
         }
         // In-process runner gets the exports prefix SEPARATELY (it applies it
@@ -354,7 +367,8 @@ fn run_node_commands(
                 }
             };
         if !ok {
-            if command.ignore_error {
+            // Global -i / --ignore-errors == every line '-'-prefixed.
+            if command.ignore_error || FLAGS.is_ignore_errors || req.ignore_errors {
                 ignored.push((command.output, code));
             } else {
                 failure = Some((command.output, code));
@@ -375,11 +389,21 @@ impl<'a> Executor<'a> {
     fn new(ev: &'a mut Evaluator) -> Result<Self> {
         let shell = ev.get_shell()?;
