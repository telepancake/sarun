From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: sarun <noreply@sarun>
Date: Fri, 10 Jul 2026 05:52:02 +0000
Subject: [PATCH] make-role argv: GNU -i/-n semantics (ignore-errors / dry-run)

---
diff --git a/src-rs/eval.rs b/src-rs/eval.rs
index 3dae458..7a8f3c1 100644
--- a/src-rs/eval.rs
+++ b/src-rs/eval.rs
@@ -267,6 +267,18 @@ pub struct Evaluator {
     /// sarun: `.NOTPARALLEL:` was seen — this make's recipes run serially
     /// even when -j / a jobserver is in effect.
     pub not_parallel: bool,
+    /// sarun: per-make GNU `-n` (dry run) / `-i` (ignore-errors). Carried on
+    /// the Evaluator — NOT the process-global FLAGS — because many in-process
+    /// makes share one process and only the FIRST argv installs FLAGS; a
+    /// recursive `$(MAKE) -n`/-i must not depend on what the top make was
+    /// invoked with. exec.rs ORs these with the global FLAGS (standalone
+    /// rkati still drives everything through FLAGS).
+    pub dry_run: bool,
+    pub ignore_errors: bool,
+    /// sarun: per-make GNU --trace (goal/recipe decision tracing; see
+    /// flags.rs). Named goal_trace — `trace` below is the pre-existing
+    /// variable-assignment tracer.
+    pub goal_trace: bool,
     /// sarun: per-instance global variable bindings, indexed by Symbol id.
     /// Moved off the process-global symbol table (symtab `symbol_data`) so each
     /// Evaluator — i.e. each make invocation — owns its OWN global namespace.
@@ -370,6 +382,9 @@ impl Evaluator {
             rule_vars: HashMap::new(),
             vpath_patterns: Vec::new(),
             not_parallel: false,
+            dry_run: false,
+            ignore_errors: false,
+            goal_trace: false,
             global_vars: Arc::new(Mutex::new(Vec::new())),
             working_dir: std::env::current_dir().unwrap_or_default(),
             include_dirs: Vec::new(),
