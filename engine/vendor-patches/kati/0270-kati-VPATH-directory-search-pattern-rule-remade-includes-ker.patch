+                }
+            }
+            for i in node.actual_order_only_inputs.iter_mut() {
+                if let Some(resolved) = self.vpath_resolve(*i) {
+                    *i = resolved;
+                }
+            }
+        }
         let actual_inputs = n.lock().actual_inputs.clone();
         for input in actual_inputs {
             let c = self.build_plan(input, Some(output))?;
