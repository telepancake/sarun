+            }
+            Value::VarRef(_, var) => {
+                let mut inner = String::new();
+                var.write_static(&mut inner);
+                name_ref(out, &inner);
+            }
+            Value::VarSubst {
+                name, pat, subst, ..
+            } => {
+                out.push_str("$(");
+                name.write_static(out);
+                out.push(':');
+                pat.write_static(out);
+                out.push('=');
+                subst.write_static(out);
+                out.push(')');
+            }
+            Value::Func { fi, args, .. } => {
+                out.push_str("$(");
