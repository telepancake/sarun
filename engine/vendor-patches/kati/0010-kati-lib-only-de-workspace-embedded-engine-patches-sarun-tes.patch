diff --git a/Cargo.toml b/Cargo.toml
index 17d18ec..7fba0a0 100644
--- a/Cargo.toml
+++ b/Cargo.toml
@@ -1,38 +1,46 @@
+# sarun: vendored lib-only patched fork of kati (github.com/google/kati).
+# Upstream commit: 7eb37cd16ed29b90335983689d3c6caabc17ca70 (2026-05-26).
+# Patches are minimal and marked `// sarun:`. The [[bench]] target is dropped
+# so criterion isn't pulled in; the upstream `[[bin]] rkati` is kept but gated
+# on the `kati-corpus` feature — it is built only when running the compat
+# corpus (`tests/corpus.rs`), never as part of the engine. The
+# `tikv-jemallocator` global allocator (linux-only, lived in main.rs) and the
+# `find_emulator` helper bin are dropped.
+#
+# Compat target: GNU make 4.3 (what Ubuntu 22.04 LTS ships, what upstream
+# kati's docker tests against). The `testcase/` directory is upstream's
+# verbatim corpus; `cargo test --features kati-corpus` diffs each `.mk`'s
+# normalized output between system `make` and our `rkati` and reports
+# `KATI_COMPAT_PASS=N/total`.
 [package]
 name = "kati"
 version = "0.1.0"
 edition = "2024"
-default-run = "rkati"
+
+[features]
+# Build the `rkati` binary and the `tests/corpus.rs` test that exercises it
+# against the vendored upstream testcase corpus. Off by default — the engine
+# does not need rkati-the-binary, only kati-the-library.
+kati-corpus = []
 
 [dependencies]
 anyhow = "1.0.98"
 bytes = "1.10.1"
-criterion = { version = "0.5.1", features = ["html_reports"] }
 env_logger = "0.11.8"
-gperftools = { version = "0.2.0", features = ["heap"], optional = true }
 libc = "0.2.172"
 log = "0.4.27"
 memchr = "2.7.4"
 os_pipe = "1.2.1"
 parking_lot = { version = "0.12.3" }
 
-[target.'cfg(target_os = "linux")'.dependencies]
-tikv-jemallocator = "0.6.0"
+[dev-dependencies]
+regex-lite = "0.1"
+tempfile = "3"
 
-[features]
-gperf = ["dep:gperftools"]
+[lib]
+path = "src-rs/lib.rs"
 
 [[bin]]
 name = "rkati"
 path = "src-rs/main.rs"
-
-[[bin]]
-name = "find_emulator"
-path = "src-rs/bins/find_emulator.rs"
-
-[lib]
-path = "src-rs/lib.rs"
-
-[[bench]]
-name = "strutil_benchmark"
-harness = false
+required-features = ["kati-corpus"]
