+    }
+
+    fn write_static(&self, out: &mut String) {
+        fn name_ref(out: &mut String, name: &str) {
+            if name.len() == 1 {
+                out.push('$');
+                out.push_str(name);
+            } else {
+                out.push_str("$(");
+                out.push_str(name);
+                out.push(')');
