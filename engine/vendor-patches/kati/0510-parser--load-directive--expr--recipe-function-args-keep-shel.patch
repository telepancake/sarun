+/// sarun: the GNU `load` / `-load` directive. We never actually dlopen a
+/// plugin — a box has no business loading host .so's into the engine — but
+/// the directive must parse and fail with GNU's wording (or be silently
+/// tolerated in its `-load` form) instead of "missing separator".
+pub struct LoadStmt {
+    loc: Loc,
+    orig: Bytes,
+
+    pub expr: Arc<Value>,
+    pub should_exist: bool,
+}
+
+impl Statement for LoadStmt {
+    fn loc(&self) -> Loc {
+        self.loc.clone()
+    }
+    fn orig(&self) -> Bytes {
+        self.orig.clone()
+    }
+    fn eval(&self, ev: &mut Evaluator) -> Result<()> {
+        ev.eval_load(self)
+    }
+}
+
+impl Debug for LoadStmt {
+    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
+        write!(f, "LoadStmt({:?}, loc={})", self.expr, self.loc)
+    }
+}
+
+impl LoadStmt {
+    pub fn new(loc: Loc, expr: Arc<Value>, should_exist: bool) -> Arc<LoadStmt> {
+        Arc::new(LoadStmt {
+            loc,
+            orig: Bytes::new(),
+            expr,
+            should_exist,
+        })
+    }
+}
+
