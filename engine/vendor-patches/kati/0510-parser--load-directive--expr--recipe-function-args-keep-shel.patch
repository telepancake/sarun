+    // sarun: `load foo.so` / `-load foo.so` — parsed like include (the
+    // file list may contain expansions), evaluated by Evaluator::eval_load.
+    fn parse_load(&mut self, line: Bytes, directive: &[u8]) -> Result<()> {
+        let loc = self.loc.clone();
+        let mut mutable_loc = loc.clone();
+        let expr = parse_expr(&mut mutable_loc, line, ParseExprOpt::Normal)?;
+        self.out_stmts
+            .lock()
+            .push(LoadStmt::new(loc, expr, directive.starts_with(b"l")));
+        self.after_rule = false;
+        Ok(())
+    }
