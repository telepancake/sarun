From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: sarun <noreply@sarun>
Date: Fri, 03 Jul 2026 16:33:27 +0000
Subject: [PATCH] parser: load directive; expr: recipe function args keep shell escapes

Two conformance TODOs retired:

load / -load directive (was 'missing separator'): parsed like include
into a LoadStmt, evaluated by never dlopening — 'load' of a missing
file reproduces GNU's two-line failure verbatim, an existing file gets
the generic '*** X: failed to load.', and '-load' tolerates silently
(GNU instead treats the file as a remakeable makefile; we lean
tolerant since a plugin can never work in-box).

\# inside function args in a RECIPE (echo \#define via $(foreach ...))
was unescaped to # at parse time, so the shell saw a comment and the
rest of the line vanished. New ParseExprOpt::FuncCommand — selected
when function args are parsed inside a Command expression — parses
function syntax but keeps \\ and \# untouched for the shell, while
still collapsing backslash-newline argument continuations (measured
GNU behavior; multiline_arg.mk holds).

Corpus 403/410 fail=0 xfail=7 xpass=0.

---
diff --git a/src-rs/eval.rs b/src-rs/eval.rs
index c3b3334..0959f62 100644
--- a/src-rs/eval.rs
+++ b/src-rs/eval.rs
@@ -1185,6 +1185,37 @@ impl Evaluator {
         Ok(())
     }
 
+    // sarun: `load` / `-load` (GNU make C plugins). We never dlopen — a box
+    // must not pull host .so's into the engine — so `load` of a missing
+    // file reproduces GNU's two-line failure verbatim and `load` of an
+    // existing file fails with the generic second line. `-load` tolerates
+    // everything silently; GNU instead treats the file like a remakeable
+    // makefile (a missing -load .so with no rule still errors there) —
+    // we lean tolerant, since a plugin can never work in-box anyway.
+    pub fn eval_load(&mut self, stmt: &crate::stmt::LoadStmt) -> Result<()> {
+        self.loc = Some(stmt.loc());
+        self.in_rule = false;
+
+        let files = stmt.expr.eval_to_buf(self)?;
+        for tok in word_scanner(&files) {
+            // `load foo.so(init_symbol)` — the file part is before '('.
+            let name = tok.split(|&b| b == b'(').next().unwrap_or(tok);
+            if !stmt.should_exist {
+                continue;
+            }
+            let f = String::from_utf8_lossy(name);
+            let exists = self.working_dir.join(&*f).exists();
+            if !exists {
+                warn_loc!(
+                    self.loc.as_ref(),
+                    "{f}: cannot open shared object file: No such file or directory"
+                );
+            }
+            error_loc!(self.loc.as_ref(), "*** {f}: failed to load.");
+        }
+        Ok(())
+    }
+
     pub fn eval_include(&mut self, stmt: &IncludeStmt) -> Result<()> {
         self.loc = Some(stmt.loc());
         self.in_rule = false;
