CONFIG_ARM64=y
# The paired arm64 appliance must execute both LP64/AArch64 and ordinary
# EABI/AArch32 processes. TCG's `max` CPU supplies AArch32 EL0; a physical
# KVM host must advertise 32-bit EL0 or Sarun must retain TCG for this pair.
CONFIG_COMPAT=y
CONFIG_KUSER_HELPERS=y
CONFIG_COMPAT_VDSO=y
CONFIG_THUMB2_COMPAT_VDSO=y
CONFIG_COMPAT_ALIGNMENT_FIXUPS=y
CONFIG_PCI=y
CONFIG_PCI_HOST_GENERIC=y
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y
CONFIG_HVC_DRIVER=y
