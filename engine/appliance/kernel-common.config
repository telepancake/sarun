# Shared root filesystem and PID-1 substrate.  This is merged over tinyconfig;
# unspecified drivers stay absent.
CONFIG_64BIT=y
CONFIG_SMP=y
# Userspace ABI needed by ordinary build tools and async runtimes. Keep the
# appliance lean by omitting unrelated devices, not by returning ENOSYS for
# foundational Linux interfaces (curl, for example, needs eventfd for its
# asynchronous resolver).
CONFIG_MULTIUSER=y
CONFIG_FUTEX=y
CONFIG_POSIX_TIMERS=y
CONFIG_EPOLL=y
CONFIG_SIGNALFD=y
CONFIG_EVENTFD=y
CONFIG_ADVISE_SYSCALLS=y
CONFIG_RSEQ=y
CONFIG_MEMFD_CREATE=y
CONFIG_FILE_LOCKING=y
CONFIG_INOTIFY_USER=y
CONFIG_TTY=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_MENU=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_MMIO=y
CONFIG_FUSE_FS=y
CONFIG_VIRTIO_FS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_BINFMT_ELF=y
CONFIG_UNIX=y
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=n
CONFIG_INET_DIAG=n
CONFIG_ETHTOOL_NETLINK=n
CONFIG_NETDEVICES=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_NET=y
# Keep default-y device families from reappearing when PCI, networking, and
# multi-user semantics are enabled. The appliance has no emulated hardware for
# any of these; its console and network are the explicit virtio/serial drivers.
CONFIG_ETHERNET=n
CONFIG_VGA_ARB=n
CONFIG_INPUT=n
CONFIG_VT=n
CONFIG_HID=n
CONFIG_POWER_SUPPLY=n
CONFIG_PPS=n
CONFIG_PTP_1588_CLOCK=n
CONFIG_FW_LOADER=n
CONFIG_MODULES=n
CONFIG_BLK_DEV_INITRD=n
CONFIG_DEBUG_KERNEL=n
CONFIG_PRINTK=y
