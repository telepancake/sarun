# Shared root filesystem and PID-1 substrate.  This is merged over tinyconfig;
# unspecified drivers stay absent.
CONFIG_64BIT=y
CONFIG_SMP=y
CONFIG_PCI=y
CONFIG_TTY=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_MENU=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_MMIO=y
CONFIG_FUSE_FS=y
CONFIG_VIRTIO_FS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_BINFMT_ELF=y
CONFIG_UNIX=y
CONFIG_NET=y
CONFIG_INET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_HW_RANDOM_VIRTIO=y
CONFIG_MODULES=n
CONFIG_BLK_DEV_INITRD=n
CONFIG_DEBUG_KERNEL=n
