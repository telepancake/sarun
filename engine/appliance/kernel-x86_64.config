CONFIG_X86_64=y
# Execute conventional i386 ELF processes alongside x86-64. The x32 ABI is a
# different ABI and is deliberately not part of this requirement.
CONFIG_IA32_EMULATION=y
CONFIG_IA32_EMULATION_DEFAULT_DISABLED=n
CONFIG_PCI=n
CONFIG_VIRTIO_MMIO_CMDLINE_DEVICES=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_PCI=n
CONFIG_SERIAL_8250_EXAR=n
CONFIG_SERIAL_8250_LPSS=n
CONFIG_SERIAL_8250_MID=n
CONFIG_SERIAL_8250_PERICOM=n
CONFIG_EARLY_PRINTK=y
CONFIG_HVC_DRIVER=y
CONFIG_CPU_FREQ=n
CONFIG_SCHED_MC_PRIO=n
CONFIG_MEI=n
CONFIG_EEPROM_93CX6=n
