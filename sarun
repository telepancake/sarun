#  Session model + discovery + robust removal
# ════════════════════════════════════════════════════════════════════════════

def _is_overlay_marker(name: str) -> bool:
    """fuse-overlayfs / aufs opaque-directory and bookkeeping markers. These are
    internal to the overlay and are not user-visible changes, so we never list,
    apply, or count them."""
    return name == ".wh..opq" or name.startswith(".wh..wh.")

def ut_split(data: bytes) -> list:
    """Split bytes into lines on \\n, keeping the terminator on each line (the last
    line keeps whatever it had). b"".join(result) == data exactly, so splicing
    these line-pieces and writing the bytes back is lossless — CR/CRLF, encoding,
    BOM and a missing final newline are all preserved."""
    parts = data.split(b"\n")
    lines = [p + b"\n" for p in parts[:-1]]
    if parts[-1]:
        lines.append(parts[-1])
    return lines


# ════════════════════════════════════════════════════════════════════════════
#  Patch codec — a byte-exact unified diff (multi-file), XZ-compressed at rest.
#  The only metadata is the original command, kept NUL-separated in the file's
#  user.slopbox.cmd xattr (no JSON, no keyed fields).
# ════════════════════════════════════════════════════════════════════════════

def state_home() -> Path:
    base = os.environ.get("XDG_STATE_HOME") or os.path.expanduser("~/.local/state")
    return Path(base) / "slopbox"

def patch_path(session_id: str) -> Path:
    return state_home() / (session_id + ".patch.xz")

# A session's whole identity is its name: "YYYYmmdd-HHMMSS_PID". The timestamp
# (1-second resolution) and the runner's pid can't collide — a live pid is unique,
# and two runs in the same second have different runner pids — so we need nothing
# else. Start time, pid and a display label are all read back out of the name; the
# name is the slopbox dir suffix (slopbox.<name>) and the patch basename
# (<name>.patch.xz). Nothing else is stored but the command.
_SID_FMT = "%Y%m%d-%H%M%S"

def make_sid() -> str:
    return time.strftime(_SID_FMT) + "_" + str(os.getpid())

def parse_sid(sid: str) -> tuple:
    """(started_epoch, pid) from a "YYYYmmdd-HHMMSS_PID" name; zeros if malformed."""
    stamp, _, pids = sid.rpartition("_")
    try: started = time.mktime(time.strptime(stamp, _SID_FMT))
    except (ValueError, OverflowError): started = 0.0
    try: pid = int(pids)
    except ValueError: pid = 0
    return started, pid

CMD_XATTR = "user.slopbox.cmd"

def _cmd_pack(cmd: list) -> bytes:
    # argv joined by NUL, exactly like /proc/<pid>/cmdline — order preserved,
    # byte-exact, no quoting ambiguity, and not JSON.
    return b"\x00".join(c.encode("utf-8", "surrogateescape") for c in cmd)

def _cmd_unpack(data: bytes) -> list:
    if not data: return []
    return [p.decode("utf-8", "surrogateescape") for p in data.split(b"\x00")]

def set_cmd_xattr(path, cmd: list) -> None:
    try: os.setxattr(path, CMD_XATTR, _cmd_pack(cmd))
    except OSError: pass

def get_cmd_xattr(path) -> list:
    try: return _cmd_unpack(os.getxattr(path, CMD_XATTR))
    except OSError: return []

_NO_NL = b"\\ No newline at end of file\n"   # standard "no newline at EOF" marker

class PatchConflict(Exception):
    """A hunk's recorded context no longer matches the file it applies to."""

def _emit(out: list, prefix: bytes, line: bytes) -> None:
    # Each physical patch line ends in \n; a content line lacking its own newline
    # gets one (as terminator) plus the NO_NL marker, so parsing is unambiguous and
    # \r (CRLF) is preserved as content.
    if line.endswith(b"\n"):
        out.append(prefix + line)
    else:
        out.append(prefix + line + b"\n"); out.append(_NO_NL)

def make_patch(files: list) -> bytes:
    """files: list of dict(rel, lower, upper, created, deleted) with lower/upper as
    byte-line lists (from ut_split). Returns the unified-diff bytes."""
    import difflib
    out = []
    for f in files:
        a = b"/dev/null" if f["created"] else b"a/" + f["rel"].encode("utf-8","surrogateescape")
        b = b"/dev/null" if f["deleted"] else b"b/" + f["rel"].encode("utf-8","surrogateescape")
        out.append(b"--- " + a + b"\n"); out.append(b"+++ " + b + b"\n")
        ll, ul = f["lower"], f["upper"]
        for g in difflib.SequenceMatcher(None, ll, ul).get_grouped_opcodes(3):
            a1, a2, b1, b2 = g[0][1], g[-1][2], g[0][3], g[-1][4]
            out.append(f"@@ -{a1+1},{a2-a1} +{b1+1},{b2-b1} @@\n".encode())
            for tag, i1, i2, j1, j2 in g:
                if tag == "equal":
                    for ln in ll[i1:i2]: _emit(out, b" ", ln)
                else:
                    for ln in ll[i1:i2]: _emit(out, b"-", ln)
                    for ln in ul[j1:j2]: _emit(out, b"+", ln)
    return b"".join(out)

def parse_patch(data: bytes) -> dict:
    """Parse unified-diff bytes into an ordered {rel: filepatch} where filepatch is
    dict(rel, created, deleted, hunks=[dict(a1, b1, lines)]) and lines is the ordered
    [(op, byteline)] with op in ' '/'-'/'+'. Ordered lines let us re-serialize and
    edit hunks losslessly."""
    import re
    files = {}; cur = None; phys = ut_split(data); i = 0
    while i < len(phys):
        line = phys[i]; i += 1
        if line.startswith(b"--- "):
            aside = line[4:].rstrip(b"\n")
            bside = phys[i][4:].rstrip(b"\n") if i < len(phys) else b""; i += 1
            created = aside == b"/dev/null"; deleted = bside == b"/dev/null"
            relb = (aside if deleted else bside)[2:]   # strip "a/" or "b/"
            rel = relb.decode("utf-8","surrogateescape")
            cur = files[rel] = dict(rel=rel, created=created, deleted=deleted, hunks=[])
        elif line.startswith(b"@@") and cur is not None:
            m = re.search(rb"-(\d+)(?:,\d+)? \+(\d+)", line)
            cur["hunks"].append(dict(a1=int(m.group(1)) - 1,
                                     b1=int(m.group(2)) - 1, lines=[]))
        elif cur and cur["hunks"] and line[:1] in (b" ", b"-", b"+"):
            prefix = line[:1]; content = line[1:]
            if i < len(phys) and phys[i] == _NO_NL:
                i += 1; content = content[:-1]      # drop the terminator we added
            cur["hunks"][-1]["lines"].append((prefix.decode(), content))
    return files

def hunk_a_lines(h): return [bl for op, bl in h["lines"] if op != "+"]
def hunk_b_lines(h): return [bl for op, bl in h["lines"] if op != "-"]

def serialize_patch(files: dict) -> bytes:
    """Inverse of parse_patch: render an ordered {rel: filepatch} back to bytes."""
    out = []
    for fp in files.values():
        a = b"/dev/null" if fp["created"] else b"a/" + fp["rel"].encode("utf-8","surrogateescape")
        b = b"/dev/null" if fp["deleted"] else b"b/" + fp["rel"].encode("utf-8","surrogateescape")
        out.append(b"--- " + a + b"\n"); out.append(b"+++ " + b + b"\n")
        for h in fp["hunks"]:
            na, nb = len(hunk_a_lines(h)), len(hunk_b_lines(h))
            out.append(f"@@ -{h['a1']+1},{na} +{h['b1']+1},{nb} @@\n".encode())
            for op, line in h["lines"]:
                _emit(out, op.encode(), line)
    return b"".join(out)

def build_file_patch(rel, lower, upper, created, deleted) -> dict:
    """Parsed filepatch for one file from its lower/upper byte-line lists."""
    return parse_patch(make_patch([dict(rel=rel, lower=lower, upper=upper,
                                        created=created, deleted=deleted)]))[rel]

def apply_hunks(base_lines: list, hunks: list) -> list:
    """Apply hunks forward onto base_lines (a byte-line list). Each hunk's recorded
    context must match exactly at its position, else PatchConflict. Used for
    round-trip verification where the base is unchanged. Returns new byte-line list."""
    out = []; pos = 0
    for h in hunks:
        a1 = h["a1"]; al = hunk_a_lines(h)
        if base_lines[a1:a1 + len(al)] != al:
            raise PatchConflict(f"context mismatch at line {a1+1}")
        if a1 < pos:
            raise PatchConflict("overlapping hunks")
        out.extend(base_lines[pos:a1]); out.extend(hunk_b_lines(h)); pos = a1 + len(al)
    out.extend(base_lines[pos:])
    return out

def locate_hunk(base_lines: list, hunk: dict) -> "int | None":
    """patch(1)-style: find where a hunk's original side occurs in base_lines,
    preferring the recorded position then searching outward. None if not found. A
    pure-insert hunk (no original lines) goes at the recorded position (clamped)."""
    al = hunk_a_lines(hunk); a1 = hunk["a1"]; n = len(base_lines)
    if not al:
        return max(0, min(a1, n))
    if base_lines[a1:a1 + len(al)] == al:
        return a1
    for off in range(1, n + 1):
        for pos in (a1 - off, a1 + off):
            if 0 <= pos <= n - len(al) and base_lines[pos:pos + len(al)] == al:
                return pos
    return None

def apply_one_hunk(base_lines: list, hunk: dict) -> tuple:
    """Apply a single hunk with offset search. Returns (new_lines, offset) where
    offset is how far from the recorded position it landed (0 = exact). Raises
    PatchConflict if the context can't be found — caller leaves the file untouched."""
    pos = locate_hunk(base_lines, hunk)
    if pos is None:
        raise PatchConflict("hunk does not apply")
    al = hunk_a_lines(hunk)
    return base_lines[:pos] + hunk_b_lines(hunk) + base_lines[pos + len(al):], pos - hunk["a1"]

def write_patch_file(path: Path, data: bytes, cmd: list) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_bytes(lzma.compress(data, preset=6))
    set_cmd_xattr(tmp, cmd)            # NUL-separated argv, nothing else
    os.replace(tmp, path)

def read_patch_file(path: Path) -> bytes:
    return lzma.decompress(path.read_bytes())


# ════════════════════════════════════════════════════════════════════════════
#  SQLite Archive (sqlar) — everything a patch can't hold (binary files,
#  symlinks, deletions) lands here next to the patch as <sid>.sqlar, so once
#  consolidate() runs the /dev/shm overlay is empty and all unreviewed changes
#  live on disk under state_home. Standard sqlar schema; one extra convention:
#  a NULL blob with a char-device mode is a deletion tombstone (an overlay
#  whiteout). Blobs are zlib-deflated when that's smaller (len(data) != sz).
# ════════════════════════════════════════════════════════════════════════════

def sqlar_path(session_id: str) -> Path:
    return state_home() / (session_id + ".sqlar")

def _sqlar_open(path) -> "sqlite3.Connection":
    path = Path(path); path.parent.mkdir(parents=True, exist_ok=True)
    conn = sqlite3.connect(str(path))
    conn.execute("CREATE TABLE IF NOT EXISTS sqlar"
                 "(name TEXT PRIMARY KEY, mode INT, mtime INT, sz INT, data BLOB)")
    return conn

def _sqlar_put_file(conn, name, content: bytes, mode, mtime) -> None:
    comp = zlib.compress(content, 6)
    data, sz = (comp, len(content)) if len(comp) < len(content) else (content, len(content))
    conn.execute("INSERT OR REPLACE INTO sqlar VALUES(?,?,?,?,?)",
                 (name, int(mode), int(mtime), sz, sqlite3.Binary(data)))

def _sqlar_put_provenance(conn, name, prov: dict) -> None:
    """Record who wrote a change (spec §11) in a side `provenance` table — invisible
    to standard sqlar tooling, the headline capability fuse-overlayfs can't provide."""
    conn.execute("CREATE TABLE IF NOT EXISTS provenance"
                 "(path TEXT PRIMARY KEY, pid INT, ppid INT, exe TEXT, argv TEXT)")
    conn.execute("INSERT OR REPLACE INTO provenance VALUES(?,?,?,?,?)",
                 (name, int(prov.get("pid") or 0), int(prov.get("ppid") or 0),
                  prov.get("exe") or "", json.dumps(prov.get("argv") or [])))

def _sqlar_put_symlink(conn, name, target: bytes, mtime) -> None:
    conn.execute("INSERT OR REPLACE INTO sqlar VALUES(?,?,?,?,?)",
                 (name, stat_mod.S_IFLNK | 0o777, int(mtime), len(target),
                  sqlite3.Binary(target)))

def _sqlar_put_tombstone(conn, name) -> None:
    conn.execute("INSERT OR REPLACE INTO sqlar VALUES(?,?,?,?,?)",
                 (name, stat_mod.S_IFCHR, 0, 0, None))

def sqlar_list(path) -> list:
    """[(name, mode, mtime, sz)] sorted by name; [] if there is no archive."""
    path = Path(path)
    if not path.exists(): return []
    conn = _sqlar_open(path)
    try: return conn.execute("SELECT name,mode,mtime,sz FROM sqlar "
                             "ORDER BY name").fetchall()
    except sqlite3.Error: return []
    finally: conn.close()

def sqlar_mode(path, name) -> "int | None":
    path = Path(path)
    if not path.exists(): return None
    conn = _sqlar_open(path)
    try:
        row = conn.execute("SELECT mode FROM sqlar WHERE name=?", (name,)).fetchone()
    except sqlite3.Error: row = None
    finally: conn.close()
    return row[0] if row else None

def sqlar_content(path, name) -> "bytes | None":
    """Decompressed bytes for one entry (the symlink target for a symlink); None if
    missing or a tombstone."""
    path = Path(path)
    if not path.exists(): return None
    conn = _sqlar_open(path)
    try:
        row = conn.execute("SELECT sz,data FROM sqlar WHERE name=?", (name,)).fetchone()
    except sqlite3.Error: row = None
    finally: conn.close()
    if not row or row[1] is None: return None
    sz, data = row[0], bytes(row[1])
    return data if len(data) == sz else zlib.decompress(data)

def sqlar_remove(path, name) -> int:
    """Drop one entry; unlink the archive when it empties. Returns entries left."""
    path = Path(path)
    if not path.exists(): return 0
    conn = _sqlar_open(path)
    try:
        conn.execute("DELETE FROM sqlar WHERE name=?", (name,)); conn.commit()
        left = conn.execute("SELECT COUNT(*) FROM sqlar").fetchone()[0]
    except sqlite3.Error: left = 1
    finally: conn.close()
    if left == 0:
        try: path.unlink()
        except OSError: pass
    return left


# ════════════════════════════════════════════════════════════════════════════
#  Network log — every gated request/response for a session, written live by the
#  in-process mitmproxy to a sibling SQLite db <sid>.flows. No overlay involved,
#  so it goes straight to state_home. Same user.slopbox.cmd xattr as the others.
# ════════════════════════════════════════════════════════════════════════════

def flows_path(session_id: str) -> Path:
    return state_home() / (session_id + ".flows")

_FLOW_BODY_CAP = 1 << 20    # store at most 1 MiB of each body (but record true size)

def _flows_open(path) -> "sqlite3.Connection":
    path = Path(path); path.parent.mkdir(parents=True, exist_ok=True)
    conn = sqlite3.connect(str(path))
    conn.execute("PRAGMA busy_timeout=3000")
    conn.execute("CREATE TABLE IF NOT EXISTS flows("
                 "id INTEGER PRIMARY KEY AUTOINCREMENT, ts REAL, action TEXT,"
                 "method TEXT, scheme TEXT, host TEXT, port INT, url TEXT, status INT,"
                 "req_headers TEXT, req_len INT, req_body BLOB,"
                 "resp_headers TEXT, resp_len INT, resp_body BLOB)")
    return conn

def _hdr_text(items) -> str:
    out = []
    for k, v in (items or []):
        if isinstance(k, bytes): k = k.decode("latin-1", "replace")
        if isinstance(v, bytes): v = v.decode("latin-1", "replace")
        out.append(f"{k}: {v}")
    return "\n".join(out)

def flows_add(path, fl: dict) -> None:
    rb = fl.get("req_body") or b""; pb = fl.get("resp_body") or b""
    conn = _flows_open(path)
    try:
        conn.execute(
            "INSERT INTO flows(ts,action,method,scheme,host,port,url,status,"
            "req_headers,req_len,req_body,resp_headers,resp_len,resp_body)"
            " VALUES(?,?,?,?,?,?,?,?,?,?,?,?,?,?)",
            (fl.get("ts", time.time()), fl.get("action", ""), fl.get("method", ""),
             fl.get("scheme", ""), fl.get("host", ""), fl.get("port", 0),
             fl.get("url", ""), fl.get("status", 0),
             _hdr_text(fl.get("req_headers")), len(rb), sqlite3.Binary(rb[:_FLOW_BODY_CAP]),
             _hdr_text(fl.get("resp_headers")), len(pb), sqlite3.Binary(pb[:_FLOW_BODY_CAP])))
        conn.commit()
    finally:
        conn.close()

def flows_list(path) -> list:
    path = Path(path)
    if not path.exists(): return []
    conn = _flows_open(path); conn.row_factory = sqlite3.Row
    try:
        return [dict(r) for r in conn.execute(
            "SELECT id,ts,action,method,host,port,url,status,req_len,resp_len"
            " FROM flows ORDER BY id").fetchall()]
    except sqlite3.Error:
        return []
    finally:
        conn.close()

def flows_get(path, fid) -> "dict | None":
    path = Path(path)
    if not path.exists(): return None
    conn = _flows_open(path); conn.row_factory = sqlite3.Row
    try:
        r = conn.execute("SELECT * FROM flows WHERE id=?", (fid,)).fetchone()
        return dict(r) if r else None
    except sqlite3.Error:
        return None
    finally:
        conn.close()


# ════════════════════════════════════════════════════════════════════════════
#  Overlay engine — pyfuse3 copy-on-write overlay, multiplexed per session.
#
#  The UI owns ONE pyfuse3 mount (see OverlayMount). Its synthetic root lists one
#  subfolder <sid> per live session; <mnt>/<sid>/… is a merged overlay of
#  lower=/ + that session's upper (live/<sid>/up) with whiteouts/opacity tracked
#  in live/<sid>/index.db. Inode numbers span the whole mount; each inode carries
#  its (sid, rel) so one Operations object serves every box.
#
#  Implements OVERLAY-SPEC.md §3–§14. Sections 1–2 (userns/fd-passing/inner-mount)
#  are DELIBERATELY not implemented — this design has none of that: the mount is
#  made the ordinary way via fusermount3 and bwrap binds the subfolder as root.
# ════════════════════════════════════════════════════════════════════════════

# Selected env keys captured per writer (provenance), per spec §3.
_PROV_ENV_KEYS = ("USER", "PWD", "SSH_CONNECTION", "TERM", "_")

FICLONE = 0x40049409   # _IOW(0x94, 9, int) — btrfs/xfs reflink ioctl


def read_provenance(pid: int) -> dict:
    """Best-effort writer provenance from host /proc/<pid>. Read SYNCHRONOUSLY from
    the write handler while the caller is still blocked (and thus still in /proc).
    Every field is best-effort — a vanished pid yields zeros/empties, never raises
    (spec §3, §8: /proc reads are the one place best-effort OSError is acceptable)."""
    info = dict(pid=int(pid), ppid=0, exe="", argv=[], env={})
    base = f"/proc/{pid}"
    try:
        with open(f"{base}/cmdline", "rb") as f:
            raw = f.read()
        info["argv"] = [p.decode("utf-8", "surrogateescape")
                        for p in raw.split(b"\x00") if p]
    except OSError: pass
    try: info["exe"] = os.readlink(f"{base}/exe")
    except OSError: pass
    try:
        with open(f"{base}/stat", "rb") as f:
            st = f.read()
        # comm is parenthesized and may contain spaces/parens; split after the last ')'
        rp = st.rfind(b")")
        rest = st[rp + 2:].split() if rp >= 0 else []
        # fields after comm: state(0) ppid(1)
        if len(rest) >= 2: info["ppid"] = int(rest[1])
    except (OSError, ValueError): pass
    try:
        with open(f"{base}/environ", "rb") as f:
            env_raw = f.read()
        env = {}
        for kv in env_raw.split(b"\x00"):
            if b"=" not in kv: continue
            k, _, v = kv.partition(b"=")
            ks = k.decode("utf-8", "surrogateescape")
            if ks in _PROV_ENV_KEYS:
                env[ks] = v.decode("utf-8", "surrogateescape")
        info["env"] = env
    except OSError: pass
    return info


def policy_check(sid: str, prov: dict, path: str, op: str) -> str:
    """THE policy hook. Called once per mutating overlay op (create/write/unlink/
    rename/setattr/…) with the session id, the writer's provenance (pid/exe/argv),
    the overlay-relative path, and the operation name. Returns "allow" or "deny".

    For v1 this always allows (no behaviour change vs the old fuse-overlayfs path).
    It exists as the single, obvious seam where per-write policy — a file-rules
    check, or an interactive UI prompt exactly like the network-approval flow —
    would attach. It runs ON the trio serving thread while the writer is blocked,
    so a future prompt would hand off to the UI thread and await, just like
    Supervisor.approval_request does for connections."""
    return "allow"


def reflink_or_copy(src_fd: int, dst_fd: int) -> str:
    """Clone src into dst. Tries FICLONE (O(1) on btrfs/xfs/bcachefs); on any of the
    not-supported errnos falls back to copy_file_range, then to a 1 MiB read/write
    loop (always correct). Returns 'reflink' or 'copy'. Never silently no-ops — a
    failure to materialize content is a correctness bug (spec §6, R5)."""
    try:
        fcntl.ioctl(dst_fd, FICLONE, src_fd)
        return "reflink"
    except OSError as e:
        if e.errno not in (errno.ENOTSUP, errno.EOPNOTSUPP, errno.EXDEV,
                           errno.EINVAL, errno.EPERM):
            raise
    # plain copy
    os.lseek(src_fd, 0, os.SEEK_SET); os.lseek(dst_fd, 0, os.SEEK_SET)
    try:
        st = os.fstat(src_fd); remaining = st.st_size
        while remaining > 0:
            n = os.copy_file_range(src_fd, dst_fd, remaining)
            if n == 0: break
            remaining -= n
        if remaining == 0:
            os.lseek(dst_fd, 0, os.SEEK_SET); os.lseek(src_fd, 0, os.SEEK_SET)
            return "copy"
    except (OSError, AttributeError):
        pass
    os.lseek(src_fd, 0, os.SEEK_SET); os.lseek(dst_fd, 0, os.SEEK_SET)
    os.ftruncate(dst_fd, 0)
    while True:
        chunk = os.read(src_fd, 1 << 20)
        if not chunk: break
        off = 0
        while off < len(chunk):
            off += os.write(dst_fd, chunk[off:])
    os.lseek(dst_fd, 0, os.SEEK_SET); os.lseek(src_fd, 0, os.SEEK_SET)
    return "copy"


class Index:
    """Per-session overlay index (live/<sid>/index.db) + write-through RAM mirror.

    The hot read paths (lookup/getattr/readdir) touch ONLY the RAM mirror; SQLite is
    written on mutation and read only for provenance / consolidate. Created mode 0700
    (R8): it holds writer provenance. Opened check_same_thread=False — the serve loop
    owns the write connection; the UI thread reads it only after the loop stops
    (lifecycle-serialized; spec §11)."""

    def __init__(self, backing: Path):
        self.backing = Path(backing)
        self.db_path = self.backing / "index.db"
        # restrict before SQLite creates the file (R8)
        old = os.umask(0o077)
        try:
            self._db = sqlite3.connect(str(self.db_path), check_same_thread=False)
        finally:
            os.umask(old)
        try: os.chmod(self.db_path, 0o700)
        except OSError: pass
        self._db.execute("PRAGMA journal_mode=WAL")
        self._db.execute("PRAGMA synchronous=NORMAL")
        self._db.executescript(
            "CREATE TABLE IF NOT EXISTS writers("
            " id INTEGER PRIMARY KEY AUTOINCREMENT, pid INT, ppid INT,"
            " exe TEXT, argv TEXT, env TEXT, captured_at REAL);"
            "CREATE TABLE IF NOT EXISTS entries("
            " path TEXT PRIMARY KEY, kind TEXT, mode INT, mtime REAL,"
            " writer_id INT, first_seen REAL, opaque INT DEFAULT 0);"
            "CREATE TABLE IF NOT EXISTS oplog("
            " id INTEGER PRIMARY KEY AUTOINCREMENT, ts REAL, op TEXT, path TEXT,"
            " writer_id INT, detail TEXT);")
        self._db.commit()
        self._writer_cache: dict = {}     # host pid -> writers.id (this process only)
        self._whiteouts: set = set()
        self._kinds: dict = {}
        self._opaque: set = set()
        self._lock = threading.Lock()     # serialize SQLite + mirror mutations
        self._load_mirror()

    def _load_mirror(self) -> None:
        for path, kind, opaque in self._db.execute(
                "SELECT path, kind, opaque FROM entries"):
            if kind == "whiteout":
                self._whiteouts.add(path)
            else:
                self._kinds[path] = kind
            if opaque:
                self._opaque.add(path)

    # ── fast RAM accessors (hot path) ───────────────────────────────────────
    def has_overlay_state(self) -> bool:
        return bool(self._whiteouts or self._kinds or self._opaque)

    def kind_of(self, rel: str) -> "str | None":
        if rel in self._whiteouts: return "whiteout"
        return self._kinds.get(rel)

    def is_opaque(self, rel: str) -> bool:
        return rel in self._opaque

    def hidden_by_opaque(self, rel: str) -> bool:
        if not self._opaque: return False
        parts = rel.split("/") if rel else []
        for i in range(len(parts)):
            anc = "/".join(parts[:i])
            if anc in self._opaque: return True
        return False

    # ── provenance ──────────────────────────────────────────────────────────
    def writer_for(self, pid: int) -> int:
        """Provenance capture (spec §3). Synchronous; caller is blocked. The writer
        row is ALWAYS inserted, even if /proc/<pid> is gone (R5/R7)."""
        cached = self._writer_cache.get(pid)
        if cached is not None: return cached
        prov = read_provenance(pid)
        with self._lock:
            cur = self._db.execute(
                "INSERT INTO writers(pid,ppid,exe,argv,env,captured_at)"
                " VALUES(?,?,?,?,?,?)",
                (prov["pid"], prov["ppid"], prov["exe"],
                 json.dumps(prov["argv"]), json.dumps(prov["env"]), time.time()))
            self._db.commit()
            wid = cur.lastrowid
        self._writer_cache[pid] = wid
        return wid

    def provenance_of(self, pid: int) -> dict:
        return read_provenance(pid)

    # ── mutations (write-through) ───────────────────────────────────────────
    def set_entry(self, path, kind, mode, writer_id, op,
                  detail: str = "", opaque=None) -> None:
        now = time.time()
        with self._lock:
            row = self._db.execute(
                "SELECT path, opaque FROM entries WHERE path=?", (path,)).fetchone()
            if row is None:
                op_q = int(opaque) if opaque is not None else 0
                self._db.execute(
                    "INSERT INTO entries(path,kind,mode,mtime,writer_id,first_seen,opaque)"
                    " VALUES(?,?,?,?,?,?,?)",
                    (path, kind, int(mode), now, writer_id, now, op_q))
            else:
                if opaque is None:
                    self._db.execute(
                        "UPDATE entries SET kind=?, mode=?, mtime=? WHERE path=?",
                        (kind, int(mode), now, path))
                else:
                    self._db.execute(
                        "UPDATE entries SET kind=?, mode=?, mtime=?, opaque=? WHERE path=?",
                        (kind, int(mode), now, int(opaque), path))
            self._db.execute(
                "INSERT INTO oplog(ts,op,path,writer_id,detail) VALUES(?,?,?,?,?)",
                (now, op, path, writer_id, detail))
            self._db.commit()
        # RAM mirror
        if kind == "whiteout":
            self._whiteouts.add(path); self._kinds.pop(path, None)
        else:
            self._kinds[path] = kind; self._whiteouts.discard(path)
        if opaque is not None:
            if opaque: self._opaque.add(path)
            else: self._opaque.discard(path)

    def del_entry(self, path, op: str = "del", writer_id=None) -> None:
        now = time.time()
        with self._lock:
            self._db.execute("DELETE FROM entries WHERE path=?", (path,))
            self._db.execute(
                "INSERT INTO oplog(ts,op,path,writer_id,detail) VALUES(?,?,?,?,?)",
                (now, op, path, writer_id, ""))
            self._db.commit()
        self._whiteouts.discard(path); self._kinds.pop(path, None)
        self._opaque.discard(path)

    def prune_subtree(self, prefix: str) -> None:
        """Drop all rows under prefix + '/' (after an rmdir whose children were
        whiteouts/entries). Mirror updated to match."""
        pref = prefix + "/"
        with self._lock:
            self._db.execute("DELETE FROM entries WHERE path LIKE ?", (pref + "%",))
            self._db.commit()
        for s in (self._whiteouts, self._opaque):
            for p in [p for p in s if p.startswith(pref)]: s.discard(p)
        for p in [p for p in self._kinds if p.startswith(pref)]:
            self._kinds.pop(p, None)

    def reparent(self, old: str, new: str, writer_id) -> None:
        """Rewrite all descendant rows old/… → new/… (dir rename). Mirror rebuilt
        for the affected subtree."""
        oldp = old + "/"; newp = new + "/"
        with self._lock:
            rows = self._db.execute(
                "SELECT path, kind, mode, opaque FROM entries WHERE path LIKE ?",
                (oldp + "%",)).fetchall()
            for path, kind, mode, opaque in rows:
                np = newp + path[len(oldp):]
                self._db.execute("DELETE FROM entries WHERE path=?", (path,))
                self._db.execute(
                    "INSERT OR REPLACE INTO entries"
                    "(path,kind,mode,mtime,writer_id,first_seen,opaque)"
                    " VALUES(?,?,?,?,?,?,?)",
                    (np, kind, mode, time.time(), writer_id, time.time(), opaque))
            self._db.commit()
        for path, kind, mode, opaque in rows:
            np = newp + path[len(oldp):]
            self._whiteouts.discard(path); self._kinds.pop(path, None); self._opaque.discard(path)
            if kind == "whiteout": self._whiteouts.add(np)
            else: self._kinds[np] = kind
            if opaque: self._opaque.add(np)

    # ── consolidate accessors (spec §11) ────────────────────────────────────
    def deletions(self) -> list:
        return sorted(self._whiteouts)

    def opaque_dirs(self) -> list:
        return sorted(self._opaque)

    def writer_provenance(self, path: str) -> "dict | None":
        cur = self._db.execute(
            "SELECT writer_id FROM entries WHERE path=?", (path,)).fetchone()
        if not cur or cur[0] is None: return None
        w = self._db.execute(
            "SELECT pid,ppid,exe,argv FROM writers WHERE id=?", (cur[0],)).fetchone()
        if not w: return None
        try: argv = json.loads(w[3]) if w[3] else []
        except (ValueError, TypeError): argv = []
        return dict(pid=w[0], ppid=w[1], exe=w[2], argv=argv)

    def close(self) -> None:
        try: self._db.close()
        except sqlite3.Error: pass


def _build_overlay_ops():
    """Build the MultiplexOverlayFs class. Imports pyfuse3 lazily so that importing
    this module (e.g. the --inner forwarder, or offline tests) does not require
    pyfuse3/trio. Returns the class."""
    import pyfuse3

    ATTR_TIMEOUT = 300.0
    ENTRY_TIMEOUT = 300.0
    NEG_TIMEOUT = 5.0

    class MultiplexOverlayFs(pyfuse3.Operations):
        """One pyfuse3 Operations object serving every box. The synthetic root ('')
        lists one child per live <sid>; below that, <sid>/<rel> is the per-session
        overlay (lower=/, upper=live/<sid>/up, index=live/<sid>/index.db).

        Inodes span the whole mount: ROOT_INODE is the synthetic root, and every
        other inode maps to a key "<sid>/<rel>" (rel may be empty for a session
        root). Sessions are added/removed by the OverlayMount as boxes come and go."""

        enable_writeback_cache = False

        def __init__(self, lower: str, on_event=None):
            super().__init__()
            self.lower_root = lower.rstrip("/") or "/"
            self.squash_uid = os.getuid()
            self.squash_gid = os.getgid()
            self.on_event = on_event or (lambda **ev: None)
            # session registry: sid -> dict(up=Path, index=Index, virtual={rel:bytes})
            self.sessions: dict = {}
            # inode maps. key for a path inside a session is (sid, rel).
            self._ino_to_key: dict = {pyfuse3.ROOT_INODE: None}   # None = synth root
            self._key_to_ino: dict = {}
            self._next_ino = pyfuse3.ROOT_INODE + 1
            self._lookup_count: dict = {}
            self._fd_table: dict = {}     # fh -> open fd (regular files)
            self._vfh: dict = {}          # fh -> (sid, rel, bytes) for virtual reads
            self._dir_snaps: dict = {}    # dh -> sorted [(name, key_or_None, attrs)]
            self._next_fh = 1
            # watchdog (spec §9): written only by this (single) trio thread
            self._req_started = None
            self._req_label = ""
            self._req_seq = 0
            self._lock = threading.Lock()   # guards inode/fh allocation vs UI thread

        # ── session registry ────────────────────────────────────────────────
        def add_session(self, sid: str, up: Path, index: "Index") -> None:
            with self._lock:
                self.sessions[sid] = dict(up=Path(up), index=index, virtual={})

        def remove_session(self, sid: str) -> None:
            with self._lock:
                self.sessions.pop(sid, None)
                dead = [ino for ino, key in self._ino_to_key.items()
                        if key and key[0] == sid]
                for ino in dead:
                    self._ino_to_key.pop(ino, None)
                    self._lookup_count.pop(ino, None)
                self._key_to_ino = {k: i for k, i in self._key_to_ino.items()
                                    if k[0] != sid}

        def add_virtual(self, sid: str, rel: str, content: bytes) -> None:
            s = self.sessions.get(sid)
            if s is not None: s["virtual"][rel.lstrip("/")] = content

        # ── inode bookkeeping ───────────────────────────────────────────────
        def _ino_for(self, sid: str, rel: str) -> int:
            key = (sid, rel)
            with self._lock:
                ino = self._key_to_ino.get(key)
                if ino is None:
                    ino = self._next_ino; self._next_ino += 1
                    self._key_to_ino[key] = ino
                    self._ino_to_key[ino] = key
                return ino

        def _key(self, inode: int):
            return self._ino_to_key.get(inode)

        # ── path helpers ─────────────────────────────────────────────────────
        def _lower_path(self, rel: str) -> str:
            return os.path.join(self.lower_root, rel) if rel else self.lower_root

        def _upper_path(self, sid: str, rel: str) -> str:
            up = self.sessions[sid]["up"]
            return str(up / rel) if rel else str(up)

        def _index(self, sid: str) -> "Index":
            return self.sessions[sid]["index"]

        # ── layer resolution (spec §4) ───────────────────────────────────────
        def _resolve_st(self, sid: str, rel: str):
            idx = self._index(sid)
            if not idx.has_overlay_state():
                try: return ("lower", self._lower_path(rel), os.lstat(self._lower_path(rel)))
                except OSError: return ("absent", None, None)
            k = idx.kind_of(rel)
            if k == "whiteout":
                return ("whiteout", None, None)
            if k is not None:
                up = self._upper_path(sid, rel)
                try: return ("upper", up, os.lstat(up))
                except OSError: pass
            if idx.hidden_by_opaque(rel):
                return ("absent", None, None)
            try: return ("lower", self._lower_path(rel), os.lstat(self._lower_path(rel)))
            except OSError: return ("absent", None, None)

        def _resolve(self, sid: str, rel: str) -> str:
            return self._resolve_st(sid, rel)[0]

        def _is_virtual(self, sid: str, rel: str) -> bool:
            s = self.sessions.get(sid)
            if not s: return False
            return rel in s["virtual"] and self._index(sid).kind_of(rel) is None

        # ── attr construction ────────────────────────────────────────────────
        def _entry(self, ino: int, st) -> "pyfuse3.EntryAttributes":
            a = pyfuse3.EntryAttributes()
            a.st_ino = ino
            a.st_mode = st.st_mode
            a.st_nlink = st.st_nlink
            a.st_uid = self.squash_uid
            a.st_gid = self.squash_gid
            a.st_rdev = getattr(st, "st_rdev", 0)
            a.st_size = st.st_size
            a.st_blksize = 512
            a.st_blocks = (st.st_size + 511) // 512
            a.st_atime_ns = int(getattr(st, "st_atime", 0) * 1e9)
            a.st_mtime_ns = int(getattr(st, "st_mtime", 0) * 1e9)
            a.st_ctime_ns = int(getattr(st, "st_ctime", 0) * 1e9)
            a.attr_timeout = ATTR_TIMEOUT
            a.entry_timeout = ENTRY_TIMEOUT
            return a

        def _synth_dir_attrs(self, ino: int) -> "pyfuse3.EntryAttributes":
            a = pyfuse3.EntryAttributes()
            a.st_ino = ino
            a.st_mode = stat_mod.S_IFDIR | 0o755
            a.st_nlink = 2
            a.st_uid = self.squash_uid
            a.st_gid = self.squash_gid
            a.st_size = 0
            a.st_blksize = 512
            a.st_blocks = 0
            now = int(time.time() * 1e9)
            a.st_atime_ns = a.st_mtime_ns = a.st_ctime_ns = now
            a.attr_timeout = ATTR_TIMEOUT
            a.entry_timeout = ENTRY_TIMEOUT
            return a

        def _virtual_attrs(self, sid: str, rel: str, ino: int) -> "pyfuse3.EntryAttributes":
            content = self.sessions[sid]["virtual"][rel]
            a = pyfuse3.EntryAttributes()
            a.st_ino = ino
            a.st_mode = stat_mod.S_IFREG | 0o644
            a.st_nlink = 1
            a.st_uid = self.squash_uid
            a.st_gid = self.squash_gid
            a.st_size = len(content)
            a.st_blksize = 512
            a.st_blocks = (len(content) + 511) // 512
            try: lst = os.lstat(self._lower_path(rel)); ts = int(lst.st_mtime * 1e9)
            except OSError: ts = int(time.time() * 1e9)
            a.st_atime_ns = a.st_mtime_ns = a.st_ctime_ns = ts
            a.attr_timeout = ATTR_TIMEOUT
            a.entry_timeout = ENTRY_TIMEOUT
            return a

        def _neg_entry(self) -> "pyfuse3.EntryAttributes":
            a = pyfuse3.EntryAttributes()
            a.st_ino = 0
            a.entry_timeout = NEG_TIMEOUT
            a.attr_timeout = NEG_TIMEOUT
            return a

        # ── watchdog (spec §9) ───────────────────────────────────────────────
        def _req_enter(self, label: str) -> None:
            self._req_started = time.monotonic(); self._req_label = label
            self._req_seq += 1

        def _req_exit(self) -> None:
            self._req_started = None

        def inflight_age(self):
            t = self._req_started
            return (time.monotonic() - t) if t is not None else None

        # ── child-path utility for synthetic root vs session paths ───────────
        def _child_key(self, parent_key, name: str):
            """Return (sid, rel) for a child `name` under parent_key (None = synth
            root, where children are session ids)."""
            if parent_key is None:
                return (name, "")                      # a session root
            sid, rel = parent_key
            child = (rel + "/" + name) if rel else name
            return (sid, child)

        def _parent_key(self, parent_key):
            if parent_key is None: return None
            sid, rel = parent_key
            if not rel: return None                    # session root's parent = synth
            up = rel.rsplit("/", 1)[0] if "/" in rel else ""
            return (sid, up)

        # ── FUSE: lookup ─────────────────────────────────────────────────────
        async def lookup(self, parent_inode, name, ctx=None):
            name = os.fsdecode(name)
            pkey = self._key(parent_inode)
            if name == ".":
                ckey = pkey
            elif name == "..":
                ckey = self._parent_key(pkey)
            else:
                ckey = self._child_key(pkey, name)
            if ckey is None:                            # synth root itself
                return self._synth_dir_attrs(pyfuse3.ROOT_INODE)
            sid, rel = ckey
            if pkey is None:                            # child of synth root = a session
                if sid not in self.sessions:
                    return self._neg_entry()
                ino = self._ino_for(sid, "")
                self._lookup_count[ino] = self._lookup_count.get(ino, 0) + 1
                return self._synth_dir_attrs(ino)
            if sid not in self.sessions:
                return self._neg_entry()
            if self._is_virtual(sid, rel):
                ino = self._ino_for(sid, rel)
                self._lookup_count[ino] = self._lookup_count.get(ino, 0) + 1
                return self._virtual_attrs(sid, rel, ino)
            layer, _ap, st = self._resolve_st(sid, rel)
            if layer in ("absent", "whiteout"):
                return self._neg_entry()
            ino = self._ino_for(sid, rel)
            self._lookup_count[ino] = self._lookup_count.get(ino, 0) + 1
            return self._entry(ino, st)

        async def getattr(self, inode, ctx=None):
            key = self._key(inode)
            if key is None:
                return self._synth_dir_attrs(pyfuse3.ROOT_INODE)
            sid, rel = key
            if sid not in self.sessions:
                raise pyfuse3.FUSEError(errno.ENOENT)
            if not rel:                                 # a session root
                return self._synth_dir_attrs(inode)
            if self._is_virtual(sid, rel):
                return self._virtual_attrs(sid, rel, inode)
            layer, _ap, st = self._resolve_st(sid, rel)
            if layer in ("absent", "whiteout"):
                raise pyfuse3.FUSEError(errno.ENOENT)
            return self._entry(inode, st)

        async def forget(self, inode_list):
            for inode, nlookup in inode_list:
                c = self._lookup_count.get(inode, 0) - nlookup
                if c <= 0:
                    self._lookup_count.pop(inode, None)
                else:
                    self._lookup_count[inode] = c

        async def setxattr(self, inode, name, value, ctx):
            raise pyfuse3.FUSEError(errno.ENOSYS)

        async def getxattr(self, inode, name, ctx):
            raise pyfuse3.FUSEError(pyfuse3.ENOATTR)

        # ── readdir ──────────────────────────────────────────────────────────
        def _scan_dir(self, sid: str, rel: str) -> list:
            """Merged listing of <sid>/<rel>: [(name, (sid, childrel) or None, attrs)].
            None key marks a virtual/synthetic-only entry where attrs are supplied."""
            idx = self._index(sid)
            names: dict = {}     # name -> (abspath_or_None, layer)
            if not idx.is_opaque(rel):
                try:
                    with os.scandir(self._lower_path(rel)) as it:
                        for de in it:
                            names[de.name] = "lower"
                except OSError: pass
            if idx.has_overlay_state():
                try:
                    with os.scandir(self._upper_path(sid, rel)) as it:
                        for de in it:
                            names[de.name] = "upper"
                except OSError: pass
                # apply index children: whiteouts remove, others ensure present
                prefix = (rel + "/") if rel else ""
                for wp in list(idx._whiteouts):
                    if wp.startswith(prefix) and "/" not in wp[len(prefix):]:
                        names.pop(wp[len(prefix):], None)
                for kp in list(idx._kinds):
                    if kp.startswith(prefix) and kp != rel and "/" not in kp[len(prefix):]:
                        names.setdefault(kp[len(prefix):], "upper")
            # virtual files in this dir
            for vp in self.sessions[sid]["virtual"]:
                pfx = (rel + "/") if rel else ""
                if vp.startswith(pfx) and "/" not in vp[len(pfx):]:
                    names.setdefault(vp[len(pfx):], "virtual")
            out = []
            for name in sorted(names):
                childrel = (rel + "/" + name) if rel else name
                if self._is_virtual(sid, childrel):
                    ino = self._ino_for(sid, childrel)
                    out.append((name, (sid, childrel),
                                self._virtual_attrs(sid, childrel, ino)))
                    continue
                layer, _ap, st = self._resolve_st(sid, childrel)
                if layer in ("absent", "whiteout"): continue
                ino = self._ino_for(sid, childrel)
                out.append((name, (sid, childrel), self._entry(ino, st)))
            return out

        async def opendir(self, inode, ctx):
            with self._lock:
                dh = self._next_fh; self._next_fh += 1
            self._dir_snaps[dh] = None
            self._dir_snaps[(dh, "inode")] = inode
            return dh

        async def readdir(self, fh, start_id, token):
            snap = self._dir_snaps.get(fh)
            if snap is None:
                inode = self._dir_snaps.get((fh, "inode"))
                key = self._key(inode)
                if key is None:
                    # synthetic root: list live sessions
                    snap = []
                    for sid in sorted(self.sessions):
                        ino = self._ino_for(sid, "")
                        snap.append((sid, self._synth_dir_attrs(ino)))
                else:
                    sid, rel = key
                    if sid in self.sessions:
                        snap = [(name, attrs)
                                for name, _k, attrs in self._scan_dir(sid, rel)]
                    else:
                        snap = []
                self._dir_snaps[fh] = snap
            for i in range(start_id, len(snap)):
                name, attrs = snap[i]
                if not pyfuse3.readdir_reply(
                        token, os.fsencode(name), attrs, i + 1):
                    break

        async def releasedir(self, fh):
            self._dir_snaps.pop(fh, None)
            self._dir_snaps.pop((fh, "inode"), None)

        async def readlink(self, inode, ctx):
            key = self._key(inode)
            if key is None: raise pyfuse3.FUSEError(errno.EINVAL)
            sid, rel = key
            layer, ap, _st = self._resolve_st(sid, rel)
            if layer in ("absent", "whiteout"): raise pyfuse3.FUSEError(errno.ENOENT)
            try: return os.fsencode(os.readlink(ap))
            except OSError as e: raise pyfuse3.FUSEError(e.errno or errno.EIO)

        # ── parent-dir materialization ───────────────────────────────────────
        def _ensure_parent_dirs(self, sid: str, rel: str, wid) -> None:
            """Materialize the chain of parent dirs of rel into the upper. Each level
            is a single mkdir; opacity is recorded if it shadows a lower dir."""
            parent = rel.rsplit("/", 1)[0] if "/" in rel else ""
            if not parent: return
            idx = self._index(sid)
            parts = parent.split("/")
            cur = ""
            for p in parts:
                cur = (cur + "/" + p) if cur else p
                upath = self._upper_path(sid, cur)
                if os.path.isdir(upath):
                    continue
                self._ensure_parent_dirs(sid, cur, wid)
                try:
                    os.mkdir(upath, 0o755)
                except FileExistsError:
                    pass
                except OSError as e:
                    raise pyfuse3.FUSEError(e.errno or errno.EIO)
                opaque = 0
                try:
                    if stat_mod.S_ISDIR(os.lstat(self._lower_path(cur)).st_mode):
                        # a real lower dir still showing through -> not opaque
                        opaque = 0
                except OSError:
                    pass
                idx.set_entry(cur, "dir", stat_mod.S_IFDIR | 0o755, wid,
                              "mkdir_parent", opaque=opaque)

        # ── copy-up (spec §5/§6) ─────────────────────────────────────────────
        def _ensure_copyup(self, sid: str, rel: str, flags: int, ctx) -> int:
            """Materialize a lower (or absent) file into the upper; return an O_RDWR
            fd on it. Fail-closed: any copy error propagates (R5)."""
            wid = self._index(sid).writer_for(ctx.pid)
            self._ensure_parent_dirs(sid, rel, wid)
            upath = self._upper_path(sid, rel)
            if os.path.lexists(upath):
                # O_NOFOLLOW: if the upper artifact is itself a symlink (planted by
                # the sandbox to point at a host file), this raises ELOOP rather than
                # opening the target — fail closed, never dereference (R1/§8).
                try:
                    return os.open(upath, os.O_RDWR | os.O_NOFOLLOW)
                except OSError as e:
                    raise pyfuse3.FUSEError(e.errno or errno.EIO)
            layer, ap, st = self._resolve_st(sid, rel)
            idx = self._index(sid)
            if layer == "lower":
                mode = stat_mod.S_IMODE(st.st_mode)
                src = os.open(ap, os.O_RDONLY)
                try:
                    dst = os.open(upath, os.O_RDWR | os.O_CREAT | os.O_NOFOLLOW, mode)
                    try:
                        method = reflink_or_copy(src, dst)
                    except OSError as e:
                        os.close(dst)
                        try: os.unlink(upath)
                        except OSError: pass
                        raise pyfuse3.FUSEError(e.errno or errno.EIO)
                finally:
                    os.close(src)
                idx.set_entry(rel, "file", st.st_mode, wid, "copyup", detail=method)
                return dst
            else:
                # absent (or whiteout cleared) -> brand new upper file
                fd = os.open(upath, os.O_RDWR | os.O_CREAT | os.O_NOFOLLOW, 0o644)
                idx.set_entry(rel, "file", stat_mod.S_IFREG | 0o644, wid, "create")
                return fd

        # ── open / read / write / release ───────────────────────────────────
        async def open(self, inode, flags, ctx):
            key = self._key(inode)
            if key is None: raise pyfuse3.FUSEError(errno.EISDIR)
            sid, rel = key
            writable = (flags & (os.O_WRONLY | os.O_RDWR)) != 0
            if self._is_virtual(sid, rel) and not writable:
                content = self.sessions[sid]["virtual"][rel]
                with self._lock:
                    fh = self._next_fh; self._next_fh += 1
                self._vfh[fh] = (sid, rel, content)
                return pyfuse3.FileInfo(fh=fh, direct_io=False, keep_cache=False)
            self._req_enter(f"open {sid}/{rel}")
            try:
                if not writable:
                    layer, ap, _st = self._resolve_st(sid, rel)
                    if layer in ("absent", "whiteout"):
                        raise pyfuse3.FUSEError(errno.ENOENT)
                    try:
                        fd = os.open(ap, os.O_RDONLY)
                    except OSError as e:
                        raise pyfuse3.FUSEError(e.errno or errno.EIO)
                else:
                    if policy_check(sid, self._index(sid).provenance_of(ctx.pid),
                                    rel, "open_write") == "deny":
                        raise pyfuse3.FUSEError(errno.EACCES)
                    fd = self._ensure_copyup(sid, rel, flags, ctx)
                    self._notify(sid)
                with self._lock:
                    fh = self._next_fh; self._next_fh += 1
                self._fd_table[fh] = fd
                return pyfuse3.FileInfo(fh=fh, direct_io=False, keep_cache=False)
            finally:
                self._req_exit()

        async def read(self, fh, off, size):
            if fh in self._vfh:
                _sid, _rel, content = self._vfh[fh]
                return content[off:off + size]
            fd = self._fd_table.get(fh)
            if fd is None: raise pyfuse3.FUSEError(errno.EBADF)
            self._req_enter("read")
            try:
                return os.pread(fd, size, off)
            except OSError as e:
                raise pyfuse3.FUSEError(e.errno or errno.EIO)
            finally:
                self._req_exit()

        async def write(self, fh, off, buf):
            fd = self._fd_table.get(fh)
            if fd is None: raise pyfuse3.FUSEError(errno.EBADF)
            self._req_enter("write")
            try:
                return os.pwrite(fd, buf, off)
            except OSError as e:
                raise pyfuse3.FUSEError(e.errno or errno.EIO)
            finally:
                self._req_exit()

        async def fsync(self, fh, datasync):
            fd = self._fd_table.get(fh)
            if fd is None: return
            try:
                if datasync: os.fdatasync(fd)
                else: os.fsync(fd)
            except OSError as e:
                raise pyfuse3.FUSEError(e.errno or errno.EIO)

        async def flush(self, fh):
            return

        async def release(self, fh):
            if fh in self._vfh:
                self._vfh.pop(fh, None); return
            fd = self._fd_table.pop(fh, None)
            if fd is not None:
                try: os.close(fd)
                except OSError: pass

        # ── create / mkdir / symlink ─────────────────────────────────────────
        async def create(self, parent_inode, name, mode, flags, ctx):
            name = os.fsdecode(name)
            pkey = self._key(parent_inode)
            if pkey is None: raise pyfuse3.FUSEError(errno.EACCES)
            sid, _rel = self._child_key(pkey, name)
            rel = self._child_key(pkey, name)[1]
            if sid not in self.sessions: raise pyfuse3.FUSEError(errno.ENOENT)
            wid = self._index(sid).writer_for(ctx.pid)
            if policy_check(sid, self._index(sid).provenance_of(ctx.pid),
                            rel, "create") == "deny":
                raise pyfuse3.FUSEError(errno.EACCES)
            self._req_enter(f"create {sid}/{rel}")
            try:
                self._ensure_parent_dirs(sid, rel, wid)
                upath = self._upper_path(sid, rel)
                try:
                    fd = os.open(upath, flags | os.O_CREAT | os.O_NOFOLLOW,
                                 mode & 0o7777)
                except OSError as e:
                    raise pyfuse3.FUSEError(e.errno or errno.EIO)
                idx = self._index(sid)
                if idx.kind_of(rel) == "whiteout":
                    idx.del_entry(rel)
                idx.set_entry(rel, "file", stat_mod.S_IFREG | (mode & 0o7777),
                              wid, "create")
                st = os.fstat(fd)
                ino = self._ino_for(sid, rel)
                self._lookup_count[ino] = self._lookup_count.get(ino, 0) + 1
                with self._lock:
                    nfh = self._next_fh; self._next_fh += 1
                self._fd_table[nfh] = fd
                self._notify(sid)
                return (pyfuse3.FileInfo(fh=nfh, direct_io=False, keep_cache=False),
                        self._entry(ino, st))
            finally:
                self._req_exit()

        async def mkdir(self, parent_inode, name, mode, ctx):
            name = os.fsdecode(name)
            pkey = self._key(parent_inode)
            if pkey is None: raise pyfuse3.FUSEError(errno.EACCES)
            sid, rel = self._child_key(pkey, name)
            if sid not in self.sessions: raise pyfuse3.FUSEError(errno.ENOENT)
            wid = self._index(sid).writer_for(ctx.pid)
            if policy_check(sid, self._index(sid).provenance_of(ctx.pid),
                            rel, "mkdir") == "deny":
                raise pyfuse3.FUSEError(errno.EACCES)
            self._ensure_parent_dirs(sid, rel, wid)
            upath = self._upper_path(sid, rel)
            try:
                os.mkdir(upath, mode & 0o7777)
            except OSError as e:
                raise pyfuse3.FUSEError(e.errno or errno.EIO)
            idx = self._index(sid)
            if idx.kind_of(rel) == "whiteout":
                idx.del_entry(rel)
            opaque = 0
            try:
                if stat_mod.S_ISDIR(os.lstat(self._lower_path(rel)).st_mode):
                    opaque = 1            # rm-rf'd then recreated over a lower dir
            except OSError:
                opaque = 0
            idx.set_entry(rel, "dir", stat_mod.S_IFDIR | (mode & 0o7777), wid,
                          "mkdir", opaque=opaque)
            ino = self._ino_for(sid, rel)
            self._lookup_count[ino] = self._lookup_count.get(ino, 0) + 1
            st = os.lstat(upath)
            self._notify(sid)
            return self._entry(ino, st)

        async def symlink(self, parent_inode, name, target, ctx):
            name = os.fsdecode(name); target = os.fsdecode(target)
            pkey = self._key(parent_inode)
            if pkey is None: raise pyfuse3.FUSEError(errno.EACCES)
            sid, rel = self._child_key(pkey, name)
            if sid not in self.sessions: raise pyfuse3.FUSEError(errno.ENOENT)
            wid = self._index(sid).writer_for(ctx.pid)
            if policy_check(sid, self._index(sid).provenance_of(ctx.pid),
                            rel, "symlink") == "deny":
                raise pyfuse3.FUSEError(errno.EACCES)
            self._ensure_parent_dirs(sid, rel, wid)
            upath = self._upper_path(sid, rel)
            # remove a stale upper artifact (no-follow safe: unlink/rmtree by lstat)
            try:
                lst = os.lstat(upath)
                if stat_mod.S_ISDIR(lst.st_mode): shutil.rmtree(upath)
                else: os.unlink(upath)
            except FileNotFoundError:
                pass
            except OSError as e:
                raise pyfuse3.FUSEError(e.errno or errno.EIO)
            try:
                os.symlink(target, upath)
            except OSError as e:
                raise pyfuse3.FUSEError(e.errno or errno.EIO)
            idx = self._index(sid)
            if idx.kind_of(rel) == "whiteout":
                idx.del_entry(rel)
            idx.set_entry(rel, "symlink", stat_mod.S_IFLNK | 0o777, wid, "symlink")
            ino = self._ino_for(sid, rel)
            self._lookup_count[ino] = self._lookup_count.get(ino, 0) + 1
            st = os.lstat(upath)
            self._notify(sid)
            return self._entry(ino, st)

        # ── unlink / rmdir ───────────────────────────────────────────────────
        def _merged_children(self, sid: str, rel: str) -> list:
            return [n for n, _k, _a in self._scan_dir(sid, rel)]

        async def unlink(self, parent_inode, name, ctx):
            name = os.fsdecode(name)
            pkey = self._key(parent_inode)
            if pkey is None: raise pyfuse3.FUSEError(errno.EACCES)
            sid, rel = self._child_key(pkey, name)
            if sid not in self.sessions: raise pyfuse3.FUSEError(errno.ENOENT)
            wid = self._index(sid).writer_for(ctx.pid)
            if policy_check(sid, self._index(sid).provenance_of(ctx.pid),
                            rel, "unlink") == "deny":
                raise pyfuse3.FUSEError(errno.EACCES)
            idx = self._index(sid)
            upath = self._upper_path(sid, rel)
            if os.path.lexists(upath):
                try: os.unlink(upath)
                except OSError as e: raise pyfuse3.FUSEError(e.errno or errno.EIO)
            lower_exists = False
            if not idx.hidden_by_opaque(rel):
                try: lower_exists = os.path.lexists(self._lower_path(rel))
                except OSError: lower_exists = False
            if lower_exists:
                idx.set_entry(rel, "whiteout", 0, wid, "unlink")
            else:
                idx.del_entry(rel, op="unlink", writer_id=wid)
            self._notify(sid)

        async def rmdir(self, parent_inode, name, ctx):
            name = os.fsdecode(name)
            pkey = self._key(parent_inode)
            if pkey is None: raise pyfuse3.FUSEError(errno.EACCES)
            sid, rel = self._child_key(pkey, name)
            if sid not in self.sessions: raise pyfuse3.FUSEError(errno.ENOENT)
            wid = self._index(sid).writer_for(ctx.pid)
            if policy_check(sid, self._index(sid).provenance_of(ctx.pid),
                            rel, "rmdir") == "deny":
                raise pyfuse3.FUSEError(errno.EACCES)
            if self._merged_children(sid, rel):
                raise pyfuse3.FUSEError(errno.ENOTEMPTY)
            idx = self._index(sid)
            upath = self._upper_path(sid, rel)
            if os.path.isdir(upath) and not os.path.islink(upath):
                try: os.rmdir(upath)
                except OSError as e: raise pyfuse3.FUSEError(e.errno or errno.EIO)
            idx.prune_subtree(rel)
            lower_is_dir = False
            if not idx.hidden_by_opaque(rel):
                try:
                    lower_is_dir = stat_mod.S_ISDIR(
                        os.lstat(self._lower_path(rel)).st_mode)
                except OSError: lower_is_dir = False
            if lower_is_dir:
                idx.set_entry(rel, "whiteout", 0, wid, "rmdir")
            else:
                idx.del_entry(rel, op="rmdir", writer_id=wid)
            self._notify(sid)

        # ── setattr ──────────────────────────────────────────────────────────
        async def setattr(self, inode, attr, fields, fh, ctx):
            key = self._key(inode)
            if key is None: raise pyfuse3.FUSEError(errno.EPERM)
            sid, rel = key
            if sid not in self.sessions: raise pyfuse3.FUSEError(errno.ENOENT)
            if policy_check(sid, self._index(sid).provenance_of(ctx.pid),
                            rel, "setattr") == "deny":
                raise pyfuse3.FUSEError(errno.EACCES)
            idx = self._index(sid)
            self._req_enter(f"setattr {sid}/{rel}")
            try:
                layer = self._resolve(sid, rel)
                if layer in ("absent", "whiteout"):
                    raise pyfuse3.FUSEError(errno.ENOENT)
                if layer == "lower":
                    fd = self._ensure_copyup(sid, rel, os.O_RDWR, ctx)
                    os.close(fd)
                upath = self._upper_path(sid, rel)
                wid = idx.writer_for(ctx.pid)
                is_link = stat_mod.S_ISLNK(os.lstat(upath).st_mode)
                try:
                    # size/mode operate on file content/inode: open ONE O_NOFOLLOW fd
                    # and use fchmod/ftruncate (R3/R4). O_NOFOLLOW makes the open of a
                    # symlink upper-artifact raise ELOOP → we never touch its target.
                    if (fields.update_size or fields.update_mode) and not is_link:
                        fd = os.open(upath, os.O_RDWR | os.O_NOFOLLOW)
                        try:
                            if fields.update_size: os.ftruncate(fd, attr.st_size)
                            if fields.update_mode:
                                os.fchmod(fd, stat_mod.S_IMODE(attr.st_mode))
                        finally:
                            os.close(fd)
                    # chown/utime have real no-follow variants (lchown / utimensat
                    # AT_SYMLINK_NOFOLLOW): they act on the link itself, never target.
                    if fields.update_uid or fields.update_gid:
                        uid = attr.st_uid if fields.update_uid else -1
                        gid = attr.st_gid if fields.update_gid else -1
                        os.chown(upath, uid, gid, follow_symlinks=False)
                    if fields.update_mtime or fields.update_atime:
                        st0 = os.lstat(upath)
                        atime = (attr.st_atime_ns / 1e9 if fields.update_atime
                                 else st0.st_atime)
                        mtime = (attr.st_mtime_ns / 1e9 if fields.update_mtime
                                 else st0.st_mtime)
                        os.utime(upath, (atime, mtime), follow_symlinks=False)
                except OSError as e:
                    raise pyfuse3.FUSEError(e.errno or errno.EIO)
                st = os.lstat(upath)
                if stat_mod.S_ISDIR(st.st_mode): kind = "dir"
                elif stat_mod.S_ISLNK(st.st_mode): kind = "symlink"
                else: kind = "file"
                idx.set_entry(rel, kind, st.st_mode, wid, "setattr")
                self._notify(sid)
                return self._entry(inode, st)
            finally:
                self._req_exit()

        async def statfs(self, ctx):
            s = pyfuse3.StatvfsData()
            try:
                vfs = os.statvfs(str(live_home()))
                s.f_bsize = vfs.f_bsize; s.f_frsize = vfs.f_frsize
                s.f_blocks = vfs.f_blocks; s.f_bfree = vfs.f_bfree
                s.f_bavail = vfs.f_bavail; s.f_files = vfs.f_files
                s.f_ffree = vfs.f_ffree; s.f_favail = vfs.f_favail
            except OSError:
                s.f_bsize = s.f_frsize = 4096
                s.f_blocks = s.f_bfree = s.f_bavail = 1 << 20
                s.f_files = s.f_ffree = s.f_favail = 1 << 16
            s.f_namemax = 255
            return s

        # ── copy-up of one entry (for rename/link materialization) ───────────
        def _copyup_one(self, sid: str, rel: str, wid) -> None:
            upath = self._upper_path(sid, rel)
            if os.path.lexists(upath): return
            self._ensure_parent_dirs(sid, rel, wid)
            layer, ap, st = self._resolve_st(sid, rel)
            idx = self._index(sid)
            if layer == "lower":
                if stat_mod.S_ISLNK(st.st_mode):
                    os.symlink(os.readlink(ap), upath)
                    idx.set_entry(rel, "symlink", stat_mod.S_IFLNK | 0o777, wid,
                                  "copyup_symlink")
                elif stat_mod.S_ISDIR(st.st_mode):
                    os.mkdir(upath, stat_mod.S_IMODE(st.st_mode))
                    idx.set_entry(rel, "dir", st.st_mode, wid, "copyup_dir")
                else:
                    src = os.open(ap, os.O_RDONLY)
                    try:
                        dst = os.open(upath, os.O_RDWR | os.O_CREAT | os.O_NOFOLLOW,
                                      stat_mod.S_IMODE(st.st_mode))
                        try: reflink_or_copy(src, dst)
                        finally: os.close(dst)
                    finally:
                        os.close(src)
                    idx.set_entry(rel, "file", st.st_mode, wid, "copyup")

        def _materialize_tree(self, sid: str, rel: str, wid) -> None:
            """Walk the merged view of rel and copy every entry into the upper."""
            self._copyup_one(sid, rel, wid)
            for name, _k, _a in self._scan_dir(sid, rel):
                child = (rel + "/" + name) if rel else name
                layer, _ap, st = self._resolve_st(sid, child)
                if layer in ("absent", "whiteout"): continue
                if stat_mod.S_ISDIR(st.st_mode):
                    self._materialize_tree(sid, child, wid)
                else:
                    self._copyup_one(sid, child, wid)

        async def rename(self, parent_old, name_old, parent_new, name_new,
                         flags, ctx):
            if flags & getattr(pyfuse3, "RENAME_EXCHANGE", 2):
                raise pyfuse3.FUSEError(errno.ENOSYS)
            name_old = os.fsdecode(name_old); name_new = os.fsdecode(name_new)
            pko = self._key(parent_old); pkn = self._key(parent_new)
            if pko is None or pkn is None: raise pyfuse3.FUSEError(errno.EACCES)
            sid_o, rel_o = self._child_key(pko, name_old)
            sid_n, rel_n = self._child_key(pkn, name_new)
            if sid_o != sid_n or sid_o not in self.sessions:
                raise pyfuse3.FUSEError(errno.EXDEV)
            sid = sid_o
            if policy_check(sid, self._index(sid).provenance_of(ctx.pid),
                            rel_o, "rename") == "deny":
                raise pyfuse3.FUSEError(errno.EACCES)
            idx = self._index(sid)
            layer_o, _ap_o, st_o = self._resolve_st(sid, rel_o)
            if layer_o in ("absent", "whiteout"):
                raise pyfuse3.FUSEError(errno.ENOENT)
            layer_n = self._resolve(sid, rel_n)
            if flags & getattr(pyfuse3, "RENAME_NOREPLACE", 1):
                if layer_n not in ("absent", "whiteout"):
                    raise pyfuse3.FUSEError(errno.EEXIST)
            wid = idx.writer_for(ctx.pid)
            self._req_enter(f"rename {sid}/{rel_o}->{rel_n}")
            try:
                dst_shadows_lower = False
                try:
                    dst_shadows_lower = (not idx.hidden_by_opaque(rel_n)
                        and stat_mod.S_ISDIR(os.lstat(self._lower_path(rel_n)).st_mode))
                except OSError:
                    dst_shadows_lower = False
                is_dir = stat_mod.S_ISDIR(st_o.st_mode)
                if is_dir:
                    self._materialize_tree(sid, rel_o, wid)
                else:
                    self._copyup_one(sid, rel_o, wid)
                upo = self._upper_path(sid, rel_o); upn = self._upper_path(sid, rel_n)
                # remove existing destination upper artifact
                try:
                    lst = os.lstat(upn)
                    if stat_mod.S_ISDIR(lst.st_mode) and not stat_mod.S_ISLNK(lst.st_mode):
                        shutil.rmtree(upn)
                    else:
                        os.unlink(upn)
                except FileNotFoundError:
                    pass
                self._ensure_parent_dirs(sid, rel_n, wid)
                try:
                    os.rename(upo, upn)
                except OSError as e:
                    raise pyfuse3.FUSEError(e.errno or errno.EIO)
                # index update
                src_shadowed_lower = False
                try:
                    src_shadowed_lower = (not idx.hidden_by_opaque(rel_o)
                        and os.path.lexists(self._lower_path(rel_o)))
                except OSError:
                    src_shadowed_lower = False
                if is_dir:
                    idx.reparent(rel_o, rel_n, wid)
                    idx.set_entry(rel_n, "dir", st_o.st_mode, wid, "rename_to",
                                  opaque=1 if dst_shadows_lower else None)
                else:
                    knd = ("symlink" if stat_mod.S_ISLNK(st_o.st_mode) else "file")
                    idx.set_entry(rel_n, knd, st_o.st_mode, wid, "rename_to",
                                  opaque=1 if dst_shadows_lower else None)
                if src_shadowed_lower:
                    idx.set_entry(rel_o, "whiteout", 0, wid, "rename_from")
                else:
                    idx.del_entry(rel_o, op="rename_from", writer_id=wid)
                self._remap_inode_subtree(sid, rel_o, rel_n)
                self._notify(sid)
            finally:
                self._req_exit()

        def _remap_inode_subtree(self, sid: str, rel_o: str, rel_n: str) -> None:
            with self._lock:
                oldp = rel_o + "/"; newp = rel_n + "/"
                remap = []
                for (ksid, krel), ino in list(self._key_to_ino.items()):
                    if ksid != sid: continue
                    if krel == rel_o:
                        remap.append(((ksid, krel), (ksid, rel_n), ino))
                    elif krel.startswith(oldp):
                        remap.append(((ksid, krel), (ksid, newp + krel[len(oldp):]), ino))
                for oldkey, newkey, ino in remap:
                    self._key_to_ino.pop(oldkey, None)
                    self._key_to_ino[newkey] = ino
                    self._ino_to_key[ino] = newkey

        async def link(self, inode, new_parent, new_name, ctx):
            new_name = os.fsdecode(new_name)
            key = self._key(inode); pkn = self._key(new_parent)
            if key is None or pkn is None: raise pyfuse3.FUSEError(errno.EPERM)
            sid, rel_src = key
            sid_n, rel_n = self._child_key(pkn, new_name)
            if sid != sid_n or sid not in self.sessions:
                raise pyfuse3.FUSEError(errno.EXDEV)
            layer, _ap, st = self._resolve_st(sid, rel_src)
            if layer in ("absent", "whiteout"): raise pyfuse3.FUSEError(errno.ENOENT)
            if stat_mod.S_ISDIR(st.st_mode): raise pyfuse3.FUSEError(errno.EPERM)
            wid = self._index(sid).writer_for(ctx.pid)
            if policy_check(sid, self._index(sid).provenance_of(ctx.pid),
                            rel_n, "link") == "deny":
                raise pyfuse3.FUSEError(errno.EACCES)
            self._copyup_one(sid, rel_src, wid)
            self._ensure_parent_dirs(sid, rel_n, wid)
            ups = self._upper_path(sid, rel_src); upn = self._upper_path(sid, rel_n)
            idx = self._index(sid)
            try:
                if stat_mod.S_ISLNK(st.st_mode):
                    os.symlink(os.readlink(ups), upn)
                    idx.set_entry(rel_n, "symlink", stat_mod.S_IFLNK | 0o777, wid,
                                  "link_as_copy", detail=rel_src)
                else:
                    src = os.open(ups, os.O_RDONLY)
                    try:
                        dst = os.open(upn, os.O_RDWR | os.O_CREAT | os.O_NOFOLLOW,
                                      stat_mod.S_IMODE(st.st_mode))
                        try: reflink_or_copy(src, dst)
                        finally: os.close(dst)
                    finally:
                        os.close(src)
                    idx.set_entry(rel_n, "file", st.st_mode, wid, "link_as_copy",
                                  detail=rel_src)
            except OSError as e:
                raise pyfuse3.FUSEError(e.errno or errno.EIO)
            ino = self._ino_for(sid, rel_n)
            self._lookup_count[ino] = self._lookup_count.get(ino, 0) + 1
            self._notify(sid)
            return self._entry(ino, os.lstat(upn))

        def _notify(self, sid: str) -> None:
            """Live-feedback seam: tell the UI a box's overlay changed so the Changes
            view refreshes event-driven (NOT by polling). Called from the mutating
            handlers; the handoff itself is thread-safe (see OverlayMount)."""
            try: self.on_event(type="overlay_changed", sid=sid)
            except Exception: pass

    return MultiplexOverlayFs


# ════════════════════════════════════════════════════════════════════════════
#  Overlay mount manager — owns the single pyfuse3 mount on a trio thread.
#
#  The pyfuse3 serve loop runs on trio in a dedicated background thread of the UI
#  process; the Textual UI + mitmproxy run on asyncio in the main thread. The two
#  loops cannot share a thread, so the serving thread does all FUSE I/O and hands
#  events to the UI thread-safely (a thread-safe queue drained via an asyncio
#  callback). Index/RAM mutations are single-writer on the serving thread.
# ════════════════════════════════════════════════════════════════════════════

class OverlayMount:
    def __init__(self, mountpoint: Path, lower: str = "/"):
        self.mountpoint = Path(mountpoint)
        self.lower = lower
        self.ops = None
        self._thread = None
        self._started = threading.Event()
        self._start_error = None
        self._stop_trio = None       # set to a trio Event from inside the loop
        self._trio_token = None
        self.event_q: "queue.Queue" = queue.Queue()

    def _on_ops_event(self, **ev) -> None:
        # called from the trio serving thread; hand off to the UI thread-safely
        self.event_q.put(ev)

    def start(self) -> bool:
        """Mount the single overlay and start serving. Blocks until the serve loop is
        actually up (or failed). Returns True on success. Fail-closed (R5): a mount
        failure is reported, never swallowed."""
        try:
            self.mountpoint.mkdir(parents=True, exist_ok=True)
        except OSError as e:
            self._start_error = e; return False
        make_ops = _build_overlay_ops()
        self.ops = make_ops(self.lower, on_event=self._on_ops_event)
        self._thread = threading.Thread(target=self._run, name="overlay-fuse",
                                        daemon=True)
        self._thread.start()
        self._started.wait(timeout=30)
        if self._start_error is not None:
            return False
        return self._started.is_set()

    def _run(self) -> None:
        import pyfuse3, trio
        fuse_options = set(pyfuse3.default_options)
        fuse_options.add("fsname=slopbox")
        # same uid as the mounter -> no allow_other needed; do NOT set
        # default_permissions (we report squash ownership ourselves).
        try:
            pyfuse3.init(self.ops, str(self.mountpoint), fuse_options)
        except Exception as e:
            self._start_error = e
            self._started.set()
            return

        async def _main():
            self._trio_token = trio.lowlevel.current_trio_token()
            self._stop_trio = trio.Event()
            async with trio.open_nursery() as nursery:
                nursery.start_soon(pyfuse3.main)
                # R6-analogue: signal "serving" only after the loop is running.
                self._started.set()
                await self._stop_trio.wait()
                # tear down: unmount so pyfuse3.main returns
                pyfuse3.close(unmount=True)
        try:
            trio.run(_main)
        except Exception as e:
            if self._start_error is None:
                self._start_error = e
            self._started.set()
        finally:
            try: pyfuse3.close(unmount=True)
            except Exception: pass

    def add_session(self, sid: str, up: Path, index: "Index") -> None:
        if self.ops is not None:
            self.ops.add_session(sid, up, index)

    def remove_session(self, sid: str) -> None:
        if self.ops is not None:
            self.ops.remove_session(sid)

    def add_ca_spoof(self, sid: str, ca_bytes: bytes, bundle_paths) -> None:
        """Register the CA-augmented trust bundle as virtual files for this session
        (spec §7): the box sees system_ca + our mitmproxy CA at every bundle path,
        but the augmented bytes are invisible to consolidate (no on-disk artifact)."""
        if self.ops is None: return
        for p in bundle_paths:
            lp = Path(p)
            try:
                if not lp.is_file(): continue
                base = lp.read_bytes()
            except OSError:
                continue
            sep = b"" if base.endswith(b"\n") else b"\n"
            self.ops.add_virtual(sid, p.lstrip("/"), base + sep + b"\n" + ca_bytes)

    def inflight_age(self):
        return self.ops.inflight_age() if self.ops else None

    def stop(self) -> None:
        """Stop serving and unmount. Lazy-unmount as a fallback so the mount table is
        clean even if the loop is wedged (spec §9 watchdog)."""
        ev = self._stop_trio; token = self._trio_token
        if ev is not None and token is not None:
            try:
                import trio
                trio.from_thread.run_sync(ev.set, trio_token=token)
            except Exception:
                pass
        if self._thread is not None:
            self._thread.join(timeout=5)
        # lazy-unmount fallback (recovers the mount table even if wedged)
        try:
            if os.path.ismount(str(self.mountpoint)):
                subprocess.run(["fusermount3", "-uz", str(self.mountpoint)],
                               stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                               timeout=10)
        except (FileNotFoundError, subprocess.TimeoutExpired):
            pass


def upper_has_changes(up: Path) -> bool:
    """True if the overlay upper holds any real change (a created/modified file or
    a whiteout deletion), ignoring the overlay's own opaque markers."""
    for root, _dirs, files in os.walk(up, onerror=lambda _e: None):
        if any(not _is_overlay_marker(nm) for nm in files):
            return True
    return False

def is_whiteout(p: Path) -> bool:
    try:
        st = p.stat(); return stat_mod.S_ISCHR(st.st_mode) and st.st_rdev == 0
    except OSError: return False

def remove_upper_entry(p: Path) -> None:
    """Remove one upper artifact: a file, a directory tree, or a char-device
    whiteout. No-op if nothing is there (e.g. an opacity-only deletion)."""
    try:
        if p.is_dir() and not p.is_symlink() and not is_whiteout(p):
            shutil.rmtree(p)
        elif p.exists() or p.is_symlink() or is_whiteout(p):
            p.unlink()
    except FileNotFoundError:
        pass

def cleanup_dirs(upper: Path, start: Path) -> None:
    """Walk up from `start` toward `upper`, removing directories that hold no real
    change. A dir with only opaque markers is removed only when the lower has
    nothing there (a freshly-created dir); otherwise the markers record deletions
    and the dir is kept. Dirs with files/whiteouts stop the walk."""
    d = start
    while d != upper and upper in d.parents:
        try: children = list(d.iterdir())
        except OSError: break
        if any(not _is_overlay_marker(c.name) for c in children):
            break
        if children:
            rel = d.relative_to(upper)
            if Path("/").joinpath(*rel.parts).is_dir():
                break
        parent = d.parent
        try: shutil.rmtree(d)
        except OSError: break
        d = parent

def _apply_overlay_entry(upper: Path, ap: Path, rel: str) -> None:
    """Write one overlay change onto the host (the same effect as the UI's Apply),
    then drop it from the overlay. A whiteout deletes; a file/symlink is copied."""
    host = Path("/") / rel
    try:
        if is_whiteout(ap):
            if host.is_dir() and not host.is_symlink(): shutil.rmtree(host)
            elif host.exists() or host.is_symlink(): host.unlink()
        elif ap.is_symlink():
            tgt = os.readlink(ap)
            if host.exists() or host.is_symlink(): host.unlink()
            host.parent.mkdir(parents=True, exist_ok=True); os.symlink(tgt, host)
        elif ap.is_file():
            host.parent.mkdir(parents=True, exist_ok=True); shutil.copy2(ap, host)
        else:
            return                                       # unknown type: leave it
    except OSError:
        return
    remove_upper_entry(ap)

def _try_fold_patch(rel, ap, host, files) -> bool:
    """Fold a text create/modify into the patch dict; True if it went in. Deletions
    and anything that isn't a clean line-diff of UTF-bytes are left for the sqlar."""
    try:
        ub = ap.read_bytes()
    except OSError:
        return False
    if b"\x00" in ub: return False
    try:
        lob = host.read_bytes() if (host.exists() and not host.is_dir()) else b""
    except OSError:
        return False
    if b"\x00" in lob: return False
    lower, upperl = ut_split(lob), ut_split(ub)
    fp = build_file_patch(rel, lower, upperl, not host.exists(), False)
    try:
        if b"".join(apply_hunks(lower, fp["hunks"])) != b"".join(upperl):
            return False
    except PatchConflict:
        return False
    files[rel] = fp
    return True

def _open_index_ro(shm_dir) -> "Index | None":
    """Open the session's index.db read-only-ish for consolidate. None if absent."""
    db = Path(shm_dir) / "index.db"
    if not db.exists(): return None
    try: return Index(Path(shm_dir))
    except sqlite3.Error: return None

def consolidate(shm_dir, session_id: str, cmd: list, index: "Index | None" = None) -> None:
    """Empty a finished session's overlay (live/<sid>) into on-disk state: text
    create/modify folds into the patch (<sid>.patch.xz); binary files and symlinks go
    into the sqlar archive (<sid>.sqlar). Deletions and opaque-dir expansions come
    from index.db (NOT from char-device whiteouts / .wh..opq scanning — those never
    exist in this overlay; R13/R14). Writer provenance per path is carried into the
    sqlar `provenance` table (spec §11). Afterwards the upper holds nothing
    reviewable, so the caller can free the backing tree. Idempotent and additive.

    File rules are consulted first, top-to-bottom: a matching 'apply' writes the
    change to the host and drops it, a matching 'discard' just drops it — either way
    it reaches neither store."""
    upper = Path(shm_dir) / "up"
    if not upper.is_dir(): return
    own_index = index is None
    idx = index if index is not None else _open_index_ro(shm_dir)
    frules = load_file_rules()
    pp = patch_path(session_id)
    files = {}
    if pp.exists():
        try: files = parse_patch(read_patch_file(pp))
        except Exception: files = {}
    sq = None                                            # lazy sqlar connection
    def _sq():
        nonlocal sq
        if sq is None: sq = _sqlar_open(sqlar_path(session_id))
        return sq
    def _prov(rel):
        return idx.writer_provenance(rel) if idx is not None else None
    moved = []
    # 1) created/modified files + symlinks in the upper (dirs are structural).
    paths = []
    for root, _dirs, names in os.walk(upper, onerror=lambda _e: None):
        for nm in names:
            paths.append(Path(root) / nm)
        # symlinks-to-dirs show up in _dirs from os.walk? No — os.walk lists symlinks
        # to dirs under dirs and does not descend; capture them explicitly.
    # also catch symlinks that point at directories (os.walk would list them as dirs)
    for root, dirs, _names in os.walk(upper, onerror=lambda _e: None):
        for d in dirs:
            p = Path(root) / d
            if p.is_symlink(): paths.append(p)
    for ap in sorted(set(paths)):
        rel = str(ap.relative_to(upper))
        act = frules.decide(rel)                         # apply / discard / None
        if act == "discard":
            remove_upper_entry(ap); cleanup_dirs(upper, ap.parent); continue
        if act == "apply":
            _apply_overlay_entry(upper, ap, rel); cleanup_dirs(upper, ap.parent)
            files.pop(rel, None); continue
        if rel in files: continue                        # already in the patch
        host = Path("/") / rel
        try:
            if ap.is_symlink():
                _sqlar_put_symlink(_sq(), rel,
                                   os.readlink(ap).encode("utf-8", "surrogateescape"),
                                   ap.lstat().st_mtime)
                p = _prov(rel)
                if p: _sqlar_put_provenance(_sq(), rel, p)
            elif ap.is_file():
                if not _try_fold_patch(rel, ap, host, files):   # not clean text
                    st = ap.stat()
                    _sqlar_put_file(_sq(), rel, ap.read_bytes(), st.st_mode, st.st_mtime)
                    p = _prov(rel)
                    if p: _sqlar_put_provenance(_sq(), rel, p)
            else:
                continue                                 # dirs handled by cleanup
        except OSError:
            continue
        moved.append(ap)
    # 2) deletions (whiteouts) from the index -> sqlar tombstones.
    if idx is not None:
        for rel in idx.deletions():
            if frules.decide(rel) == "discard": continue
            host = Path("/") / rel
            if frules.decide(rel) == "apply":
                try:
                    if host.is_dir() and not host.is_symlink(): shutil.rmtree(host)
                    elif host.exists() or host.is_symlink(): host.unlink()
                except OSError: pass
                continue
            if host.exists() or host.is_symlink():
                _sqlar_put_tombstone(_sq(), rel)
                p = _prov(rel)
                if p: _sqlar_put_provenance(_sq(), rel, p)
        # 3) opaque dirs: expand into per-lower-child tombstones for children not
        #    re-materialized in the upper (spec §11/§12).
        for drel in idx.opaque_dirs():
            lower = Path("/") / drel
            if not lower.is_dir(): continue
            for lroot, ldirs, lfiles in os.walk(lower, onerror=lambda _e: None):
                for nm in ldirs + lfiles:
                    crel = os.path.relpath(os.path.join(lroot, nm), "/")
                    if (upper / crel).exists() or (upper / crel).is_symlink():
                        continue                          # re-materialized in upper
                    if frules.decide(crel) in ("apply", "discard"): continue
                    _sqlar_put_tombstone(_sq(), crel)
    if files:
        write_patch_file(pp, serialize_patch(files), cmd)
    elif pp.exists():
        pp.unlink()
    if sq is not None:
        sq.commit(); sq.close(); set_cmd_xattr(sqlar_path(session_id), cmd)
    for ap in moved:
        remove_upper_entry(ap); cleanup_dirs(upper, ap.parent)
    if own_index and idx is not None:
        idx.close()

def _pid_alive(pid: int) -> bool:
    if not pid: return False
    try:
        os.kill(pid, 0); return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True

def rm_rf(path) -> None:
    """Remove a tree, fixing perms (fuse-overlayfs workdir can be unwritable)."""
    path = str(path)
    if not os.path.exists(path) and not os.path.islink(path):
        return
    def _fix_and_retry(func, p, _exc):
        try:
            os.chmod(p, 0o700)
            par = os.path.dirname(p)
            if par: os.chmod(par, 0o700)
        except OSError:
            pass
        try: func(p)
        except OSError: pass
    try:
        shutil.rmtree(path, onexc=_fix_and_retry)
    except TypeError:
        shutil.rmtree(path, onerror=_fix_and_retry)
    if os.path.exists(path):
        for root, dirs, files in os.walk(path, topdown=False):
            for nm in files + dirs:
                fp = os.path.join(root, nm)
                try: os.chmod(fp, 0o700)
                except OSError: pass
                try: (os.rmdir if os.path.isdir(fp) and not os.path.islink(fp)
                      else os.unlink)(fp)
                except OSError: pass
        try: os.chmod(path, 0o700); os.rmdir(path)
        except OSError: pass



@dataclass
class Session:
    session_id: str                # "YYYYmmdd-HHMMSS_PID" — the whole identity
    cmd: list
    shm_dir: str = ""              # the session backing dir: live/<sid> (up + index.db)
    status: str = "running"
    exit_code: "int | None" = None
    conn_allowed: int = 0
    conn_denied: int = 0
    bytes_up: int = 0
    bytes_down: int = 0
    sess_rules: list = field(default_factory=list)   # ordered, session-only Rules
    live: bool = False
    has_patch: bool = False                           # a consolidated patch exists
    has_sqlar: bool = False                           # a consolidated sqlar exists
    has_flows: bool = False                           # a network log exists
    # started time and pid are not stored — they are read back out of the name.
    @property
    def started(self) -> float: return parse_sid(self.session_id)[0]
    @property
    def pid(self) -> int: return parse_sid(self.session_id)[1]
    @property
    def stamp(self) -> str: return self.session_id.partition("_")[0]
    @property
    def upper(self) -> str: return str(Path(self.shm_dir) / "up")
    @property
    def index_db(self) -> str: return str(Path(self.shm_dir) / "index.db")
    def to_dict(self) -> dict:
        d = {k: v for k, v in asdict(self).items() if k != "sess_rules"}
        d["sess_rules"] = [r.to_line() for r in self.sess_rules]
        d["upper"] = self.upper
        d["started"] = self.started; d["pid"] = self.pid; d["stamp"] = self.stamp
        return d


def discover_sessions() -> dict:
    """Find sessions purely from filesystem names: live/<sid> backing dirs (an
    un-consolidated/orphaned overlay) plus <sid>.patch.xz / <sid>.sqlar / <sid>.flows
    under state_home. All but the command is in <sid>."""
    out = {}
    lh = live_home()
    if lh.exists():
        for d in lh.iterdir():
            if not (d / "up").is_dir(): continue          # not a slopbox backing dir
            sid = d.name
            out[sid] = Session(
                session_id=sid, cmd=get_cmd_xattr(d), shm_dir=str(d),
                status="running" if _pid_alive(parse_sid(sid)[1]) else "finished",
                live=False)
    sd = state_home()
    if sd.exists():
        def _store(sid, src):
            s = out.get(sid)
            if s is None:
                s = out[sid] = Session(
                    session_id=sid, cmd=get_cmd_xattr(src),
                    shm_dir=str(live_dir(sid)),
                    status="finished", live=False)
            return s
        for pf in sd.glob("*.patch.xz"):
            _store(pf.name[:-len(".patch.xz")], pf).has_patch = True
        for af in sd.glob("*.sqlar"):
            _store(af.name[:-len(".sqlar")], af).has_sqlar = True
        for ff in sd.glob("*.flows"):
            _store(ff.name[:-len(".flows")], ff).has_flows = True
    return out


# ════════════════════════════════════════════════════════════════════════════
#  Supervisor (in-process inside the UI)
# ════════════════════════════════════════════════════════════════════════════

@dataclass
class Pending:
    request_id: str; session_id: str; host: str; port: int
    scheme: str; ts: float; future: Any
    url: str = ""; ips: list = field(default_factory=list)
    cnames: list = field(default_factory=list)

class Supervisor:
    def __init__(self, rules: Rules, mount: "OverlayMount | None" = None):
        self.rules = rules
        self.mount = mount               # the single pyfuse3 OverlayMount (UI-owned)
        self.indexes: dict = {}          # sid -> live Index (for running sessions)
        self.sessions: dict = {}
        self.pending: dict = {}
        self.patches: dict = {}          # sid -> {files, dirty, touched, mtime}
        self._consolidated: set = set()  # sids whose overlay we've folded to a patch
        self._dns_cache: dict = {}
        self._counter = 0
        self.on_event = lambda ev: None
        self.sessions.update(discover_sessions())

    def _emit(self, **ev: Any) -> None: self.on_event(ev)

    def sweep_orphans(self) -> None:
        """At UI startup, consolidate-or-leave each orphaned live/<sid> from a prior
        crash: its runner is gone, so fold its overlay into patch/sqlar (deletions
        and opacity come from its index.db) and remove the spent backing tree. Leaves
        live/ empty at rest for any session that had no reviewable changes."""
        lh = live_home()
        if not lh.exists(): return
        for d in sorted(lh.iterdir()):
            if not (d / "up").is_dir(): continue
            sid = d.name
            if _pid_alive(parse_sid(sid)[1]): continue   # a running runner owns it
            try:
                consolidate(str(d), sid, get_cmd_xattr(d))
            except Exception as e:
                print(f"slopbox(ui): sweep of {sid} failed: {e}", file=sys.stderr)
                continue
            try:
                if not upper_has_changes(d / "up"):
                    rm_rf(d)
            except OSError:
                pass

    def rescan(self) -> None:
        disk = discover_sessions()
        for sid, s in disk.items():
            cur = self.sessions.get(sid)
            if cur is None:
                self.sessions[sid] = s
                self._emit(type="session_added", session=s.to_dict())
            elif not cur.live:
                ns = "running" if _pid_alive(cur.pid) else (
                    cur.status if cur.status == "killed" else "finished")
                changed = (ns != cur.status or cur.has_patch != s.has_patch
                           or cur.has_sqlar != s.has_sqlar or cur.has_flows != s.has_flows)
                cur.status = ns; cur.has_patch = s.has_patch
                cur.has_sqlar = s.has_sqlar; cur.has_flows = s.has_flows
                if changed:
                    self._emit(type="session_updated", session=cur.to_dict())
        for sid in list(self.sessions):
            s = self.sessions[sid]
            if s.live: continue
            shm_gone = not (s.shm_dir and Path(s.shm_dir).exists())
            inmem = self.patches.get(sid)
            patch_gone = not patch_path(sid).exists() and not (inmem and inmem["files"])
            sqlar_gone = not sqlar_path(sid).exists()
            flows_gone = not flows_path(sid).exists()
            if shm_gone and patch_gone and sqlar_gone and flows_gone:
                del self.sessions[sid]
                self._emit(type="session_removed", session_id=sid)

    def _resolve(self, host: str) -> tuple:
        """Best-effort DNS: (ips, cnames). Cached for the UI's lifetime. Uses
        gethostbyname_ex for the IPv4 + CNAME/alias chain and getaddrinfo for
        IPv6 (and IPv4). All best-effort — failures just yield empty lists."""
        cached = self._dns_cache.get(host)
        if cached is not None:
            return cached
        ips, cnames = set(), set()
        try:
            canon, aliases, addrs = socket.gethostbyname_ex(host)
            ips.update(addrs)
            if canon and canon.rstrip(".").lower() != host.lower():
                cnames.add(canon.rstrip(".").lower())
            cnames.update(a.rstrip(".").lower() for a in aliases)
        except OSError:
            pass
        try:
            for *_, sa in socket.getaddrinfo(host, None):
                ips.add(sa[0])
        except OSError:
            pass
        res = (sorted(ips), sorted(cnames)); self._dns_cache[host] = res
        return res

    def _decide(self, s: Session, host: str, port: int,
                url: str = None) -> "str | None":
        need_dns = self.rules.needs_dns() or any(
            r.kind in ("ip", "cname") for r in s.sess_rules)
        ips, cnames = self._resolve(host) if need_dns else ((), ())
        # session rules first (temporary overrides), then the permanent ruleset;
        # each evaluated top-to-bottom, first match wins.
        for r in s.sess_rules:
            if r.matches(host, port, url, ips, cnames):
                return r.action
        return self.rules.decide(host, port, url, ips, cnames)

    def precheck(self, sid, host, port, url=None) -> "str | None":
        """Rule-only decision (no prompting) for the given request."""
        s = self.sessions.get(sid)
        if not s: return "deny"
        return self._decide(s, host, port, url)

    def _record_traffic(self, s, host, port, scheme, action,
                        bytes_up=0, bytes_down=0, status=0) -> None:
        # Keep the compact per-session tallies shown in the Slopboxes table; we no
        # longer keep a connection-by-connection log (the Approvals panel is the
        # live view, and the upstream fetch isn't ours to journal).
        if action == "allow": s.conn_allowed += 1
        else: s.conn_denied += 1
        s.bytes_up += bytes_up; s.bytes_down += bytes_down
        self._emit(type="session_updated", session=s.to_dict())

    def register(self, msg: dict) -> dict:
        """Set up a box's overlay and expose it as a mount subfolder. Returns the ack
        dict the ChannelServer sends back to the runner: the absolute <mnt>/<sid>
        bind target, so the runner can bwrap onto it. Fail-closed: any setup error is
        reported in the ack, never swallowed (R5)."""
        sid = msg["session_id"]
        cmd = msg.get("cmd", [])
        if self.mount is None or self.mount.ops is None:
            return dict(ok=False, error="overlay mount is not available")
        backing = live_dir(sid)
        up = backing / "up"
        try:
            # 0700: live/<sid> holds provenance (R8).
            old = os.umask(0o077)
            try:
                backing.mkdir(parents=True, exist_ok=True)
                up.mkdir(parents=True, exist_ok=True)
            finally:
                os.umask(old)
            os.chmod(backing, 0o700)
            set_cmd_xattr(backing, list(cmd))
            index = Index(backing)
        except (OSError, sqlite3.Error) as e:
            return dict(ok=False, error=f"overlay setup failed: {e}")
        self.indexes[sid] = index
        self.mount.add_session(sid, up, index)
        # CA-augmented trust bundle as virtual files (spec §7), if networked.
        net = bool(msg.get("want_net"))
        if net:
            try:
                ca = CA_CERT.read_bytes() if CA_CERT.exists() else b""
            except OSError:
                ca = b""
            if ca.strip():
                self.mount.add_ca_spoof(sid, ca, SYSTEM_CA_FILES)
        box_root = str(mnt_point() / sid)
        s = Session(session_id=sid, cmd=cmd, shm_dir=str(backing),
                    status="running", live=True)
        for h in msg.get("session_whitelist", []):
            s.sess_rules.append(Rule("allow", "host", h))
        self.sessions[sid] = s
        self._consolidated.discard(sid)
        self._emit(type="session_added", session=s.to_dict())
        return dict(ok=True, mount=box_root, shm_dir=str(backing), net=net)

    def unregister(self, msg: dict) -> None:
        sid = msg["session_id"]
        s = self.sessions.get(sid)
        # Teardown: remove the box from the live mount set, consolidate its overlay
        # (deletions/opacity from index.db, provenance into the sqlar), then drop the
        # backing tree. live/ + the synthetic root are empty at rest. Fail-closed on
        # the security-critical teardown — log, don't silently pass.
        if self.mount is not None:
            self.mount.remove_session(sid)
        index = self.indexes.pop(sid, None)
        backing = live_dir(sid)
        if backing.exists():
            try:
                consolidate(str(backing), sid, list(s.cmd) if s else get_cmd_xattr(backing),
                            index=index)
            except Exception as e:
                print(f"slopbox(ui): consolidate {sid} failed: {e}", file=sys.stderr)
        if index is not None:
            index.close()
        try:
            if not (backing.exists() and upper_has_changes(backing / "up")):
                rm_rf(backing)
        except OSError:
            pass
        if not s:
            return
        s.live = False
        if s.status == "running": s.status = msg.get("status", "finished")
        s.exit_code = msg.get("exit_code")
        self.patches.pop(sid, None)
        s.has_patch = patch_path(sid).exists()
        s.has_sqlar = sqlar_path(sid).exists()
        s.has_flows = flows_path(sid).exists()
        self._consolidated.add(sid)
        # nothing reviewable at all -> drop the entry entirely
        if not (s.has_patch or s.has_sqlar or s.has_flows
                or (backing.exists() and upper_has_changes(backing / "up"))):
            self.sessions.pop(sid, None)
            self._emit(type="session_removed", session_id=sid)
        else:
            s.shm_dir = str(backing)
            self._emit(type="session_updated", session=s.to_dict())

    def drop(self, msg: dict) -> None:
        # Runner reports the session left nothing to review; remove it outright.
        if self.sessions.pop(msg["session_id"], None) is not None:
            self._emit(type="session_removed", session_id=msg["session_id"])

    async def approval_request(self, sid, host, port, scheme, url="") -> dict:
        s = self.sessions.get(sid)
        if not s:
            return {"action": "deny", "scope": "once"}
        decided = self._decide(s, host, port, url)
        if decided:
            self._record_traffic(s, host, port, scheme, decided)
            return {"action": decided, "scope": "rule"}
        self._counter += 1
        rid = f"{sid[:8]}-{self._counter}"
        fut = asyncio.get_event_loop().create_future()
        # Resolve now so the approval UI can offer IP / CNAME matches to the user.
        ips, cnames = self._resolve(host)
        self.pending[rid] = Pending(rid, sid, host, port, scheme, time.time(), fut,
                                    url=url, ips=ips, cnames=cnames)
        self._emit(type="approval_pending", approval=self._pending_dict(rid))
        try:
            result = await asyncio.wait_for(asyncio.shield(fut), timeout=300)
        except asyncio.TimeoutError:
            result = {"action": "deny", "scope": "once"}
        self.pending.pop(rid, None)
        action, scope = result["action"], result["scope"]
        # The UI hands back the exact rule it wants ("kind:pattern") and where to
        # put it; we only synthesise a host rule if it didn't supply one.
        spec = result.get("spec") or f"host:{host}"
        at_top = result.get("at_top", False)
        if scope in ("session", "permanent"):
            rule = Rule.parse(f"{action} {spec}")
            if rule:
                if scope == "session":
                    s.sess_rules.insert(0 if at_top else len(s.sess_rules), rule)
                else:
                    self.rules.insert(rule, at_top=at_top)
                    self._emit(type="rules_updated")
        self._record_traffic(s, host, port, scheme, action)
        self._emit(type="approval_resolved", request_id=rid)
        return {"action": action, "scope": scope}

    def resolve(self, rid, action, scope, spec=None, at_top=False) -> None:
        p = self.pending.get(rid)
        if p and not p.future.done():
            p.future.set_result({"action": action, "scope": scope,
                                 "spec": spec, "at_top": at_top})

    def note_traffic(self, sid, host, port, scheme, action, bu, bd, status) -> None:
        s = self.sessions.get(sid)
        if s: self._record_traffic(s, host, port, scheme, action, bu, bd, status)

    def log_flow(self, sid, fl: dict) -> None:
        """Persist one completed request/response into the session's <sid>.flows db."""
        try: flows_add(flows_path(sid), fl)
        except Exception: return
        s = self.sessions.get(sid)
        try: set_cmd_xattr(flows_path(sid), list(s.cmd) if s else [])
        except Exception: pass
        if s and not s.has_flows:
            s.has_flows = True
            self._emit(type="session_updated", session=s.to_dict())

    def flows(self, sid) -> list:
        return flows_list(flows_path(sid))

    def flow_detail(self, sid, fid) -> "dict | None":
        return flows_get(flows_path(sid), fid)

    def _pending_dict(self, rid) -> dict:
        p = self.pending[rid]
        return dict(request_id=p.request_id, session_id=p.session_id,
                    host=p.host, port=p.port, scheme=p.scheme, ts=p.ts,
                    url=p.url, ips=p.ips, cnames=p.cnames)

    def kill(self, sid) -> None:
        # s.pid is the runner ("slopbox CMD") process, derived from the session id.
        # SIGTERM to it trips the runner's handler, which tears down the bwrap group
        # and unmounts; we must NOT killpg here — the runner shares the launching
        # shell's process group.
        s = self.sessions.get(sid)
        if not s or not _pid_alive(s.pid): return
        try: os.kill(s.pid, signal.SIGTERM)
        except ProcessLookupError: pass
        s.status = "killed"
        self._emit(type="session_updated", session=s.to_dict())

    def delete(self, sid) -> None:
        s = self.sessions.get(sid)
        if not s: return
        if _pid_alive(s.pid) and s.live: return
        # detach from the live mount if it was somehow still attached, close the
        # index, and remove the backing tree + all on-disk stores.
        if self.mount is not None:
            self.mount.remove_session(sid)
        idx = self.indexes.pop(sid, None)
        if idx is not None:
            try: idx.close()
            except Exception: pass
        if s.shm_dir:
            rm_rf(s.shm_dir)
        for f in (patch_path(sid), sqlar_path(sid), flows_path(sid)):
            if f.exists():
                try: f.unlink()
                except OSError: pass
        self.patches.pop(sid, None)
        del self.sessions[sid]
        self._emit(type="session_removed", session_id=sid)

    @staticmethod
    def _is_whiteout(p: Path) -> bool:
        return is_whiteout(p)

    # Surfacing deletions caused by an opaque directory can in principle touch a
    # large lower tree; cap it so the review list can't be flooded.
    _OPAQUE_DELETE_CAP = 500

    def _index_for(self, sid) -> "Index | None":
        """The session's overlay index: the live one for a running box, else one
        opened on its backing dir. The live-change listing reads the box's upper
        plus this index (deletions/opacity), per the spec — not whiteout scanning."""
        idx = self.indexes.get(sid)
        if idx is not None: return idx
        s = self.sessions.get(sid)
        if s and s.shm_dir:
            db = Path(s.shm_dir) / "index.db"
            if db.exists():
                try: return Index(Path(s.shm_dir))
                except sqlite3.Error: return None
        return None

    def overlay_entries(self, sid) -> list:
        s = self.sessions.get(sid)
        if not s: return []
        upper = Path(s.upper)
        if not upper.exists(): return []
        idx = self.indexes.get(sid)        # only the live in-RAM index (no reopen)
        entries: dict = {}            # rel -> entry
        # 1) created/modified files + symlinks present in the upper.
        paths = []
        for root, dirs, files in os.walk(upper, onerror=lambda _e: None):
            rootp = Path(root)
            for nm in files: paths.append(rootp / nm)
            for nm in dirs:
                p = rootp / nm
                if p.is_symlink(): paths.append(p)
        for ap in sorted(set(paths)):
            try:
                if ap.is_dir() and not ap.is_symlink(): continue
            except OSError:
                continue
            rel = str(ap.relative_to(upper)); real = Path("/") / rel
            try: size = ap.stat().st_size if (ap.is_file() and not ap.is_symlink()) else 0
            except OSError: size = 0
            is_text = False
            if size and size < (10 << 20):
                try: ap.read_bytes()[:512].decode(); is_text = True
                except (UnicodeDecodeError, OSError): pass
            stale = False
            exists = real.exists() or real.is_symlink()
            if exists:
                try: stale = real.lstat().st_mtime > ap.lstat().st_mtime
                except OSError: stale = False
            entries[rel] = dict(path=rel,
                                kind="modified" if exists else "created",
                                size=size, is_text=is_text, stale=stale)
        # 2) deletions (whiteouts) + opaque-dir expansion from the index.
        if idx is not None:
            for rel in idx.deletions():
                entries[rel] = dict(path=rel, kind="deleted", size=0,
                                    is_text=False, stale=False)
            added = 0
            for drel in idx.opaque_dirs():
                if added >= self._OPAQUE_DELETE_CAP: break
                lower = Path("/") / drel
                if not lower.is_dir(): continue
                for lroot, ldirs, lfiles in os.walk(lower, onerror=lambda _e: None):
                    for nm in ldirs + lfiles:
                        rel = os.path.relpath(os.path.join(lroot, nm), "/")
                        if rel in entries: continue
                        entries[rel] = dict(path=rel, kind="deleted",
                                            size=0, is_text=False)
                        added += 1
                        if added >= self._OPAQUE_DELETE_CAP: break
                    if added >= self._OPAQUE_DELETE_CAP: break
        return [entries[k] for k in sorted(entries)]

    def overlay_diff(self, sid, rel) -> dict:
        import difflib
        s = self.sessions.get(sid)
        if not s: return dict(kind="error", error="no session")
        rel = rel.lstrip("/"); up = Path(s.upper) / rel; lo = Path("/") / rel
        if self._is_whiteout(up): return dict(kind="deleted", diff=None, raw=None, content=None)
        if not up.exists():
            # deletion implied by an opaque parent directory (no upper artifact)
            return dict(kind="deleted", diff=None, raw=None, content=None)
        if not up.is_file(): return dict(kind="directory", diff=None, raw=None, content=None)
        try:
            ut = up.read_text(errors="replace")
            lt = lo.read_text(errors="replace") if lo.exists() else ""
            # Split WITHOUT keepends and join with "\n": mixing keepends with
            # lineterm="" leaves the ---/+++/@@ headers without terminators, so
            # they run into the first change ("…@@+line") and hide it.
            diff = "\n".join(difflib.unified_diff(
                lt.splitlines(), ut.splitlines(),
                fromfile=f"a/{rel}", tofile=f"b/{rel}", lineterm=""))
            return dict(kind="modified" if lo.exists() else "created",
                        diff=diff, raw=ut, content=None, is_text=True)
        except (UnicodeDecodeError, OSError):
            try:
                raw = up.read_bytes()
                return dict(kind="modified" if lo.exists() else "created",
                            diff=None, raw=None,
                            content=base64.b64encode(raw).decode(), is_text=False)
            except OSError as e:
                return dict(kind="error", error=str(e))

    def _file_hunks(self, sid, rel):
        """For a text file change return (lower_lines, upper_lines, groups) where
        the line lists are **bytes** (split on \\n, terminators kept) so splicing is
        byte-exact, and groups are difflib grouped opcodes (one hunk + context each).
        None if it isn't a line-splittable change (binary / deleted / directory)."""
        s = self.sessions.get(sid)
        if not s: return None
        rel = rel.lstrip("/")
        src = Path(s.upper) / rel; dst = Path("/") / rel
        if not src.is_file() or self._is_whiteout(src): return None
        try:
            ut = src.read_bytes(); lt = dst.read_bytes() if dst.exists() else b""
        except OSError:
            return None
        if b"\x00" in ut or b"\x00" in lt:        # NUL byte -> treat as binary
            return None
        import difflib
        ll = ut_split(lt); ul = ut_split(ut)
        groups = list(difflib.SequenceMatcher(None, ll, ul).get_grouped_opcodes(3))
        return (ll, ul, groups)

    def overlay_hunks(self, sid, rel) -> dict:
        """Text changes are returned as a list of hunks for per-hunk apply/discard;
        anything else falls back to the whole-file diff for display only. Hunk line
        text is decoded only for *display* — the splice operates on the raw bytes."""
        info = self._file_hunks(sid, rel)
        if info is None:
            return dict(is_text=False, hunks=[], diff=self.overlay_diff(sid, rel))
        ll, ul, groups = info
        def disp(b): return b.decode("utf-8", "replace").rstrip("\r\n")
        hunks = []
        for gi, group in enumerate(groups):
            a1, a2 = group[0][1], group[-1][2]
            b1, b2 = group[0][3], group[-1][4]
            lines = [("hdr", f"@@ -{a1+1},{a2-a1} +{b1+1},{b2-b1} @@")]
            for tag, i1, i2, j1, j2 in group:
                if tag == "equal":
                    for ln in ll[i1:i2]: lines.append((" ", disp(ln)))
                else:
                    for ln in ll[i1:i2]: lines.append(("-", disp(ln)))
                    for ln in ul[j1:j2]: lines.append(("+", disp(ln)))
            hunks.append(dict(index=gi, lines=lines))
        return dict(is_text=True, hunks=hunks)

    def _settle_file(self, sid, rel) -> None:
        """After a hunk op, if the overlay copy no longer differs from the host (or
        a created file has been emptied), drop it from the overlay and clean up."""
        s = self.sessions.get(sid)
        if not s: return
        rel = rel.lstrip("/")
        upper = Path(s.upper); src = upper / rel; dst = Path("/") / rel
        if not src.is_file(): return
        try:
            up = src.read_bytes()
            settled = (up == dst.read_bytes()) if dst.exists() else (len(up) == 0)
        except OSError:
            return
        if settled:
            self._remove_upper_entry(src)
            self._cleanup_dirs(upper, src.parent)
            self._maybe_remove_empty(sid)

    def overlay_apply_hunk(self, sid, rel, index) -> dict:
        # Apply one hunk forward onto the host file; the overlay already has it, so
        # that hunk simply stops being a difference. Byte-exact: we splice raw
        # byte-lines and write bytes (line endings / encoding preserved verbatim).
        info = self._file_hunks(sid, rel)
        if info is None: return dict(ok=False, error="not a text change")
        ll, ul, groups = info
        if not (0 <= index < len(groups)): return dict(ok=False, error="stale hunk")
        g = groups[index]
        a1, a2, b1, b2 = g[0][1], g[-1][2], g[0][3], g[-1][4]
        new_lower = ll[:a1] + ul[b1:b2] + ll[a2:]
        dst = Path("/") / rel.lstrip("/")
        try:
            dst.parent.mkdir(parents=True, exist_ok=True)
            dst.write_bytes(b"".join(new_lower))
        except OSError as e:
            return dict(ok=False, error=str(e))
        self._settle_file(sid, rel)
        return dict(ok=True)

    def overlay_discard_hunk(self, sid, rel, index) -> dict:
        # Revert one hunk in the overlay file (back to the host's bytes there).
        info = self._file_hunks(sid, rel)
        if info is None: return dict(ok=False, error="not a text change")
        ll, ul, groups = info
        if not (0 <= index < len(groups)): return dict(ok=False, error="stale hunk")
        g = groups[index]
        a1, a2, b1, b2 = g[0][1], g[-1][2], g[0][3], g[-1][4]
        new_upper = ul[:b1] + ll[a1:a2] + ul[b2:]
        src = Path(self.sessions[sid].upper) / rel.lstrip("/")
        try:
            src.write_bytes(b"".join(new_upper))
        except OSError as e:
            return dict(ok=False, error=str(e))
        self._settle_file(sid, rel)
        return dict(ok=True)

    def _remove_upper_entry(self, p: Path) -> None:
        remove_upper_entry(p)

    def _cleanup_dirs(self, upper: Path, start: Path) -> None:
        cleanup_dirs(upper, start)

    def _maybe_remove_empty(self, sid) -> None:
        """A finished session vanishes only when it holds nothing at all — no overlay
        change, no patch, no sqlar, and no network log. The connection log alone is
        reason enough to keep the entry around."""
        s = self.sessions.get(sid)
        if not s or s.live or _pid_alive(s.pid): return
        try: overlay = upper_has_changes(Path(s.upper))
        except OSError: overlay = False
        patch = bool(self._patch(sid)["files"]) or patch_path(sid).exists()
        sqlar = sqlar_path(sid).exists()
        flows = flows_path(sid).exists()
        if not overlay and not patch and not sqlar and not flows:
            self.delete(sid)

    def overlay_apply(self, sid, paths) -> dict:
        # Apply == write the change onto the host, then discard it from the
        # overlay (so the overlay shrinks and can vanish once empty).
        s = self.sessions.get(sid)
        if not s: return dict(applied=[], errors=[{"error": "no session"}])
        upper = Path(s.upper)
        kinds = {e["path"]: e["kind"] for e in self.overlay_entries(sid)}
        paths = paths or list(kinds)
        applied, errors = [], []
        for rel in paths:
            src, dst = upper / rel, Path("/") / rel
            try:
                # A deletion may come from a whiteout *or* from an opaque parent
                # directory (which leaves no per-file artifact in the upper).
                if kinds.get(rel) == "deleted" or self._is_whiteout(src):
                    if dst.is_dir() and not dst.is_symlink(): shutil.rmtree(dst)
                    elif dst.exists() or dst.is_symlink(): dst.unlink()
                elif src.is_dir(): dst.mkdir(parents=True, exist_ok=True)
                elif src.is_file():
                    dst.parent.mkdir(parents=True, exist_ok=True)
                    shutil.copy2(src, dst)
                self._remove_upper_entry(src)       # discard from the overlay
                self._cleanup_dirs(upper, src.parent)
                applied.append(rel)
            except OSError as e:
                errors.append({"path": rel, "error": str(e)})
        self._maybe_remove_empty(sid)
        return dict(applied=applied, errors=errors)

    def overlay_discard(self, sid, paths) -> dict:
        s = self.sessions.get(sid)
        if not s: return dict(discarded=[], errors=[{"error": "no session"}])
        upper = Path(s.upper)
        idx = self.indexes.get(sid)        # live index (deletions live here, not upper)
        paths = paths or [e["path"] for e in self.overlay_entries(sid)]
        discarded, errors = [], []
        for rel in paths:
            r = rel.lstrip("/")
            p = upper / r
            try:
                # drop an index-recorded whiteout (a deletion the box made)
                if idx is not None and idx.kind_of(r) == "whiteout":
                    idx.del_entry(r, op="discard_whiteout")
                self._remove_upper_entry(p)
                self._cleanup_dirs(upper, p.parent)
                discarded.append(rel)
            except OSError as e:
                errors.append({"path": rel, "error": str(e)})
        self._maybe_remove_empty(sid)
        return dict(discarded=discarded, errors=errors)

    # ─── consolidated patch layer (host ← overlay ← patch) ──────────────────
    def _cmd_of(self, sid) -> list:
        s = self.sessions.get(sid)
        return list(s.cmd) if s else []

    @staticmethod
    def _host_lines(rel) -> list:
        host = Path("/") / rel
        try:
            if host.exists() and not host.is_dir(): return ut_split(host.read_bytes())
        except OSError: pass
        return []

    @staticmethod
    def _patch_mtime(sid):
        pf = patch_path(sid)
        try: return pf.stat().st_mtime_ns if pf.exists() else None
        except OSError: return None

    def _patch(self, sid) -> dict:
        """Lazily load the session's patch into memory: {files, dirty, touched, mtime}.
        The patch file can be (re)written behind our back — by the runner when a
        subprocess finishes, or by consolidate() — so when we hold no unsaved edits
        and the on-disk file has changed (appeared / updated / removed) we reload it.
        A dirty in-memory patch is authoritative and never clobbered by a reload."""
        p = self.patches.get(sid)
        st = self._patch_mtime(sid)
        if p is not None and not p["dirty"] and p.get("mtime") != st:
            p = None
        if p is None:
            files = {}
            if st is not None:
                try: files = parse_patch(read_patch_file(patch_path(sid)))
                except Exception: files = {}
            p = self.patches[sid] = dict(files=files, dirty=False,
                                         touched=time.time(), mtime=st)
        return p

    def patch_dirty(self, sid) -> bool:
        return bool(self.patches.get(sid, {}).get("dirty"))

    def save_patch(self, sid) -> None:
        p = self.patches.get(sid)
        if p is None: return
        pf = patch_path(sid)
        if p["files"]:
            write_patch_file(pf, serialize_patch(p["files"]), self._cmd_of(sid))
            s = self.sessions.get(sid)
            if s: s.has_patch = True
        else:
            if pf.exists():
                try: pf.unlink()
                except OSError: pass
            s = self.sessions.get(sid)
            if s: s.has_patch = False
        p["dirty"] = False
        p["mtime"] = self._patch_mtime(sid)
        self._maybe_remove_empty(sid)

    def _patch_warn(self, rel, fp) -> bool:
        base = self._host_lines(rel)
        return any(locate_hunk(base, h) != h["a1"] for h in fp["hunks"])

    def _patch_entries(self, sid) -> list:
        out = []
        for rel, fp in self._patch(sid)["files"].items():
            kind = "deleted" if fp["deleted"] else ("created" if fp["created"] else "modified")
            out.append(dict(path=rel, kind=kind, size=0, is_text=True,
                            stale=self._patch_warn(rel, fp), source="patch"))
        return out

    def _ensure_consolidated(self, sid) -> None:
        """Fold a finished session's overlay into its patch the first time we look
        at it — the same consolidation unregister does, but for orphaned sessions
        sitting on disk (e.g. a crashed runner). Never touches a live/running session
        (its overlay is still moving and its index is owned by the serve loop)."""
        if sid in self._consolidated: return
        s = self.sessions.get(sid)
        if not s or s.live or _pid_alive(s.pid): return
        self._consolidated.add(sid)
        if not (s.shm_dir and Path(s.shm_dir).exists()): return
        # a leftover live index handle (shouldn't exist for a non-live session) —
        # close it so consolidate opens a clean one.
        idx = self.indexes.pop(sid, None)
        if idx is not None:
            try: idx.close()
            except Exception: pass
        try:
            consolidate(s.shm_dir, sid, s.cmd)
        except Exception:
            return
        self.patches.pop(sid, None)        # force a reload of the freshly-written patch
        s.has_patch = patch_path(sid).exists()
        s.has_sqlar = sqlar_path(sid).exists()
        # consolidate() empties the overlay (text → patch, the rest → sqlar), so the
        # backing tree is now spent — free it; the on-disk stores are the record.
        try: empty = not upper_has_changes(Path(s.upper))
        except OSError: empty = False
        if empty:
            rm_rf(s.shm_dir)

    # ─── sqlar layer (binary files, symlinks, deletions a patch can't hold) ──
    def _sqlar_entries(self, sid) -> list:
        out = []
        for name, mode, mtime, sz in sqlar_list(sqlar_path(sid)):
            host = Path("/") / name
            if stat_mod.S_ISCHR(mode):
                kind, stale = "deleted", False
            else:
                exists = host.exists() or host.is_symlink()
                kind = "modified" if exists else "created"
                stale = False
                if exists:
                    try: stale = host.lstat().st_mtime > mtime
                    except OSError: stale = False
            out.append(dict(path=name, kind=kind, size=sz, is_text=False,
                            stale=stale, source="sqlar"))
        return out

    def _in_sqlar(self, sid, rel) -> bool:
        return sqlar_mode(sqlar_path(sid), rel.lstrip("/")) is not None

    def _sqlar_display(self, sid, rel) -> dict:
        sp = sqlar_path(sid); rel = rel.lstrip("/")
        mode = sqlar_mode(sp, rel)
        if mode is None: return dict(is_text=False, hunks=[], diff=dict(kind="error", error="gone"))
        host = Path("/") / rel
        if stat_mod.S_ISCHR(mode):
            return dict(is_text=False, hunks=[], diff=dict(kind="deleted"))
        if stat_mod.S_ISLNK(mode):
            tgt = sqlar_content(sp, rel) or b""
            d = dict(kind="modified" if host.is_symlink() else "created",
                     diff="symlink → " + tgt.decode("utf-8", "replace"))
            return dict(is_text=False, hunks=[], diff=d)
        raw = sqlar_content(sp, rel) or b""
        return dict(is_text=False, hunks=[],
                    diff=dict(kind="modified" if host.exists() else "created",
                              content=base64.b64encode(raw).decode()))

    def _sqlar_apply(self, sid, rel) -> dict:
        sp = sqlar_path(sid); rel = rel.lstrip("/")
        mode = sqlar_mode(sp, rel)
        if mode is None: return dict(ok=False, error="not in archive")
        host = Path("/") / rel
        try:
            if stat_mod.S_ISCHR(mode):                      # tombstone → delete
                if host.is_dir() and not host.is_symlink(): shutil.rmtree(host)
                elif host.exists() or host.is_symlink(): host.unlink()
            elif stat_mod.S_ISLNK(mode):
                tgt = (sqlar_content(sp, rel) or b"").decode("utf-8", "surrogateescape")
                if host.exists() or host.is_symlink(): host.unlink()
                host.parent.mkdir(parents=True, exist_ok=True); os.symlink(tgt, host)
            else:
                host.parent.mkdir(parents=True, exist_ok=True)
                host.write_bytes(sqlar_content(sp, rel) or b"")
                try: os.chmod(host, stat_mod.S_IMODE(mode))
                except OSError: pass
        except OSError as e:
            return dict(ok=False, error=str(e))
        sqlar_remove(sp, rel)
        return dict(ok=True)

    def _sqlar_discard(self, sid, rel) -> dict:
        sqlar_remove(sqlar_path(sid), rel.lstrip("/"))
        return dict(ok=True)

    def session_changes(self, sid) -> list:
        """All changes for a session — overlay, patch and sqlar — each tagged with
        its source. (A file is in exactly one of the three.)"""
        self._ensure_consolidated(sid)
        ov = self.overlay_entries(sid)
        for e in ov: e["source"] = "overlay"
        return ov + self._patch_entries(sid) + self._sqlar_entries(sid)

    def change_mode(self, sid, rel, source) -> "int | None":
        """st_mode for a changed file (for the path/mode header): the overlay copy,
        the sqlar entry, or the host file behind a patch — None if unavailable."""
        rel = rel.lstrip("/")
        if source == "sqlar":
            return sqlar_mode(sqlar_path(sid), rel)
        if source == "overlay":
            s = self.sessions.get(sid)
            if s:
                try: return (Path(s.upper) / rel).lstat().st_mode
                except OSError: return None
        host = Path("/") / rel
        try: return host.lstat().st_mode if (host.exists() or host.is_symlink()) else None
        except OSError: return None

    def _in_patch(self, sid, rel) -> bool:
        return rel.lstrip("/") in self._patch(sid)["files"]

    def hunks(self, sid, rel) -> dict:
        rel2 = rel.lstrip("/")
        if self._in_patch(sid, rel2): return self._patch_hunks_display(sid, rel2)
        if self._in_sqlar(sid, rel2): return self._sqlar_display(sid, rel2)
        return self.overlay_hunks(sid, rel)

    def _patch_hunks_display(self, sid, rel) -> dict:
        fp = self._patch(sid)["files"].get(rel)
        if not fp: return dict(is_text=True, hunks=[])
        base = self._host_lines(rel); hunks = []
        for gi, h in enumerate(fp["hunks"]):
            pos = locate_hunk(base, h)
            warn = ("  ⚠ won't apply" if pos is None else
                    f"  ⚠ offset {pos - h['a1']:+d}" if pos != h["a1"] else "")
            lines = [("hdr", f"@@ -{h['a1']+1} +{h['b1']+1} @@{warn}")]
            for op, bl in h["lines"]:
                lines.append((op, bl.decode("utf-8", "replace").rstrip("\r\n")))
            hunks.append(dict(index=gi, lines=lines))
        return dict(is_text=True, hunks=hunks)

    def apply_hunk(self, sid, rel, index) -> dict:
        rel2 = rel.lstrip("/")
        if self._in_patch(sid, rel2): return self._patch_apply_hunk(sid, rel2, index)
        if self._in_sqlar(sid, rel2): return dict(ok=False, error="binary — apply whole file")
        return self.overlay_apply_hunk(sid, rel, index)

    def discard_hunk(self, sid, rel, index) -> dict:
        rel2 = rel.lstrip("/")
        if self._in_patch(sid, rel2): return self._patch_discard_hunk(sid, rel2, index)
        if self._in_sqlar(sid, rel2): return dict(ok=False, error="binary — discard whole file")
        return self.overlay_discard_hunk(sid, rel, index)

    def _drop_patch_file(self, sid, rel) -> None:
        p = self._patch(sid)
        if rel in p["files"]:
            del p["files"][rel]; p["dirty"] = True; p["touched"] = time.time()

    def _patch_apply_hunk(self, sid, rel, index) -> dict:
        p = self._patch(sid); fp = p["files"].get(rel)
        if not fp or not (0 <= index < len(fp["hunks"])):
            return dict(ok=False, error="stale hunk")
        h = fp["hunks"][index]; host = Path("/") / rel
        try: new, _off = apply_one_hunk(self._host_lines(rel), h)
        except PatchConflict:
            return dict(ok=False, error="hunk does not apply — file left unchanged")
        try:
            host.parent.mkdir(parents=True, exist_ok=True); host.write_bytes(b"".join(new))
        except OSError as e:
            return dict(ok=False, error=str(e))
        del fp["hunks"][index]
        if not fp["hunks"]: del p["files"][rel]
        p["dirty"] = True; p["touched"] = time.time()
        return dict(ok=True)

    def _patch_discard_hunk(self, sid, rel, index) -> dict:
        p = self._patch(sid); fp = p["files"].get(rel)
        if not fp or not (0 <= index < len(fp["hunks"])):
            return dict(ok=False, error="stale hunk")
        del fp["hunks"][index]
        if not fp["hunks"]: del p["files"][rel]
        p["dirty"] = True; p["touched"] = time.time()
        return dict(ok=True)

    def apply(self, sid, paths) -> dict:
        # Route each path to its store: patch (apply every hunk), sqlar (write the
        # blob / delete for a tombstone), or the live overlay.
        if paths is None: paths = [e["path"] for e in self.session_changes(sid)]
        pf = self._patch(sid)["files"]
        res = dict(applied=[], errors=[]); ov = []
        for rel in paths:
            r = rel.lstrip("/")
            if r in pf:
                ok = True
                while pf.get(r, {}).get("hunks"):
                    if not self._patch_apply_hunk(sid, r, 0).get("ok"): ok = False; break
                (res["applied"] if ok else res["errors"]).append(
                    rel if ok else {"path": rel, "error": "some hunks did not apply"})
            elif self._in_sqlar(sid, r):
                rr = self._sqlar_apply(sid, r)
                (res["applied"] if rr.get("ok") else res["errors"]).append(
                    rel if rr.get("ok") else {"path": rel, "error": rr.get("error")})
            else:
                ov.append(rel)
        if ov:
            o = self.overlay_apply(sid, ov)
            res["applied"] += o["applied"]; res["errors"] += o["errors"]
        self._maybe_remove_empty(sid)
        return res

    def discard(self, sid, paths) -> dict:
        if paths is None: paths = [e["path"] for e in self.session_changes(sid)]
        pf = self._patch(sid)["files"]
        res = dict(discarded=[], errors=[]); ov = []
        for rel in paths:
            r = rel.lstrip("/")
            if r in pf:
                self._drop_patch_file(sid, r); res["discarded"].append(rel)
            elif self._in_sqlar(sid, r):
                self._sqlar_discard(sid, r); res["discarded"].append(rel)
            else:
                ov.append(rel)
        if ov:
            o = self.overlay_discard(sid, ov)
            res["discarded"] += o["discarded"]; res["errors"] += o["errors"]
        self._maybe_remove_empty(sid)
        return res


# ════════════════════════════════════════════════════════════════════════════
#  In-process mitmproxy: drive one connection per passed FD
# ════════════════════════════════════════════════════════════════════════════

# A per-connection session id, read by the gating addon's hooks. It is set in
# handle_fd before the mitmproxy handler runs; asyncio copies the current context
# into the child tasks mitmproxy spawns, so each connection's hooks see their own
# session id even when many run concurrently.
_CURRENT_SID: "contextvars.ContextVar[str]" = contextvars.ContextVar(
    "slopbox_session_id", default="")


class _GatingAddon:
    """A mitmproxy addon that gates each http(s) connection through the Supervisor
    and logs completed traffic. It runs inside the UI's addon chain next to
    mitmproxy's own NextLayer / TlsConfig addons, which do the real protocol and
    TLS work — so this only has to make the allow/deny decision."""
    def __init__(self, sup: "Supervisor"):
        self.sup = sup

    def _deny(self, flow):
        from mitmproxy import http
        flow.response = http.Response.make(
            403, b"slopbox: denied\n", {"Content-Type": "text/plain"})

    async def _gate(self, flow, scheme: str, url: str = "") -> None:
        res = await self.sup.approval_request(
            _CURRENT_SID.get(), flow.request.host, flow.request.port, scheme, url)
        if res.get("action") != "allow":
            self._deny(flow)

    async def http_connect(self, flow):
        # https: gate the tunnel by host/ip/cname (the URL isn't visible yet).
        await self._gate(flow, "https")

    async def request(self, flow):
        url = flow.request.pretty_url
        if flow.request.scheme == "http":
            # http has no CONNECT: this is the one place we gate it (URL known).
            await self._gate(flow, "http", url)
        else:
            # https was already gated at CONNECT; here we only enforce a URL-level
            # deny rule, so we don't prompt twice for the same connection.
            if self.sup.precheck(_CURRENT_SID.get(), flow.request.host,
                                 flow.request.port, url) == "deny":
                self._deny(flow)

    def response(self, flow):
        req, resp = flow.request, flow.response
        denied = bool(resp and resp.status_code == 403
                      and b"slopbox: denied" in (resp.content or b""))
        sid = _CURRENT_SID.get(); action = "deny" if denied else "allow"
        self.sup.note_traffic(
            sid, req.host, req.port, req.scheme, action,
            len(req.content or b""),
            len(resp.content or b"") if resp else 0,
            resp.status_code if resp else 0)
        # Persist the whole exchange for after-the-fact review.
        try: req_body = bytes(req.content or b"")
        except Exception: req_body = b""
        try: resp_body = bytes(resp.content or b"") if resp else b""
        except Exception: resp_body = b""
        self.sup.log_flow(sid, dict(
            ts=time.time(), action=action, method=req.method, scheme=req.scheme,
            host=req.host, port=req.port, url=req.pretty_url,
            status=resp.status_code if resp else 0,
            req_headers=list(req.headers.items()), req_body=req_body,
            resp_headers=list(resp.headers.items()) if resp else [], resp_body=resp_body))


class ProxyEngine:
    """
    For each client FD handed over by a slopbox, we build an asyncio stream and run
    a real mitmproxy connection handler against an in-process mitmproxy Master. The
    Master carries mitmproxy's default addons (NextLayer, TlsConfig, …) so http and
    https are handled exactly as mitmproxy would, plus our _GatingAddon which asks
    the Supervisor to allow/deny each host. The upstream fetch happens here, in the
    UI's own network context; the slopbox itself has no route to the internet.
    """
    def __init__(self, sup: "Supervisor", loop: asyncio.AbstractEventLoop,
                 schedule):
        self.sup = sup
        self.loop = loop
        self.schedule = schedule       # call(coro) -> schedules Supervisor coro
        self._master = None
        self._opts = None
        self._mode = None
        self._ready = False
        try:
            from mitmproxy import options as moptions, addons, hooks as mhooks
            from mitmproxy.master import Master
            from mitmproxy.proxy import mode_specs
            opts = moptions.Options()
            master = Master(opts, event_loop=loop)
            master.addons.add(*addons.default_addons())
            master.addons.add(_GatingAddon(sup))
            # Point mitmproxy at our generated CA and keep it from starting any
            # listening server of its own (we feed it connections by hand).
            # Updating options fires ConfigureHook synchronously; we also trigger a
            # full configure so addons like TlsConfig build their cert store now.
            opts.update(confdir=str(MITM_CONFDIR), server=False)
            master.addons.trigger(mhooks.ConfigureHook(set(opts.keys())))
            self._master = master
            self._opts = opts
            self._mode = mode_specs.ProxyMode.parse("regular")
            self._ready = True
        except Exception as e:
            print(f"slopbox(ui): mitmproxy unavailable: {e}", file=sys.stderr)

    @property
    def ready(self) -> bool:
        return self._ready

    async def handle_fd(self, fd: int, session_id: str) -> None:
        if not self._ready:
            try: os.close(fd)
            except OSError: pass
            return
        from mitmproxy.proxy.mode_servers import ProxyConnectionHandler
        from mitmproxy.proxy import layers

        sock = socket.socket(fileno=fd)
        sock.setblocking(False)
        try:
            reader, writer = await asyncio.open_connection(sock=sock)
        except OSError:
            try: sock.close()
            except OSError: pass
            return

        _CURRENT_SID.set(session_id)
        handler = ProxyConnectionHandler(
            self._master, reader, writer, self._opts, self._mode)
        # Seed the regular-proxy top layer exactly as mitmproxy's RegularInstance
        # does; without it the NextLayer addon has no layer stack to reason about.
        handler.layer = layers.modes.HttpProxy(handler.layer.context)
        try:
            await handler.handle_client()
        except Exception:
            pass
        finally:
            try: writer.close()
            except Exception: pass


# ════════════════════════════════════════════════════════════════════════════
#  Control + FD-channel socket server (inside the UI)
# ════════════════════════════════════════════════════════════════════════════

class ChannelServer:
    """
    One Unix socket carries two kinds of client:
      - control clients (runner register/unregister/etc.): newline JSON, no FDs
      - FD clients (inner forwarder): a single sendmsg with {session_id} + 1 FD
    We disambiguate by inspecting the first message's ancillary data.
    """
    def __init__(self, sup: Supervisor, engine: "ProxyEngine", sock_path: str):
        self.sup = sup; self.engine = engine; self.sock_path = sock_path
        self._srv = None

    async def start(self) -> None:
        try: os.unlink(self.sock_path)
        except FileNotFoundError: pass
        # We need ancillary-data (FD) reception, which asyncio streams don't do.
        # So we run a raw socket accept loop in a thread, dispatching to the loop.
        self._sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        self._sock.bind(self.sock_path)
        os.chmod(self.sock_path, 0o600)
        self._sock.listen(128)
        self._sock.setblocking(False)
        self._loop = asyncio.get_event_loop()
        self._task = asyncio.ensure_future(self._accept_loop())

    async def _accept_loop(self) -> None:
        while True:
            try:
                conn, _ = await self._loop.sock_accept(self._sock)
            except (OSError, asyncio.CancelledError):
                break
            asyncio.ensure_future(self._handle(conn))

    async def _handle(self, conn: socket.socket) -> None:
        conn.setblocking(False)
        try:
            # Peek the first message WITH ancillary space to detect an FD.
            msg, anc, _flags, _addr = await self._loop.run_in_executor(
                None, self._recvmsg_blocking, conn)
            fds = []
            for lvl, typ, data in anc:
                if lvl == socket.SOL_SOCKET and typ == socket.SCM_RIGHTS:
                    a = array.array("i"); a.frombytes(data); fds.extend(a.tolist())
            if fds:
                # FD client: forwarder handed us a connection.
                try:
                    meta = json.loads(msg.decode() or "{}")
                except json.JSONDecodeError:
                    meta = {}
                sid = meta.get("session_id", "")
                # hand the first FD to the proxy engine; close any extras
                for extra in fds[1:]:
                    try: os.close(extra)
                    except OSError: pass
                conn.close()
                await self.engine.handle_fd(fds[0], sid)
                return
            # Control client: first line is JSON; keep reading lines. A control
            # message may produce a reply (register acks with the mount path); we
            # write it back on the same connection so the runner can block on it.
            buf = msg
            while True:
                if b"\n" in buf:
                    line, buf = buf.split(b"\n", 1)
                    if line.strip():
                        reply = self._dispatch_control(line)
                        if reply is not None:
                            try:
                                await self._loop.sock_sendall(
                                    conn, (json.dumps(reply) + "\n").encode())
                            except OSError:
                                pass
                    continue
                more = await self._loop.sock_recv(conn, 4096)
                if not more:
                    if buf.strip():
                        reply = self._dispatch_control(buf)
                        if reply is not None:
                            try:
                                await self._loop.sock_sendall(
                                    conn, (json.dumps(reply) + "\n").encode())
                            except OSError:
                                pass
                    break
                buf += more
        except (OSError, asyncio.CancelledError):
            pass
        finally:
            try: conn.close()
            except OSError: pass

    def _recvmsg_blocking(self, conn):
        conn.setblocking(True)
        try:
            return conn.recvmsg(65536, socket.CMSG_SPACE(4 * 16))
        finally:
            conn.setblocking(False)

    def _dispatch_control(self, line: bytes) -> "dict | None":
        try: msg = json.loads(line.decode())
        except json.JSONDecodeError: return None
        t = msg.get("type")
        if t == "register":
            try:
                return self.sup.register(msg)          # acks with the mount path
            except Exception as e:
                return dict(ok=False, error=str(e))
        elif t == "unregister": self.sup.unregister(msg)
        elif t == "remove": self.sup.drop(msg)
        return None

    async def stop(self) -> None:
        if getattr(self, "_task", None):
            self._task.cancel()
        try:
            self._sock.close()
        except OSError:
            pass
        try: os.unlink(self.sock_path)
        except FileNotFoundError: pass


