        RIGHT={"boxes":"#box-detail","changes":"#cd-log","netlog":"#flow-wrap",
               "procs":"#proc-wrap","net":"#rule-detail","file":"#rule-detail"}
        # One direct key per list (shown — and highlighted for the current one — in
        # the bottom key bar). No tab strip: the active view is the lit-up key.
        VIEW_KEY={"boxes":"b","changes":"c","netlog":"t","procs":"p",
                  "net":"w","file":"f"}
        BINDINGS=[
            Binding("b","view_boxes","boxes"),
            Binding("c","view_changes","changes"),
            Binding("t","view_netlog","network"),
            Binding("p","view_procs","processes"),
            Binding("w","view_net","net rules"),
            Binding("f","view_file","file rules"),
            Binding("escape","back","back"),
            Binding("q","quit","quit"),
            # Approval keys act on the oldest pending request from anywhere, without
            # moving focus. The banner shows them in place.
            Binding("y","ap_allow","",show=False),
            Binding("n","ap_deny","",show=False),
            Binding("Y","ap_allow_rule","",show=False),
            Binding("N","ap_deny_rule","",show=False)]
        sessions=reactive({}, layout=True)
        pending=reactive({}, layout=True)

        def __init__(self):
            super().__init__()
            # Snappy, not dial-up: disable smooth-scroll/other animation so
            # PgUp/PgDn jump a page instantly instead of re-compositing the whole
            # screen frame-by-frame.
            self.animation_level="none"
            self.view="boxes"
            self.rules_store=Rules(rules_file())
            self.frules_store=FileRules(file_rules_file())
            # The UI owns the single pyfuse3 overlay mount (started in on_mount on a
            # dedicated trio thread). The Supervisor drives it as boxes come and go.
            # NB: not `self.mount` — that would shadow textual App.mount().
            self.overlay_mount=OverlayMount(mnt_point(), lower="/")
            self.sup=Supervisor(self.rules_store, mount=self.overlay_mount)
            self.sup.on_event=self._on_evt
            self.engine=None
            self.server=None
            self._sel_sid=None
            self._ch_entries=[]
            self._ch_index={}    # {path -> entry} mirror of _ch_entries for O(1) lookup
            # Changes pane is a directory TREE (same scheme as procs): _ch_rows is the
            # DFS-ordered render list [(key, name, depth, connector)], built from
            # _ch_entries only when the change set actually changes (so the 0.3s tick
            # never re-sorts). _ch_conn = connector row keys the cursor skips.
            self._ch_rows=[]; self._ch_conn=set()
            self._nf_flows=[]
            self._last_loaded_sid=None  # guard against reload on re-highlight
            # Live boxes: per-sid incremental change map {rel -> {path,kind,size}},
            # seeded once then folded from the enriched FUSE event stream — never
            # re-walked on the hot path. Finished boxes: their immutable change list
            # is computed once and cached here, invalidated only on a real edit.
            self._live_changes={}     # sid -> {rel -> record}
            self._fin_changes={}      # sid -> [entry,...]  (cached finished set)
            # Viewport-lazy per-row decoration: is_text/stale/precise-kind computed
            # ONLY for rows scrolled into view, cached per (sid -> {rel -> decor})
            # so a row is decorated at most once until its sid cache is invalidated.
            self._ch_decor={}         # sid -> {rel -> {is_text,stale,kind}}
            # Proc pane: a finished box's full process table is immutable, so compute
            # it ONCE and cache it here (like _fin_changes); a live box is served from
            # its Index's bounded active set every tick (O(active set), no full query).
            self._fin_procs={}        # sid -> (procs, tree)  (built once, cached)
            self._pr_conn=set()       # connector-only proc row keys (cursor skips)
            self._pr_procs=[]; self._pr_key=None   # current proc-pane rows + repaint key
            self._pr_pp={}            # tgid->ppid map from the last proc-tree build
            # Off-loop consolidation progress: sid -> (done, total) for the box(es)
            # currently folding in a worker thread. The in-progress set itself lives on
            # review._consolidating (consulted for placeholder gating); this only holds
            # the latest fraction to render. Both are mutated on the UI thread only —
            # the worker marshals updates via call_from_thread.
            self._cons_progress={}
            # Off-loop structural (binary) diff. The heavy readelf/openssl/… parsers
            # run in a worker thread under bwrap, so the UI never blocks decompiling a
            # big binary. Started after a 0.1s debounce (so fast navigation doesn't even
            # spawn them), animated while running, and killed if the selection moves
            # away before it finishes.
            self._struct_gen=0        # bumped on cancel/supersede; stale workers ignored
            self._struct_proc=None    # the live bwrap Popen (killed on navigate-away)
            self._struct_lock=threading.Lock()
            self._struct_timer=None   # 0.1s debounce handle
            self._struct_spin_timer=None; self._struct_spin_item=None; self._struct_spin_i=0
            self._struct_job=None
            self._tick_err_count=0    # throttled error counter for _tick guard sections

        def compose(self) -> ComposeResult:
            yield Header()
            yield Static("", id="cons-bar")       # transient consolidation progress
            yield Static("", id="appr-bar")       # transient approval banner
            with Horizontal(id="main"):
                with Vertical(id="left"):
                    yield Static("", id="left-title", classes="pt")
                    yield SessionTable(id="s-tab", cursor_type="row")
                    yield ChangesTable(id="cf-tab", cursor_type="row")
                    yield NetTable(id="nf-tab", cursor_type="row")
                    yield NetTable(id="pr-tab", cursor_type="row")
                    yield RulesList(id="w-list")
                    yield FileRulesList(id="r-list")
                with Vertical(id="right"):
                    yield Static("", id="right-title", classes="pt")
                    yield Static("", id="cd-info")
                    yield Static("", id="box-detail")
                    yield DiffView(id="cd-log")
                    with VerticalScroll(id="flow-wrap"):
                        yield Static("", id="flow-detail")
                    with VerticalScroll(id="proc-wrap"):
                        yield Static("", id="proc-detail")
                    yield Static("", id="rule-detail")
            yield Static("", id="c-bar")
            yield Static("", id="status")
            yield Static("", id="keybar")         # global keys; active list lit up

        async def on_mount(self):
            self.query_one("#s-tab",DataTable).add_columns(
                "F","Name","PID","Cmd","✓","✗","↑","↓","Age")
            self.query_one("#nf-tab",DataTable).add_columns(
                "Time","","Method","Host","St","↑","↓")
            self.query_one("#cf-tab",DataTable).add_columns("","Path","Size")
            self.query_one("#pr-tab",DataTable).add_columns(
                "TGID","PPID","Exe","Argv")
            loop=asyncio.get_running_loop()
            # ensure_ca_cert may block up to ~5 s (polling for mitmdump to write
            # the CA cert file); run it in a thread-pool executor so it does not
            # stall the UI event loop during startup.
            await loop.run_in_executor(None, ensure_ca_cert)
            # Start the single pyfuse3 overlay mount on its dedicated trio thread.
            # Until it is up, no slopbox can run (it has nowhere to bind its root).
            mount_ok=self.overlay_mount.start()
            # A prior crash may have left orphaned live/<sid> backings: fold them
            # off the loop so startup stays responsive behind a big orphan.
            try: await self.sup.sweep_orphans(loop)
            except Exception: pass
            self.engine=ProxyEngine(self.sup, loop,
                                    lambda coro: asyncio.create_task(coro))
            self.server=ChannelServer(self.sup, self.engine, sock_path())
            await self.server.start()
            msg = f"listening · {sock_path()}"
            if mount_ok:
                msg += f"  ·  overlay {mnt_point()}"
            else:
                err=getattr(self.overlay_mount,"_start_error",None)
                msg += f"  [red](overlay mount FAILED: {err} — slopboxes cannot run)[/]"
            if not self.engine.ready:
                msg += "  [red](mitmproxy unavailable — no gating)[/]"
            self._status(msg)
            self._refresh_rules()
            self._refresh_file_rules()
            for s in self.sup.sessions.values():
                d=s.to_dict(); d["path"]=self.sup.display_path(s.session_id)
                self.sessions={**self.sessions, s.session_id:d}
            self._rebuild_sessions()
            self._set_view("boxes")           # shows only the slopbox list + detail
            self.set_interval(3, self._tick)
            # Live feedback: drain the overlay's thread-safe event queue often so the
            # Changes view updates as the box writes (event-driven, not by polling).
            # The serving thread enqueues; we apply on the UI thread.
            self.set_interval(0.3, self._drain_overlay_events)

        # ── off-loop consolidation (folding a finished box's overlay → sqlar) ──
        def _is_consolidating(self, sid):
            return sid in self.sup.review._consolidating

        def _maybe_start_consolidate(self, sid):
            """If a FINISHED box still needs its overlay folded into the sqlar, kick the
            fold off the UI loop in a worker thread and return True (so the caller shows
            a placeholder instead of reading the not-yet-complete state). Returns False
            when nothing to do (already consolidated, live, or no backing). Idempotent:
            the prep marks the box + drops its stale Index, and _consolidating guards
            against a second worker for the same sid."""
            review=self.sup.review
            if sid in review._consolidating: return True
            args=review._consolidate_prep(sid)        # loop-thread: marks + drops Index
            if args is None: return False             # nothing to fold
            review._consolidating.add(sid)
            self._cons_progress[sid]=(0,0)
            self._render_cons_bar()
            # @work thread worker: consolidate runs OFF the loop; a finished box has no
            # live Index, and consolidate opens its own sqlar conn over this box's own
            # files, so nothing else touches that box's sqlar while it runs.
            self.run_worker(
                lambda: self._consolidate_worker(sid, args["shm_dir"]),
                thread=True, exclusive=False, name=f"consolidate:{sid}")
            return True

        def _consolidate_worker(self, sid, shm_dir):
            """Worker-THREAD body: the slow deflate pass. Touches only this box's files
            via consolidate(); every UI/registry touch is marshaled back to the loop
            with call_from_thread (progress + completion). Never draws from here."""
            def _prog(done, total):
                self.call_from_thread(self._cons_progress_update, sid, done, total)
            try:
                consolidate(shm_dir, sid, progress=_prog)
            except Exception as e:
                self.call_from_thread(self._consolidate_failed, sid, str(e)); return
            self.call_from_thread(self._consolidate_done, sid)

        def _cons_progress_update(self, sid, done, total):
            # LOOP thread (marshaled): record the fraction and repaint the top bar.
            if sid not in self.sup.review._consolidating: return
            self._cons_progress[sid]=(done,total)
            self._render_cons_bar()

        def _consolidate_done(self, sid):
            # LOOP thread (marshaled): finish registry bookkeeping, clear the in-progress
            # flag, and refresh whatever pane is showing this box so the now-consolidated
            # change set renders in place of the placeholder.
            self.sup.review._consolidate_finish(sid)
            self.sup.review._consolidating.discard(sid)
            self._cons_progress.pop(sid, None)
            self._fin_changes.pop(sid, None)   # force a fresh read of the folded sqlar
            self._ch_decor.pop(sid, None)
            self._render_cons_bar()
            if self._sel_sid==sid:
                if self.view=="changes": self._load_changes(sid, force=True)
                elif self.view=="boxes": self._update_box_detail()
                elif self.view=="procs": self._load_procs(sid, force=True)

        def _consolidate_failed(self, sid, err):
            # LOOP thread (marshaled): don't wedge the box forever — drop the flags and
            # surface the error. (prep already added it to _consolidated; clearing that
            # too lets a later view retry the fold.)
            self.sup.review._consolidating.discard(sid)
            self.sup.review._consolidated.discard(sid)
            self._cons_progress.pop(sid, None)
            self._render_cons_bar()
            self._status(Text(f"consolidate {sid[:8]} failed: {err}", style="red"))

        def _render_cons_bar(self):
            bar=self.query_one("#cons-bar",Static)
            cons=self.sup.review._consolidating
            if not cons:
                bar.set_class(False,"show"); bar.update(""); return
            sid=self._sel_sid if self._sel_sid in cons else next(iter(cons))
            done,total=self._cons_progress.get(sid,(0,0))
            t=Text()
            t.append("⟳ Consolidating ", style="bold")
            t.append(sid[:8], style="bold")
            if total:
                pct=int(done*100/total); w=20; fill=int(w*done/total)
                t.append("  ["); t.append("█"*fill, style="bold")
                t.append("·"*(w-fill), style="dim"); t.append(f"] {done}/{total} ({pct}%)")
            else:
                t.append("…")
            if len(cons)>1: t.append(f"  (+{len(cons)-1} more)", style="dim")
            bar.update(t); bar.set_class(True,"show")

        # ── change-set cache: live (incremental) vs finished (static) ──────────
        def _changes_for(self, sid):
            """The change-entry list for a box, cheap on the hot path. A live box is
            served from its incremental map (seeded once); a finished box from a
            cache computed once and invalidated only on a real edit. A finished box
            that still needs folding kicks the off-loop worker and reads as empty
            (placeholder) until it completes."""
            if sid is None: return []
            if self.sup.review._live(sid):
                self._fin_changes.pop(sid, None)
                return self._live_list(sid)
            self._live_changes.pop(sid, None)
            if self._maybe_start_consolidate(sid):
                return []                              # mid-fold: placeholder, no read
            if sid not in self._fin_changes:
                try: self._fin_changes[sid]=self.sup.review.session_changes(sid)
                except Exception: self._fin_changes[sid]=[]
            return self._fin_changes[sid]

        def _live_map(self, sid):
            """The live change set as a {rel->record} dict, seeded with ONE full pass
            the first time the box is shown and kept current incrementally by
            _fold_event thereafter. _fold_event moves each touched key to the end, so
            iteration order is recency (oldest first), newest last."""
            m=self._live_changes.get(sid)
            if m is None:
                m={}
                try:
                    for e in self.sup.review.session_changes(sid):
                        m[e["path"]]=dict(path=e["path"], kind=e["kind"],
                                          size=e.get("size",0))
                except Exception: pass
                self._live_changes[sid]=m
            return m

        def _live_list(self, sid):
            """Sorted entry list for a live box — for the interactive review table,
            which needs a stable order to scroll/select against."""
            m=self._live_map(sid)
            return [m[k] for k in sorted(m)]

        def _live_recent(self, sid, n):
            """The n most-recently-changed entries for a live box, newest first,
            straight from the notify-stream order — no sort. O(n) regardless of how
            many files the box has touched. Returns (total_count, entries)."""
            m=self._live_map(sid)
            keys=list(itertools.islice(reversed(m), n))   # O(n), newest first
            return len(m), [m[k] for k in keys]

        def _fold_event(self, sid, rel, op):
            """Fold one enriched FUSE event into the live map in O(1). Converges to the
            same SET the full walk produces: deletions mark 'deleted'; creates/mods
            upsert with kind 'modified' if the host path exists else 'created'."""
            if rel is None or sid not in self._live_changes: return
            m=self._live_changes[sid]; rel=rel.lstrip("/")
            # The row's content moved: drop its cached decoration so it's recomputed
            # lazily the next time it's visible.
            self._ch_decor.get(sid, {}).pop(rel, None)
            # pop-then-(maybe)-reinsert moves the touched key to the END of the dict,
            # so iteration order tracks recency for the live tail preview.
            m.pop(rel, None)
            if op=="deleted":
                host=Path("/")/rel
                # A create-then-delete of a host-absent path leaves no change.
                if host.exists() or host.is_symlink():
                    m[rel]=dict(path=rel, kind="deleted", size=0)
            else:
                host=Path("/")/rel
                kind="modified" if (host.exists() or host.is_symlink()) else "created"
                m[rel]=dict(path=rel, kind=kind, size=0)

        def _invalidate_changes(self, sid):
            """A real edit happened to a box's change set (hunk/whole-file apply or
            discard, or a file-rule change): drop the cache so the next view recomputes."""
            self._fin_changes.pop(sid, None)
            self._live_changes.pop(sid, None)
            self._ch_decor.pop(sid, None)
            self.sup.review.invalidate_struct(sid)

        def _drain_overlay_events(self):
            # Live proc retirement runs on THIS reliable 0.3s cadence (not the 3s
            # _tick, which can be starved): re-poll the active set every tick the
            # proc pane is open so dead rows retire within _PROC_RETIRE_S even when
            # no overlay events are arriving. _load_procs is a cheap O(active set)
            # kill(0) probe and diffs the table in place (no blink, cursor kept).
            if self.view=="procs" and self._sel_sid:
                try: self._load_procs(self._sel_sid)
                except Exception: pass
            changed=set()
            try:
                while True:
                    ev=self.overlay_mount.event_q.get_nowait()
                    if ev.get("type")=="overlay_changed" and ev.get("sid"):
                        sid=ev["sid"]; changed.add(sid)
                        # Fold into the live map in O(1) — no walk on this 0.3s path.
                        self._fold_event(sid, ev.get("rel"), ev.get("op"))
            except queue.Empty:
                pass
            if not changed: return
            # refresh the live change listing for the affected box if it's on screen.
            # No force: _load_changes reads the cheap in-RAM map and the table diffs
            # in place — the 0.3s drain never re-walks the overlay.
            if self.view=="changes" and self._sel_sid in changed:
                self._load_changes(self._sel_sid)
            if self.view=="boxes" and self._sel_sid in changed:
                self._update_box_detail()

        async def on_unmount(self):
            try: self._cancel_struct()    # kill any in-flight structural parser
            except Exception: pass
            if self.server: await self.server.stop()
            # Tear down the single overlay mount; lazy-unmount fallback keeps the
            # mount table clean even if a handler is wedged.
            try: self.overlay_mount.stop()
            except Exception: pass

        # ── event handling ────────────────────────────────────────────────────
        def _on_evt(self, ev): self.call_later(self._apply_evt, ev)

        def _select_sid(self, sid):
            """Make `sid` the selected box (cursor + patch target) without disturbing
            the current view."""
            self._sel_sid=self._last_loaded_sid=sid
            self.sup.selected_sid=sid
            try:
                tbl=self.query_one("#s-tab",DataTable)
                tbl.move_cursor(row=tbl.get_row_index(sid), animate=False)
            except Exception: pass

        def _most_recent_sid(self):
            if not self.sessions: return None
            return max(self.sessions.items(),
                       key=lambda kv: kv[1]["started"])[0]

        def _apply_evt(self, ev):
            t=ev["type"]
            if t=="session_added":
                s=ev["session"]; self.sessions={**self.sessions,s["session_id"]:s}
                self._rebuild_sessions(preserve=True)
                # A newly-launched box is ALWAYS selected (becomes the patch target).
                self._select_sid(s["session_id"])
                if self.view=="boxes": self._update_box_detail()
            elif t=="session_updated":
                s=ev["session"]; sid=s["session_id"]
                self.sessions={**self.sessions,sid:s}
                self._rebuild_sessions(preserve=True)
                # live→stopped: drop the incremental map and recompute the finished set
                # via _changes_for, which folds OFF the loop when the box still needs it
                # (it usually doesn't — unregister already consolidated on teardown).
                # Self-heals any drift without blocking the loop on a big fold.
                if sid in self._live_changes and not self.sup.review._live(sid):
                    self._live_changes.pop(sid, None)
                    self._ch_decor.pop(sid, None)   # live decor may differ from sqlar
                    self._fin_changes.pop(sid, None)
                    try: self._changes_for(sid)   # populates the cache or starts the fold
                    except Exception: pass
                    if self.view=="changes" and self._sel_sid==sid:
                        self._load_changes(sid, force=True)
                if self.view=="boxes": self._update_box_detail()
            elif t=="session_renamed":
                # A finished/discovered box (no live Session) got a new NAME label.
                sid=ev["session_id"]; cur=self.sessions.get(sid)
                if cur is not None:
                    nd={**cur, "name":ev.get("name") or cur.get("name"),
                        "path":self.sup.display_path(sid)}
                    self.sessions={**self.sessions, sid:nd}
                    self._rebuild_sessions(preserve=True)
                    if self.view=="boxes": self._update_box_detail()
            elif t=="session_removed":
                sid=ev["session_id"]
                self._live_changes.pop(sid, None); self._fin_changes.pop(sid, None)
                self._ch_decor.pop(sid, None)
                self.sessions={k:v for k,v in self.sessions.items() if k!=sid}
                self._rebuild_sessions(preserve=True)
                if self._sel_sid==sid:
                    # The selected box was removed (e.g. an empty box that left no
                    # changes): fall back to the next most-recent remaining entry.
                    nxt=self._most_recent_sid()
                    if nxt:
                        self._select_sid(nxt)
                    else:
                        self._sel_sid=None; self._last_loaded_sid=None
                        self.sup.selected_sid=None
                    self._ch_entries=[]; self._ch_index={}; self._rebuild_ch()
                if self.view=="boxes": self._update_box_detail()
            elif t=="select_box":
                # A CLI `slopbox NAME …` selected this box: move the cursor to it.
                sid=ev["session_id"]
                if sid in self.sessions:
                    self._select_sid(sid)
                    if self.view=="boxes": self._update_box_detail()
            elif t=="approval_pending":
                a=ev["approval"]; self.pending={**self.pending,a["request_id"]:a}
                # No focus stealing: just raise the banner, beep, and (if available)
                # fire a desktop notification. The keys work from wherever you are.
                self._render_appr(); self.bell()
                self._notify("slopbox: approve connection?",
                             f"{a['scheme']} {a['host']}:{a['port']}")
            elif t=="approval_resolved":
                rid=ev["request_id"]
                self.pending={k:v for k,v in self.pending.items() if k!=rid}
                self._render_appr()
            elif t=="rules_updated":
                self._refresh_rules()
                if self.view=="net": self._update_rule_detail()
            elif t=="consolidate_started":
                # unregister's teardown fold runs off-loop; show the #cons-bar +
                # placeholder (it already added the sid to review._consolidating on
                # the loop). Reuses the same progress machinery as the interactive
                # off-loop worker.
                self._cons_progress[ev["session_id"]]=(0,0)
                self._render_cons_bar()
            elif t=="consolidate_progress":
                sid=ev["session_id"]
                if sid in self.sup.review._consolidating:
                    self._cons_progress[sid]=(ev["done"],ev["total"])
                    self._render_cons_bar()
            elif t=="consolidate_finished":
                # unregister already discarded the sid from _consolidating + closed the
                # Index on the loop; drop the fraction, invalidate the now-folded box's
                # caches, repaint, and refresh whatever pane is showing it (a following
                # session_updated/removed event handles the registry-level redraw).
                sid=ev["session_id"]
                self._cons_progress.pop(sid, None)
                self._fin_changes.pop(sid, None); self._ch_decor.pop(sid, None)
                self._render_cons_bar()
                if self._sel_sid==sid:
                    if self.view=="changes": self._load_changes(sid, force=True)
                    elif self.view=="boxes": self._update_box_detail()
                    elif self.view=="procs": self._load_procs(sid, force=True)

        def _tick(self):
            # Watchdog: if a FUSE handler has wedged the single serve loop,
            # lazy-unmount to abort the connection and free parked clients.
            try:
                if self.overlay_mount.watchdog_recover():
                    self._status("[red]overlay handler hung — recovered "
                                 "(lazy-unmounted)[/]")
            except Exception: pass
            # Section-guarded: a failure in any one section must NOT abort the rest
            # (e.g. a rescan/render error used to starve the live proc refresh, so
            # dead rows never retired). Each section is independent and best-effort.
            def _g(fn):
                try: fn()
                except Exception as _e:
                    self._tick_err_count += 1
                    # Throttle: log the first occurrence and every 20th thereafter.
                    if self._tick_err_count == 1 or self._tick_err_count % 20 == 0:
                        import traceback as _tb
                        print(f"slopbox: _tick error (#{self._tick_err_count}):",
                              _tb.format_exc().rstrip(), file=sys.stderr)
            _g(self.sup.rescan)
            _g(lambda: self._rebuild_sessions(preserve=True))
            _g(self._render_appr)
            if self._sel_sid is None:
                s=self._sel_session()
                if s: self._sel_sid=self._last_loaded_sid=s["session_id"]
            self.sup.selected_sid=self._sel_sid
            if self.view=="changes" and self._sel_sid:
                _g(lambda: self._load_changes(self._sel_sid))
            if self.view=="netlog" and self._sel_sid:
                _g(lambda: self._load_flows(self._sel_sid))
            if self.view=="procs" and self._sel_sid:
                _g(lambda: self._load_procs(self._sel_sid))
            if self.view=="boxes":
                _g(self._update_box_detail)
            _g(self._cbar)    # keep the dirty/count indicator current

        # ── view machinery: one left list at a time + its right-pane detail ────
        def _set_view(self, v):
            # Leaving the diff pane: kill any structural parser still running for it.
            if self.view=="changes" and v!="changes":
                self._cancel_struct()
            self.view=v
            for k,sel in self.LEFT.items():
                try: self.query_one(sel).display=(k==v)
                except Exception: pass
            rsel=self.RIGHT[v]
            for sel in set(self.RIGHT.values()):
                try: self.query_one(sel).display=(sel==rsel)
                except Exception: pass
            try: self.query_one("#cd-info").display=(v=="changes")   # full-path header
            except Exception: pass
            self._titles()
            if v=="changes" and self._sel_sid:
                self._load_changes(self._sel_sid, force=True)
                self._update_cd_info()
            if v=="netlog" and self._sel_sid:
                self._load_flows(self._sel_sid, force=True)
            if v=="procs" and self._sel_sid:
                self._load_procs(self._sel_sid, force=True)
            self._update_right()
            try: self.query_one(self.LEFT[v]).focus()
            except Exception: pass

        def action_view_boxes(self): self._set_view("boxes")
        def action_view_changes(self): self._set_view("changes")
        def action_view_procs(self):
            # Cross-pane jump: entering procs FROM a changes/netlog row focuses the
            # process responsible — the file's writer (sqlar writer tag / live Index)
            # or the flow's process_id. Resolve BEFORE switching; graceful if the
            # process isn't in the displayed list (retired / none recorded): just show
            # the pane (a finished box's full table still contains it).
            target=None
            try:
                if self.view=="changes" and self._sel_sid:
                    rel=self._sel_path()
                    if rel: target=self.sup.writer_id(self._sel_sid, rel)
                elif self.view=="netlog" and self._sel_sid:
                    fid=self._sel_flow()
                    if fid is not None:
                        f=self.sup.flow_detail(self._sel_sid, fid)
                        if f: target=f.get("process_id")
            except Exception: target=None
            self._set_view("procs")
            if target is not None: self._focus_proc(target)
        def _focus_proc(self, pid):
            try:
                t=self.query_one("#pr-tab",DataTable)
                t.move_cursor(row=t.get_row_index(str(pid)), animate=False)
            except Exception: pass   # not in the displayed active set — leave cursor
        def action_view_netlog(self): self._set_view("netlog")
        def action_view_net(self): self._set_view("net")
        def action_view_file(self): self._set_view("file")

        # Per-view pane headers (left = the list, right = its detail) and the set of
        # action keys advertised in the bottom bar for that view.
        _LEFT_HDR={
            "boxes":"● SLOPBOXES   [dim]R run · F fin · K kill · ✓/✗ conns[/]",
            "changes":"📁 FILES   [dim]+ new · ~ mod · - del · [/][reverse red]![/][dim] stale[/]",
            "netlog":"🌐 CONNECTIONS   [dim]✓ allowed · ✗ denied · ↑ req · ↓ resp[/]",
            "procs":"⚙ PROCESSES   [dim]tgid · ppid · exe · argv[/]",
            "net":"✓ NETWORK RULES   [dim]top → bottom, first match wins[/]",
            "file":"✓ FILE RULES   [dim]top → bottom, first match wins[/]"}
        _RIGHT_HDR={
            "boxes":"≣ DETAIL","changes":"≡ DIFF","netlog":"≡ REQUEST · RESPONSE",
            "procs":"≡ ENVIRONMENT",
            "net":"⛁ WHAT IT MATCHES","file":"⛁ WHAT IT MATCHES"}
        _ACTS={
            "boxes":[("↵","review"),("k","kill"),("d","delete")],
            "changes":[("↵","diff"),("a","apply"),("x","discard"),
                       ("X","disc all")],
            "netlog":[("↑/↓","browse")],
            "procs":[("↑/↓","browse")],
            "net":[("↵/e","edit"),("d","remove"),("^↑/^↓","move")],
            "file":[("a","add"),("↵/e","edit"),("d","remove"),("^↑/^↓","move")]}

        def _titles(self):
            try: self.query_one("#left-title",Static).update(self._LEFT_HDR[self.view])
            except Exception: pass
            try: self.query_one("#right-title",Static).update(self._RIGHT_HDR[self.view])
            except Exception: pass
            self._keybar()

        def _keybar(self):
            t=Text()
            # Six view keys: the current view is lit up (its key reversed and
            # its name in bright bold, the others dim) so "which view" is obvious.
            for v in self.VIEWS:
                k=self.VIEW_KEY[v]; on=(v==self.view)
                t.append(f" {k} ", style="reverse bold" if on else "bold")
                t.append(self.VIEW_TITLE[v]+"  ",
                         style="bold yellow" if on else "dim")
            t.append(" │  ", style="dim")
            for k,lab in self._ACTS[self.view]:
                t.append(k, style="bold"); t.append(f" {lab}  ", style="dim")
            t.append(" esc back  q quit", style="dim")
            try: self.query_one("#keybar",Static).update(t)
            except Exception: pass

        def _update_right(self):
            if self.view=="boxes": self._update_box_detail()
            elif self.view=="netlog": self._update_flow_detail()
            elif self.view=="procs": self._update_proc_detail()
            elif self.view in ("net","file"): self._update_rule_detail()

        def _notify(self, title, body):
            exe=shutil.which("notify-send")
            if not exe: return
            try:
                subprocess.Popen([exe,"-a","slopbox","-u","critical",title,body],
                                 stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            except Exception: pass

        def _first_pending(self):
            return next(iter(self.pending.values()), None)

        def _render_appr(self):
            bar=self.query_one("#appr-bar",Static)
            if not self.pending:
                bar.set_class(False,"show"); bar.update(""); return
            a=self._first_pending(); n=len(self.pending)
            t=Text()
            t.append("⚡ ALLOW? ", style="bold")
            t.append(a["scheme"]+" ", style="bold")
            t.append(a["host"], style="cyan"); t.append(f":{a['port']}")
            t.append(f"  [{a['session_id'][:8]}]", style="dim")
            if n>1: t.append(f"  (+{n-1} more)", style="dim")
            t.append("      ")
            t.append("y", style="reverse"); t.append(" allow  ")
            t.append("n", style="reverse"); t.append(" deny  ")
            t.append("Y", style="reverse"); t.append(" allow rule…  ")
            t.append("N", style="reverse"); t.append(" deny rule…")
            bar.update(t); bar.set_class(True,"show")

        def _sync_table(self, table, rows):
            # Reconcile a DataTable against the desired (key, cells) rows IN PLACE.
            # When the set+order of rows is unchanged we only rewrite changed cells,
            # so the cursor, scroll and selection are never disturbed by a refresh.
            # Only a structural change (row added/removed/reordered) rebuilds, and
            # even then the cursor is restored by key.
            cur=[rk.value for rk in table.rows]
            new=[k for k,_ in rows]
            if cur==new:
                cols=list(table.columns)
                for key,cells in rows:
                    for ck,val in zip(cols,cells):
                        try:
                            if table.get_cell(key,ck)!=val:
                                table.update_cell(key,ck,val,update_width=False)
                        except Exception: pass
                return
            saved=None
            if table.row_count:
                try: saved=table.coordinate_to_cell_key((table.cursor_row,0)).row_key.value
                except Exception: saved=None
            table.clear()
            for key,cells in rows:
                table.add_row(*cells,key=key)
            if saved is not None:
                try: table.move_cursor(row=table.get_row_index(saved),animate=False)
                except Exception: pass

        # ── pane renderers ────────────────────────────────────────────────────
        def _rebuild_sessions(self, preserve=False):
            # Build a DFS-ordered tree via the shared build_path_tree core (same pattern
            # as the proc pane and changes pane).  Connector rows (a dotted prefix that
            # has no actual box) are skipped — only real boxes appear.  The indent+connector
            # scheme mirrors _ch_indent / the proc-pane indent exactly.
            # Tree structure follows the DERIVED dotted display path (parent_box_id walk);
            # rows are keyed by the box_id key. The leaf label is the box's NAME.
            members={sid: tuple((s.get("path") or s.get("name") or sid).split("."))
                     for sid, s in self.sessions.items()}
            tree_rows=build_path_tree(members, lambda p: ".".join(p))
            rows=[]
            for key, _payload, depth, connector in tree_rows:
                if connector: continue   # structural prefix with no real box — skip
                s=self.sessions.get(key)
                if s is None: continue
                c=sty(s["status"])
                flag={"running":"R","finished":"F","killed":"K"}.get(s["status"],"?")
                indent=self._ch_indent(depth)
                basename=s.get("name") or key   # the box's NAME (display only)
                rows.append((key,[
                    Text(flag, style=c), Text(indent+basename, style=c),
                    str(s["pid"]), Text(" ".join(s["cmd"])[:24]),
                    Text(str(s["conn_allowed"]), style="green"),
                    Text(str(s["conn_denied"]), style="red"),
                    fmt_bytes(s["bytes_up"]), fmt_bytes(s["bytes_down"]),
                    fmt_age(s["started"])]))
            self._sync_table(self.query_one("#s-tab",DataTable), rows)

        def _update_box_detail(self):
            d=self.query_one("#box-detail",Static)
            s=self._sel_session()
            if not s:
                doc=collect_docs()
                if doc:
                    d.update(Text.from_markup(doc))
                else:
                    d.update(Text("(no slopbox selected)", style="dim"))
                return
            sid=s["session_id"]
            t=Text()
            t.append((s.get("path") or s.get("name") or sid)+"\n",
                     style="bold "+(sty(s["status"]) or ""))
            t.append("status  ", style="dim"); t.append(s["status"]+"\n", style=sty(s["status"]))
            t.append("cmd     ", style="dim"); t.append(" ".join(s["cmd"])+"\n")
            t.append("pid     ", style="dim")
            t.append(f"{s['pid']}    age {fmt_age(s['started'])}\n")
            t.append("conns   ", style="dim")
            t.append(f"{s['conn_allowed']} ✓ ", style="green")
            t.append(f"{s['conn_denied']} ✗", style="red")
            t.append(f"    ↑{fmt_bytes(s['bytes_up'])} ↓{fmt_bytes(s['bytes_down'])}\n", style="dim")
            if s.get("has_flows"):
                t.append("network ", style="dim")
                t.append(f"{len(self.sup.flows(sid))} connection(s)   ")
                t.append("[t for log]\n", style="dim")
            live=False
            try: live=self.sup.review._live(sid)
            except Exception: pass
            if live:
                # LIVE: show the notify-stream TAIL — the files that just changed,
                # newest first. O(200), never sorts the (possibly millions-large) set,
                # and it's the meaningful thing to watch while the box runs.
                self._fin_changes.pop(sid, None)
                total, entries = self._live_recent(sid, 200)
                label = "recently changed"
            else:
                try: entries=self._changes_for(sid)   # kicks the off-loop fold if needed
                except Exception: entries=[]
                if self._is_consolidating(sid):
                    t.append("changes ", style="dim")
                    t.append("consolidating…\n", style="bold")
                    d.update(t); return
                total=len(entries); entries=entries[:200]
                label = "↵ to review"
            t.append("changes ", style="dim")
            t.append(f"{total} file(s)   ")
            t.append(f"[{label}]\n\n", style="dim")
            # Preview only (not a scrollable table): use cached decoration where it
            # exists, else the cheap kind with a neutral glyph — never stat all files.
            sig={"created":("+","green"),"modified":("~","yellow"),"deleted":("-","red"),
                 "changed":("·","dim"),"symlink":("·","dim")}
            for e in entries:
                dd=self._decor_of(sid, e["path"])
                kind=dd["kind"] if dd else e["kind"]
                stale=bool(dd and dd.get("stale"))
                sym,col=sig.get(kind,("·","dim"))
                t.append("  "); t.append(sym+" ", style=col)
                t.append(e["path"]+"\n", style="red" if stale else "")
            d.update(t)

        def _update_rule_detail(self):
            d=self.query_one("#rule-detail",Static)
            if self.view=="net":
                rules=self.rules_store.rules
                i=self.query_one("#w-list",ListView).index
                if i is None or not (0<=i<len(rules)):
                    d.update(Text("(no rule — connections fall through to a prompt)", style="dim")); return
                r=rules[i]; t=Text()
                t.append(("ALLOW" if r.action=="allow" else "DENY")+"\n",
                         style="green bold" if r.action=="allow" else "red bold")
                t.append("kind     ", style="dim"); t.append(r.kind+"\n")
                t.append("pattern  ", style="dim"); t.append(r.pattern+"\n\n")
                help={"host":"Match the request's hostname. * and ? wildcards; "
                              "*.example.com also matches example.com. Optional :PORT.",
                      "ip":"Match a resolved IP — a literal address or a CIDR network "
                           "(e.g. 10.0.0.0/8, ::1).",
                      "cname":"Match any name in the DNS CNAME/alias chain (wildcards ok).",
                      "url":"Match http(s) URLs by exact value or prefix."}.get(r.kind,"")
                t.append(help, style="dim"); d.update(t)
            else:
                rules=self.frules_store.rules
                i=self.query_one("#r-list",ListView).index
                if i is None or not (0<=i<len(rules)):
                    d.update(Text("(no rule — changes are kept for review)", style="dim")); return
                r=rules[i]; t=Text()
                acol={"apply":"green bold","discard":"red bold",
                      "passthrough":"cyan bold"}.get(r.action,"bold")
                t.append(r.action.upper()+"\n", style=acol)
                t.append("glob     ", style="dim"); t.append(r.pattern+"\n\n")
                t.append(r.action, style="bold")
                expl={"apply":" writes the change to the host during capture.",
                      "discard":" drops the change during capture.",
                      "passthrough":" acts directly on the real host and captures "
                                    "nothing for this path."}.get(r.action,"")
                t.append(expl+"\n", style="dim")
                t.append("* in a segment · ** across dirs · @(a|b) !(x) {a,b} · "
                         "bare name = any depth · leading / = anchored", style="dim")
                d.update(t)

        def _refresh_rules(self):
            lv=self.query_one("#w-list",ListView)
            idx=lv.index
            lv.clear()
            for r in self.rules_store.rules:
                col="red" if r.action=="deny" else "green"
                sign="−" if r.action=="deny" else "+"
                lv.append(ListItem(Label(Text(f"{sign} {r.kind}:{r.pattern}", style=col))))
            n=len(self.rules_store.rules)
            if idx is not None and n: lv.index=min(idx, n-1)

        def _rule_del(self, i):
            self.rules_store.remove_at(i); self._refresh_rules()
        def _rule_move(self, i, d):
            j=self.rules_store.move(i, d); self._refresh_rules()
            try: self.query_one("#w-list",ListView).index=j
            except Exception: pass
        def _rule_edit_at(self, i):
            rules=self.rules_store.rules
            if i is None or not (0<=i<len(rules)): return
            def done(line):
                if line is None: return
                r=Rule.parse(line)
                if not r: self._status("invalid rule — keeping the old one"); return
                rules[i]=r; self.rules_store.save(); self._refresh_rules()
                try: self.query_one("#w-list",ListView).index=i
                except Exception: pass
            self.push_screen(RuleLineModal(rules[i].to_line()), done)

        @on(ListView.Selected, "#w-list")
        def _rule_activated(self, ev):
            self._rule_edit_at(self.query_one("#w-list",ListView).index)

        def _refresh_file_rules(self):
            lv=self.query_one("#r-list",ListView)
            idx=lv.index; lv.clear()
            _col={"discard":"red","apply":"green","passthrough":"cyan"}
            _sign={"discard":"−","apply":"+","passthrough":"→"}
            for r in self.frules_store.rules:
                col=_col.get(r.action,"green"); sign=_sign.get(r.action,"+")
                lv.append(ListItem(Label(Text(f"{sign} {r.action} {r.pattern}", style=col))))
            n=len(self.frules_store.rules)
            if idx is not None and n: lv.index=min(idx, n-1)

        def _file_rules_changed(self):
            # A new/changed rule should get a chance to act on whatever is still in
            # the overlays, so let those sessions consolidate again on next view.
            self.sup.review.invalidate_consolidation()
            self._fin_changes.clear(); self._live_changes.clear()
            self._ch_decor.clear()
            self._refresh_file_rules()

        def _file_rule_add(self):
            def done(line):
                if not line: return
                r=FileRule.parse(line)
                if not r:
                    self._status("invalid file rule — use: apply|discard <glob>"); return
                self.frules_store.insert(r); self._file_rules_changed()
                try: self.query_one("#r-list",ListView).index=len(self.frules_store.rules)-1
                except Exception: pass
            self.push_screen(FileRuleLineModal("discard "), done)

        def _file_rule_edit_at(self, i):
            rules=self.frules_store.rules
            if i is None or not (0<=i<len(rules)): return
            def done(line):
                if line is None: return
                r=FileRule.parse(line)
                if not r: self._status("invalid file rule — keeping the old one"); return
                rules[i]=r; self.frules_store.save(); self._file_rules_changed()
                try: self.query_one("#r-list",ListView).index=i
                except Exception: pass
            self.push_screen(FileRuleLineModal(rules[i].to_line()), done)

        def _file_rule_del(self, i):
            self.frules_store.remove_at(i); self._file_rules_changed()
        def _file_rule_move(self, i, d):
            j=self.frules_store.move(i, d); self._file_rules_changed()
            try: self.query_one("#r-list",ListView).index=j
            except Exception: pass

        @on(ListView.Selected, "#r-list")
        def _file_rule_activated(self, ev):
            self._file_rule_edit_at(self.query_one("#r-list",ListView).index)

        def _decor_of(self, sid, rel):
            """Cached per-row decoration for (sid, rel), or None if not yet computed."""
            return self._ch_decor.get(sid, {}).get(rel)

        def _ch_indent(self, depth):
            # Same indent glyph/scheme as the proc pane, for visual consistency.
            return "  "*depth + ("└ " if depth else "")

        def _ch_cells(self, e, depth):
            # One REAL change row's cells from the cheap backbone + its (maybe-absent)
            # lazy decoration. The NAME column shows only the basename, indented by tree
            # depth (the full path lives in the cd-info header above the diff). An
            # undecorated changed/symlink row renders with a neutral '…' placeholder
            # rather than a guessed kind; deleted is known from the backbone.
            sigs={"created":("+","green"),"modified":("~","yellow"),"deleted":("-","red")}
            d=self._decor_of(self._sel_sid, e["path"])
            kind=d["kind"] if d else e["kind"]
            stale=bool(d and d.get("stale"))
            sym,col=sigs.get(kind,("…","dim"))
            t=Text(sym, style=col)
            if stale: t.append("!", style="reverse red")  # host is newer
            name=e["path"].rsplit("/",1)[-1]
            return [t, Text(self._ch_indent(depth)+name, style="red" if stale else ""),
                    fmt_bytes(e["size"]) if e["size"] else ""]

        def _conn_cells(self, name, depth):
            # A structural directory row (a prefix that isn't itself a change): dimmed,
            # basename + "/", cursor-skipped — display-only, never an apply target.
            return [Text(""), Text(self._ch_indent(depth)+name+"/", style="dim"), ""]

        def _build_ch_tree(self):
            # Build the change set into a DFS-ordered directory tree via the shared
            # generic core. Members keyed by full path, path tuple = path components.
            # Connector dir prefixes (not themselves changes) come back as tuple keys;
            # give them a stable "d/<joined>" string row key so the cursor can skip them.
            members={e["path"]:tuple(e["path"].split("/")) for e in self._ch_entries}
            rows=[]; conn=set()
            for key, joined, depth, connector in build_path_tree(members, lambda p:"/".join(p)):
                if connector:
                    rk="d/"+joined; conn.add(rk)
                    rows.append((rk, joined.rsplit("/",1)[-1], depth, True))
                else:
                    rows.append((key, joined.rsplit("/",1)[-1], depth, False))
            self._ch_rows=rows; self._ch_conn=conn

        def _rebuild_ch(self, preserve=False):
            # Rebuild the cached tree (set/order/labels) then feed it to _sync_table;
            # only runs when _ch_entries actually changed, so the 0.3s tick never sorts.
            self._build_ch_tree()
            ent={e["path"]:e for e in self._ch_entries}
            rows=[]
            for rk, name, depth, connector in self._ch_rows:
                if connector: rows.append((rk, self._conn_cells(name, depth)))
                else: rows.append((rk, self._ch_cells(ent[rk], depth)))
            self._sync_table(self.query_one("#cf-tab",DataTable), rows)
            self._skip_conn_ch()
            self._decorate_visible()

        def _skip_conn(self, t, conn):
            # Nudge the cursor off a connector row: scan forward then back to nearest real row.
            if not conn: return
            if not t.row_count: return
            try: ck=t.coordinate_to_cell_key((t.cursor_row,0)).row_key.value
            except Exception: return
            if ck not in conn: return
            keys=[rk.value for rk in t.rows]
            i=t.cursor_row
            nxt=next((j for j in range(i+1,len(keys)) if keys[j] not in conn),
                     next((j for j in range(i-1,-1,-1) if keys[j] not in conn), None))
            if nxt is not None:
                try: t.move_cursor(row=nxt, animate=False)
                except Exception: pass

        def _skip_conn_ch(self):
            # Keep the cursor off dimmed connector dir rows: nudge to the next real entry.
            self._skip_conn(self.query_one("#cf-tab",DataTable), self._ch_conn)

        def _decorate_visible(self):
            # Viewport-scoped lazy decoration: compute is_text/stale/precise-kind ONLY
            # for the REAL rows currently scrolled into view (DataTable renders only
            # those), cache per (sid,rel), then repaint just those cells. Connector dir
            # rows need no decoration. Never iterates all n.
            sid=self._sel_sid
            if sid is None or self.view!="changes": return
            try: tbl=self.query_one("#cf-tab",DataTable)
            except Exception: return
            n=len(self._ch_rows)
            if not n: return
            top=max(0, int(tbl.scroll_offset.y))
            # Before first layout size.height is 0 — fall back to a small window, NEVER
            # n, so a huge box is never fully decorated at first paint.
            h=tbl.size.height or 40
            lo=max(0, top-2); hi=min(n, top+h+2)   # small over-scan for smoothness
            ent={e["path"]:e for e in self._ch_entries}
            cache=self._ch_decor.setdefault(sid, {})
            cols=list(tbl.columns); src=None
            for i in range(lo, hi):
                rk, name, depth, connector = self._ch_rows[i]
                if connector: continue            # structural dir row: no decoration
                e=ent.get(rk)
                if e is None: continue
                rel=e["path"]
                if rel in cache: continue
                if e["kind"]=="deleted":
                    cache[rel]=dict(is_text=False, stale=False, kind="deleted")
                else:
                    if src is None: src=self.sup.review._source(sid)
                    try: cache[rel]=self.sup.review.decorate(sid, rel, source=src)
                    except Exception: cache[rel]=dict(is_text=False, stale=False, kind=e["kind"])
                cells=self._ch_cells(e, depth)
                for ck,val in zip(cols, cells):
                    try:
                        if tbl.get_cell(rel,ck)!=val:
                            tbl.update_cell(rel,ck,val,update_width=False)
                    except Exception: pass

        def _diff_info_lines(self, d):
            k=d.get("kind")
            if k=="deleted": return [Text("DELETED", style="red bold")]
            if k=="directory": return [Text("DIRECTORY", style="cyan")]
            if k=="error": return [Text(str(d.get("error")), style="red")]
            diff=d.get("diff"); out=[]
            if diff is not None:
                for ln in diff.splitlines():
                    if ln.startswith(("+++","---")): out.append(Text(ln, style="bold"))
                    elif ln.startswith("+"): out.append(Text(ln, style="green"))
                    elif ln.startswith("-"): out.append(Text(ln, style="red"))
                    elif ln.startswith("@@"): out.append(Text(ln, style="cyan"))
                    else: out.append(Text(ln, style="dim"))
                if not diff.strip(): out.append(Text("(no textual diff)", style="dim"))
            else:
                raw=base64.b64decode(d.get("content") or b"")
                out.append(Text(f"binary · {fmt_bytes(len(raw))}", style="dim"))
                for i in range(0,min(len(raw),256),16):
                    ch=raw[i:i+16]; h=" ".join(f"{b:02x}" for b in ch)
                    a="".join(chr(b) if 0x20<=b<0x7f else "." for b in ch)
                    out.append(Text(f"{i:04x}  {h:<48}  {a}", style="dim"))
            return out

        _STRUCT_STYLE={"type":"yellow","hdr":"bold cyan","+":"green","-":"red",
                       "@":"cyan","err":"red"," ":"dim","dim":"dim"}
        def _struct_text(self, style, txt):
            return Text(txt, style=self._STRUCT_STYLE.get(style, ""))

        # ── off-loop structural (binary) diff: debounce + spinner + cancel ──────
        def _cancel_struct(self):
            """Supersede any in-flight structural diff: stop the debounce, stop the
            spinner, and KILL the running bwrap parser (don't keep decompiling a 100MB
            binary the user has navigated away from). Bumping the generation makes any
            worker already past the kill point discard its result."""
            self._struct_gen += 1
            if self._struct_timer is not None:
                try: self._struct_timer.stop()
                except Exception: pass
                self._struct_timer=None
            self._stop_struct_spin()
            with self._struct_lock:
                proc=self._struct_proc; self._struct_proc=None
            if proc is not None:
                try: os.killpg(proc.pid, signal.SIGKILL)
                except Exception:
                    try: proc.kill()
                    except Exception: pass
            self._struct_job=None

        def _stop_struct_spin(self):
            if self._struct_spin_timer is not None:
                try: self._struct_spin_timer.stop()
                except Exception: pass
                self._struct_spin_timer=None
            self._struct_spin_item=None

        def _struct_spin_tick(self):
            frames="⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏"
            self._struct_spin_i=(self._struct_spin_i+1)%len(frames)
            if self._struct_spin_item is not None:
                try: self._struct_spin_item.update(Text(
                    f"  {frames[self._struct_spin_i]} analyzing structure…  "
                    "(navigate away to cancel)", style="dim"))
                except Exception: pass

        def _begin_struct(self, sid, rel, job, dv):
            """A heavyweight structural diff is pending for (sid,rel): show an animated
            indicator now and start the sandboxed parser after a 0.1s debounce, so
            scrolling through rows stays smooth and only the row you settle on runs."""
            self._struct_job=job
            self._struct_spin_i=0
            self._struct_spin_item=Label(Text("  ⠋ analyzing structure…  "
                                              "(navigate away to cancel)", style="dim"))
            dv.append(ListItem(self._struct_spin_item))
            self._struct_spin_timer=self.set_interval(0.12, self._struct_spin_tick)
            gen=self._struct_gen
            self._struct_timer=self.set_timer(
                0.1, lambda: self._run_struct(gen, sid, rel, job))

        def _run_struct(self, gen, sid, rel, job):
            if gen != self._struct_gen: return        # superseded during the debounce
            self._struct_timer=None
            self.run_worker(lambda: self._struct_worker(gen, sid, rel, job),
                            thread=True, exclusive=False, name="structdiff")

        def _struct_worker(self, gen, sid, rel, job):
            """Worker THREAD: run the sandboxed parser(s). on_spawn registers the bwrap
            Popen so _cancel_struct can kill it; a generation bump makes us discard a
            late result. Result is cached by structural_diff_finish; the loop just
            re-renders from cache."""
            def on_spawn(proc):
                with self._struct_lock:
                    if gen == self._struct_gen: self._struct_proc=proc
                    else:
                        try: os.killpg(proc.pid, signal.SIGKILL)
                        except Exception:
                            try: proc.kill()
                            except Exception: pass
            try:
                self.sup.review.structural_diff_finish(job, on_spawn=on_spawn)
            finally:
                with self._struct_lock: self._struct_proc=None
            self.call_from_thread(self._struct_done, gen, sid, rel)

        def _struct_done(self, gen, sid, rel):
            if gen != self._struct_gen: return        # superseded: ignore
            self._stop_struct_spin()
            # The result is now cached; re-render the diff in place (quick() returns the
            # full cached lines, no job, so no new worker is kicked).
            if (self.view=="changes" and self._sel_sid==sid
                    and self._sel_path()==rel):
                self._load_diff(sid, rel, keep_pos=True)

        def _update_cd_info(self, rel=None):
            # Full path + kind/size/mode shown above the diff, since the file
            # list truncates the path to keep the basename readable.
            info=self.query_one("#cd-info",Static)
            rel = rel if rel is not None else self._sel_path()
            ent = self._ch_index.get(rel) if rel else None
            if not ent:
                info.update(Text("")); return
            mode = self.sup.review.change_mode(self._sel_sid, ent["path"])
            # The selected row is visible → use its lazy decoration for the precise
            # kind/stale (decorate on the spot if it hasn't been seen yet).
            d=self._decor_of(self._sel_sid, ent["path"])
            if d is None and ent["kind"]!="deleted":
                try: d=self._ch_decor.setdefault(self._sel_sid, {}).setdefault(
                    ent["path"], self.sup.review.decorate(self._sel_sid, ent["path"]))
                except Exception: d=None
            kind=d["kind"] if d else ent["kind"]
            stale=bool(d and d.get("stale"))
            t=Text()
            t.append("/"+ent["path"], style="bold")
            t.append("\n")
            t.append(f"{kind}", style="dim")
            if ent.get("size"): t.append(f" · {fmt_bytes(ent['size'])}", style="dim")
            if mode is not None:
                t.append(f" · {stat_mod.filemode(mode)} {oct(stat_mod.S_IMODE(mode))}", style="dim")
            if stale:
                t.append("  ⚠ host changed since capture", style="reverse red")
            info.update(t)

        def _load_diff(self, sid, rel, keep_pos=False):
            dv=self.query_one("#cd-log",DiffView)
            keep=dv.index if keep_pos else None
            # Supersede any structural diff in flight for a previous row: stop its
            # spinner and KILL its bwrap parser so navigation never blocks or lingers.
            self._cancel_struct()
            res=self.sup.review.hunks(sid, rel)
            dv.clear()
            if res.get("is_text"):
                hunks=res.get("hunks") or []
                if not hunks:
                    dv.append(ListItem(Label(Text("(no textual differences)", style="dim"))))
                for h in hunks:
                    dv.append(HunkItem(h["index"], h["lines"]))
            else:
                for line in self._diff_info_lines(res.get("diff") or {}):
                    dv.append(ListItem(Label(line)))
                # Read-only binary insight: libmagic type + (for recognized types) a
                # structural diff. The FAST half (type + differ pick) renders now; the
                # heavy sandboxed parser runs off-loop, debounced 0.1s, animated, and
                # cancellable — so a big binary never locks the UI.
                try: head, job = self.sup.review.structural_diff_quick(sid, rel)
                except Exception: head, job = [], None
                if head: dv.append(ListItem(Label(Text(""))))
                for style, txt in head:
                    dv.append(ListItem(Label(self._struct_text(style, txt))))
                if job is not None:
                    self._begin_struct(sid, rel, job, dv)
            n=len(dv.children)
            if keep is not None and n: dv.index=min(keep, n-1)
            elif n: dv.index=0   # highlight a hunk so a/x act without an extra step

        def _hunk_op(self, index, discard):
            sid=self._sel_sid; p=self._sel_path()
            if not sid or p is None: return
            r=(self.sup.review.discard_hunk if discard
               else self.sup.review.apply_hunk)(sid, p, index)
            if not r.get("ok"): self._status(Text(r.get("error") or "hunk op failed")); return
            self._invalidate_changes(sid)   # a real edit changed the set
            self._load_changes(sid)
            if any(e["path"]==p for e in self._ch_entries):
                self._load_diff(sid, p, keep_pos=True)
            else:
                try: self.query_one("#cd-log",DiffView).clear()
                except Exception: pass
            self._cbar("hunk " + ("discarded" if discard else "applied"))
        def _hunk_apply(self, index): self._hunk_op(index, discard=False)
        def _hunk_discard(self, index): self._hunk_op(index, discard=True)

        def _status(self, t):
            try: self.query_one("#status",Static).update(t)
            except Exception: pass
        def _cbar(self, msg=""):
            n=len(self._ch_entries)
            extra=f"{n} change(s)" + (f"  ·  {msg}" if msg else "")
            # Persistent indicator when mitmproxy is unavailable: networking is off
            # and all connections from slopboxes will be silently dropped.
            net_warn = ("  [red bold]⚡ mitmproxy unavailable — networking disabled[/]"
                        if self.engine is not None and not self.engine.ready else "")
            try: self.query_one("#c-bar",Static).update(f"  [dim]{extra}[/]{net_warn}")
            except Exception: pass

        def _sel_session(self):
            t=self.query_one("#s-tab",DataTable)
            if not t.row_count: return None
            try: return self.sessions.get(
                t.coordinate_to_cell_key((t.cursor_row,0)).row_key.value)
            except Exception: return None
        def _sel_path(self):
            # The selected REAL change's full path. Connector dir rows are display-only:
            # the cursor skips them, but guard here too so apply/discard/p-jump never act
            # on a structural row.
            t=self.query_one("#cf-tab",DataTable)
            if not t.row_count: return None
            try: k=t.coordinate_to_cell_key((t.cursor_row,0)).row_key.value
            except Exception: return None
            return None if k in self._ch_conn else k

        def _load_changes(self, sid, force=False):
            entries=self._changes_for(sid)   # kicks the off-loop fold if needed
            # Mid-fold: show a placeholder row, never the partial state. _changes_for
            # already started the worker; just render the wait.
            if self._is_consolidating(sid):
                self._ch_entries=[]; self._ch_index={}
                self._sync_table(self.query_one("#cf-tab",DataTable),
                                 [("consolidating",
                                   [Text(""), Text("consolidating…", style="dim"),
                                    Text("")])])
                self._ch_rows=[]; self._ch_conn=set()
                self._cbar("consolidating…")
                return
            # Only touch the table when the set of changes actually differs, so the
            # periodic refresh keeps the pane live without blinking or losing the
            # cursor while nothing is changing.
            if not force and entries==self._ch_entries:
                return
            self._ch_entries=entries
            self._ch_index={e["path"]:e for e in entries}
            self._rebuild_ch(preserve=True)
            self._cbar()

        def _load_flows(self, sid, force=False):
            flows=self.sup.flows(sid)
            # Flows are append-only (AUTOINCREMENT id, never updated). A cheap
            # change-key (count, last id) is equivalent to full equality for these.
            def _flows_key(fl): return (len(fl), fl[-1]["id"] if fl else None)
            if not force and _flows_key(flows)==_flows_key(self._nf_flows):
                return
            self._nf_flows=flows
            def row(f):
                act="✓" if f["action"]=="allow" else "✗"
                col="green" if f["action"]=="allow" else "red"
                hp=f"{f['host']}:{f['port']}" if f["port"] not in (80,443) else f["host"]
                stc="green" if 200<=f["status"]<400 else ("red" if f["status"]>=400 else "")
                return (f["id"], [
                    Text(time.strftime("%H:%M:%S", time.localtime(f["ts"]))),
                    Text(act, style=col), Text(f["method"]),
                    Text(hp, style="cyan"),
                    Text(str(f["status"] or ""), style=stc),
                    fmt_bytes(f["req_len"]), fmt_bytes(f["resp_len"])])
            self._sync_table(self.query_one("#nf-tab",DataTable), [row(f) for f in flows])
            self._update_flow_detail()

        def _update_flow_detail(self):
            d=self.query_one("#flow-detail",Static)
            sid=self._sel_sid; fid=self._sel_flow()
            if not sid or fid is None:
                d.update(Text("(no connection selected)", style="dim")); return
            f=self.sup.flow_detail(sid, fid)
            if not f:
                d.update(Text("(gone)", style="dim")); return
            def body(blob, n):
                if not blob: return Text("  (empty)\n", style="dim")
                raw=bytes(blob)
                try:
                    txt=raw.decode("utf-8")
                    t=Text(txt[:8000])
                    if len(txt)>8000 or n>len(raw): t.append(f"\n  … {fmt_bytes(n)} total\n", style="dim")
                    else: t.append("\n")
                    return t
                except UnicodeDecodeError:
                    return Text(f"  binary · {fmt_bytes(n)}\n", style="dim")
            t=Text()
            t.append(f["action"].upper()+"  ", style="green bold" if f["action"]=="allow" else "red bold")
            t.append(f["method"]+" ", style="bold")
            t.append(f["url"], style="cyan"); t.append("\n\n")
            t.append("── request headers ──\n", style="dim")
            t.append((f["req_headers"] or "").rstrip()+"\n", style="")
            t.append("── request body ──\n", style="dim"); t.append(body(f["req_body"], f["req_len"]))
            t.append("\n")
            t.append(f"── response  [{f['status']}] ──\n", style="dim")
            t.append((f["resp_headers"] or "").rstrip()+"\n", style="")
            t.append("── response body ──\n", style="dim"); t.append(body(f["resp_body"], f["resp_len"]))
            d.update(t)

        def _sel_flow(self):
            t=self.query_one("#nf-tab",DataTable)
            if not t.row_count: return None
            try: return t.coordinate_to_cell_key((t.cursor_row,0)).row_key.value
            except Exception: return None

        # ── processes pane (the selected box's process table) ────────────────
        def _load_procs(self, sid, force=False):
            # LIVE box: the Index's bounded active set (htop-style), O(active set), no
            # full-table query — dead-but-not-yet-retired rows are highlighted. FINISHED
            # box: the full immutable process history, tree-built once and cached.
            # Both render as a process TREE: build_proc_tree gives DFS-ordered rows,
            # depth-indented; connector-only ancestors (added to connect the tree) are
            # dimmed and the cursor skips them. The live lookup resolves ancestors
            # outside the active set; the finished full table is self-contained.
            # Mid-fold (finished box still consolidating): the sqlar this pane reads is
            # being rewritten off the loop — show the placeholder, don't read it.
            if not self.sup.review._live(sid) and self._maybe_start_consolidate(sid):
                self._sync_table(self.query_one("#pr-tab",DataTable),
                                 [("consolidating",
                                   [Text("…"), Text(""),
                                    Text("consolidating", style="dim"), Text("")])])
                self._pr_key=None
                self._update_proc_detail()
                return
            root=self.sup.proc_roots(sid)
            live=self.sup.processes_live(sid)
            if live is not None:
                self._fin_procs.pop(sid, None)
                key=live
                procs=[(p, tg, pp, ex, av) for (p, tg, pp, ex, av, _al, _dd) in live]
                dead={tg for (_p, tg, _pp, _ex, _av, _al, dd) in live if dd}
                tree=build_proc_tree(procs, root,
                                     lambda tg: self.sup.proc_info(sid, tg))
            else:
                if sid not in self._fin_procs:
                    procs=self.sup.processes(sid)
                    self._fin_procs[sid]=(procs, build_proc_tree(procs, root, None))
                procs,tree=self._fin_procs[sid]
                key=procs; dead=set()
            cur=getattr(self,"_pr_key",None)
            if not force and key==cur: return
            # Capture the cursored proc's tgid before the rebuild (real row key is
            # str(pid)->tgid via the prior snapshot; connector key is "c<tgid>"); if it
            # vanishes we relocate the cursor to its nearest surviving ancestor below.
            pt=self.query_one("#pr-tab",DataTable)
            cur_tg=None
            try: ck=pt.coordinate_to_cell_key((pt.cursor_row,0)).row_key.value
            except Exception: ck=None
            if ck is not None:
                if isinstance(ck,str) and ck.startswith("c"):
                    try: cur_tg=int(ck[1:])
                    except ValueError: cur_tg=None
                else:
                    cur_tg=next((tg for (p,tg,_pp,_ex,_av) in (self._pr_procs or [])
                                 if str(p)==ck), None)
            prev_pp=getattr(self,"_pr_pp",{})
            self._pr_key=key
            self._pr_procs=[(p,tg,pp,ex,av) for (p,tg,pp,ex,av,_d,c) in tree if not c]
            self._pr_conn={("c"+str(tg)) for (_p,tg,_pp,_ex,_av,_d,c) in tree if c}
            # New-tree maps for the ancestor walk: tgid->row key (present) and tgid->ppid
            # (combined with the prior snapshot so a multi-level vanish still resolves).
            present={}; new_pp={}
            rows=[]
            for pid, tgid, ppid, exe, argv, depth, conn in tree:
                indent=self._ch_indent(depth)
                nm=Text(indent+(exe.rsplit("/",1)[-1] or exe or "?")[:18], style="cyan")
                ar=Text(" ".join(argv)[:40], style="dim")
                if conn:                          # structural-only ancestor: dimmed
                    rk="c"+str(tgid)
                    tg=Text(str(tgid), style="dim"); pp=Text(str(ppid), style="dim")
                    nm.stylize("dim"); ar.stylize("dim")
                elif tgid in dead:                # htop-style: process exited, flashing out
                    rk=str(pid)
                    tg=Text(str(tgid), style="red"); pp=Text(str(ppid), style="red")
                    nm.stylize("red"); ar.stylize("red")
                else:
                    rk=str(pid); tg=str(tgid); pp=str(ppid)
                present[tgid]=rk; new_pp[tgid]=ppid
                rows.append((rk, [tg, pp, nm, ar]))
            ppid_of=dict(prev_pp); ppid_of.update(new_pp)
            self._pr_pp=new_pp
            # Capture the user's vertical scroll so a scrolled-down tree view
            # survives the rebuild (clear()+re-add resets scroll_y to 0).
            scroll_y=pt.scroll_offset.y
            self._sync_table(pt, rows)
            # If the cursored proc vanished, move to its nearest surviving ancestor
            # (root only if the whole chain is gone). _sync_table left the cursor at row
            # 0 since the key was absent; relocate before connector-skip.
            if cur_tg is not None and cur_tg not in present:
                rk=nearest_surviving_row(cur_tg, ppid_of, present)
                if rk is not None:
                    try: pt.move_cursor(row=pt.get_row_index(rk), animate=False)
                    except Exception: pass
            self._skip_conn_proc()
            # Restore scroll after rows/cursor settle, clamped to new content.
            try: pt.scroll_to(y=min(scroll_y, max(0, pt.virtual_size.height-pt.scrollable_content_region.height)), animate=False)
            except Exception: pass
            self._update_proc_detail()

        def _skip_conn_proc(self):
            # Keep the cursor off dimmed connector rows: nudge to the next real member.
            self._skip_conn(self.query_one("#pr-tab",DataTable), getattr(self,"_pr_conn",None))

        def _sel_proc(self):
            t=self.query_one("#pr-tab",DataTable)
            if not t.row_count: return None
            try: return int(t.coordinate_to_cell_key((t.cursor_row,0)).row_key.value)
            except Exception: return None

        def _update_proc_detail(self):
            d=self.query_one("#proc-detail",Static)
            sid=self._sel_sid; pid=self._sel_proc()
            if not sid or pid is None:
                d.update(Text("(no process selected)", style="dim")); return
            row=next((p for p in (self._pr_procs or []) if p[0]==pid), None)
            t=Text()
            if row:
                _id,tgid,ppid,exe,argv=row
                t.append(f"tgid {tgid}  ppid {ppid}\n", style="bold")
                t.append("exe   ", style="dim"); t.append((exe or "?")+"\n")
                t.append("argv  ", style="dim"); t.append(" ".join(argv)+"\n\n")
            env=self.sup.process_env(sid, pid)
            t.append("── environment ──\n", style="dim")
            if not env:
                t.append("(none captured — run with -t to record the environment)\n",
                         style="dim")
            for k in sorted(env):
                t.append(k, style="cyan"); t.append("="+env[k]+"\n")
            d.update(t)

        @on(DataTable.RowHighlighted, "#pr-tab")
        def _ph(self, ev):
            if self.view!="procs": return
            if ev.row_key and ev.row_key.value in getattr(self,"_pr_conn",()):
                self._skip_conn_proc()
            self._update_proc_detail()

        @on(DataTable.RowHighlighted, "#s-tab")
        def _sc(self, ev):
            if ev.row_key and ev.row_key.value:
                sid=ev.row_key.value
                self._sel_sid=sid
                if sid!=self._last_loaded_sid:
                    self._last_loaded_sid=sid
                    self._load_changes(sid, force=True)
                if self.view=="boxes": self._update_box_detail()

        @on(DataTable.RowSelected, "#s-tab")
        def _s_open(self, ev):
            # Enter on a slopbox → review its changes.
            if ev.row_key and ev.row_key.value:
                self._sel_sid=ev.row_key.value; self._last_loaded_sid=ev.row_key.value
                self._set_view("changes")

        @on(DataTable.RowHighlighted, "#cf-tab")
        def _cc(self, ev):
            if ev.row_key and ev.row_key.value in self._ch_conn:
                self._skip_conn_ch(); return       # nudge off the dimmed dir row
            if ev.row_key and ev.row_key.value and self._sel_sid:
                self._decorate_visible()
                self._update_cd_info(ev.row_key.value)
                self._load_diff(self._sel_sid, ev.row_key.value)

        @on(DataTable.RowHighlighted, "#nf-tab")
        def _nc(self, ev):
            if self.view=="netlog": self._update_flow_detail()

        @on(DataTable.RowSelected, "#cf-tab")
        def _f_open(self, ev):
            # Enter on a real file focuses the diff/hunk pane for it; dir rows are inert.
            if ev.row_key and ev.row_key.value and ev.row_key.value not in self._ch_conn \
               and self._sel_sid:
                self._load_diff(self._sel_sid, ev.row_key.value)
                try: self.query_one("#cd-log",DiffView).focus()
                except Exception: pass

        @on(ListView.Highlighted, "#w-list")
        def _net_hl(self, ev):
            if self.view=="net": self._update_rule_detail()

        @on(ListView.Highlighted, "#r-list")
        def _file_hl(self, ev):
            if self.view=="file": self._update_rule_detail()

        # ── actions ───────────────────────────────────────────────────────────
        def action_back(self):
            """Esc steps back: diff → file list; any other list → slopboxes."""
            if self.view=="changes":
                try: in_diff=self.focused is self.query_one("#cd-log",DiffView)
                except Exception: in_diff=False
                if in_diff:
                    try: self.query_one("#cf-tab",DataTable).focus()
                    except Exception: pass
                    return
            if self.view!="boxes":
                self._set_view("boxes")

        def action_kill(self):
            s=self._sel_session()
            if not s or s["status"]!="running":
                self._status("no running session selected"); return
            def done(ok):
                if ok: self.sup.kill(s["session_id"])
            label=s.get("path") or s.get("name") or s["session_id"]
            self.push_screen(Confirm(styled("Kill ", (label,"bold"), "?")), done)

        def action_delete(self):
            s=self._sel_session()
            if not s: return
            if s["status"]=="running": self._status("kill it first"); return
            sid=s["session_id"]
            label=s.get("path") or s.get("name") or sid
            # Count DIRECT children (by parent pointer) so we can offer re-parenting.
            kids=[k for k,v in self.sessions.items() if str(v.get("parent_box_id")) == sid]
            if kids:
                # Has children: dissolve re-parents them up to this box's own parent.
                def done_splice(ok):
                    if not ok: return
                    r=self.sup.dissolve(sid)
                    if r.get("ok"):
                        self._status(styled(
                            "dissolved '", (label, "bold"),
                            f"', re-parented {len(r.get('reparented',[]))} box(es)"))
                    else:
                        self._status(Text(r.get("error") or "dissolve failed", style="red"))
                self.push_screen(Confirm(styled(
                    "Delete ", (label, "bold"),
                    f" and re-parent {len(kids)} child(ren)?")), done_splice)
            else:
                def done(ok):
                    if not ok: return
                    r=self.sup.dissolve(sid)
                    if not r.get("ok"):
                        self._status(Text(r.get("error") or "delete failed", style="red"))
                self.push_screen(Confirm(styled("Delete ", (label,"bold"), " and its overlay?")), done)

        def action_rename(self):
            s=self._sel_session()
            if not s: return
            sid=s["session_id"]
            def done(name):
                if not name: return
                rep=self.sup.rename(sid, name)
                if not rep.get("ok"): self._status(rep.get("error") or "rename failed")
                else: self._status(styled("renamed → ", (rep['name'], "bold")))
            self.push_screen(RenameModal(s.get("name") or sid), done)

        def action_ap_allow(self): self._ap_once("allow")
        def action_ap_deny(self): self._ap_once("deny")
        def _ap_once(self, action):
            a=self._first_pending()
            if a: self.sup.policy.resolve(a["request_id"], action, "once")

        def action_ap_allow_rule(self): self._ap_rule("allow")
        def action_ap_deny_rule(self): self._ap_rule("deny")
        def _ap_rule(self, action):
            a=self._first_pending()
            if not a: return
            rid=a["request_id"]
            def done(res):
                if res:
                    scope,spec,at_top=res
                    self.sup.policy.resolve(rid, action, scope, spec, at_top)
            self.push_screen(RuleModal(action, a), done)

        def action_refresh(self):
            if self._sel_sid: self._load_changes(self._sel_sid)

        def _refresh_after(self, sid, p):
            self._invalidate_changes(sid)   # a real edit changed the set
            self._load_changes(sid)
            if p is not None and any(e["path"]==p for e in self._ch_entries):
                self._load_diff(sid, p, keep_pos=True)
            else:
                try: self.query_one("#cd-log",DiffView).clear()
                except Exception: pass

        def action_apply_one(self):
            p,sid=self._sel_path(),self._sel_sid
            if p and sid:
                r=self.sup.review.apply(sid,[p]); self._cbar(f"applied {len(r['applied'])}")
                self._refresh_after(sid, p)

        def action_apply_all(self):
            sid=self._sel_sid
            if not sid: return
            s=self.sessions.get(sid,{})
            warn="\n[yellow]still running[/]" if s.get("status")=="running" else ""
            def done(ok):
                if ok:
                    r=self.sup.review.apply(sid,None); self._cbar(f"applied {len(r['applied'])}")
                    self._refresh_after(sid, None)
            self.push_screen(Confirm(f"Apply all {len(self._ch_entries)} changes?{warn}"), done)

        def action_discard_one(self):
            p,sid=self._sel_path(),self._sel_sid
            if p and sid:
                self.sup.review.discard(sid,[p]); self._refresh_after(sid, p)

        def action_discard_all(self):
            sid=self._sel_sid
            if not sid: return
            def done(ok):
                if ok: self.sup.review.discard(sid,None); self._refresh_after(sid, None)
            self.push_screen(Confirm(f"Discard ALL {len(self._ch_entries)} changes?"), done)

    return UI


# ════════════════════════════════════════════════════════════════════════════
#  CLI commands
# ════════════════════════════════════════════════════════════════════════════
# run_ui, cmd_run, cmd_patch, cmd_apply, cmd_discard, cmd_rename — the top-level
# entry points for each slopbox subcommand, called from main().
def run_ui() -> int:
    # A single UI instance only: if one is already running its control socket
    # answers, so refuse a second.
    if ui_is_running(sock_path()):
        print("slopbox: the UI is already running"
              f" (control socket {sock_path()}).\n"
              "  Only one UI instance may run; use the existing one.",
              file=sys.stderr)
        return 4
    ensure_dirs()
    _make_ui_app()().run()
    return 0


def cmd_patch(target=None) -> int:
    """Print the unified patch for a slopbox to stdout, by asking the running UI over
    the control socket. `target` (an sid/NAME) selects the box; None = the UI's
    currently-selected box."""
    if not ui_is_running(sock_path()):
        print("slopbox: the UI is not running.", file=sys.stderr); return 3
    rep = sync_request(sock_path(), type="patch", sid=target)
    if not rep or not rep.get("ok"):
        print("slopbox: " + ((rep or {}).get("error") or "no patch available"),
              file=sys.stderr)
        return 1
    data = base64.b64decode(rep.get("patch") or b"")
    sys.stdout.buffer.write(data)
    return 0


def _cmd_review(verb: str, done: str, target=None) -> int:
    """Shared body for apply/discard: act on a box (`target` sid/NAME, else the UI's
    selection) over the control socket, then print the summary. The box is consumed
    (force-deleted) by the UI."""
    if not ui_is_running(sock_path()):
        print("slopbox: the UI is not running.", file=sys.stderr); return 3
    rep = sync_request(sock_path(), type=verb, sid=target)
    if not rep or not rep.get("ok"):
        print("slopbox: " + ((rep or {}).get("error") or f"nothing to {verb}"),
              file=sys.stderr)
        return 1
    print(f"{done} {rep.get('count', 0)} changes, slopbox {rep.get('sid')} removed")
    return 0


def cmd_apply(target=None) -> int:
    """Apply a box's entire change set to the host, then remove it."""
    return _cmd_review("apply", "applied", target)


def cmd_discard(target=None) -> int:
    """Discard a box's entire change set, then remove it."""
    return _cmd_review("discard", "discarded", target)


def cmd_rename(target, new_name) -> int:
    """Rename a slopbox (`target` box_id/NAME/display-path, else the UI's selection) to
    NEW_NAME. NEW_NAME is a single NAME segment (the label); the box's identity (box_id)
    never changes."""
    if not new_name:
        print("slopbox: usage: slopbox [NAME] rename NEWNAME", file=sys.stderr)
        return 2
    if not valid_name(new_name):
        print("slopbox: invalid name — a single CAPS segment (e.g. BOB), "
              "no dots, no trailing '-'.", file=sys.stderr)
        return 2
    if not ui_is_running(sock_path()):
        print("slopbox: the UI is not running.", file=sys.stderr); return 3
    rep = sync_request(sock_path(), type="rename", sid=target, name=new_name)
    if not rep or not rep.get("ok"):
        print("slopbox: " + ((rep or {}).get("error") or "rename failed"),
              file=sys.stderr)
        return 1
    print(f"renamed {rep.get('old')} → {rep.get('name')}")
    return 0


_USAGE = ("slopbox                         start the UI\n"
          "       slopbox patch                   print selected box's patch (stdout)\n"
          "       slopbox apply                   apply selected box's changes, remove it\n"
          "       slopbox discard                 discard selected box's changes, remove it\n"
          "       slopbox rename NEWNAME          rename the selected box\n"
          "       slopbox NAME [SUBCOMMAND]       select box NAME, then run SUBCOMMAND\n"
          "                                       (e.g. slopbox BOB patch · slopbox BOB -- ls)\n"
          "       slopbox [NAME] [-n] [-t] [-d] [-w HOST]... [-C DIR] -- CMD [ARGS...]\n"
          "         -n  networking via mitmproxy   -t  process tracing\n"
          "         -d  direct host access (no capture)\n"
          "         a NAME is CAPS/digits/'-', starts with a letter, no trailing '-'")


# ════════════════════════════════════════════════════════════════════════════
#  Entry
# ════════════════════════════════════════════════════════════════════════════

def main() -> int:
    argv = sys.argv[1:]

    # inner mode: slopbox --inner --channel PATH -- CMD...
    if argv and argv[0] == "--inner":
        ap = argparse.ArgumentParser(prog="slopbox --inner")
        ap.add_argument("--channel", default="")
        ap.add_argument("cmd", nargs=argparse.REMAINDER)
        ns = ap.parse_args(argv[1:])
        cmd = ns.cmd
        if cmd and cmd[0] == "--": cmd = cmd[1:]
        return run_inner(ns.channel, cmd)

    if not argv:
        return run_ui()

    if argv[0] in ("-h", "--help"):
        print("usage: " + _USAGE); return 0

    # An optional leading box NAME (dotted or single segment, all-CAPS) selects that
    # box; the rest of the line then applies to it. `slopbox BOB patch`,
    # `slopbox A.B rename NEW`, `slopbox BOB -- ls`, or bare `slopbox BOB` (select).
    # For a `-- cmd`, a non-existent name means CREATE a new box with that name.
    # A missing existing box (for select/patch/apply/discard/rename) is an error.
    target = None
    if argv and valid_dotted_name(argv[0]):
        target = argv[0]; argv = argv[1:]
        # Only try to select an EXISTING box for non-run ops.  For `-- cmd`, the name
        # might be a NEW box to create; defer the existence check to cmd_run/register.
        _is_run_op = "--" in argv
        if not _is_run_op:
            # select/patch/apply/discard/rename: the box must exist.
            if ui_is_running(sock_path()):
                rep = sync_request(sock_path(), type="select", sid=target)
                if not rep or not rep.get("ok"):
                    print("slopbox: " + ((rep or {}).get("error")
                                         or f"no slopbox '{target}'"), file=sys.stderr)
                    return 1
            elif not (sqlar_path(target).exists() or live_dir(target).exists()):
                print(f"slopbox: no slopbox '{target}'", file=sys.stderr); return 1
        if not argv:
            return 0                          # bare `slopbox NAME` just selects

    if argv and argv[0] == "patch":
        return cmd_patch(target)

    if argv and argv[0] == "apply":
        return cmd_apply(target)

    if argv and argv[0] == "discard":
        return cmd_discard(target)

    if argv and argv[0] == "rename":
        return cmd_rename(target, argv[1] if len(argv) > 1 else "")

    # The command MUST come after `--`. Flags come before it.
    if "--" not in argv:
        # A bare `slopbox ls` is the common mistake — point at the fix.
        # Don't echo back the flags as the command (that would suggest an
        # invalid `slopbox -- -t`); just show the canonical shape.
        print("slopbox: the command must come after `--`.\n"
              "  e.g.  slopbox -- CMD [ARGS...]\n"
              "  (flags go before `--`:  slopbox -t -d -- ls -la)",
              file=sys.stderr)
        return 2

    sep = argv.index("--")
    pre, cmd = argv[:sep], argv[sep + 1:]

    ap = argparse.ArgumentParser(prog="slopbox", add_help=False, usage=_USAGE)
    ap.add_argument("-w", dest="session_whitelist", action="append", default=[], metavar="HOST")
    ap.add_argument("-n", dest="net", action="store_true")
    ap.add_argument("-t", dest="trace", action="store_true")
    ap.add_argument("-d", dest="direct", action="store_true")
    ap.add_argument("-C", dest="chdir", default=None)
    try:
        ns = ap.parse_args(pre)
    except SystemExit:
        return 2
    if not cmd:
        print("slopbox: no command after `--`.", file=sys.stderr); return 2
    return cmd_run(cmd, ns.net, ns.trace, ns.direct, ns.session_whitelist, ns.chdir,
                   reuse_sid=target)


if __name__ == "__main__":
    sys.exit(main())


