def ensure_ca_cert() -> Path:
    if CA_CERT.exists(): return CA_CERT
    try:
        with socket.socket() as s:
            s.bind(("127.0.0.1", 0)); tmp_port = s.getsockname()[1]
        proc = subprocess.Popen(
            ["mitmdump", "-q", "--listen-host", "127.0.0.1",
             "--listen-port", str(tmp_port), "--set", f"confdir={MITM_CONFDIR}"],
            stdin=subprocess.DEVNULL, stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL)
        for _ in range(50):
            if CA_CERT.exists(): break
            time.sleep(0.1)
        proc.terminate()
        try: proc.wait(timeout=3)
        except Exception: proc.kill()
    except FileNotFoundError:
        pass
    return CA_CERT


# ════════════════════════════════════════════════════════════════════════════
#  Runner — `slopbox CMD [ARGS...]`
# ════════════════════════════════════════════════════════════════════════════

def find_self() -> str: return os.path.abspath(sys.argv[0])

_BWRAP_HELP = None
def bwrap_supports(flag: str) -> bool:
    global _BWRAP_HELP
    if _BWRAP_HELP is None:
        try:
            r = subprocess.run(["bwrap", "--help"], capture_output=True,
                               text=True, timeout=5)
            _BWRAP_HELP = r.stdout + r.stderr
        except Exception:
            _BWRAP_HELP = ""
    return flag in _BWRAP_HELP

def cmd_run(cmd, label, no_net, session_whitelist, chdir) -> int:
    if not cmd:
        print("slopbox: no command given", file=sys.stderr); return 2

    label = label or time.strftime("%Y%m%d-%H%M%S")
    sid = str(uuid.uuid4())
    started_at = time.time()
    shm_dir = Path(tempfile.mkdtemp(prefix=f"{SHM_PREFIX}{label}.", dir=SHM_ROOT))
    up = shm_dir / "up"; work = shm_dir / "work"; merged = shm_dir / "merged"
    for d in (up, work, merged): d.mkdir()

    have_ui = ui_is_running(SOCK_PATH)
    net = not no_net
    can_net = net and have_ui and CA_CERT.exists()

    # Diagnostics go to stderr (never stdout) and only ever before/after the
    # child runs, so the wrapped command's stdout stays clean and an interactive
    # screen never gets garbled mid-run.
    print(f"slopbox: {label}  ({'net' if net else 'no-net'}, "
          f"UI {'connected' if have_ui else 'absent'}"
          f"{'' if can_net else ' → no network'})", file=sys.stderr)
    print(f"  overlay upper: {up}", file=sys.stderr)

    # The slopbox runs as a foreground job so interactive programs can read the
    # keyboard. The actual terminal hand-off happens *inside* the namespace (see
    # run_inner) where process-group ids are namespace-local; out here we only
    # remember the original foreground group as a safety net to restore on exit,
    # and ignore SIGTTOU so that restore can't stop us once we've been backgrounded.
    tty_fd = next((fd for fd in (0, 1, 2) if os.isatty(fd)), None)
    old_fg_pgrp = None
    old_ttou = None
    if tty_fd is not None:
        try: old_fg_pgrp = os.tcgetpgrp(tty_fd)
        except OSError: old_fg_pgrp = None
        old_ttou = signal.signal(signal.SIGTTOU, signal.SIG_IGN)

    fuse_mounted = False
    launched = False
    code = 1

    try:
        # fuse-overlayfs root
        fr = subprocess.run(
            ["fuse-overlayfs", "-o", "lowerdir=/", "-o", f"upperdir={up}",
             "-o", f"workdir={work}", "-o", f"squash_to_uid={os.getuid()}",
             "-o", f"squash_to_gid={os.getgid()}", str(merged)],
            stdout=subprocess.DEVNULL, stderr=subprocess.PIPE)
        if fr.returncode != 0 or not os.path.ismount(merged):
            print("slopbox: fuse-overlayfs failed:",
                  fr.stderr.decode(errors='replace').strip(), file=sys.stderr)
            rm_rf(shm_dir); return 1
        fuse_mounted = True

        # the inner forwarder needs the channel socket bound in; the channel is
        # the UI socket. We bind its directory in so connect() works.
        chan = SOCK_PATH if can_net else ""

        args = ["bwrap",
                "--bind", str(merged), "/",
                "--proc", "/proc", "--dev", "/dev",
                "--ro-bind-try", "/sys", "/sys",
                "--tmpfs", "/tmp", "--tmpfs", "/run",
                "--unshare-pid", "--unshare-ipc", "--unshare-uts", "--unshare-net",
                "--cap-drop", "ALL", "--die-with-parent",
                "--chdir", chdir or os.getcwd()]
        if bwrap_supports("--as-pid-1"):
            args += ["--as-pid-1"]
        if can_net:
            # bind the UI socket in (its dir) so the forwarder can reach it
            args += ["--bind", os.path.dirname(SOCK_PATH), os.path.dirname(SOCK_PATH)]
            args += ["--ro-bind", str(CA_CERT), str(CA_CERT)]
            proxy = f"http://127.0.0.1:{INNER_PROXY_PORT}"
            for var in ("http_proxy", "https_proxy", "HTTP_PROXY", "HTTPS_PROXY"):
                args += ["--setenv", var, proxy]
            for var in ("REQUESTS_CA_BUNDLE", "SSL_CERT_FILE",
                        "CURL_CA_BUNDLE", "NODE_EXTRA_CA_CERTS"):
                args += ["--setenv", var, str(CA_CERT)]
        # run our own --inner, which starts the forwarder then execs cmd
        args += ["--", sys.executable, find_self(), "--inner",
                 "--channel", chan, "--sid", sid, "--", *cmd]

        # Launch the slopbox in its own process group so it (and everything it
        # spawns) can be foregrounded and killed as a unit. preexec_fn runs in the
        # child between fork and exec; we also set it from the parent to close the
        # race, then hand the terminal's foreground to that group.
        proc = subprocess.Popen(args, preexec_fn=os.setpgrp)
        launched = True
        try: os.setpgid(proc.pid, proc.pid)
        except OSError: pass

        # Track the session by the bwrap pid (its process-group leader) so the UI
        # can check liveness and killpg the whole tree.
        write_meta(shm_dir, sid, label, list(cmd), proc.pid, started_at)
        if have_ui:
            sync_send(SOCK_PATH, type="register", session_id=sid, label=label,
                      cmd=list(cmd), pid=proc.pid, shm_dir=str(shm_dir),
                      started=started_at, session_whitelist=session_whitelist)

        def _sig(_s, _f):
            try: os.killpg(proc.pid, signal.SIGTERM)
            except OSError:
                try: proc.terminate()
                except OSError: pass
        signal.signal(signal.SIGTERM, _sig)
        signal.signal(signal.SIGINT, _sig)

        code = proc.wait()
    finally:
        # Restore terminal foreground before we print anything else, so our own
        # output never races the child's or trips SIGTTOU.
        if tty_fd is not None and old_fg_pgrp is not None:
            try: os.tcsetpgrp(tty_fd, old_fg_pgrp)
            except OSError: pass
        if old_ttou is not None:
            try: signal.signal(signal.SIGTTOU, old_ttou)
            except (OSError, ValueError): pass
        if fuse_mounted:
            fuse_unmount(str(merged))

    if not launched:
        rm_rf(shm_dir)
        if have_ui:
            sync_send(SOCK_PATH, type="unregister", session_id=sid,
                      status="finished", exit_code=1)
        return 1

    # If nothing real was written, don't leave an empty session behind: drop the
    # overlay and ask the UI to remove the session outright (nothing to review).
    if not upper_has_changes(up):
        rm_rf(shm_dir)
        if have_ui:
            sync_send(SOCK_PATH, type="remove", session_id=sid)
        print(f"slopbox: {label} exited ({code}); no changes.", file=sys.stderr)
        return code or 0

    if have_ui:
        sync_send(SOCK_PATH, type="unregister", session_id=sid,
                  status="finished", exit_code=code or 0)
    print(f"slopbox: {label} exited ({code}). Review changes in the UI, "
          f"or: {up}", file=sys.stderr)
    return code or 0


