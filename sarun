#  Rules
# ════════════════════════════════════════════════════════════════════════════

RULE_KINDS = ("host", "ip", "cname", "url")


def _host_glob(pat: str, name: str) -> bool:
    """Wildcard hostname match. `*.example.com` matches example.com and any
    subdomain; otherwise standard glob (`*`, `?`)."""
    name = (name or "").rstrip(".").lower(); pat = pat.rstrip(".").lower()
    if pat.startswith("*.") and name == pat[2:]: return True
    return fnmatch.fnmatch(name, pat)


def _ip_match(pat: str, ip: str) -> bool:
    """Match an IP (v4/v6) against an address or CIDR network."""
    try:
        addr = ipaddress.ip_address(ip)
        if "/" in pat:
            return addr in ipaddress.ip_network(pat, strict=False)
        return addr == ipaddress.ip_address(pat)
    except ValueError:
        return False


@dataclass
class Rule:
    action: str            # "allow" | "deny"
    kind: str              # one of RULE_KINDS
    pattern: str

    def matches(self, host, port, url, ips, cnames) -> bool:
        k, p = self.kind, self.pattern
        if k == "host":
            # optional :port suffix (but not for bare IPv6 literals)
            if ":" in p and p.rpartition(":")[2].isdigit() and not p.startswith("["):
                h, _, pp = p.rpartition(":")
                return _host_glob(h, host) and int(pp) == port
            return _host_glob(p, host)
        if k == "ip":
            return any(_ip_match(p, ip) for ip in ips)
        if k == "cname":
            return any(_host_glob(p, c) for c in cnames)
        if k == "url":
            return bool(url) and (url == p or url.startswith(p))
        return False

    def to_line(self) -> str:
        return f"{self.action} {self.kind}:{self.pattern}"

    @staticmethod
    def parse(line: str) -> "Rule | None":
        s = line.strip()
        if not s or s.startswith("#"):
            return None
        action = "allow"
        # explicit verb, or legacy "!" deny prefix
        low = s.lower()
        if low.startswith("allow ") or low.startswith("deny "):
            verb, _, rest = s.partition(" ")
            action = verb.lower(); s = rest.strip()
        elif s.startswith("!"):
            action = "deny"; s = s[1:].strip()
        kind = "host"
        if ":" in s:
            maybe, _, rest = s.partition(":")
            if maybe.lower() in RULE_KINDS:
                kind = maybe.lower(); s = rest.strip()
        if not s:
            return None
        return Rule(action=action, kind=kind, pattern=s)


class Rules:
    """An ordered rule list, evaluated top-to-bottom — first match wins."""
    def __init__(self, path: Path):
        self.path = path; self.rules: list = []; self.load()
    def load(self) -> None:
        try: text = self.path.read_text()
        except OSError: text = ""
        self.rules = [r for r in (Rule.parse(ln) for ln in text.splitlines()) if r]
    def save(self) -> None:
        self.path.parent.mkdir(parents=True, exist_ok=True)
        self.path.write_text("".join(r.to_line() + "\n" for r in self.rules))
    def needs_dns(self) -> bool:
        return any(r.kind in ("ip", "cname") for r in self.rules)
    def decide(self, host, port, url=None, ips=(), cnames=()) -> "str | None":
        for r in self.rules:
            if r.matches(host, port, url, ips, cnames):
                return r.action
        return None
    def insert(self, rule: Rule, at_top: bool = False) -> None:
        self.rules.insert(0 if at_top else len(self.rules), rule); self.save()
    def remove_at(self, i: int) -> None:
        if 0 <= i < len(self.rules): del self.rules[i]; self.save()
    def move(self, i: int, delta: int) -> int:
        j = i + delta
        if 0 <= i < len(self.rules) and 0 <= j < len(self.rules):
            self.rules[i], self.rules[j] = self.rules[j], self.rules[i]
            self.save(); return j
        return i


# ════════════════════════════════════════════════════════════════════════════
#  File rules — apply / discard a change by path glob (first match wins)
# ════════════════════════════════════════════════════════════════════════════
#
# Patterns are extended shell globs (bash-style) over the change's absolute path,
# via wcmatch with GLOBSTAR + EXTGLOB + BRACE:
#   *            any run of non-/ characters (stays within one path segment)
#   ?            one non-/ character
#   **           crosses /, so **/ = any depth, /var/**/*.log = under /var
#   @(a|b) !(x) +(…) *(…) ?(…)   extglob groups;  {a,b}  brace alternation
# A pattern with no slash, or no leading /, matches at any depth (so *.txt, .~*,
# a, dir/**/*.txt). A leading / anchors at the filesystem root.

_GLOB_FLAGS = None

def _path_match(pat: str, rel: str) -> bool:
    global _GLOB_FLAGS
    pat = pat.strip()
    if not pat: return False
    # Lazy import: keeps a bare `import slopbox` (the in-slopbox --inner path)
    # stdlib-only — only the runner/UI that actually matches files needs wcmatch.
    from wcmatch import glob as _wg
    if _GLOB_FLAGS is None:
        _GLOB_FLAGS = _wg.GLOBSTAR | _wg.EXTGLOB | _wg.BRACE | _wg.DOTGLOB
    s = "/" + rel.lstrip("/")                    # the change's absolute path
    if "/" not in pat or not pat.startswith("/"):
        pat = "**/" + pat                        # bare name / relative → any depth
    try:
        return bool(_wg.globmatch(s, pat, flags=_GLOB_FLAGS))
    except ValueError:
        return False


@dataclass
class FileRule:
    action: str            # "apply" | "discard"
    pattern: str

    def matches(self, rel: str) -> bool:
        return _path_match(self.pattern, rel)

    def to_line(self) -> str:
        return f"{self.action} {self.pattern}"

    @staticmethod
    def parse(line: str) -> "FileRule | None":
        s = line.strip()
        if not s or s.startswith("#"):
            return None
        verb, _, rest = s.partition(" ")
        action = verb.lower(); pat = rest.strip()
        if action not in ("apply", "discard") or not pat:
            return None
        return FileRule(action=action, pattern=pat)


class FileRules:
    """An ordered apply/discard rule list, evaluated top-to-bottom — first match
    wins. Same shape as the network Rules, so the UI edits both the same way."""
    def __init__(self, path: Path):
        self.path = path; self.rules: list = []; self.load()
    def load(self) -> None:
        try: text = self.path.read_text()
        except OSError: text = ""
        self.rules = [r for r in (FileRule.parse(ln) for ln in text.splitlines()) if r]
    def save(self) -> None:
        self.path.parent.mkdir(parents=True, exist_ok=True)
        self.path.write_text("".join(r.to_line() + "\n" for r in self.rules))
    def decide(self, rel: str) -> "str | None":
        for r in self.rules:
            if r.matches(rel):
                return r.action
        return None
    def insert(self, rule: FileRule, at_top: bool = False) -> None:
        self.rules.insert(0 if at_top else len(self.rules), rule); self.save()
    def remove_at(self, i: int) -> None:
        if 0 <= i < len(self.rules): del self.rules[i]; self.save()
    def move(self, i: int, delta: int) -> int:
        j = i + delta
        if 0 <= i < len(self.rules) and 0 <= j < len(self.rules):
            self.rules[i], self.rules[j] = self.rules[j], self.rules[i]
            self.save(); return j
        return i

def load_file_rules() -> FileRules:
    return FileRules(FILE_RULES_FILE)


