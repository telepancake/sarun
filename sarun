# User docs are `#:`-prefixed Rich-markup blocks dispersed beside the code they document;
# collected here and shown in the right pane when no box is selected. Keep them next to
# the relevant code.
_collect_docs_cache: "str | None" = None

def collect_docs() -> str:
    """Scan the program's own source for `#:`-prefixed doc blocks and return them
    joined as a Rich-markup string (blank line between blocks). Cached: the source
    never changes during a run. Falls back to a short fallback string on read error;
    returns "" for a legitimately empty doc set."""
    global _collect_docs_cache
    if _collect_docs_cache is not None:
        return _collect_docs_cache
    try:
        src_path = os.path.abspath(__file__)
        with open(src_path, "r", encoding="utf-8", errors="replace") as fh:
            lines = fh.readlines()
    except Exception as e:
        print(f"slopbox: collect_docs: could not read source {__file__!r}: {e}",
              file=sys.stderr)
        _collect_docs_cache = "[dim](slopbox — run commands in an inspectable sandbox)[/]"
        return _collect_docs_cache
    blocks = []
    current: "list[str]" = []
    for raw in lines:
        stripped = raw.rstrip("\n")
        if stripped == "#:":
            current.append("")
        elif stripped.startswith("#: "):
            current.append(stripped[3:])
        else:
            if current:
                blocks.append("\n".join(current))
                current = []
    if current:
        blocks.append("\n".join(current))
    result = "\n\n".join(blocks) if blocks else ""
    _collect_docs_cache = result
    return result

