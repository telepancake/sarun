def find_self() -> str: return os.path.abspath(sys.argv[0])

_BWRAP_HELP = None
def bwrap_supports(flag: str) -> bool:
    global _BWRAP_HELP
    if _BWRAP_HELP is None:
        try:
            r = subprocess.run(["bwrap", "--help"], capture_output=True,
                               text=True, timeout=5)
            _BWRAP_HELP = r.stdout + r.stderr
        except Exception:
            _BWRAP_HELP = ""
    return flag in _BWRAP_HELP

# ── runner-mode detection: ambient caps vs. unprivileged user namespace ─────
# The runner needs CAP_SYS_ADMIN (to unshare pid/ipc/uts/mount) and
# CAP_NET_ADMIN (to bring up loopback in the nested netns). There are two ways
# to have them: (a) ambient — the process already holds them (fast path, e.g.
# running as root in this dev container); (b) synthesize them inside a fresh
# unprivileged user namespace via `bwrap --unshare-user`, which works in
# rootless Podman / Fedora toolbox where you lack ambient caps but CAN create
# nested user namespaces.

def _capeff_has_caps(capeff_hex: str) -> bool:
    """Return True iff the CapEff hex string has BOTH CAP_SYS_ADMIN (bit 21)
    and CAP_NET_ADMIN (bit 12) set. Pure/testable: takes the hex string."""
    try:
        bits = int(capeff_hex, 16)
    except (ValueError, TypeError):
        return False
    CAP_NET_ADMIN = 12
    CAP_SYS_ADMIN = 21
    return bool(bits & (1 << CAP_SYS_ADMIN)) and bool(bits & (1 << CAP_NET_ADMIN))

def _have_ambient_caps() -> bool:
    """True iff this process holds BOTH CAP_SYS_ADMIN and CAP_NET_ADMIN in its
    effective set (parsed from /proc/self/status CapEff). False if unreadable."""
    try:
        with open("/proc/self/status") as f:
            for line in f:
                if line.startswith("CapEff:"):
                    return _capeff_has_caps(line.split(":", 1)[1].strip())
    except OSError:
        return False
    return False

_USERNS_RUNNER_WORKS = None
def _userns_runner_works() -> bool:
    """True iff we can synthesize the runner's caps in a fresh unprivileged user
    namespace. END-TO-END probe: `bwrap --unshare-user --unshare-net
    --dev-bind / / --cap-add CAP_SYS_ADMIN --cap-add CAP_NET_ADMIN -- /bin/true`.
    --unshare-net exercises loopback setup, which needs CAP_NET_ADMIN inside the
    new userns — this deliberately catches the Ubuntu 24.04 AppArmor case where
    a userns is created but caps are stripped (a bare `unshare` check misses it).
    Cached; returns False on any error/timeout/missing bwrap."""
    global _USERNS_RUNNER_WORKS
    if _USERNS_RUNNER_WORKS is not None:
        return _USERNS_RUNNER_WORKS
    try:
        r = subprocess.run(
            ["bwrap", "--unshare-user", "--unshare-net", "--dev-bind", "/", "/",
             "--cap-add", "CAP_SYS_ADMIN", "--cap-add", "CAP_NET_ADMIN",
             "--", "/bin/true"],
            capture_output=True, timeout=15)
        _USERNS_RUNNER_WORKS = (r.returncode == 0)
    except Exception:
        _USERNS_RUNNER_WORKS = False
    return _USERNS_RUNNER_WORKS

# ── hardened runner for UNTRUSTED parsers ──────────────────────────────────
# The ONLY place we spawn a parser (readelf/openssl/objdump/…) over bytes that
# came out of a box. General primitive: "run this argv over these untrusted
# bytes, fully sandboxed" — not diff-specific, so a future caller (e.g. rendering
# a network-flow body) can reuse it unchanged. Defence in depth: no namespaces
# (--unshare-all → no net), no caps, read-only root, rlimited, wall-clock timed,
# process group killed on expiry. Never raises into the caller.
_SANDBOX_PATH = "/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

def _untrusted_rlimits(timeout, out_cap):
    cpu = max(1, int(timeout) + 1)
    def _set():
        os.setpgrp()
        resource.setrlimit(resource.RLIMIT_CPU, (cpu, cpu))
        AS = 512 * 1024 * 1024
        resource.setrlimit(resource.RLIMIT_AS, (AS, AS))
        fsz = max(out_cap, 1024 * 1024)
        resource.setrlimit(resource.RLIMIT_FSIZE, (fsz, fsz))
    return _set

def run_on_untrusted(argv, files, timeout=10, out_cap=256 * 1024, on_spawn=None):
    """Run `argv` over untrusted `files` (name->bytes) inside a throwaway bwrap.
    `files` are written to a fresh temp dir, ro-bound read-only into the sandbox;
    `argv` placeholders like "{in}" resolve to the path INSIDE the sandbox.
    `on_spawn(proc)`, if given, receives the bwrap Popen right after launch so a
    caller on another thread can kill it (the box runs under --die-with-parent in its
    own pid namespace, so a SIGKILL to the group tears the whole tree down — no
    zombies). Returns (ok, output_text, err): ok False + a clean error string on
    timeout / oom / missing tool / nonzero exit / external kill. Never raises."""
    if shutil.which("bwrap") is None:
        return (False, "", "bwrap unavailable")
    try:
        with tempfile.TemporaryDirectory(prefix="ut-") as td:
            inside = "/tmp/ut"
            sub = {}
            for name, data in (files or {}).items():
                p = os.path.join(td, name)
                with open(p, "wb") as f: f.write(data)
                sub[name] = inside + "/" + name
            real = [sub.get(a.strip("{}"), a) if (a.startswith("{") and a.endswith("}"))
                    else a for a in argv]
            bw = ["bwrap", "--unshare-pid", "--unshare-ipc", "--unshare-uts",
                  "--unshare-net", "--die-with-parent", "--new-session",
                  "--cap-drop", "ALL", "--ro-bind", "/", "/",
                  "--proc", "/proc", "--dev", "/dev", "--tmpfs", "/tmp",
                  "--ro-bind", td, inside, "--chdir", inside,
                  "--clearenv", "--setenv", "PATH", _SANDBOX_PATH, "--"] + real
            try:
                proc = subprocess.Popen(
                    bw, stdin=subprocess.DEVNULL, stdout=subprocess.PIPE,
                    stderr=subprocess.PIPE, preexec_fn=_untrusted_rlimits(timeout, out_cap))
            except Exception as e:
                return (False, "", f"spawn failed: {e}")
            if on_spawn is not None:
                try: on_spawn(proc)
                except Exception: pass
            try:
                out, err = proc.communicate(timeout=timeout)
            except subprocess.TimeoutExpired:
                try: os.killpg(proc.pid, signal.SIGKILL)
                except Exception:
                    try: proc.kill()
                    except Exception: pass
                try: proc.communicate(timeout=2)
                except Exception: pass
                return (False, "", f"timed out after {timeout}s")
            out_t = out[:out_cap].decode("utf-8", "replace")
            if proc.returncode != 0:
                msg = (err or b"").decode("utf-8", "replace").strip()[:2000]
                if proc.returncode < 0:
                    return (False, out_t, f"killed by signal {-proc.returncode}"
                            + (f": {msg}" if msg else " (rlimit?)"))
                return (False, out_t, msg or f"exit {proc.returncode}")
            return (True, out_t, "")
    except Exception as e:
        return (False, "", f"sandbox error: {e}")

#: [b]Running a command in a slopbox[/]
#: [cyan]slopbox [NAME] [FLAGS] -- CMD [ARGS…][/]
#:
#: The command [b]must[/] follow [cyan]--[/]. Flags go before it:
#:   [cyan]-n[/]        enable outbound networking via mitmproxy (default: off — loopback only)
#:   [cyan]-t[/]        enable process tracing (capture pid/exe/argv of every writer)
#:   [cyan]-d[/]        direct host access — no overlay, no capture (for trusted commands)
#:   [cyan]-w HOST[/]   pre-allow HOST for this session (repeatable)
#:   [cyan]-C DIR[/]    working directory inside the slopbox (default: current directory)
#:
#: An optional [cyan]NAME[/] (all-caps) before the flags re-uses or creates a named box.
#: The UI must be running: it owns the overlay mount the box binds as its root.
#: Examples:
#:   [cyan]slopbox -- pip install requests[/]       (anonymous box, no network)
#:   [cyan]slopbox -n -- curl https://example.com[/] (with network approval)
#:   [cyan]slopbox WORK -n -- make[/]               (named WORK box, with network)
def cmd_run(cmd, net, trace, direct, session_whitelist, chdir, reuse_sid=None) -> int:
    if not cmd:
        print("slopbox: no command given", file=sys.stderr); return 2

    # A nested runner (launched INSIDE an already-running box) reaches the UI via
    # UI_SOCK_INBOX (the host socket bind-mounted into the box at a fixed path).  A
    # top-level runner on the host uses sock_path().  Pure path-presence: no env var.
    _ctrl_sock = UI_SOCK_INBOX if os.path.exists(UI_SOCK_INBOX) else sock_path()

    # The UI is now the mount provider: it owns the single pyfuse3 overlay and
    # exposes this box as a subfolder under it. So the UI MUST be running — fail
    # fast and clearly otherwise. (We deliberately trade no-UI operation for live
    # feedback + per-write policy; there is no run-without-UI path.)
    if not ui_is_running(_ctrl_sock):
        print("slopbox: the UI is not running.\n"
              "  The UI owns the overlay mount that the slopbox binds as its root,\n"
              "  so a slopbox cannot run without it. Start the UI first:\n"
              "      slopbox            # (in another terminal)\n"
              f"  (expected control socket: {_ctrl_sock})", file=sys.stderr)
        return 3

    # Detect whether we are running INSIDE a box (nested launch) or on the host.
    # Pure path-presence: the host socket is bind-mounted at UI_SOCK_INBOX inside any
    # running box (it's the same check that chose _ctrl_sock above).
    _in_box = (_ctrl_sock == UI_SOCK_INBOX)

    # Build the register message fields for naming.
    #
    # IN-BOX launch: send only a RELATIVE single-segment name (flag `relname`) so the
    # UI can scope it under the kernel-derived enclosing box.  Never send an absolute
    # name from inside a box — the box must not influence its own parent.
    #
    # HOST launch: send the absolute name (possibly dotted) as `session_id`.  The UI
    # resolves the parent from the name prefix and decides create-vs-rerun.
    #
    # The UI mints the box_id and assigns an A<n> NAME when none is supplied. The runner
    # never sends a path-component sid — it sends a NAME candidate (or none).
    _extra_reg: dict = {}
    sid = None                    # no runner-chosen identity; the UI mints box_id
    rerun = False
    if _in_box and reuse_sid is not None:
        # In-box named launch: reuse_sid is the single segment typed by the user.
        # Reject dots/slashes here to prevent subtree escape (the UI also checks).
        if not valid_name(reuse_sid) or "." in reuse_sid or "/" in reuse_sid:
            print(f"slopbox: in-box name must be a single segment (no dots/slashes): "
                  f"{reuse_sid!r}", file=sys.stderr)
            return 2
        _extra_reg["relname"] = reuse_sid
    elif _in_box and reuse_sid is None:
        # In-box, no name: send empty relname so the UI assigns a default A<n>.
        _extra_reg["relname"] = ""
    elif not _in_box and reuse_sid is not None:
        # Host named launch: send the NAME (may be a dotted display path, e.g. A.B).
        # The UI resolves the parent from the prefix and decides create-vs-rerun.
        sid = reuse_sid
    # else host no-name: sid stays None → UI mints box_id + A<n>.

    # Our own HOST-namespace provenance: this runner is the box's root process for this
    # run. The UI persists it as a root process row (tgid == our pid, argv == cmd); a
    # re-run adds another root to the box's process forest. full_env so a traced box
    # has the root env too.
    self_prov = read_provenance(os.getpid(), full_env=True)

    # Register with the UI and BLOCK until it has created live/<sid>, built the
    # index, added the session to the mount, and exposed <mnt>/<sid> — only then
    # does the bwrap bind target exist. The ack carries the absolute mount path.
    # We send our own pidfd alongside the JSON so the UI can derive our HOST pid
    # via /proc/self/fdinfo (the codebase's universal identity path) instead of
    # SO_PEERCRED.  Works for both top-level runners and nested-box runners.
    # For nested boxes register_request also returns a dir-fd to the child overlay.
    ack, mount_fd = register_request(_ctrl_sock, type="register", session_id=sid,
                                     cmd=list(cmd), prov=self_prov, root_tgid=os.getpid(),
                                     session_whitelist=session_whitelist, want_rerun=rerun,
                                     want_net=net, want_trace=trace, want_direct=direct,
                                     **_extra_reg)
    if not ack or not ack.get("ok") or not ack.get("mount"):
        if mount_fd >= 0:
            try: os.close(mount_fd)
            except OSError: pass
        print("slopbox: could not start slopbox"
              f"{(' — ' + ack['error']) if ack and ack.get('error') else ''}.",
              file=sys.stderr)
        return 1
    box_root = ack["mount"]                      # <mnt>/<box_id>
    # The UI minted the box_id; the mount subfolder IS str(box_id). Use it as the
    # teardown/relay key (unregister uses this exact key).
    sid = Path(box_root).name
    # For shm_dir, prefer the ack value (UI tells us the real backing path).
    shm_dir = ack.get("shm_dir", str(live_dir(sid)))
    can_net = net and bool(ack.get("net")) and ca_cert_path().exists()
    # The owner token is held HERE, in the runner (outside the box). Only we can
    # unregister this session; in-box code never sees it.
    owner_token = ack.get("owner_token", "")
    relay_path = ack.get("relay", "")            # this box's own FD relay socket

    # Diagnostics go to stderr (never stdout) and only ever before/after the
    # child runs, so the wrapped command's stdout stays clean.
    flags = ",".join(f for f, on in (("net", net), ("trace", trace),
                                     ("direct", direct)) if on) or "isolated"
    print(f"slopbox: {sid}  ({flags}, UI connected"
          f"{'' if can_net else ' → no network'})", file=sys.stderr)
    print(f"  overlay root: {box_root}", file=sys.stderr)

    tty_fd = next((fd for fd in (0, 1, 2) if os.isatty(fd)), None)
    old_fg_pgrp = None
    old_ttou = None
    if tty_fd is not None:
        try: old_fg_pgrp = os.tcgetpgrp(tty_fd)
        except OSError: old_fg_pgrp = None
        old_ttou = signal.signal(signal.SIGTTOU, signal.SIG_IGN)

    launched = False
    code = 1

    try:
        # The inner forwarder needs this box's OWN relay socket bound in (never the
        # UI control socket). We bind only the relay socket's dedicated directory, so
        # the box can reach nothing but its own per-session FD relay.
        chan = relay_path if (can_net and relay_path) else ""

        # bwrap security boundary: the box's <mnt>/<sid> subfolder is bind-mounted
        # as its root (own pid/ipc/uts/net namespaces, all caps dropped, runs as
        # you). The bind-as-root confines the box to its subfolder; it cannot reach
        # <mnt>/ or another session's <sid>. No userns, no fd-passing, no inner mount.
        #
        # NESTED LAUNCH: when mount_fd >= 0, the UI sent us a mount fd (open_tree fd)
        # to the child overlay via SCM_RIGHTS.  We use move_mount to graft it at a
        # temporary path inside the CURRENT (parent box) mount namespace, then pass
        # that path to bwrap as --bind <tmpdir> /.  This avoids any path resolution of
        # the sibling overlay root, which isn't reachable by path inside the parent
        # box.  For a top-level box (mount_fd < 0) we keep --bind <path> / unchanged.
        #
        # The host control socket is bind-mounted read-only at UI_SOCK_INBOX so that a
        # nested `./sarun -- cmd` inside the box can reach the UI. Parent identity is
        # kernel-derived (pidfd → _host_pid_from_pidfd → PPid walk) at the UI; the
        # box's runner sends its own pidfd on the register connection, and the UI
        # never trusts any pid or sid from the message body.
        _nested_mp: "str | None" = None
        if mount_fd >= 0:
            # Graft child overlay at a tmpdir inside the parent box's namespace.
            # /tmp is a fresh tmpfs inside the box (always writable), so create
            # the mount point there; bwrap's --bind <tmpdir> / sees it normally.
            try:
                _nested_mp = tempfile.mkdtemp()
                err = _move_mount(mount_fd, _nested_mp)
                if err == 0:
                    bind_root_args = ["--bind", _nested_mp, "/"]
                else:
                    # move_mount failed (old kernel or EPERM) — fall back to path
                    print(f"slopbox: nested LAUNCH: move_mount errno={err}, "
                          "falling back to path bind", file=sys.stderr)
                    try: os.rmdir(_nested_mp)
                    except OSError: pass
                    _nested_mp = None
                    bind_root_args = ["--bind", str(box_root), "/"]
            except OSError:
                _nested_mp = None
                bind_root_args = ["--bind", str(box_root), "/"]
            try: os.close(mount_fd)
            except OSError: pass
            mount_fd = -1   # consumed
            popen_pass_fds: tuple = ()
        else:
            bind_root_args = ["--bind", str(box_root), "/"]
            popen_pass_fds = ()
        # When nested (inside a parent box), the host sock_path() isn't accessible;
        # the UI socket is already visible at UI_SOCK_INBOX inside the box, so
        # bind-mount UI_SOCK_INBOX → UI_SOCK_INBOX (forwarding it to the child box).
        _ui_sock_src = _ctrl_sock if _ctrl_sock == UI_SOCK_INBOX else sock_path()
        # ── runner mode (computed ONCE) ─────────────────────────────────────
        # Two ways to get the runner's two required caps (CAP_SYS_ADMIN to
        # unshare pid/ipc/uts/mount; CAP_NET_ADMIN to bring up loopback in the
        # nested netns):
        #   "ambient" — the process already holds them (fast path; e.g. running
        #               as root, or with the caps granted by the container).
        #   "userns"  — synthesize a fresh UNPRIVILEGED user namespace via
        #               `--unshare-user` and retain the same two caps inside it.
        #               This is what lets slopbox run in rootless Podman / Fedora
        #               toolbox, where you lack ambient caps but CAN create
        #               nested user namespaces. (v1 keeps the caps; a later change
        #               will drop them entirely in this path.)
        # SLOPBOX_FORCE_USERNS=1 forces the userns path even when ambient caps
        # exist, so the new path is testable where the fast path would win.
        _force_userns = os.environ.get("SLOPBOX_FORCE_USERNS") == "1"
        if not _force_userns and _have_ambient_caps():
            _runner_mode = "ambient"
        elif _userns_runner_works():
            _runner_mode = "userns"
        else:
            print(
                "slopbox: cannot create the runner sandbox.\n"
                "  No ambient CAP_SYS_ADMIN/CAP_NET_ADMIN, and unprivileged user\n"
                "  namespaces are unavailable — so there is no way to obtain the two\n"
                "  caps a box needs (unshare pid/ipc/uts/mount; bring up loopback).\n"
                "  Likely causes and fixes:\n"
                "    - Docker's default seccomp profile blocks nested user namespaces.\n"
                "      Run under rootless Podman or a Fedora toolbox instead.\n"
                "    - Ubuntu 24.04 restricts unprivileged userns via AppArmor\n"
                "      (kernel.apparmor_restrict_unprivileged_userns=1). Either set it\n"
                "      to 0 (sysctl) or ship an AppArmor profile carrying the `userns,`\n"
                "      rule for this binary.\n"
                "    - /dev/fuse must be present: a toolbox provides it; under plain\n"
                "      podman add `--device /dev/fuse`.",
                file=sys.stderr)
            return 4
        # --unshare-* flags: in userns mode we additionally unshare the user
        # namespace. bwrap's default identity map maps the launching uid/gid to
        # themselves, so the box still "runs as you" — no --uid/--gid needed.
        unshare_args = ["--unshare-pid", "--unshare-ipc", "--unshare-uts",
                        "--unshare-net"]
        if _runner_mode == "userns":
            unshare_args.append("--unshare-user")
        args = ["bwrap",
                *bind_root_args,
                "--proc", "/proc", "--dev", "/dev",
                "--ro-bind-try", "/sys", "/sys",
                "--tmpfs", "/tmp", "--tmpfs", "/run",
                "--ro-bind", _ui_sock_src, UI_SOCK_INBOX,
                *unshare_args,
                # Keep only the two caps a box needs to itself HOST a box:
                # CAP_SYS_ADMIN (unshare pid/ipc/uts/mount) and CAP_NET_ADMIN
                # (bring up loopback in the nested netns). Drop the other ~38.
                # In "ambient" mode these come from the process's ambient set; in
                # "userns" mode they are synthesized inside the fresh --unshare-user
                # namespace and retained here (v1 — a later change drops them in the
                # userns path). We can't know in advance whether a box will run
                # `./sarun` inside it, so every box must keep these (a leaf box like
                # run_on_untrusted, which provably never nests, still drops ALL).
                # sarun is not the hard isolation boundary — compose it inside
                # another sandbox if stronger lockdown is wanted.
                "--cap-drop", "ALL", "--cap-add", "CAP_SYS_ADMIN",
                "--cap-add", "CAP_NET_ADMIN", "--die-with-parent",
                "--chdir", chdir or os.getcwd()]
        if bwrap_supports("--as-pid-1"):
            args += ["--as-pid-1"]
        if can_net and chan:
            # bind ONLY this box's relay-socket directory in (holds nothing but the
            # per-session relay.sock) so the forwarder can reach its own relay — and
            # nothing else under the runtime dir (not the control socket, not live/,
            # not <mnt>/).
            chan_dir = os.path.dirname(chan)
            args += ["--bind", chan_dir, chan_dir]
            _ca = ca_cert_path()
            args += ["--ro-bind", str(_ca), str(_ca)]
            proxy = f"http://127.0.0.1:{INNER_PROXY_PORT}"
            for var in ("http_proxy", "https_proxy", "HTTP_PROXY", "HTTPS_PROXY"):
                args += ["--setenv", var, proxy]
            # The overlay synthesizes a CA-augmented trust bundle as a *virtual*
            # file at each system bundle path (invisible to review), so point the
            # bundle-based tools at the in-overlay system bundle path; fall back to
            # the bare CA if no system bundle was found.
            primary = primary_ca_path()
            cafile = primary if primary else str(_ca)
            for var in ("REQUESTS_CA_BUNDLE", "SSL_CERT_FILE",
                        "CURL_CA_BUNDLE", "GIT_SSL_CAINFO"):
                args += ["--setenv", var, cafile]
            # node merges NODE_EXTRA_CA_CERTS with its built-in roots, so it only
            # needs the addition, not the whole bundle.
            args += ["--setenv", "NODE_EXTRA_CA_CERTS", str(_ca)]
        # run our own --inner, which starts the forwarder then execs cmd
        args += ["--", sys.executable, find_self(), "--inner",
                 "--channel", chan, "--", *cmd]

        proc = subprocess.Popen(args, preexec_fn=os.setpgrp,
                                pass_fds=popen_pass_fds)
        launched = True
        try: os.setpgid(proc.pid, proc.pid)
        except OSError: pass

        def _sig(_s, _f):
            try: os.killpg(proc.pid, signal.SIGTERM)
            except OSError:
                try: proc.terminate()
                except OSError: pass
        signal.signal(signal.SIGTERM, _sig)
        signal.signal(signal.SIGINT, _sig)

        code = proc.wait()
    finally:
        # Restore terminal foreground before we print anything else, so our own
        # output never races the child's or trips SIGTTOU.
        if tty_fd is not None and old_fg_pgrp is not None:
            try: os.tcsetpgrp(tty_fd, old_fg_pgrp)
            except OSError: pass
        if old_ttou is not None:
            try: signal.signal(signal.SIGTTOU, old_ttou)
            except (OSError, ValueError): pass
        # Leak guards: close any unconsumed mount_fd; detach the nested mount point.
        if mount_fd >= 0:
            try: os.close(mount_fd)
            except OSError: pass
        if _nested_mp is not None:
            # Lazy umount after bwrap exits; then rmdir the mount point.
            _lazy_umount(_nested_mp)
            try: os.rmdir(_nested_mp)
            except OSError: pass

    # Tell the UI we exited. The UI runs consolidate() on live/<sid>, removes
    # <mnt>/<sid> from the live set, and deletes live/<sid>. (The runner does NOT
    # consolidate: the UI owns the index/mount and the only live index handle.)
    sync_send(_ctrl_sock, type="unregister", session_id=sid, owner_token=owner_token,
              status="finished" if launched else "error",
              exit_code=(code or 0) if launched else 1)
    print(f"slopbox: {sid} exited ({code if launched else 1}). "
          f"Review changes in the UI.", file=sys.stderr)
    return (code or 0) if launched else 1


#: [b]UI panes and navigation[/]
#: The UI has two panels: a left list and a right detail. Switch views with:
#:   [cyan]b[/]  Boxes — all slopboxes; select one, press [cyan]↵[/] to review its changes
#:   [cyan]c[/]  Changes — the file tree of what the selected box wrote; [cyan]↵[/] on a file shows its diff
#:   [cyan]t[/]  Network log — every connection the box made and whether it was allowed
#:   [cyan]p[/]  Processes — the process tree of writers captured during the run
#:   [cyan]w[/]  Net rules — the permanent allow/deny ruleset (edit with [cyan]a[/]/[cyan]e[/]/[cyan]d[/]/[cyan]↑↓[/])
#:   [cyan]f[/]  File rules — the apply/discard/passthrough ruleset (same editing keys)
#:
#: In the Changes diff view: [cyan]a[/] applies a hunk to the host, [cyan]x[/]/[cyan]d[/] discards it.
#: When a network connection needs approval a banner appears at the top:
#:   [cyan]y[/] / [cyan]n[/]  allow / deny this request once
#:   [cyan]Y[/] / [cyan]N[/]  allow / deny and add a permanent rule
#: Press [cyan]esc[/] to go back, [cyan]q[/] to quit.

# ════════════════════════════════════════════════════════════════════════════
#  UI — `slopbox`
# ════════════════════════════════════════════════════════════════════════════

def _make_ui_app():
    """Build and return the Textual UI App class. Factored out of run_ui() so tests
    can construct it under app.run_test() without entering the blocking run loop."""
    from textual import on
    from textual.app import App, ComposeResult
    from textual.binding import Binding
    from textual.containers import Horizontal, Vertical, Container, VerticalScroll
    from textual.reactive import reactive
    from textual.screen import ModalScreen
    from textual.widgets import (
        Button, Checkbox, DataTable, Header, Input, Label,
        ListItem, ListView, Static)
    from rich.text import Text

    # Build a styled line as data: each fragment is (text, style); the text is
    # stored verbatim and never parsed for markup, so file contents / filenames /
    # hostnames can't inject styling. Use this for anything program-derived.
    def styled(*frags) -> Text:
        t=Text()
        for frag in frags:
            if isinstance(frag, tuple): t.append(frag[0], style=frag[1])
            else: t.append(frag)
        return t

    def fmt_age(ts):
        s = int(time.time()-ts)
        if s<60: return f"{s}s"
        if s<3600: return f"{s//60}m{s%60:02d}s"
        return f"{s//3600}h{(s%3600)//60:02d}m"
    sty = lambda st: {"running":"green","finished":"dim","killed":"red","error":"red"}.get(st,"")

    # ── modals ────────────────────────────────────────────────────────────────
    class Confirm(ModalScreen):
        BINDINGS=[("y","yes",""),("n","no",""),("escape","no","")]
        def __init__(self,m): super().__init__(); self.m=m
        def compose(self):
            with Container(id="confirm-box"):
                yield Label(self.m, id="confirm-msg")
                with Horizontal(id="confirm-btns"):
                    yield Button("Yes [y]", variant="error", id="cy")
                    yield Button("No [n]", id="cn")
        def action_yes(self): self.dismiss(True)
        def action_no(self): self.dismiss(False)
        @on(Button.Pressed,"#cy")
        def _y(self): self.dismiss(True)
        @on(Button.Pressed,"#cn")
        def _n(self): self.dismiss(False)

    class RuleModal(ModalScreen):
        # Let the user write the exact rule (kind:pattern) and choose where it goes,
        # instead of the program guessing. It shows what this request can be matched
        # on — host, resolved IPs, CNAME chain, URL — so those are easy to copy.
        # Returns (scope, spec, at_top) or None.
        BINDINGS=[("escape","cancel",""),("ctrl+p","perm","")]
        def __init__(self, action, appr):
            super().__init__(); self.action=action; self.a=appr
        def compose(self):
            a=self.a
            verb="ALLOW" if self.action=="allow" else "DENY"
            col="success" if self.action=="allow" else "error"
            ips=", ".join(a.get("ips") or []) or "—"
            cnames=", ".join(a.get("cnames") or []) or "—"
            url=a.get("url") or "—"
            with Vertical(id="rule-box"):
                yield Label(f" [{col}]{verb}[/] rule", id="rule-title")
                yield Label(styled(("host  ","dim"), (a['host'],"cyan"), f":{a['port']}"))
                yield Label(styled(("ip    ","dim"), ips))
                yield Label(styled(("cname ","dim"), cnames))
                yield Label(styled(("url   ","dim"), url))
                yield Input(value=f"host:{a['host']}", id="rule-input")
                yield Label("[dim]kinds:  host:NAME[:PORT]  ·  ip:ADDR|CIDR  ·  "
                            "cname:NAME  ·  url:PREFIX[/]")
                yield Label("[dim]host & cname take [b]*[/b] wildcards — "
                            "[b]*.example.com[/b] matches example.com and any "
                            "subdomain; [b]*[/b] alone matches anything[/]")
                yield Checkbox("insert at top (checked first)", id="rule-top")
                with Horizontal(id="rule-btns"):
                    yield Button("This session [↵]", id="rb-sess", variant="primary")
                    yield Button("Permanent [^p]", id="rb-perm", variant="warning")
                    yield Button("Cancel [esc]", id="rb-cancel")
        def on_mount(self): self.query_one("#rule-input",Input).focus()
        def _spec(self): return self.query_one("#rule-input",Input).value.strip()
        def _top(self): return self.query_one("#rule-top",Checkbox).value
        def _go(self, scope):
            s=self._spec()
            if s: self.dismiss((scope, s, self._top()))
        def action_perm(self): self._go("permanent")
        def action_cancel(self): self.dismiss(None)
        @on(Input.Submitted,"#rule-input")
        def _submit(self): self._go("session")
        @on(Button.Pressed,"#rb-sess")
        def _s(self): self._go("session")
        @on(Button.Pressed,"#rb-perm")
        def _p(self): self._go("permanent")
        @on(Button.Pressed,"#rb-cancel")
        def _c(self): self.dismiss(None)

    class _SimpleInputModal(ModalScreen):
        """Base for single-Input modals: title label, one Input, one help label.
        title may be a str or a Rich Text; initial is the starting input value.
        Dismisses with the stripped input value (str) on submit, None on cancel."""
        BINDINGS=[("escape","cancel","")]
        def __init__(self, title, help_text, initial=""):
            super().__init__()
            self._title=title; self._help=help_text; self._initial=initial
        def compose(self):
            with Vertical(id="rule-box"):
                yield Label(self._title, id="rule-title")
                yield Input(value=self._initial, id="rule-input")
                yield Label(self._help)
        def on_mount(self): self.query_one("#rule-input",Input).focus()
        def action_cancel(self): self.dismiss(None)
        @on(Input.Submitted,"#rule-input")
        def _save(self): self.dismiss(self.query_one("#rule-input",Input).value.strip())

    class RuleLineModal(_SimpleInputModal):
        # Edit one existing rule as a full line. Returns the new line or None.
        def __init__(self, line):
            super().__init__(
                " Edit rule",
                "[dim]<allow|deny> <kind>:<pattern>   "
                "(host/cname take [b]*[/b] wildcards) · Enter save · "
                "Esc cancel[/]",
                initial=line)

    class FileRuleLineModal(_SimpleInputModal):
        # Add or edit one file rule as a full line. Returns the new line or None.
        def __init__(self, line):
            super().__init__(
                " File rule",
                "[dim]<apply|discard> <path-glob>   e.g. "
                "[b]discard *.log[/b] · [b]apply src/**/*.py[/b] · "
                "[b]discard .~*[/b] · [b]apply /etc/**[/b]\n"
                "[b]*[/b] stays in one path segment · [b]**[/b] crosses "
                "dirs · a bare name matches at any depth · leading "
                "[b]/[/b] anchors at root · Enter save · Esc cancel[/]",
                initial=line)

    class RenameModal(_SimpleInputModal):
        # Rename the selected box. Returns the new NAME or None.
        def __init__(self, cur):
            super().__init__(
                styled(" Rename ", (cur, "bold")),
                "[dim]CAPITALS, digits and [b]-[/b] · start with a letter · "
                "no trailing [b]-[/b]   e.g. [b]BOB5-24-YES[/b] · "
                "Enter save · Esc cancel[/]",
                initial="")

