        async def on_mount(self):
            self.query_one("#s-tab",DataTable).add_columns(
                "F","Started","PID","Cmd","✓","✗","↑","↓","Age")
            self.query_one("#nf-tab",DataTable).add_columns(
                "Time","","Method","Host","St","↑","↓")
            self.query_one("#cf-tab",DataTable).add_columns("","S","Path","Size")
            ensure_ca_cert()
            loop=asyncio.get_event_loop()
            # Start the single pyfuse3 overlay mount on its dedicated trio thread.
            # Until it is up, no slopbox can run (it has nowhere to bind its root).
            mount_ok=self.mount.start()
            # A prior crash may have left orphaned live/<sid> backings: fold them.
            try: self.sup.sweep_orphans()
            except Exception: pass
            self.engine=ProxyEngine(self.sup, loop,
                                    lambda coro: asyncio.ensure_future(coro))
            self.server=ChannelServer(self.sup, self.engine, SOCK_PATH)
            await self.server.start()
            msg = f"listening · {SOCK_PATH}"
            if mount_ok:
                msg += f"  ·  overlay {mnt_point()}"
            else:
                err=getattr(self.mount,"_start_error",None)
                msg += f"  [red](overlay mount FAILED: {err} — slopboxes cannot run)[/]"
            if not self.engine.ready:
                msg += "  [red](mitmproxy unavailable — no gating)[/]"
            self._status(msg)
            self._refresh_rules()
            self._refresh_file_rules()
            for s in self.sup.sessions.values():
                self.sessions={**self.sessions, s.session_id:s.to_dict()}
            self._rebuild_sessions()
            self._set_view("boxes")           # shows only the slopbox list + detail
            self.set_interval(3, self._tick)
            # Live feedback: drain the overlay's thread-safe event queue often so the
            # Changes view updates as the box writes (event-driven, NOT by polling
            # /dev/shm). The serving thread enqueues; we apply on the UI thread.
            self.set_interval(0.3, self._drain_overlay_events)

        def _drain_overlay_events(self):
            changed=set()
            try:
                while True:
                    ev=self.mount.event_q.get_nowait()
                    if ev.get("type")=="overlay_changed" and ev.get("sid"):
                        changed.add(ev["sid"])
            except queue.Empty:
                pass
            if not changed: return
            # refresh the live change listing for the affected box if it's on screen
            if self.view=="changes" and self._ch_sid in changed:
                self._load_changes(self._ch_sid, force=True)
            if self.view=="boxes" and self._ch_sid in changed:
                self._update_box_detail()

        async def on_unmount(self):
            self._save_all_patches()
            if self.server: await self.server.stop()
            # Tear down the single overlay mount; lazy-unmount fallback keeps the
            # mount table clean even if a handler is wedged.
            try: self.mount.stop()
            except Exception: pass

        def _save_all_patches(self):
            for sid, p in list(self.sup.patches.items()):
                if p.get("dirty"):
                    try: self.sup.save_patch(sid)
                    except Exception: pass

        def _on_evt(self, ev): self.call_later(self._apply_evt, ev)

        def _apply_evt(self, ev):
            t=ev["type"]
            if t in ("session_added","session_updated"):
                s=ev["session"]; self.sessions={**self.sessions,s["session_id"]:s}
                self._rebuild_sessions(preserve=True)
                if self.view=="boxes": self._update_box_detail()
            elif t=="session_removed":
                sid=ev["session_id"]
                self.sessions={k:v for k,v in self.sessions.items() if k!=sid}
                self._rebuild_sessions(preserve=True)
                if self._ch_sid==sid:
                    self._ch_sid=None; self._last_loaded_sid=None
                    self._ch_entries=[]; self._rebuild_ch()
                if self.view=="boxes": self._update_box_detail()
            elif t=="approval_pending":
                a=ev["approval"]; self.pending={**self.pending,a["request_id"]:a}
                # No focus stealing: just raise the banner, beep, and (if available)
                # fire a desktop notification. The keys work from wherever you are.
                self._render_appr(); self.bell()
                self._notify("slopbox: approve connection?",
                             f"{a['scheme']} {a['host']}:{a['port']}")
            elif t=="approval_resolved":
                rid=ev["request_id"]
                self.pending={k:v for k,v in self.pending.items() if k!=rid}
                self._render_appr()
            elif t=="rules_updated":
                self._refresh_rules()
                if self.view=="net": self._update_rule_detail()

        def _tick(self):
            self.sup.rescan()
            self._rebuild_sessions(preserve=True)
            self._render_appr()
            # Autosave any in-memory patch that's been dirty and idle for 60s, to
            # avoid thrashing the compressed file on every edit.
            now=time.time()
            for sid, p in list(self.sup.patches.items()):
                if p.get("dirty") and now - p.get("touched", now) >= 60:
                    self.sup.save_patch(sid)
            if self._ch_sid is None:
                s=self._sel_session()
                if s: self._ch_sid=self._last_loaded_sid=s["session_id"]
            if self.view=="changes" and self._ch_sid:
                self._load_changes(self._ch_sid)
            if self.view=="netlog" and self._ch_sid:
                self._load_flows(self._ch_sid)
            if self.view=="boxes":
                self._update_box_detail()
            self._cbar()    # keep the dirty/count indicator current

        # ── view machinery: one left list at a time + its right-pane detail ────
        def _set_view(self, v):
            if self.view=="changes" and v!="changes":
                self._save_all_patches()      # leaving changes autosaves the patch
            self.view=v
            for k,sel in self.LEFT.items():
                try: self.query_one(sel).display=(k==v)
                except Exception: pass
            rsel=self.RIGHT[v]
            for sel in ("#box-detail","#cd-log","#flow-wrap","#rule-detail"):
                try: self.query_one(sel).display=(sel==rsel)
                except Exception: pass
            try: self.query_one("#cd-info").display=(v=="changes")   # full-path header
            except Exception: pass
            self._titles()
            if v=="changes" and self._ch_sid:
                self._load_changes(self._ch_sid, force=True)
                self._update_cd_info()
            if v=="netlog" and self._ch_sid:
                self._load_flows(self._ch_sid, force=True)
            self._update_right()
            try: self.query_one(self.LEFT[v]).focus()
            except Exception: pass

        def action_view_boxes(self): self._set_view("boxes")
        def action_view_changes(self): self._set_view("changes")
        def action_view_netlog(self): self._set_view("netlog")
        def action_view_net(self): self._set_view("net")
        def action_view_file(self): self._set_view("file")

