#  Control + FD-channel socket server (inside the UI)
# ════════════════════════════════════════════════════════════════════════════

class RelayServer:
    """A per-session FD relay. One of these is created by the Supervisor for each
    networked box; it listens on that box's OWN relay socket (relay_sock_path(sid),
    bound into only that box). Every FD that arrives here is gated as `sid` — the
    sender cannot choose another session's rules, because there is no sid in the
    message and this loop is hard-bound to one sid. This socket carries FD messages
    ONLY: it never accepts a register/unregister/control message, so untrusted in-box
    code that can reach it can do nothing but hand us its own connections."""
    def __init__(self, engine: "ProxyEngine", sid: str, sock_path: str,
                 loop: asyncio.AbstractEventLoop):
        self.engine = engine; self.sid = sid; self.sock_path = sock_path
        self._loop = loop; self._sock = None; self._task = None

    def start(self) -> None:
        try: os.makedirs(os.path.dirname(self.sock_path), mode=0o700, exist_ok=True)
        except OSError: pass
        try: os.unlink(self.sock_path)
        except FileNotFoundError: pass
        self._sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        self._sock.bind(self.sock_path)
        try: os.chmod(self.sock_path, 0o600)
        except OSError: pass
        self._sock.listen(64)
        self._sock.setblocking(False)
        self._task = asyncio.ensure_future(self._accept_loop())

    async def _accept_loop(self) -> None:
        while True:
            try:
                conn, _ = await self._loop.sock_accept(self._sock)
            except (OSError, asyncio.CancelledError):
                break
            asyncio.ensure_future(self._handle(conn))

    async def _handle(self, conn: socket.socket) -> None:
        conn.setblocking(False)
        try:
            _msg, anc, _flags, _addr = await self._loop.run_in_executor(
                None, _recvmsg_blocking, conn)
            fds = []
            for lvl, typ, data in anc:
                if lvl == socket.SOL_SOCKET and typ == socket.SCM_RIGHTS:
                    a = array.array("i"); a.frombytes(data); fds.extend(a.tolist())
            conn.close()
            # The ancillary fd array from --inner is [request_socket] or
            # [request_socket, pidfd]: index 0 is always the connection socket the
            # engine drives; index 1, if present, is a pidfd for the connecting in-box
            # workload process. The payload carries no process fields — the pidfd is
            # the channel. The sid is NEVER taken from the message; it is THIS relay's.
            pidfd = fds[1] if len(fds) > 1 else -1
            for extra in fds[2:]:
                try: os.close(extra)
                except OSError: pass
            if fds:
                # Derive the HOST-namespace pid from the pidfd (its fdinfo reports the
                # pid in OUR — the UI's host — namespace), then read provenance with
                # the same host-side read_provenance() the FUSE path uses. Every tgid
                # we persist is thus a HOST pid; a dead/missing peer → untagged flow.
                prov = {"tgid": 0}
                if pidfd >= 0:
                    host_pid = _host_pid_from_pidfd(pidfd)
                    if host_pid > 0:
                        info = read_provenance(host_pid, full_env=True)
                        ppid_tgid = tgid_of(info["ppid"]) if info.get("ppid") else 0
                        prov = {"tgid": tgid_of(host_pid), "ppid": ppid_tgid,
                                "exe": info["exe"], "argv": info["argv"],
                                "env": info["env"]}
                    try: os.close(pidfd)
                    except OSError: pass
                _CURRENT_PROV.set(prov)
                await self.engine.handle_fd(fds[0], self.sid)
        except (OSError, asyncio.CancelledError):
            try: conn.close()
            except OSError: pass

    def stop(self) -> None:
        if self._task is not None:
            self._task.cancel()
        try:
            if self._sock is not None: self._sock.close()
        except OSError:
            pass
        try: os.unlink(self.sock_path)
        except FileNotFoundError: pass


def _host_pid_from_pidfd(pidfd: int) -> int:
    """Resolve a pidfd to a HOST-namespace pid by parsing /proc/self/fdinfo/<pidfd>.

    A pidfd's fdinfo `Pid:` line reports the target's pid in the READER's pid
    namespace — and the UI runs in the host namespace, so the value we read IS the
    host pid (this is what makes the box→pidfd→UI chain yield a host-namespace pid
    instead of the box-namespace pid SO_PEERCRED would give). A reaped/dead process
    shows `Pid:\t-1` (or 0); the line may list several space-separated pids across
    nested namespaces, and the first is the one in our namespace. Returns the host
    pid, or 0 on a dead process / unparseable fdinfo (→ untagged flow)."""
    try:
        with open(f"/proc/self/fdinfo/{pidfd}", "rb") as f:
            for line in f:
                if line.startswith(b"Pid:"):
                    rest = line.split(b":", 1)[1].split()
                    return int(rest[0]) if rest else 0
    except (OSError, ValueError, IndexError):
        return 0
    return 0


def _recvmsg_blocking(conn):
    conn.setblocking(True)
    try:
        # Up to 16 fds: --inner sends [request_socket] or [request_socket, pidfd].
        return conn.recvmsg(65536, socket.CMSG_SPACE(4 * 16))
    finally:
        conn.setblocking(False)


class ChannelServer:
    """
    The UI control socket (ui.sock). It carries control messages ONLY (register /
    unregister / remove): newline JSON, no FDs. This socket is NEVER bind-mounted
    into a sandbox, so untrusted in-box code cannot reach it. FD relay for networked
    boxes happens on per-session RelayServer sockets instead (see RelayServer).
    """
    def __init__(self, sup: Supervisor, engine: "ProxyEngine", sock_path: str):
        self.sup = sup; self.engine = engine; self.sock_path = sock_path
        self._sock = None

    async def start(self) -> None:
        try: os.unlink(self.sock_path)
        except FileNotFoundError: pass
        self._sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        self._sock.bind(self.sock_path)
        os.chmod(self.sock_path, 0o600)
        self._sock.listen(128)
        self._sock.setblocking(False)
        self._loop = asyncio.get_event_loop()
        self.sup.attach_relay_factory(self._loop, self.engine)
        self._task = asyncio.ensure_future(self._accept_loop())

    async def _accept_loop(self) -> None:
        while True:
            try:
                conn, _ = await self._loop.sock_accept(self._sock)
            except (OSError, asyncio.CancelledError):
                break
            asyncio.ensure_future(self._handle(conn))

    async def _handle(self, conn: socket.socket) -> None:
        conn.setblocking(False)
        try:
            # Control client: each line is JSON. Any ancillary FDs on this socket are
            # rejected (closed): the control socket never carries connection FDs — that
            # is the per-session RelayServer's job. A register message produces a reply
            # (the mount path + owner token) written back on the same connection so the
            # runner can block on it.
            buf = b""
            while True:
                if b"\n" in buf:
                    line, buf = buf.split(b"\n", 1)
                    if line.strip():
                        reply = await self._dispatch_control(line)
                        if reply is not None:
                            try:
                                await self._loop.sock_sendall(
                                    conn, (json.dumps(reply) + "\n").encode())
                            except OSError:
                                pass
                    continue
                more = await self._loop.sock_recv(conn, 4096)
                if not more:
                    if buf.strip():
                        reply = await self._dispatch_control(buf)
                        if reply is not None:
                            try:
                                await self._loop.sock_sendall(
                                    conn, (json.dumps(reply) + "\n").encode())
                            except OSError:
                                pass
                    break
                buf += more
        except (OSError, asyncio.CancelledError):
            pass
        finally:
            try: conn.close()
            except OSError: pass

    async def _dispatch_control(self, line: bytes) -> "dict | None":
        try: msg = json.loads(line.decode())
        except json.JSONDecodeError: return None
        t = msg.get("type")
        if t == "register":
            try:
                return self.sup.register(msg)          # acks with the mount path
            except Exception as e:
                return dict(ok=False, error=str(e))
        elif t == "unregister": await self.sup.unregister_async(msg, self._loop)
        elif t == "remove": self.sup.drop(msg)
        elif t == "patch":
            # On-demand patch for the UI's currently-selected box. The patch needs the
            # box consolidated; for a finished box that is the slow deflate pass, so run
            # it in the executor (awaited — the CLI is blocked on this reply) instead of
            # inline, keeping the loop free for the UI/proxy while it runs.
            try:
                sid = self.sup.selected_sid
                if not sid:
                    return dict(ok=False, error="no slopbox selected in the UI")
                await self.sup.consolidate_in_executor(self._loop, sid)
                data = self.sup.review.patch_text(sid)
                return dict(ok=True, patch=base64.b64encode(data).decode())
            except Exception as e:
                return dict(ok=False, error=str(e))
        return None

    async def stop(self) -> None:
        if getattr(self, "_task", None):
            self._task.cancel()
        try:
            self.sup.stop_all_relays()
        except Exception:
            pass
        if self._sock is not None:
            try:
                self._sock.close()
            except OSError:
                pass
        try: os.unlink(self.sock_path)
        except FileNotFoundError: pass


