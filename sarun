            self.engine=None
            self.server=None
            self._all_traffic=[]
            self._ch_sid=None
            self._ch_entries=[]
            self._last_loaded_sid=None  # guard against reload on re-highlight

        def compose(self) -> ComposeResult:
            yield Header()
            with TabbedContent(id="tabs", initial="t-sb"):
