    # Build a styled line as data: each fragment is (text, style); the text is
    # stored verbatim and never parsed for markup, so file contents / filenames /
    # hostnames can't inject styling. Use this for anything program-derived.
    def styled(*frags) -> Text:
        t=Text()
        for frag in frags:
            if isinstance(frag, tuple): t.append(frag[0], style=frag[1])
            else: t.append(frag)
        return t

    def fmt_bytes(n):
        for u, d in (("G",1<<30),("M",1<<20),("K",1<<10)):
            if n >= d: return f"{n/d:.1f}{u}"
        return f"{n}B"
    def fmt_age(ts):
        s = int(time.time()-ts)
        if s<60: return f"{s}s"
        if s<3600: return f"{s//60}m{s%60:02d}s"
        return f"{s//3600}h{(s%3600)//60:02d}m"
    sty = lambda st: {"running":"green","finished":"dim","killed":"red"}.get(st,"")

    class Confirm(ModalScreen):
        BINDINGS=[("y","yes",""),("n","no",""),("escape","no","")]
        def __init__(self,m): super().__init__(); self.m=m
