                  Binding("s","save","save patch")]
        def action_save(self): self.app.action_save_patch()
        def _idx(self):
            it=self.highlighted_child
            return it.hunk_index if isinstance(it,HunkItem) else None
        def action_apply(self):
            i=self._idx()
            if i is not None: self.app._hunk_apply(i)
        def action_discard(self):
            i=self._idx()
            if i is not None: self.app._hunk_discard(i)

