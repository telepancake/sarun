        async def on_mount(self):
            self.query_one("#s-tab",DataTable).add_columns(
                "F","Label","PID","Cmd","✓","✗","↑","↓","Age")
            self.query_one("#cf-tab",DataTable).add_columns("","Path","Size")
            ensure_ca_cert()
            loop=asyncio.get_event_loop()
            self.engine=ProxyEngine(self.sup, loop,
                                    lambda coro: asyncio.ensure_future(coro))
            self.server=ChannelServer(self.sup, self.engine, SOCK_PATH)
            await self.server.start()
            msg = f"listening · {SOCK_PATH}"
            if not self.engine.ready:
                msg += "  [red](mitmproxy unavailable — no gating)[/]"
            self._status(msg)
            self._refresh_rules()
            for s in self.sup.sessions.values():
                self.sessions={**self.sessions, s.session_id:s.to_dict()}
            self._rebuild_sessions()
            self.set_interval(3, self._tick)

        async def on_unmount(self):
            if self.server: await self.server.stop()

        def _on_evt(self, ev): self.call_later(self._apply_evt, ev)

        def _apply_evt(self, ev):
            t=ev["type"]
            if t in ("session_added","session_updated"):
                s=ev["session"]; self.sessions={**self.sessions,s["session_id"]:s}
                self._rebuild_sessions(preserve=True)
            elif t=="session_removed":
                sid=ev["session_id"]
                self.sessions={k:v for k,v in self.sessions.items() if k!=sid}
                self._rebuild_sessions(preserve=True)
                if self._ch_sid==sid:
                    self._ch_sid=None; self._last_loaded_sid=None
                    self._ch_entries=[]; self._rebuild_ch()
            elif t=="approval_pending":
                a=ev["approval"]; self.pending={**self.pending,a["request_id"]:a}
                self._rebuild_approvals(preserve=True); self.bell()
            elif t=="approval_resolved":
                rid=ev["request_id"]
                self.pending={k:v for k,v in self.pending.items() if k!=rid}
                self._rebuild_approvals(preserve=True)
            elif t=="traffic":
                self._ingest(ev["event"]); s=ev["session"]
                self.sessions={**self.sessions,s["session_id"]:s}
                self._rebuild_sessions(preserve=True)
            elif t=="rules_updated":
                self._refresh_rules()

        def _tick(self):
            self.sup.rescan()
            self._rebuild_sessions(preserve=True)
            self._rebuild_approvals(preserve=True)
            # Keep the Changes pane live for the selected session (its overlay can
            # keep growing while the process runs). Falls back to the highlighted
            # row if no selection has been recorded yet.
            if self._ch_sid is None:
                s=self._sel_session()
                if s: self._ch_sid=self._last_loaded_sid=s["session_id"]
            if self._ch_sid:
                self._load_changes(self._ch_sid)

        def _sync_table(self, table, rows):
            # Reconcile a DataTable against the desired (key, cells) rows IN PLACE.
            # When the set+order of rows is unchanged we only rewrite changed cells,
            # so the cursor, scroll and selection are never disturbed by a refresh.
            # Only a structural change (row added/removed/reordered) rebuilds, and
            # even then the cursor is restored by key.
            cur=[rk.value for rk in table.rows]
            new=[k for k,_ in rows]
            if cur==new:
                cols=list(table.columns)
                for key,cells in rows:
                    for ck,val in zip(cols,cells):
                        try:
                            if table.get_cell(key,ck)!=val:
                                table.update_cell(key,ck,val,update_width=False)
                        except Exception: pass
                return
            saved=None
            if table.row_count:
                try: saved=table.coordinate_to_cell_key((table.cursor_row,0)).row_key.value
                except Exception: saved=None
            table.clear()
            for key,cells in rows:
                table.add_row(*cells,key=key)
            if saved is not None:
                try: table.move_cursor(row=table.get_row_index(saved),animate=False)
                except Exception: pass

        def _rebuild_sessions(self, preserve=False):
            rows=[]
            for sid,s in sorted(self.sessions.items(),
                                key=lambda x:x[1]["started"], reverse=True):
                c=sty(s["status"])
                flag={"running":"R","finished":"F","killed":"K"}.get(s["status"],"?")
                rows.append((sid,[
                    f"[{c}]{flag}[/]", f"[{c}]{s['label']}[/]",
                    str(s["pid"]), " ".join(s["cmd"])[:24],
                    f"[green]{s['conn_allowed']}[/]", f"[red]{s['conn_denied']}[/]",
                    fmt_bytes(s["bytes_up"]), fmt_bytes(s["bytes_down"]),
                    fmt_age(s["started"])]))
            self._sync_table(self.query_one("#s-tab",DataTable), rows)

        def _rebuild_approvals(self, preserve=False):
            lv=self.query_one("#a-list",ListView)
            self.query_one("#a-pane").set_class(bool(self.pending),"pending")
            new_ids=list(self.pending.keys())
            cur_ids=[c.a.get("request_id") for c in lv.children
                     if isinstance(c,ApprovalItem)]
            if cur_ids==new_ids:
                return                       # nothing added/removed: leave it alone
            saved=lv.index
            lv.clear()
            for a in self.pending.values(): lv.append(ApprovalItem(a))
            if saved is not None and 0<=saved<len(self.pending):
                lv.index=saved

        def _refresh_rules(self):
            lv=self.query_one("#w-list",ListView)
            idx=lv.index
            lv.clear()
            for r in self.rules_store.rules:
                lv.append(ListItem(Label(r.label())))
            n=len(self.rules_store.rules)
            if idx is not None and n: lv.index=min(idx, n-1)

        def _rule_del(self, i):
            self.rules_store.remove_at(i); self._refresh_rules()
        def _rule_move(self, i, d):
            j=self.rules_store.move(i, d); self._refresh_rules()
            try: self.query_one("#w-list",ListView).index=j
            except Exception: pass
        def _rule_edit_at(self, i):
            rules=self.rules_store.rules
            if i is None or not (0<=i<len(rules)): return
            def done(line):
                if line is None: return
                r=Rule.parse(line)
                if not r: self._status("invalid rule — keeping the old one"); return
                rules[i]=r; self.rules_store.save(); self._refresh_rules()
                try: self.query_one("#w-list",ListView).index=i
                except Exception: pass
            self.push_screen(RuleLineModal(rules[i].to_line()), done)

        @on(ListView.Selected, "#w-list")
        def _rule_activated(self, ev):
            self._rule_edit_at(self.query_one("#w-list",ListView).index)

        def _rebuild_ch(self, preserve=False):
            rows=[(e["path"], [ICON.get(e["kind"],"?"), e["path"],
                               fmt_bytes(e["size"]) if e["size"] else ""])
                  for e in self._ch_entries]
            self._sync_table(self.query_one("#cf-tab",DataTable), rows)

        def _ingest(self, ev):
            self._all_traffic.append(ev)
            self._write(self.query_one("#t-log",RichLog), ev, True)
            if not self.log_filter or self.log_filter==ev.get("session_id"):
                self._write(self.query_one("#c-log",RichLog), ev, not bool(self.log_filter))

        def _write(self, w, ev, sid):
            act=ev.get("action","?"); col="green" if act=="allow" else "red"
            ts=time.strftime("%H:%M:%S", time.localtime(ev.get("ts",time.time())))
            st=f" [{ev['status']}]" if ev.get("status") else ""
            bu,bd=ev.get("bytes_up",0),ev.get("bytes_down",0)
            bt=f" [dim]↑{fmt_bytes(bu)} ↓{fmt_bytes(bd)}[/]" if (bu or bd) else ""
            sd=f" [dim cyan]{ev.get('session_id','')[:8]}[/]" if sid else ""
            w.write(f"[dim]{ts}[/]{sd} [{col}]{'✓' if act=='allow' else '✗'}[/] "
                    f"[bold]{ev.get('scheme','?')}[/] "
                    f"[cyan]{ev.get('host','?')}[/]:{ev.get('port','?')}{st}{bt}")

        def _show_diff(self, d):
            log=self.query_one("#cd-log",RichLog); log.clear()
            k=d.get("kind")
            if k=="deleted": log.write("[red bold]DELETED[/]"); return
            if k=="directory": log.write("[cyan]DIRECTORY[/]"); return
            if k=="error": log.write(f"[red]{d.get('error')}[/]"); return
            diff=d.get("diff")
            if diff is not None:
                for ln in diff.splitlines():
                    if ln.startswith(("+++","---")): log.write(f"[bold]{ln}[/]")
                    elif ln.startswith("+"): log.write(f"[green]{ln}[/]")
                    elif ln.startswith("-"): log.write(f"[red]{ln}[/]")
                    elif ln.startswith("@@"): log.write(f"[cyan]{ln}[/]")
                    else: log.write(ln)
                if not diff.strip(): log.write("[dim](no textual diff)[/]")
            else:
                raw=base64.b64decode(d.get("content") or b"")
                log.write(f"[dim]binary · {fmt_bytes(len(raw))}[/]")
                for i in range(0,min(len(raw),256),16):
                    ch=raw[i:i+16]; h=" ".join(f"{b:02x}" for b in ch)
                    a="".join(chr(b) if 0x20<=b<0x7f else "." for b in ch)
                    log.write(f"[dim]{i:04x}[/]  {h:<48}  {a}")

        def _status(self, t):
            try: self.query_one("#status",Static).update(t)
            except Exception: pass
        def _cbar(self, extra):
            try: self.query_one("#c-bar",Static).update(
                f"  r refresh · a/A apply · x/X discard · e edit   [dim]{extra}[/]")
            except Exception: pass

        def _sel_session(self):
            t=self.query_one("#s-tab",DataTable)
            if not t.row_count: return None
            try: return self.sessions.get(
                t.coordinate_to_cell_key((t.cursor_row,0)).row_key.value)
            except Exception: return None
        def _sel_approval(self):
            it=self.query_one("#a-list",ListView).highlighted_child
            return it.a if isinstance(it,ApprovalItem) else None
        def _sel_path(self):
            t=self.query_one("#cf-tab",DataTable)
            if not t.row_count: return None
            try: return t.coordinate_to_cell_key((t.cursor_row,0)).row_key.value
            except Exception: return None

        def _load_changes(self, sid, force=False):
            entries=self.sup.overlay_entries(sid)
            # Only touch the table when the set of changes actually differs, so the
            # periodic refresh keeps the pane live without blinking or losing the
            # cursor while nothing is changing.
            if not force and entries==self._ch_entries:
                return
            self._ch_entries=entries
            self._rebuild_ch(preserve=True)
            self._cbar(f"{len(self._ch_entries)} change(s)")

        @on(DataTable.RowHighlighted, "#s-tab")
        def _sc(self, ev):
            if ev.row_key and ev.row_key.value:
                sid=ev.row_key.value
                self._ch_sid=sid
                if sid!=self._last_loaded_sid:
                    self._last_loaded_sid=sid
                    self._load_changes(sid, force=True)

        @on(DataTable.RowHighlighted, "#cf-tab")
        def _cc(self, ev):
            if ev.row_key and ev.row_key.value and self._ch_sid:
                self._show_diff(self.sup.overlay_diff(self._ch_sid, ev.row_key.value))

        def action_tab(self, t):
            self.query_one("#tabs",TabbedContent).active=t
            if t=="t-ch" and self._ch_sid: self._load_changes(self._ch_sid, force=True)

        def action_kill(self):
            s=self._sel_session()
            if not s or s["status"]!="running":
                self._status("no running session selected"); return
            def done(ok):
                if ok: self.sup.kill(s["session_id"])
            self.push_screen(Confirm(f"Kill [bold]{s['label']}[/]?"), done)

        def action_delete(self):
            s=self._sel_session()
            if not s: return
            if s["status"]=="running": self._status("kill it first"); return
            def done(ok):
                if ok: self.sup.delete(s["session_id"])
            self.push_screen(Confirm(f"Delete [bold]{s['label']}[/] and its overlay?"), done)

        def action_filt(self):
            s=self._sel_session()
            self.log_filter=None if self.log_filter else (s["session_id"] if s else None)
            self._status("log: all" if not self.log_filter else f"log: {s['label']}")
            cl=self.query_one("#c-log",RichLog); cl.clear()
            for ev in self._all_traffic:
                if not self.log_filter or self.log_filter==ev.get("session_id"):
                    self._write(cl, ev, not bool(self.log_filter))

        def action_ap_once(self, action):
            a=self._sel_approval()
            if not a: self._status("no approval selected"); return
            self.sup.resolve(a["request_id"], action, "once")

        def action_ap_rule(self, action):
            a=self._sel_approval()
            if not a: self._status("no approval selected"); return
            rid=a["request_id"]
            def done(res):
                if res:
                    scope,spec,at_top=res
                    self.sup.resolve(rid, action, scope, spec, at_top)
            self.push_screen(RuleModal(action, a), done)

        def action_refresh(self):
            if self._ch_sid: self._load_changes(self._ch_sid)

        def action_apply_one(self):
            p,sid=self._sel_path(),self._ch_sid
            if p and sid:
                r=self.sup.overlay_apply(sid,[p]); self._cbar(f"applied {len(r['applied'])}")

        def action_apply_all(self):
            sid=self._ch_sid
            if not sid: return
            s=self.sessions.get(sid,{})
            warn="\n[yellow]still running[/]" if s.get("status")=="running" else ""
            def done(ok):
                if ok:
                    r=self.sup.overlay_apply(sid,None); self._cbar(f"applied {len(r['applied'])}")
            self.push_screen(Confirm(f"Apply all {len(self._ch_entries)} changes?{warn}"), done)

        def action_discard_one(self):
            p,sid=self._sel_path(),self._ch_sid
            if p and sid:
                self.sup.overlay_discard(sid,[p]); self._load_changes(sid)

        def action_discard_all(self):
            sid=self._ch_sid
            if not sid: return
            def done(ok):
                if ok: self.sup.overlay_discard(sid,None); self._load_changes(sid)
            self.push_screen(Confirm(f"Discard ALL {len(self._ch_entries)} changes?"), done)

        def action_edit(self):
            p,sid=self._sel_path(),self._ch_sid
            if not p or not sid: return
            d=self.sup.overlay_diff(sid,p)
            if d.get("kind")=="deleted": self._status("can't edit a deletion"); return
            if not d.get("is_text"): self._status("binary — can't edit"); return
            def done(content):
                if content is not None: self.sup.overlay_edit(sid,p,content)
            self.push_screen(Editor(p, d.get("raw") or ""), done)

    ensure_dirs()
    UI().run()
    return 0


# ════════════════════════════════════════════════════════════════════════════
#  Entry
# ════════════════════════════════════════════════════════════════════════════

def main() -> int:
    argv = sys.argv[1:]

    # inner mode: slopbox --inner --channel PATH --sid SID -- CMD...
    if argv and argv[0] == "--inner":
        ap = argparse.ArgumentParser(prog="slopbox --inner")
        ap.add_argument("--channel", default="")
        ap.add_argument("--sid", required=True)
        ap.add_argument("cmd", nargs=argparse.REMAINDER)
        ns = ap.parse_args(argv[1:])
        cmd = ns.cmd
        if cmd and cmd[0] == "--": cmd = cmd[1:]
        return run_inner(ns.channel, ns.sid, cmd)

    if not argv:
        return run_ui()

    ap = argparse.ArgumentParser(
        prog="slopbox",
        usage="slopbox            (start UI)\n"
              "       slopbox [-l NAME] [-w HOST]... [-n] [-C DIR] CMD [ARGS...]")
    ap.add_argument("-l", dest="label", default=None)
    ap.add_argument("-w", dest="whitelist", action="append", default=[], metavar="HOST")
    ap.add_argument("-n", dest="no_net", action="store_true")
    ap.add_argument("-C", dest="chdir", default=None)
    ap.add_argument("cmd", nargs=argparse.REMAINDER)
    if argv[0] in ("-h","--help"):
        ap.print_help(); return 0
    ns = ap.parse_args(argv)
    cmd = ns.cmd
    if cmd and cmd[0] == "--": cmd = cmd[1:]
    return cmd_run(cmd, ns.label, ns.no_net, ns.whitelist, ns.chdir)


if __name__ == "__main__":
    sys.exit(main())
