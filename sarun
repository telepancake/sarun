# These are pure path helpers: they must NOT create anything at import time. The
# in-slopbox `--inner` process imports this module too, and any directory it
# touched (under the slopboxed HOME) would be captured by the overlay and show up
# as a bogus "change". Real directory creation is deferred to ensure_dirs(),
# called only by the UI and the runner.
def data_home() -> Path:
    base = os.environ.get("XDG_DATA_HOME") or os.path.expanduser("~/.local/share")
    return Path(base) / "slopbox"

def config_home() -> Path:
    base = os.environ.get("XDG_CONFIG_HOME") or os.path.expanduser("~/.config")
    return Path(base) / "slopbox"

def runtime_home() -> Path:
    base = os.environ.get("XDG_RUNTIME_DIR")
    return Path(base) / "slopbox" if base else data_home()

def live_home() -> Path:
    """Root of per-box backing dirs: live/<box_id>/up is the discovery sentinel (an
    empty dir that gates box discovery — box writes do NOT land here). Sits next to
    the per-box <box_id>.sqlar under state_home — i.e. ON DISK, not the RAM-backed
    XDG_RUNTIME_DIR tmpfs. Being on the same filesystem as the lower (/) lets pool
    blobs reflink at copy-up. (runtime_home keeps only small ephemera: the control
    socket and the FUSE mountpoint.) Created mode 0700."""
    return state_home() / "live"

def live_dir(box_id) -> Path:
    # Keyed by the box's stable integer id (as a path component, str(box_id)). A
    # rename changes only the box's NAME label in meta — never this dir.
    return live_home() / str(box_id)

# ── content pool ────────────────────────────────────────────────────────────
# A box's regular-file BYTES live in a flat pool, addressed not by host path but
# by <box_id>/<shard>/<row_id>: the box's stable id (filename-independent, so a
# box rename never moves its bytes) and the sqlar entry's row id (stable across
# renames once we update the name in place). The NO-MIRROR invariant now holds for
# ALL kinds: regular files in this pool, and dirs + symlinks ENTIRELY in the sqlar
# rows (dir mode/mtime; symlink target written into the row at creation) served
# from the in-RAM Index mirror — NOTHING is materialized under up/<rel>. The only
# on-disk artifact in up/ is the empty `up/` dir itself, the box-backing sentinel
# that gates discovery ((d/"up").is_dir()). This eliminates the last mirrored-on-
# disk surface and the symlink-escape surface a planted upper symlink would expose:
# readlink/getattr/readdir answer from the row/mirror, never os.readlink/lstat/
# scandir of an artifact. A box's whole working set drops as a unit when its
# <box_id> dir is removed; the shard level keeps any one directory from collecting
# the millions of inodes a large box can produce.
POOL_SHARDS = 1024
# The AT-REST fold threshold: at consolidate/promote, a regular file at least this
# large is kept as a PERMANENT pool file (the row stays resident: data NULL, bytes
# on disk) rather than folded inline into the sqlar blob. Both are valid rest forms;
# the choice is per file, by size. This is a storage-layout knob, set near the
# SQLite internal-vs-external-blob crossover. It is INDEPENDENT of WBUF_SPILL: that
# is a live RAM-vs-disk write-buffer knob and the two need not coincide.
POOL_RESIDENT_MIN = 64 << 10

def pool_home() -> Path:
    return live_home() / "blob"

def box_pool_dir(box_id: int) -> Path:
    return pool_home() / str(int(box_id))

def blob_path(box_id: int, row_id: int) -> Path:
    rid = int(row_id)
    return box_pool_dir(box_id) / f"{rid % POOL_SHARDS:03x}" / str(rid)

def state_home() -> Path:
    base = os.environ.get("XDG_STATE_HOME") or os.path.expanduser("~/.local/state")
    return Path(base) / "slopbox"

def box_ctime(box_id) -> float:
    """A box's age anchor: the ctime of its on-disk identity — the sqlar if present,
    else the backing dir. Replaces parsing a timestamp out of the (now numeric) id."""
    for p in (sqlar_path(box_id), live_dir(box_id)):
        try: return os.stat(p).st_ctime
        except OSError: pass
    return 0.0

# The internal identity of a box is its stable integer box_id, minted eagerly at
# creation. As a path component it is str(box_id): it names live/<box_id>,
# <mnt>/<box_id>, <box_id>.sqlar, the per-session relay socket dir, and the pool
# dir. It is never derived from a name and never changes (a rename is a meta-only
# label write). Any id that arrives as a path component MUST be validated as a plain
# decimal string before use.
#: [b]Box identity, names, and nesting[/]
#: Every box has a stable integer [cyan]box_id[/] that never changes — renaming only changes the
#: display label, never the backing data. Box [b]names[/] are ALL-CAPS identifiers
#: ([cyan]MY-BOX[/], [cyan]WORK[/]) — capitals only, digits, hyphens; must start with a letter.
#: If you do not supply a name, the box gets an automatic name ([cyan]A1[/], [cyan]A2[/], …).
#: Boxes can be [b]nested[/] with dotted names: [cyan]PARENT.CHILD[/] places CHILD inside PARENT's
#: overlay, so CHILD sees PARENT's captured changes as its lower layer. Discarding PARENT
#: copies its files down into children so their inherited view survives.

BOX_ID_RE = re.compile(r"\d+\Z")
# A user-assigned box name: CAPITALS / digits / '-', starts with a letter, never ends
# with a '-'. Uppercase so it can never collide with a lowercase subcommand verb
# (patch/apply/discard/rename) on the command line, and it is a traversal-safe path
# component (no '/', no '.', no '..') usable directly as the box's <name>.sqlar identity.
NAME_RE = re.compile(r"[A-Z]([A-Z0-9-]*[A-Z0-9])?\Z")
# A DOTTED box name: one or more NAME segments separated by '.'.  Each segment must
# satisfy NAME_RE; the whole string must have no empty segments (no leading/trailing/
# consecutive dots), no '/' and no '..'.  By construction each segment is traversal-safe,
# so the whole dotted string is safe as a single path component (we store A.B as one dir).
DOTTED_NAME_RE = re.compile(
    r"[A-Z]([A-Z0-9-]*[A-Z0-9])?(\.[A-Z]([A-Z0-9-]*[A-Z0-9])?)* \Z".replace(" ", ""))

def valid_name(name: "str | None") -> bool:
    return bool(isinstance(name, str) and NAME_RE.match(name))

def valid_dotted_name(name: "str | None") -> bool:
    """True for a dotted-path name: one or more NAME segments joined by '.'.
    Each segment matches NAME_RE (starts with a capital letter, only CAPS/digits/'-',
    never ends with '-').  Rejects empty string, leading/trailing dots, consecutive dots
    ('..'), any '/', and any standalone '..' segment — all traversal-safe by construction.
    A single-segment name (no dot) is also valid (it equals valid_name)."""
    return bool(isinstance(name, str) and DOTTED_NAME_RE.match(name))

def valid_box_id(box_id: "str | None") -> bool:
    # The internal box key is str(box_id): a plain decimal string. This validates a
    # path component / teardown key — NOT a user-facing name (see valid_name).
    return bool(isinstance(box_id, str) and BOX_ID_RE.match(box_id))

def relay_dir(box_id) -> Path:
    """The per-session directory that holds ONLY this box's relay socket. Bound into
    exactly this box (and no other), so an FD arriving on its relay socket is always
