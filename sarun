            except Exception: pass

        @on(ListView.Selected, "#r-list")
        def _file_rule_activated(self, ev):
            self._file_rule_edit_at(self.query_one("#r-list",ListView).index)

        def _rebuild_ch(self, preserve=False):
            sigs={"created":("+","green"),"modified":("~","yellow"),"deleted":("-","red")}
            def flag(e):
                sym,col=sigs.get(e["kind"],("?",""))
                t=Text(sym, style=col)
                if e.get("stale"): t.append("!", style="reverse red")  # host is newer
                return t
            def src(e):
                # where this change currently lives: P = consolidated patch (on
                # disk / in memory), O = raw overlay on /dev/shm.
                if e.get("source")=="patch": return Text("P", style="blue")
                return Text("O", style="dim")
            rows=[(e["path"], [flag(e), src(e),
                               Text(e["path"], style="red" if e.get("stale") else ""),
                               fmt_bytes(e["size"]) if e["size"] else ""])
                  for e in self._ch_entries]
            self._sync_table(self.query_one("#cf-tab",DataTable), rows)

        def _ingest(self, ev):
            self._all_traffic.append(ev)
            self._write(self.query_one("#t-log",RichLog), ev, True)
            if not self.log_filter or self.log_filter==ev.get("session_id"):
                self._write(self.query_one("#c-log",RichLog), ev, not bool(self.log_filter))

        def _write(self, w, ev, sid):
            act=ev.get("action","?"); col="green" if act=="allow" else "red"
            ts=time.strftime("%H:%M:%S", time.localtime(ev.get("ts",time.time())))
            t=Text()
            t.append(ts+" ", style="dim")
            if sid: t.append(str(ev.get("session_id",""))[:8]+" ", style="dim cyan")
            t.append(("✓" if act=="allow" else "✗")+" ", style=col)
            t.append(str(ev.get("scheme","?"))+" ", style="bold")
            t.append(str(ev.get("host","?")), style="cyan")
            t.append(":"+str(ev.get("port","?")))
            if ev.get("status"): t.append(f" [{ev['status']}]")
            bu,bd=ev.get("bytes_up",0),ev.get("bytes_down",0)
            if bu or bd: t.append(f" ↑{fmt_bytes(bu)} ↓{fmt_bytes(bd)}", style="dim")
            w.write(t)

        def _diff_info_lines(self, d):
            k=d.get("kind")
            if k=="deleted": return [Text("DELETED", style="red bold")]
            if k=="directory": return [Text("DIRECTORY", style="cyan")]
            if k=="error": return [Text(str(d.get("error")), style="red")]
            diff=d.get("diff"); out=[]
            if diff is not None:
                for ln in diff.splitlines():
                    if ln.startswith(("+++","---")): out.append(Text(ln, style="bold"))
                    elif ln.startswith("+"): out.append(Text(ln, style="green"))
                    elif ln.startswith("-"): out.append(Text(ln, style="red"))
                    elif ln.startswith("@@"): out.append(Text(ln, style="cyan"))
                    else: out.append(Text(ln, style="dim"))
                if not diff.strip(): out.append(Text("(no textual diff)", style="dim"))
            else:
                raw=base64.b64decode(d.get("content") or b"")
                out.append(Text(f"binary · {fmt_bytes(len(raw))}", style="dim"))
                for i in range(0,min(len(raw),256),16):
                    ch=raw[i:i+16]; h=" ".join(f"{b:02x}" for b in ch)
                    a="".join(chr(b) if 0x20<=b<0x7f else "." for b in ch)
                    out.append(Text(f"{i:04x}  {h:<48}  {a}", style="dim"))
            return out

        def _load_diff(self, sid, rel, keep_pos=False):
            dv=self.query_one("#cd-log",DiffView)
            keep=dv.index if keep_pos else None
            res=self.sup.hunks(sid, rel)
            dv.clear()
            if res.get("is_text"):
                hunks=res.get("hunks") or []
                if not hunks:
                    dv.append(ListItem(Label(Text("(no textual differences)", style="dim"))))
                for h in hunks:
                    dv.append(HunkItem(h["index"], h["lines"]))
            else:
                for line in self._diff_info_lines(res.get("diff") or {}):
                    dv.append(ListItem(Label(line)))
            n=len(dv.children)
            if keep is not None and n: dv.index=min(keep, n-1)

        def _hunk_op(self, index, discard):
            sid=self._ch_sid; p=self._sel_path()
            if not sid or p is None: return
            r=(self.sup.discard_hunk if discard
               else self.sup.apply_hunk)(sid, p, index)
            if not r.get("ok"): self._status(Text(r.get("error") or "hunk op failed")); return
            self._load_changes(sid)
            if any(e["path"]==p for e in self._ch_entries):
                self._load_diff(sid, p, keep_pos=True)
            else:
                try: self.query_one("#cd-log",DiffView).clear()
                except Exception: pass
            self._cbar("hunk " + ("discarded" if discard else "applied"))
        def _hunk_apply(self, index): self._hunk_op(index, discard=False)
        def _hunk_discard(self, index): self._hunk_op(index, discard=True)

        def _status(self, t):
            try: self.query_one("#status",Static).update(t)
            except Exception: pass
        def _cbar(self, msg=""):
            sid=self._ch_sid
            dirty=("[reverse red] ● UNSAVED PATCH — press s to save [/]  "
                   if sid and self.sup.patch_dirty(sid) else "")
            n=len(self._ch_entries)
            extra=f"{n} change(s)" + (f"  ·  {msg}" if msg else "")
            try: self.query_one("#c-bar",Static).update(f"  {dirty}[dim]{extra}[/]")
            except Exception: pass

        def _sel_session(self):
            t=self.query_one("#s-tab",DataTable)
            if not t.row_count: return None
            try: return self.sessions.get(
                t.coordinate_to_cell_key((t.cursor_row,0)).row_key.value)
            except Exception: return None
        def _sel_approval(self):
            it=self.query_one("#a-list",ListView).highlighted_child
            return it.a if isinstance(it,ApprovalItem) else None
        def _sel_path(self):
            t=self.query_one("#cf-tab",DataTable)
            if not t.row_count: return None
            try: return t.coordinate_to_cell_key((t.cursor_row,0)).row_key.value
            except Exception: return None

        def _load_changes(self, sid, force=False):
            entries=self.sup.session_changes(sid)
            # Only touch the table when the set of changes actually differs, so the
            # periodic refresh keeps the pane live without blinking or losing the
            # cursor while nothing is changing.
            if not force and entries==self._ch_entries:
                return
            self._ch_entries=entries
            self._rebuild_ch(preserve=True)
            self._cbar()

        @on(DataTable.RowHighlighted, "#s-tab")
        def _sc(self, ev):
            if ev.row_key and ev.row_key.value:
                sid=ev.row_key.value
                self._ch_sid=sid
                if sid!=self._last_loaded_sid:
                    self._last_loaded_sid=sid
                    self._load_changes(sid, force=True)

        @on(DataTable.RowSelected, "#s-tab")
        def _s_open(self, ev):
            # Enter on a slopbox drills into its Changes view.
            if ev.row_key and ev.row_key.value:
                self._open_changes(ev.row_key.value)

        @on(DataTable.RowHighlighted, "#cf-tab")
        def _cc(self, ev):
            if ev.row_key and ev.row_key.value and self._ch_sid:
                self._load_diff(self._ch_sid, ev.row_key.value)

        @on(DataTable.RowSelected, "#cf-tab")
        def _f_open(self, ev):
            # Enter on a file focuses the diff/hunk pane for it.
            if ev.row_key and ev.row_key.value and self._ch_sid:
                self._load_diff(self._ch_sid, ev.row_key.value)
                try: self.query_one("#cd-log",DiffView).focus()
                except Exception: pass

        def _goto(self, t):
            # Leaving the content view autosaves any dirty patch.
            if self.query_one("#tabs",TabbedContent).active=="t-ch" and t!="t-ch":
                self._save_all_patches()
            self.query_one("#tabs",TabbedContent).active=t
            if t=="t-ch" and self._ch_sid: self._load_changes(self._ch_sid, force=True)
            # Move focus into the tab's primary pane so the footer shows its keys.
            focus={"t-sb":"#s-tab","t-ch":"#cf-tab","t-fr":"#r-list",
                   "t-tr":"#t-log"}.get(t)
            if focus:
                try: self.query_one(focus).focus()
                except Exception: pass

        # ── drill-down navigation: Enter goes in, Esc comes back ──────────────
        #   Slopboxes ──enter──▶ Changes (this slopbox) ──enter──▶ Diff
        #             ◀──esc─────          ◀──esc──────
        def _open_changes(self, sid):
            self._ch_sid=sid; self._last_loaded_sid=sid
            self._goto("t-ch")

        def action_back(self):
            """Step back out: Diff → files → Slopboxes; Traffic → Slopboxes."""
            active=self.query_one("#tabs",TabbedContent).active
            if active=="t-ch":
                try: in_diff=self.focused is self.query_one("#cd-log",DiffView)
                except Exception: in_diff=False
                if in_diff:
                    try: self.query_one("#cf-tab",DataTable).focus()
                    except Exception: pass
                else:
                    self._goto("t-sb")
            elif active in ("t-tr","t-fr"):
                self._goto("t-sb")

        def action_traffic(self): self._goto("t-tr")
        def action_rules(self): self._goto("t-fr")

        def action_kill(self):
            s=self._sel_session()
            if not s or s["status"]!="running":
                self._status("no running session selected"); return
            def done(ok):
                if ok: self.sup.kill(s["session_id"])
            self.push_screen(Confirm(styled("Kill ", (s['label'],"bold"), "?")), done)

        def action_delete(self):
            s=self._sel_session()
            if not s: return
            if s["status"]=="running": self._status("kill it first"); return
            def done(ok):
                if ok: self.sup.delete(s["session_id"])
            self.push_screen(Confirm(styled("Delete ", (s['label'],"bold"), " and its overlay?")), done)

        def action_filt(self):
            s=self._sel_session()
            self.log_filter=None if self.log_filter else (s["session_id"] if s else None)
            self._status("log: all" if not self.log_filter else styled("log: ", (s['label'],"")))
            cl=self.query_one("#c-log",RichLog); cl.clear()
            for ev in self._all_traffic:
                if not self.log_filter or self.log_filter==ev.get("session_id"):
                    self._write(cl, ev, not bool(self.log_filter))

        def action_ap_once(self, action):
            a=self._sel_approval()
            if not a: self._status("no approval selected"); return
            self.sup.resolve(a["request_id"], action, "once")

        def action_ap_rule(self, action):
            a=self._sel_approval()
            if not a: self._status("no approval selected"); return
            rid=a["request_id"]
            def done(res):
                if res:
                    scope,spec,at_top=res
                    self.sup.resolve(rid, action, scope, spec, at_top)
            self.push_screen(RuleModal(action, a), done)

        def action_refresh(self):
            if self._ch_sid: self._load_changes(self._ch_sid)

        def action_save_patch(self):
            sid=self._ch_sid
            if not sid: return
            self.sup.save_patch(sid); self._load_changes(sid); self._cbar("patch saved")

        def _refresh_after(self, sid, p):
            self._load_changes(sid)
            if p is not None and any(e["path"]==p for e in self._ch_entries):
                self._load_diff(sid, p, keep_pos=True)
            else:
                try: self.query_one("#cd-log",DiffView).clear()
                except Exception: pass

        def action_apply_one(self):
            p,sid=self._sel_path(),self._ch_sid
            if p and sid:
                r=self.sup.apply(sid,[p]); self._cbar(f"applied {len(r['applied'])}")
                self._refresh_after(sid, p)

        def action_apply_all(self):
            sid=self._ch_sid
            if not sid: return
            s=self.sessions.get(sid,{})
            warn="\n[yellow]still running[/]" if s.get("status")=="running" else ""
            def done(ok):
                if ok:
                    r=self.sup.apply(sid,None); self._cbar(f"applied {len(r['applied'])}")
                    self._refresh_after(sid, None)
            self.push_screen(Confirm(f"Apply all {len(self._ch_entries)} changes?{warn}"), done)

        def action_discard_one(self):
            p,sid=self._sel_path(),self._ch_sid
            if p and sid:
                self.sup.discard(sid,[p]); self._refresh_after(sid, p)

        def action_discard_all(self):
            sid=self._ch_sid
            if not sid: return
            def done(ok):
                if ok: self.sup.discard(sid,None); self._refresh_after(sid, None)
            self.push_screen(Confirm(f"Discard ALL {len(self._ch_entries)} changes?"), done)

    ensure_dirs()
    UI().run()
    return 0


# ════════════════════════════════════════════════════════════════════════════
#  Entry
# ════════════════════════════════════════════════════════════════════════════

def main() -> int:
    argv = sys.argv[1:]

    # inner mode: slopbox --inner --channel PATH --sid SID -- CMD...
    if argv and argv[0] == "--inner":
        ap = argparse.ArgumentParser(prog="slopbox --inner")
        ap.add_argument("--channel", default="")
        ap.add_argument("--sid", required=True)
        ap.add_argument("cmd", nargs=argparse.REMAINDER)
        ns = ap.parse_args(argv[1:])
        cmd = ns.cmd
        if cmd and cmd[0] == "--": cmd = cmd[1:]
        return run_inner(ns.channel, ns.sid, cmd)

    if not argv:
        return run_ui()

    ap = argparse.ArgumentParser(
        prog="slopbox",
        usage="slopbox            (start UI)\n"
              "       slopbox [-l NAME] [-w HOST]... [-n] [-C DIR] CMD [ARGS...]")
    ap.add_argument("-l", dest="label", default=None)
    ap.add_argument("-w", dest="whitelist", action="append", default=[], metavar="HOST")
    ap.add_argument("-n", dest="no_net", action="store_true")
    ap.add_argument("-C", dest="chdir", default=None)
    ap.add_argument("cmd", nargs=argparse.REMAINDER)
    if argv[0] in ("-h","--help"):
        ap.print_help(); return 0
    ns = ap.parse_args(argv)
    cmd = ns.cmd
    if cmd and cmd[0] == "--": cmd = cmd[1:]
    return cmd_run(cmd, ns.label, ns.no_net, ns.whitelist, ns.chdir)


if __name__ == "__main__":
    sys.exit(main())
