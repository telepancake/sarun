        @on(Button.Pressed,"#rb-sess")
        def _s(self): self._go("session")
        @on(Button.Pressed,"#rb-perm")
        def _p(self): self._go("permanent")
        @on(Button.Pressed,"#rb-cancel")
        def _c(self): self.dismiss(None)

