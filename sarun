def ensure_ca_cert() -> "Path | None":
    """Generate the mitmproxy CA cert if not already present. Returns CA_CERT on
    success or None if mitmdump is unavailable or times out."""
    if CA_CERT.exists(): return CA_CERT
    try:
        # Port 0: let mitmdump pick a free ephemeral port — no TOCTOU race.
        proc = subprocess.Popen(
            ["mitmdump", "-q", "--listen-host", "127.0.0.1",
             "--listen-port", "0", "--set", f"confdir={MITM_CONFDIR}"],
            stdin=subprocess.DEVNULL, stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL)
        for _ in range(50):
            if CA_CERT.exists(): break
            time.sleep(0.1)
        proc.terminate()
        try: proc.wait(timeout=3)
        except Exception: proc.kill()
    except FileNotFoundError:
        pass
    if not CA_CERT.exists():
        print("slopbox: ensure_ca_cert: mitmdump timed out; CA cert not generated",
              file=sys.stderr)
        return None
    return CA_CERT


# Where the various distros keep the system CA bundle that OpenSSL/curl/git read
# by default. We add our mitmproxy CA to every one that exists.
SYSTEM_CA_FILES = (
    "/etc/ssl/certs/ca-certificates.crt",                   # Debian/Ubuntu/Arch
    "/etc/pki/tls/certs/ca-bundle.crt",                     # Fedora/RHEL (symlink)
    "/etc/pki/ca-trust/extracted/pem/tls-ca-bundle.pem",   # Fedora/RHEL (real)
    "/etc/ssl/cert.pem",                                    # Alpine/LibreSSL/BSD
    "/etc/ssl/ca-bundle.pem",                               # openSUSE
)

def primary_ca_path() -> "str | None":
    for f in SYSTEM_CA_FILES:
        if Path(f).is_file(): return f
    return None

# The CA-augmented trust bundle is synthesized as virtual files at each system
# bundle path (see OverlayMount.add_ca_spoof / MultiplexOverlayFs virtual files):
# the box sees system CA + our mitmproxy CA there, but the augmented bytes have
# no on-disk artifact, so they stay invisible to change review.


