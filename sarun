    def fmt_bytes(n):
        for u, d in (("G",1<<30),("M",1<<20),("K",1<<10)):
            if n >= d: return f"{n/d:.1f}{u}"
        return f"{n}B"
    def fmt_age(ts):
        s = int(time.time()-ts)
        if s<60: return f"{s}s"
        if s<3600: return f"{s//60}m{s%60:02d}s"
        return f"{s//3600}h{(s%3600)//60:02d}m"
