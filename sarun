#  Session model + discovery + robust removal
# ════════════════════════════════════════════════════════════════════════════

# ════════════════════════════════════════════════════════════════════════════
#  Patch codec — a byte-exact unified diff (multi-file), computed ON DEMAND from
#  the single sqlar (there is no patch file at rest). Used to render text diffs in
#  the Changes view, to apply/discard an individual hunk, and to print a box's
#  whole patch over the control socket (`slopbox patch`). The original command is
#  the box's ROOT process row in the same sqlar (tgid == the sid's pid).
# ════════════════════════════════════════════════════════════════════════════

def ut_split(data: bytes) -> list:
    """Split bytes into lines on \\n, keeping the terminator on each line (the last
    line keeps whatever it had). b"".join(result) == data exactly, so splicing
    these line-pieces and writing the bytes back is lossless — CR/CRLF, encoding,
    BOM and a missing final newline are all preserved."""
    parts = data.split(b"\n")
    lines = [p + b"\n" for p in parts[:-1]]
    if parts[-1]:
        lines.append(parts[-1])
    return lines

# A session's whole identity is its name: "YYYYmmdd-HHMMSS_PID". The timestamp
# (1-second resolution) and the runner's pid can't collide — a live pid is unique,
# and two runs in the same second have different runner pids — so we need nothing
# else. Start time, pid and a display label are all read back out of the name; the
# name is used as the live/<sid> backing dir, the <mnt>/<sid> mount subfolder, and
# the single db basename (<sid>.sqlar). The command is the root process row in it.
_SID_FMT = "%Y%m%d-%H%M%S"

def make_sid() -> str:
    return time.strftime(_SID_FMT) + "_" + str(os.getpid())

def parse_sid(sid: str) -> tuple:
    """(started_epoch, pid) from a "YYYYmmdd-HHMMSS_PID" name; zeros if malformed.
    A rare ".<hex>" collision suffix is stripped before parsing the host pid."""
    if not isinstance(sid, str): return 0.0, 0
    stamp, _, pids = sid.partition(".")[0].rpartition("_")
    try: started = time.mktime(time.strptime(stamp, _SID_FMT))
    except (ValueError, OverflowError): started = 0.0
    try: pid = int(pids)
    except ValueError: pid = 0
    return started, pid

_PROC_TREE_DEPTH = 64   # defensive cap on a root→self walk (cycles / runaway chains)

def build_path_tree(members, payload_of):
    """Generic stateless TREE core shared by the proc and file panes. `members` maps
    key -> path-tuple for the REAL rows. Every ancestor PREFIX of a member's path that
    isn't itself a member is unioned in as a structural CONNECTOR, so the tree is fully
    connected; sorting all rows by their path tuple yields DFS order (a parent/prefix
    immediately precedes its subtree, siblings ordered by the tuple). `payload_of(path)`
    resolves the per-row payload for any node (member or connector) — the caller keys it
    however it likes (proc: last tuple element = tgid; file: the joined path).

    Returns [(key, payload, depth, connector)] in DFS order, where depth=len(path)-1 and
    `connector`=True for a purely-structural prefix added by the union. Order-independent:
    output is a pure function of the member set + payload_of."""
    paths = {}                                # path-tuple -> key  (member or connector)
    is_member = {}                            # path-tuple -> bool
    for key, path in members.items():
        path = tuple(path)
        paths[path] = key; is_member[path] = True
        for i in range(1, len(path)):         # union in every ancestor prefix
            pre = path[:i]
            if pre not in paths:
                paths.setdefault(pre, pre); is_member.setdefault(pre, False)
    for path in list(paths):
        is_member.setdefault(path, False)
    rows = []
    for path in sorted(paths):                # lexicographic path → DFS order
        connector = not is_member[path]
        rows.append((paths[path], payload_of(path), len(path) - 1, connector))
    return rows

def build_proc_tree(procs, root_pid, lookup):
    """Stateless process-TREE assembly: turn a flat viewing list into DFS-ordered,
    depth-indented rows that stay correct under any scroll/paging with NO global tree
    state. For each member compute its root→self pid path by walking the ppid chain up
    to `root_pid` (defensive: visited-guard, stop at root / ppid<=1 / a missing
    ancestor, cap depth). UNION in every ancestor met while walking — even ones not in
    `procs` — so the tree is fully connected; the generic core (build_path_tree) then
    sorts by path tuple to yield DFS order (parent immediately before its subtree,
    siblings by pid).

    `procs` is [(id, tgid, ppid, exe, argv-list)]; `lookup(tgid)->(ppid,exe,argv)|None`
    resolves connector ancestors not present in `procs` (same builder for live/finished).
    Returns [(id, tgid, ppid, exe, argv, depth, connector)] in DFS order, where
    depth=len(path)-1 and `connector`=True for a purely-structural ancestor (added by
    the union, not a member of `procs`). Order-independent: output is a pure function of
    the (root_pid, lookup, set-of-procs)."""
    members = {}                              # tgid -> (id, ppid, exe, argv)
    for pid, tgid, ppid, exe, argv in procs:
        members[tgid] = (pid, ppid, exe or "", list(argv))
    nodes = {}                                # tgid -> (ppid, exe, argv)
    for tgid, (_id, ppid, exe, argv) in members.items():
        nodes[tgid] = (ppid, exe, argv)

    def info(tgid):
        if tgid in nodes: return nodes[tgid]
        m = members.get(tgid)
        if m is not None: return m[1], m[2], m[3]
        got = lookup(tgid) if lookup else None
        return got                            # (ppid,exe,argv) or None

    def path_of(tgid):
        path = []; seen = set()
        cur = tgid
        for _ in range(_PROC_TREE_DEPTH):
            if cur in seen: break             # cycle guard
            seen.add(cur); path.append(cur)
            if cur == root_pid: break         # reached the box root
            got = info(cur)
            if got is None: break             # missing ancestor: stop, link what we have
            ppid = got[0]
            if ppid <= 1: break               # init / unknown parent
            nodes.setdefault(ppid, info(ppid) or (0, "", []))
            cur = ppid
        path.reverse()
        return tuple(path)

    member_paths = {tgid: path_of(tgid) for tgid in list(members)}

    def payload_of(path):
        tgid = path[-1]                       # last pid-path element identifies the proc
        ppid, exe, argv = nodes.get(tgid) or (info(tgid) or (0, "", []))
        connector = tgid not in members
        pid = members[tgid][0] if not connector else tgid
        return pid, tgid, ppid, exe, argv

    rows = build_path_tree(member_paths, payload_of)
    return [(pid, tgid, ppid, exe, argv, depth, connector)
            for (_tgid, (pid, tgid, ppid, exe, argv), depth, connector) in rows]

_NO_NL = b"\\ No newline at end of file\n"   # standard "no newline at EOF" marker

class PatchConflict(Exception):
    """A hunk's recorded context no longer matches the file it applies to."""

def _emit(out: list, prefix: bytes, line: bytes) -> None:
    # Each physical patch line ends in \n; a content line lacking its own newline
    # gets one (as terminator) plus the NO_NL marker, so parsing is unambiguous and
    # \r (CRLF) is preserved as content.
    if line.endswith(b"\n"):
        out.append(prefix + line)
    else:
        out.append(prefix + line + b"\n"); out.append(_NO_NL)

def make_patch(files: list) -> bytes:
    """files: list of dict(rel, lower, upper, created, deleted) with lower/upper as
    byte-line lists (from ut_split). Returns the unified-diff bytes."""
    out = []
    for f in files:
        a = b"/dev/null" if f["created"] else b"a/" + f["rel"].encode("utf-8","surrogateescape")
        b = b"/dev/null" if f["deleted"] else b"b/" + f["rel"].encode("utf-8","surrogateescape")
        out.append(b"--- " + a + b"\n"); out.append(b"+++ " + b + b"\n")
        ll, ul = f["lower"], f["upper"]
        for g in difflib.SequenceMatcher(None, ll, ul).get_grouped_opcodes(3):
            a1, a2, b1, b2 = g[0][1], g[-1][2], g[0][3], g[-1][4]
            out.append(f"@@ -{a1+1},{a2-a1} +{b1+1},{b2-b1} @@\n".encode())
            for tag, i1, i2, j1, j2 in g:
                if tag == "equal":
                    for ln in ll[i1:i2]: _emit(out, b" ", ln)
                else:
                    for ln in ll[i1:i2]: _emit(out, b"-", ln)
                    for ln in ul[j1:j2]: _emit(out, b"+", ln)
    return b"".join(out)

def parse_patch(data: bytes) -> dict:
    """Parse unified-diff bytes into an ordered {rel: filepatch} where filepatch is
    dict(rel, created, deleted, hunks=[dict(a1, b1, lines)]) and lines is the ordered
    [(op, byteline)] with op in ' '/'-'/'+'. Ordered lines let us re-serialize and
    edit hunks losslessly."""
    files = {}; cur = None; phys = ut_split(data); i = 0
    while i < len(phys):
        line = phys[i]; i += 1
        if line.startswith(b"--- "):
            aside = line[4:].rstrip(b"\n")
            bside = phys[i][4:].rstrip(b"\n") if i < len(phys) else b""; i += 1
            created = aside == b"/dev/null"; deleted = bside == b"/dev/null"
            relb = (aside if deleted else bside)[2:]   # strip "a/" or "b/"
            rel = relb.decode("utf-8","surrogateescape")
            cur = files[rel] = dict(rel=rel, created=created, deleted=deleted, hunks=[])
        elif line.startswith(b"@@") and cur is not None:
            m = re.search(rb"-(\d+)(?:,\d+)? \+(\d+)", line)
            cur["hunks"].append(dict(a1=int(m.group(1)) - 1,
                                     b1=int(m.group(2)) - 1, lines=[]))
        elif cur and cur["hunks"] and line[:1] in (b" ", b"-", b"+"):
            prefix = line[:1]; content = line[1:]
            if i < len(phys) and phys[i] == _NO_NL:
                i += 1; content = content[:-1]      # drop the terminator we added
            cur["hunks"][-1]["lines"].append((prefix.decode(), content))
    return files

def hunk_a_lines(h): return [bl for op, bl in h["lines"] if op != "+"]
def hunk_b_lines(h): return [bl for op, bl in h["lines"] if op != "-"]

def serialize_patch(files: dict) -> bytes:
    """Inverse of parse_patch: render an ordered {rel: filepatch} back to bytes."""
    out = []
    for fp in files.values():
        a = b"/dev/null" if fp["created"] else b"a/" + fp["rel"].encode("utf-8","surrogateescape")
        b = b"/dev/null" if fp["deleted"] else b"b/" + fp["rel"].encode("utf-8","surrogateescape")
        out.append(b"--- " + a + b"\n"); out.append(b"+++ " + b + b"\n")
        for h in fp["hunks"]:
            na, nb = len(hunk_a_lines(h)), len(hunk_b_lines(h))
            out.append(f"@@ -{h['a1']+1},{na} +{h['b1']+1},{nb} @@\n".encode())
            for op, line in h["lines"]:
                _emit(out, op.encode(), line)
    return b"".join(out)

def build_file_patch(rel, lower, upper, created, deleted) -> dict:
    """Parsed filepatch for one file from its lower/upper byte-line lists."""
    return parse_patch(make_patch([dict(rel=rel, lower=lower, upper=upper,
                                        created=created, deleted=deleted)]))[rel]

# ════════════════════════════════════════════════════════════════════════════
#  The single per-instance database — ONE sqlite file per slopbox (the sqlar).
#
#  There is exactly ONE database file per box, at sqlar_path(sid). It is BOTH the
#  live index (consulted on every FUSE op, mirrored in RAM for the hot path) AND
#  the at-rest archive. It holds ALL state in one schema:
#
#    sqlar(name, mode, mtime, sz, data, opaque, writer)
#        every file/dir/symlink/whiteout entry with its metadata. `data` is the
#        zlib-deflated file content (NULL until consolidate() fills it from the
#        overlay upper). A char-device mode with NULL data is a deletion
#        tombstone (whiteout). `opaque`=1 marks an opaque directory. `writer` is
#        the process-table id (FK to process.id) that produced/last-modified it.
#    provenance(path, pid, ppid, exe, argv)
#        per-path writer provenance (pid/exe/argv).
#    process(id, tgid, ppid, exe, argv, env_id)
#        the box's process table (one row per traced tgid); env_id -> env.id.
#    env(id, hash, env)
#        unique environment json, deduped by hash and referenced by env_id.
#    flows(...)
#        every gated request/response for the box.
#
#  The overlay upper (live/<sid>/up) is a directory of real files where the box's
#  bytes land fast during the run; it is NOT a database. consolidate() reads those
#  bytes and UPDATEs each already-existing sqlar row's NULL `data` in place, then
#  tears the upper down — the sqlar is then self-contained.
# ════════════════════════════════════════════════════════════════════════════

def _like_escape(s: str) -> str:
    """Escape \\ % _ for use with LIKE ? ESCAPE '\\\\'."""
    return s.replace("\\", "\\\\").replace("%", "\\%").replace("_", "\\_")

def sqlar_path(session_id: str) -> Path:
    return state_home() / (session_id + ".sqlar")

def _sqlar_open(path) -> "sqlite3.Connection":
    path = Path(path); path.parent.mkdir(parents=True, exist_ok=True)
    # 0700: the single db holds writer provenance (pid/exe/argv/env).
    old = os.umask(0o077)
    try:
        conn = sqlite3.connect(str(path))
    finally:
        os.umask(old)
    try: os.chmod(str(path), 0o600)
    except OSError: pass
    conn.execute("PRAGMA busy_timeout=3000")
    conn.executescript(
        "CREATE TABLE IF NOT EXISTS sqlar"
        "(name TEXT PRIMARY KEY, mode INT, mtime INT, sz INT, data BLOB,"
        " opaque INT DEFAULT 0, writer INT);"
        "CREATE TABLE IF NOT EXISTS provenance"
        "(path TEXT PRIMARY KEY, pid INT, ppid INT, exe TEXT, argv TEXT);"
        "CREATE TABLE IF NOT EXISTS env"
        "(id INTEGER PRIMARY KEY AUTOINCREMENT, hash TEXT UNIQUE, env TEXT);"
        "CREATE TABLE IF NOT EXISTS process"
        "(id INTEGER PRIMARY KEY AUTOINCREMENT, tgid INT UNIQUE, ppid INT,"
        " exe TEXT, argv TEXT, env_id INT);"
        "CREATE TABLE IF NOT EXISTS flows("
        " id INTEGER PRIMARY KEY AUTOINCREMENT, ts REAL, action TEXT,"
        " method TEXT, scheme TEXT, host TEXT, port INT, url TEXT, status INT,"
        " process_id INT, req_headers TEXT, req_len INT, req_body BLOB,"
        " resp_headers TEXT, resp_len INT, resp_body BLOB);")
    return conn

def _sqlar_deflate(content: bytes):
    comp = zlib.compress(content, 6)
    return (comp, len(content)) if len(comp) < len(content) else (content, len(content))

def _sqlar_put_file(conn, name, content: bytes, mode, mtime) -> None:
    data, sz = _sqlar_deflate(content)
    conn.execute("INSERT INTO sqlar(name,mode,mtime,sz,data) VALUES(?,?,?,?,?)"
                 " ON CONFLICT(name) DO UPDATE SET mode=excluded.mode,"
                 " mtime=excluded.mtime, sz=excluded.sz, data=excluded.data",
                 (name, int(mode), int(mtime), sz, sqlite3.Binary(data)))

def _sqlar_put_provenance(conn, name, prov: dict) -> None:
    conn.execute("INSERT OR REPLACE INTO provenance VALUES(?,?,?,?,?)",
                 (name, int(prov.get("pid") or 0), int(prov.get("ppid") or 0),
                  prov.get("exe") or "", json.dumps(prov.get("argv") or [])))

def _sqlar_put_symlink(conn, name, target: bytes, mtime) -> None:
    conn.execute("INSERT INTO sqlar(name,mode,mtime,sz,data) VALUES(?,?,?,?,?)"
                 " ON CONFLICT(name) DO UPDATE SET mode=excluded.mode,"
                 " mtime=excluded.mtime, sz=excluded.sz, data=excluded.data",
                 (name, stat_mod.S_IFLNK | 0o777, int(mtime), len(target),
                  sqlite3.Binary(target)))

def _sqlar_put_tombstone(conn, name) -> None:
    conn.execute("INSERT INTO sqlar(name,mode,mtime,sz,data) VALUES(?,?,?,?,?)"
                 " ON CONFLICT(name) DO UPDATE SET mode=excluded.mode,"
                 " mtime=excluded.mtime, sz=excluded.sz, data=excluded.data",
                 (name, stat_mod.S_IFCHR, 0, 0, None))

def sqlar_list(path) -> list:
    """[(name, mode, mtime, sz)] sorted by name; [] if there is no archive."""
    path = Path(path)
    if not path.exists(): return []
    conn = _sqlar_open(path)
    try: return conn.execute("SELECT name,mode,mtime,sz FROM sqlar "
                             "ORDER BY name").fetchall()
    except sqlite3.Error: return []
    finally: conn.close()

def sqlar_mode(path, name) -> "int | None":
    path = Path(path)
    if not path.exists(): return None
    conn = _sqlar_open(path)
    try:
        row = conn.execute("SELECT mode FROM sqlar WHERE name=?", (name,)).fetchone()
    except sqlite3.Error: row = None
    finally: conn.close()
    return row[0] if row else None

def sqlar_mtime(path, name) -> "float | None":
    path = Path(path)
    if not path.exists(): return None
    conn = _sqlar_open(path)
    try:
        row = conn.execute("SELECT mtime FROM sqlar WHERE name=?", (name,)).fetchone()
    except sqlite3.Error: row = None
    finally: conn.close()
    return row[0] if row else None

def sqlar_content(path, name) -> "bytes | None":
    """Decompressed bytes for one entry (the symlink target for a symlink); None if
    missing, a tombstone, or content not yet consolidated (NULL blob)."""
    path = Path(path)
    if not path.exists(): return None
    conn = _sqlar_open(path)
    try:
        row = conn.execute("SELECT sz,data FROM sqlar WHERE name=?", (name,)).fetchone()
    except sqlite3.Error: row = None
    finally: conn.close()
    if not row or row[1] is None: return None
    sz, data = row[0], bytes(row[1])
    return data if len(data) == sz else zlib.decompress(data)

def sqlar_remove(path, name) -> int:
    """Drop one entry; unlink the archive when it empties of entries. Returns
    entries left."""
    path = Path(path)
    if not path.exists(): return 0
    conn = _sqlar_open(path)
    try:
        conn.execute("DELETE FROM sqlar WHERE name=?", (name,))
        conn.execute("DELETE FROM provenance WHERE path=?", (name,)); conn.commit()
        left = conn.execute("SELECT COUNT(*) FROM sqlar").fetchone()[0]
        flows = conn.execute("SELECT COUNT(*) FROM flows").fetchone()[0]
    except sqlite3.Error: left = 1; flows = 1
    finally: conn.close()
    if left == 0 and flows == 0:
        try: path.unlink()
        except OSError: pass
    return left


# ════════════════════════════════════════════════════════════════════════════
#  Network log — every gated request/response for a session, written live by the
#  in-process mitmproxy into the `flows` table of the box's single sqlar db (the
#  same file as the file index). No separate flows file. Each flow can carry the
#  process-table id (process_id) of the in-box process that opened the connection.
# ════════════════════════════════════════════════════════════════════════════

_FLOW_BODY_CAP = 1 << 20    # store at most 1 MiB of each body (but record true size)
_PROC_RETIRE_S = 4.0        # live proc pane: keep a dead tgid (highlighted) this long
_ACTIVE_CAP    = 4096       # active set hard cap (bounds RAM when the pane is unwatched)

def _hdr_text(items) -> str:
    out = []
    for k, v in (items or []):
        if isinstance(k, bytes): k = k.decode("latin-1", "replace")
        if isinstance(v, bytes): v = v.decode("latin-1", "replace")
        out.append(f"{k}: {v}")
    return "\n".join(out)

def flows_add(path, fl: dict) -> None:
    rb = fl.get("req_body") or b""; pb = fl.get("resp_body") or b""
    conn = _sqlar_open(path)
    try:
        conn.execute(
            "INSERT INTO flows(ts,action,method,scheme,host,port,url,status,process_id,"
            "req_headers,req_len,req_body,resp_headers,resp_len,resp_body)"
            " VALUES(?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)",
            (fl.get("ts", time.time()), fl.get("action", ""), fl.get("method", ""),
             fl.get("scheme", ""), fl.get("host", ""), fl.get("port", 0),
             fl.get("url", ""), fl.get("status", 0), fl.get("process_id"),
             _hdr_text(fl.get("req_headers")), len(rb), sqlite3.Binary(rb[:_FLOW_BODY_CAP]),
             _hdr_text(fl.get("resp_headers")), len(pb), sqlite3.Binary(pb[:_FLOW_BODY_CAP])))
        conn.commit()
    finally:
        conn.close()

def flows_list(path) -> list:
    path = Path(path)
    if not path.exists(): return []
    conn = _sqlar_open(path); conn.row_factory = sqlite3.Row
    try:
        return [dict(r) for r in conn.execute(
            "SELECT id,ts,action,method,host,port,url,status,process_id,req_len,resp_len"
            " FROM flows ORDER BY id").fetchall()]
    except sqlite3.Error:
        return []
    finally:
        conn.close()

def flows_get(path, fid) -> "dict | None":
    path = Path(path)
    if not path.exists(): return None
    conn = _sqlar_open(path); conn.row_factory = sqlite3.Row
    try:
        r = conn.execute("SELECT * FROM flows WHERE id=?", (fid,)).fetchone()
        return dict(r) if r else None
    except sqlite3.Error:
        return None
    finally:
        conn.close()


def has_flows(path) -> bool:
    path = Path(path)
    if not path.exists(): return False
    conn = _sqlar_open(path)
    try: return conn.execute("SELECT COUNT(*) FROM flows").fetchone()[0] > 0
    except sqlite3.Error: return False
    finally: conn.close()


def process_list(path) -> list:
    """[(id, tgid, ppid, exe, argv-list)] for the box's process table."""
    path = Path(path)
    if not path.exists(): return []
    conn = _sqlar_open(path)
    try:
        rows = conn.execute("SELECT id,tgid,ppid,exe,argv FROM process "
                            "ORDER BY id").fetchall()
    except sqlite3.Error: return []
    finally: conn.close()
    out = []
    for pid, tgid, ppid, exe, argv in rows:
        try: av = json.loads(argv) if argv else []
        except (ValueError, TypeError): av = []
        out.append((pid, tgid, ppid, exe or "", av))
    return out

def sqlar_writer_id(path, rel) -> "int | None":
    """The process-table row id that wrote `rel` (the sqlar `writer` tag), or None.
    Finished-box path: read straight from the consolidated single sqlar."""
    path = Path(path)
    if not path.exists(): return None
    conn = _sqlar_open(path)
    try:
        row = conn.execute("SELECT writer FROM sqlar WHERE name=?", (rel,)).fetchone()
    except sqlite3.Error: row = None
    finally: conn.close()
    return row[0] if row and row[0] is not None else None

def process_env(path, proc_id) -> dict:
    """The deduped environment for one process row (resolved via env_id)."""
    path = Path(path)
    if not path.exists(): return {}
    conn = _sqlar_open(path)
    try:
        row = conn.execute(
            "SELECT env.env FROM process JOIN env ON process.env_id=env.id"
            " WHERE process.id=?", (proc_id,)).fetchone()
    except sqlite3.Error: row = None
    finally: conn.close()
    if not row or not row[0]: return {}
    try: return json.loads(row[0])
    except (ValueError, TypeError): return {}

def root_cmd(sid: str) -> list:
    """The box's command: argv of the ROOT process row in <sid>.sqlar, keyed by the
    host pid embedded in the sid. [] if the sid is malformed or no such row exists.
    The persisted single source of truth, surviving after the runner exits."""
    root_pid = parse_sid(sid)[1]
    if not root_pid: return []
    for _id, tgid, _ppid, _exe, argv in process_list(sqlar_path(sid)):
        if tgid == root_pid: return list(argv)
    return []


# ════════════════════════════════════════════════════════════════════════════
#  Overlay engine — pyfuse3 copy-on-write overlay, multiplexed per session.
#
#  The UI owns ONE pyfuse3 mount (see OverlayMount). Its synthetic root lists one
#  subfolder <sid> per live session; <mnt>/<sid>/… is a merged overlay of
#  lower=/ + that session's upper (live/<sid>/up) with whiteouts/opacity tracked
#  in the per-box <sid>.sqlar. Inode numbers span the whole mount; each inode carries
#  its (sid, rel) so one Operations object serves every box.
#
#  This design has NO user namespaces, NO /dev/fuse fd-passing, and NO inner
#  mount/pivot_root — deliberately, so it nests cleanly inside containers
#  (toolbox, etc.) needing nothing beyond fusermount3. The mount is made the
#  ordinary way via fusermount3 and bwrap binds the subfolder as root.
# ════════════════════════════════════════════════════════════════════════════

# Selected env keys captured per writer (provenance).
_PROV_ENV_KEYS = ("USER", "PWD", "SSH_CONNECTION", "TERM", "_")

FICLONE = 0x40049409   # _IOW(0x94, 9, int) — btrfs/xfs reflink ioctl


def _proc_status_field(pid: int, field: str) -> "int | None":
    """One integer field (e.g. Tgid, PPid) from /proc/<pid>/status. None if gone."""
    try:
        with open(f"/proc/{pid}/status", "rb") as f:
            for ln in f:
                if ln.startswith(field.encode() + b":"):
                    return int(ln.split()[1])
    except (OSError, ValueError, IndexError):
        pass
    return None

def tgid_of(pid: int) -> int:
    """Resolve a FUSE ctx.pid (a thread id) to its thread-group id via
    /proc/<pid>/status Tgid; falls back to pid itself if unreadable."""
    t = _proc_status_field(pid, "Tgid")
    return t if t is not None else int(pid)


def _proc_start_time(pid: int) -> int:
    """The process's start time (field 22 of /proc/<pid>/stat, jiffies since boot).
    0 if unreadable. Cheap and stable for a live process; used to detect PID reuse so
    a provenance cache entry is not reused across two different processes (LOW-1)."""
    try:
        with open(f"/proc/{pid}/stat", "rb") as f:
            st = f.read()
        rp = st.rfind(b")")
        rest = st[rp + 2:].split() if rp >= 0 else []
        return int(rest[19]) if len(rest) >= 20 else 0
    except (OSError, ValueError):
        return 0


def read_provenance(pid: int, full_env: bool = False) -> dict:
    """Best-effort writer provenance from host /proc/<pid>. Read SYNCHRONOUSLY from
    the write handler while the caller is still blocked (and thus still in /proc).
    Every field is best-effort — a vanished pid yields zeros/empties, never raises
    (/proc reads are the one place best-effort OSError is acceptable). full_env
    captures the whole environment (for the process table when tracing is on);
    otherwise only the small _PROV_ENV_KEYS subset is kept."""
    info = dict(pid=int(pid), ppid=0, exe="", argv=[], env={}, start_time=0)
    base = f"/proc/{pid}"
    try:
        with open(f"{base}/cmdline", "rb") as f:
            raw = f.read()
        info["argv"] = [p.decode("utf-8", "surrogateescape")
                        for p in raw.split(b"\x00") if p]
    except OSError: pass
    try: info["exe"] = os.readlink(f"{base}/exe")
    except OSError: pass
    try:
        with open(f"{base}/stat", "rb") as f:
            st = f.read()
        # comm is parenthesized and may contain spaces/parens; split after the last ')'
        rp = st.rfind(b")")
        rest = st[rp + 2:].split() if rp >= 0 else []
        # fields after comm: state(0) ppid(1) ... starttime(19) (jiffies since boot).
        # starttime distinguishes a reused pid from the original process (LOW-1).
        if len(rest) >= 2: info["ppid"] = int(rest[1])
        if len(rest) >= 20: info["start_time"] = int(rest[19])
    except (OSError, ValueError): pass
    try:
        with open(f"{base}/environ", "rb") as f:
            env_raw = f.read()
        env = {}
        for kv in env_raw.split(b"\x00"):
            if b"=" not in kv: continue
            k, _, v = kv.partition(b"=")
            ks = k.decode("utf-8", "surrogateescape")
            if full_env or ks in _PROV_ENV_KEYS:
                env[ks] = v.decode("utf-8", "surrogateescape")
        info["env"] = env
    except OSError: pass
    return info


def policy_check(sid: str, prov: dict, path: str, op: str) -> str:
    """THE policy hook. Called once per mutating overlay op (create/write/unlink/
    rename/setattr/…) with the session id, the writer's provenance (pid/exe/argv),
    the overlay-relative path, and the operation name. Returns "allow" or "deny".

    For v1 this always allows. It exists as the single, obvious seam where
    per-write policy — a file-rules check, or an interactive UI prompt exactly
    like the network-approval flow — would attach. It runs ON the trio serving
    thread while the writer is blocked, so a future prompt would hand off to the
    UI thread and await, just like Supervisor.approval_request does for connections."""
    return "allow"


def reflink_or_copy(src_fd: int, dst_fd: int) -> str:
    """Clone src into dst. Tries FICLONE (O(1) on btrfs/xfs/bcachefs); on any of the
    not-supported errnos falls back to copy_file_range, then to a 1 MiB read/write
    loop (always correct). Returns 'reflink' or 'copy'. Never silently no-ops — a
    failure to materialize content is a correctness bug."""
    try:
        fcntl.ioctl(dst_fd, FICLONE, src_fd)
        return "reflink"
    except OSError as e:
        if e.errno not in (errno.ENOTSUP, errno.EOPNOTSUPP, errno.EXDEV,
                           errno.EINVAL, errno.EPERM):
            raise
    # plain copy
    os.lseek(src_fd, 0, os.SEEK_SET); os.lseek(dst_fd, 0, os.SEEK_SET)
    try:
        st = os.fstat(src_fd); remaining = st.st_size
        while remaining > 0:
            n = os.copy_file_range(src_fd, dst_fd, remaining)
            if n == 0: break
            remaining -= n
        if remaining == 0:
            os.lseek(dst_fd, 0, os.SEEK_SET); os.lseek(src_fd, 0, os.SEEK_SET)
            return "copy"
    except (OSError, AttributeError):
        pass
    os.lseek(src_fd, 0, os.SEEK_SET); os.lseek(dst_fd, 0, os.SEEK_SET)
    os.ftruncate(dst_fd, 0)
    while True:
        chunk = os.read(src_fd, 1 << 20)
        if not chunk: break
        off = 0
        while off < len(chunk):
            off += os.write(dst_fd, chunk[off:])
    os.lseek(dst_fd, 0, os.SEEK_SET); os.lseek(src_fd, 0, os.SEEK_SET)
    return "copy"


def _kind_of_mode(mode: int) -> str:
    if stat_mod.S_ISCHR(mode): return "whiteout"
    if stat_mod.S_ISDIR(mode): return "dir"
    if stat_mod.S_ISLNK(mode): return "symlink"
    return "file"


class Index:
    """The single per-instance database (sqlar_path(sid)) + a write-through RAM
    mirror. There is exactly ONE sqlite file per box; this class is the set of
    operations on it that the FUSE layer needs — there is no separate index.db.

    On every mutating FUSE op the entry row is upserted into the `sqlar` table
    right then (data = NULL for files: the bytes are in the overlay upper and the
    NULL blob is filled in during consolidate()). The hot read paths
    (lookup/getattr/readdir) touch ONLY the RAM mirror; the db is written on
    mutation and read for provenance / process detail. Opened
    check_same_thread=False — the serve loop owns all mutations (under
    self._lock); the UI thread reads concurrently and relies on the lock for
    SQLite safety and GIL-protected dict reads for the RAM mirror.

    A box's process tracing (when -t is on) records each unique tgid into the
    `process` table here, deduping its environment via the `env` table; the
    process row id tags both modified file entries (the `writer` column) and
    network flows."""

    def __init__(self, backing: Path):
        self.backing = Path(backing)
        # The single db: state_home/<sid>.sqlar. The sid is the backing dir name.
        self.db_path = sqlar_path(self.backing.name)
        # Create the parent dir + the one schema (the single source of the schema).
        _sqlar_open(self.db_path).close()
        self._db = sqlite3.connect(str(self.db_path), check_same_thread=False)
        self._db.execute("PRAGMA journal_mode=WAL")
        self._db.execute("PRAGMA synchronous=NORMAL")
        self._proc_cache: dict = {}       # (tgid) -> process.id (this process only)
        self._prov_cache: dict = {}       # host pid -> provenance dict (hot-path cache)
        self._prov_by_proc: dict = {}     # process.id -> provenance dict
        # Live "active set": tgid -> last-seen monotonic, stamped every time the FUSE
        # serve thread or the relay path records/sees a tgid (in-memory only, NOT
        # persisted — the persistent `process` table keeps the full history). Reads
        # come from the UI thread; the dict is GIL-atomic like the other RAM mirrors.
        self._active: dict = {}           # tgid -> last-seen monotonic
        self._dead_since: dict = {}       # tgid -> first monotonic kill(0) saw it dead
        self._tracing = False             # -t: record the process table
        # The box's root process: the host pid embedded in the sid. Newly-inserted
        # process rows bubble up their PPid chain until they reach it (3c records its
        # row at register), so the table stays one connected tree. 0 if the sid is
        # malformed — bubbling then simply doesn't run.
        self._root_pid = parse_sid(self.backing.name)[1]
        self._whiteouts: set = set()
        self._kinds: dict = {}
        self._opaque: set = set()
        self._lock = threading.Lock()     # serialize SQLite + mirror mutations
        self._load_mirror()

    def set_tracing(self, on: bool) -> None:
        self._tracing = bool(on)

    def _load_mirror(self) -> None:
        for path, mode, opaque in self._db.execute(
                "SELECT name, mode, opaque FROM sqlar"):
            kind = _kind_of_mode(mode)
            if kind == "whiteout":
                self._whiteouts.add(path)
            else:
                self._kinds[path] = kind
            if opaque:
                self._opaque.add(path)

    @staticmethod
    def _row_mode(kind, mode) -> int:
        if kind == "whiteout": return stat_mod.S_IFCHR
        return int(mode)

    # ── fast RAM accessors (hot path) ───────────────────────────────────────
    def has_overlay_state(self) -> bool:
        return bool(self._whiteouts or self._kinds or self._opaque)

    def kind_of(self, rel: str) -> "str | None":
        if rel in self._whiteouts: return "whiteout"
        return self._kinds.get(rel)

    def is_opaque(self, rel: str) -> bool:
        return rel in self._opaque

    def hidden_by_opaque(self, rel: str) -> bool:
        if not self._opaque: return False
        parts = rel.split("/") if rel else []
        for i in range(len(parts)):
            anc = "/".join(parts[:i])
            if anc in self._opaque: return True
        return False

    def children_of(self, rel: str) -> tuple:
        """Index entries that are DIRECT children of dir `rel`, for the merged
        readdir scan: (whiteouts, present). `whiteouts` is the set of child names
        that whiteout a lower entry (remove from the listing); `present` is the
        set of child names that have an index kind (ensure present in the
        listing). Names only — caller resolves each via kind_of/_resolve_st."""
        prefix = (rel + "/") if rel else ""
        whiteouts, present = set(), set()
        for wp in self._whiteouts:
            if wp.startswith(prefix) and "/" not in wp[len(prefix):]:
                whiteouts.add(wp[len(prefix):])
        for kp in self._kinds:
            if kp.startswith(prefix) and kp != rel and "/" not in kp[len(prefix):]:
                present.add(kp[len(prefix):])
        return whiteouts, present

    # ── provenance / process table ──────────────────────────────────────────
    def _prov_key(self, pid: int) -> tuple:
        """Cache key that survives PID reuse: (pid, /proc start_time)."""
        return (pid, _proc_start_time(pid))

    def _touch_active(self, tgid: int) -> None:
        """Re-stamp a tgid in the active set (last-seen monotonic) and keep the set
        bounded: when it crosses the cap, drop the oldest-seen dead entries so RAM
        stays bounded even if the proc pane is never opened to drive retirement.
        Serve/relay-thread write; GIL-atomic dict ops (Index threading contract)."""
        now = time.monotonic()
        self._active[tgid] = now
        if len(self._active) > _ACTIVE_CAP:
            for t, _seen in sorted(self._active.items(), key=lambda kv: kv[1]):
                if len(self._active) <= _ACTIVE_CAP: break
                if t == tgid or _pid_alive(t): continue
                self._active.pop(t, None); self._dead_since.pop(t, None)

    def writer_for(self, pid: int) -> int:
        """Resolve the FUSE ctx.pid (a TID) to its tgid and return that tgid's
        process-table row id, inserting it (and its deduped env) on first sight.
        Always returns an id even if /proc is gone. The id tags the file entry."""
        tgid = tgid_of(pid)
        self._touch_active(tgid)                 # active-set: re-stamp on every sight
        cached = self._proc_cache.get(tgid)
        if cached is not None: return cached
        # When tracing, capture the FULL environment for the process table; the
        # subset-cached provenance_of() is enough otherwise. Resolve the parent to
        # its tgid and hand off to the single insert/dedup path (which also bubbles
        # the PPid chain up to the box root so the table stays one connected tree).
        prov = read_provenance(pid, full_env=True) if self._tracing \
            else self.provenance_of(pid)
        ppid_tgid = tgid_of(prov["ppid"]) if prov.get("ppid") else 0
        return self.process_from_prov(dict(tgid=tgid, ppid=ppid_tgid,
                                           exe=prov["exe"], argv=prov["argv"],
                                           env=prov.get("env") or {})) or tgid

    def process_from_prov(self, prov: dict) -> "int | None":
        """Insert/dedup a process row from a provenance dict (tgid/ppid/exe/argv/env,
        all HOST-namespace — resolved by RelayServer from the --inner pidfd via host
        /proc, consistent with the FUSE path) and return its row id. Returns None if no
        tgid was supplied. Same process-table + env-crc32 dedup as writer_for."""
        tgid = int(prov.get("tgid") or 0)
        if not tgid: return None
        self._touch_active(tgid)                  # active-set: re-stamp on every sight
        cached = self._proc_cache.get(tgid)
        if cached is not None: return cached
        ppid_tgid = int(prov.get("ppid") or 0)
        exe = prov.get("exe") or ""
        argv = prov.get("argv") or []
        env = prov.get("env") or {}
        with self._lock:
            eid = None
            if self._tracing:
                env_json = json.dumps(env, sort_keys=True)
                env_hash = str(zlib.crc32(env_json.encode())) + ":" + str(len(env_json))
                self._db.execute("INSERT OR IGNORE INTO env(hash,env) VALUES(?,?)",
                                 (env_hash, env_json))
                eid = self._db.execute("SELECT id FROM env WHERE hash=?",
                                       (env_hash,)).fetchone()[0]
            cur = self._db.execute(
                "INSERT OR IGNORE INTO process(tgid,ppid,exe,argv,env_id)"
                " VALUES(?,?,?,?,?)",
                (tgid, ppid_tgid, exe, json.dumps(argv), eid))
            inserted = cur.rowcount > 0   # newly recorded vs. already present
            pid_row = self._db.execute("SELECT id FROM process WHERE tgid=?",
                                       (tgid,)).fetchone()[0]
            self._db.commit()
        self._proc_cache[tgid] = pid_row
        self._prov_by_proc[pid_row] = dict(pid=tgid, ppid=ppid_tgid, exe=exe, argv=argv)
        if inserted: self._bubble_parent(tgid, ppid_tgid)
        return pid_row

    def _bubble_parent(self, tgid: int, ppid: int) -> None:
        """Record this row's parent (and so its whole PPid chain) so the per-box
        process table forms ONE tree rooted at the sid's host pid. Runs only when a
        row was genuinely new — the dedup short-circuit of process_from_prov stops
        the recursion at the first ancestor already present (the root row, recorded
        at register, is always present), guaranteeing termination. Best-effort: a
        failed ancestor /proc read links a minimal row and stops, never raises.
        STOPS at: the root tgid (boundary — never walk above it into the runner's
        own host ancestry), ppid<=1 (init), or any already-recorded parent."""
        if not self._root_pid: return            # malformed sid: don't bubble
        if tgid == self._root_pid: return        # the root row is the boundary
        if ppid <= 1: return                     # reached init; no system procs
        if ppid in self._proc_cache: return      # parent already linked
        try:
            pprov = read_provenance(ppid, full_env=self._tracing)
        except OSError:
            pprov = dict(ppid=0, exe="", argv=[], env={})
        # A live parent yields its own ppid (walk continues up); a vanished parent
        # yields ppid 0 — a minimal row is still linked (tgid=ppid), then the next
        # frame stops at ppid<=1 since the grandparent is unreachable.
        parent = dict(tgid=tgid_of(ppid) or ppid,
                      ppid=tgid_of(pprov.get("ppid")) if pprov.get("ppid") else 0,
                      exe=pprov.get("exe") or "", argv=pprov.get("argv") or [],
                      env=pprov.get("env") or {})
        self.process_from_prov(parent)           # recurses up; dedup ends the walk

    def proc_info(self, tgid: int) -> "tuple | None":
        """(ppid, exe, argv-list) for ANY recorded tgid, in or out of the active set —
        the tree builder uses it to resolve connector ancestors. RAM-only read of the
        GIL-atomic caches (Index threading contract): _proc_cache maps tgid→row id and
        _prov_by_proc maps row id→provenance. None if the tgid was never recorded."""
        pid_row = self._proc_cache.get(tgid)
        prov = self._prov_by_proc.get(pid_row) if pid_row is not None else None
        if prov is None: return None
        return prov["ppid"], prov["exe"] or "", list(prov["argv"])

    def live_processes(self) -> list:
        """htop-style live view of the box's ACTIVE SET: the recently-seen tgids only,
        decorated from the in-memory caches (NO full-table scan, cost O(active set)).
        Returns [(id, tgid, ppid, exe, argv-list, alive, dead)] where `alive` is a
        kill(0) liveness probe over just the active set and `dead` flags a row that
        kill(0) reports gone but is still inside its retirement grace window. A tgid
        first seen dead is stamped and kept (highlighted) for _PROC_RETIRE_S, then
        pruned from the active set — the persistent `process` table is untouched.
        UI-thread read of the GIL-atomic active-set/cache dicts (Index contract)."""
        now = time.monotonic()
        out = []
        for tgid in list(self._active):
            alive = _pid_alive(tgid)
            if alive:
                self._dead_since.pop(tgid, None)
            else:
                first = self._dead_since.get(tgid)
                if first is None:
                    self._dead_since[tgid] = first = now
                if now - first >= _PROC_RETIRE_S:    # retire: drop from the live pane
                    self._active.pop(tgid, None)
                    self._dead_since.pop(tgid, None)
                    continue
            pid_row = self._proc_cache.get(tgid)
            prov = self._prov_by_proc.get(pid_row) if pid_row is not None else None
            if prov is not None:
                ppid, exe, argv = prov["ppid"], prov["exe"], prov["argv"]
            else:
                ppid, exe, argv = 0, "", []
            out.append((pid_row if pid_row is not None else tgid, tgid, ppid,
                        exe or "", list(argv), alive, not alive))
        out.sort(key=lambda r: r[1])
        return out

    def add_flow(self, fl: dict) -> None:
        """Append one completed flow to the box's single sqlar via THIS handle — the
        one writer (under self._lock), so a flow write never opens a second handle to
        the WAL db and never races the serve thread into SQLITE_BUSY."""
        rb = fl.get("req_body") or b""; pb = fl.get("resp_body") or b""
        with self._lock:
            self._db.execute(
                "INSERT INTO flows(ts,action,method,scheme,host,port,url,status,process_id,"
                "req_headers,req_len,req_body,resp_headers,resp_len,resp_body)"
                " VALUES(?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)",
                (fl.get("ts", time.time()), fl.get("action", ""), fl.get("method", ""),
                 fl.get("scheme", ""), fl.get("host", ""), fl.get("port", 0),
                 fl.get("url", ""), fl.get("status", 0), fl.get("process_id"),
                 _hdr_text(fl.get("req_headers")), len(rb),
                 sqlite3.Binary(rb[:_FLOW_BODY_CAP]),
                 _hdr_text(fl.get("resp_headers")), len(pb),
                 sqlite3.Binary(pb[:_FLOW_BODY_CAP])))
            self._db.commit()

    def provenance_of(self, pid: int) -> dict:
        """Provenance for a pid, cached per (pid, start_time) for this process."""
        key = self._prov_key(pid)
        cached = self._prov_cache.get(key)
        if cached is not None: return cached
        prov = read_provenance(pid)
        self._prov_cache[key] = prov
        return prov

    # ── mutations (write-through; upsert into the single sqlar) ──────────────
    def _upsert(self, path, mode, writer_id, opaque) -> None:
        """Upsert one entry row with data=NULL (filled at consolidate). opaque None
        means leave as-is on update; writer_id None means leave as-is on update."""
        row = self._db.execute(
            "SELECT opaque, writer FROM sqlar WHERE name=?", (path,)).fetchone()
        if row is None:
            self._db.execute(
                "INSERT INTO sqlar(name,mode,mtime,sz,data,opaque,writer)"
                " VALUES(?,?,?,?,?,?,?)",
                (path, int(mode), 0, 0, None,
                 int(opaque) if opaque is not None else 0, writer_id))
        else:
            op_q = int(opaque) if opaque is not None else row[0]
            wr = writer_id if writer_id is not None else row[1]
            self._db.execute(
                "UPDATE sqlar SET mode=?, opaque=?, writer=? WHERE name=?",
                (int(mode), op_q, wr, path))

    def set_entry(self, path, kind, mode, writer_id, op,
                  detail: str = "", opaque=None) -> None:
        with self._lock:
            self._upsert(path, self._row_mode(kind, mode), writer_id, opaque)
            self._db.commit()
            # RAM mirror — mutate under the SAME lock.
            if kind == "whiteout":
                self._whiteouts.add(path); self._kinds.pop(path, None)
            else:
                self._kinds[path] = kind; self._whiteouts.discard(path)
            if opaque is not None:
                if opaque: self._opaque.add(path)
                else: self._opaque.discard(path)

    def del_entry(self, path, op: str = "del", writer_id=None) -> None:
        with self._lock:
            self._db.execute("DELETE FROM sqlar WHERE name=?", (path,))
            self._db.commit()
            self._whiteouts.discard(path); self._kinds.pop(path, None)
            self._opaque.discard(path)

    def prune_subtree(self, prefix: str) -> None:
        pref = prefix + "/"
        with self._lock:
            self._db.execute("DELETE FROM sqlar WHERE name LIKE ? ESCAPE '\\'",
                             (_like_escape(pref) + "%",))
            self._db.commit()
            for s in (self._whiteouts, self._opaque):
                for p in [p for p in s if p.startswith(pref)]: s.discard(p)
            for p in [p for p in self._kinds if p.startswith(pref)]:
                self._kinds.pop(p, None)

    def reparent(self, old: str, new: str, writer_id) -> None:
        oldp = old + "/"; newp = new + "/"
        with self._lock:
            rows = self._db.execute(
                "SELECT name, mode, opaque, writer FROM sqlar WHERE name LIKE ? ESCAPE '\\'",
                (_like_escape(oldp) + "%",)).fetchall()
            for path, mode, opaque, writer in rows:
                np = newp + path[len(oldp):]
                self._db.execute("DELETE FROM sqlar WHERE name=?", (path,))
                self._db.execute(
                    "INSERT OR REPLACE INTO sqlar"
                    "(name,mode,mtime,sz,data,opaque,writer)"
                    " VALUES(?,?,?,?,?,?,?)",
                    (np, mode, 0, 0, None, opaque, writer))
            self._db.commit()
            for path, mode, opaque, writer in rows:
                np = newp + path[len(oldp):]
                kind = _kind_of_mode(mode)
                self._whiteouts.discard(path); self._kinds.pop(path, None); self._opaque.discard(path)
                if kind == "whiteout": self._whiteouts.add(np)
                else: self._kinds[np] = kind
                if opaque: self._opaque.add(np)

    # ── consolidate accessors ────────────────────────────────────
    def deletions(self) -> list:
        with self._lock:
            snap = list(self._whiteouts)
        return sorted(snap)

    def opaque_dirs(self) -> list:
        with self._lock:
            snap = list(self._opaque)
        return sorted(snap)

    def writer_id_for(self, path: str) -> "int | None":
        """The process-table row id that last wrote `path` (the sqlar `writer` tag),
        or None. Keys the proc pane → used to focus the writer when jumping to procs.
        UI-thread read of the single sqlar handle: take _lock so it never races the
        serve thread's writes on the shared connection (Index threading contract)."""
        try:
            with self._lock:
                row = self._db.execute(
                    "SELECT writer FROM sqlar WHERE name=?", (path,)).fetchone()
        except sqlite3.Error: return None
        return row[0] if row and row[0] is not None else None

    def writer_provenance(self, path: str) -> "dict | None":
        # No lock: consolidate-only precondition — called post-teardown with the box
        # dead and the serve thread stopped, so there is no concurrent writer.
        cur = self._db.execute(
            "SELECT writer FROM sqlar WHERE name=?", (path,)).fetchone()
        if not cur or cur[0] is None: return None
        cached = self._prov_by_proc.get(cur[0])
        if cached is not None: return dict(cached)
        w = self._db.execute(
            "SELECT tgid,ppid,exe,argv FROM process WHERE id=?", (cur[0],)).fetchone()
        if not w: return None
        try: argv = json.loads(w[3]) if w[3] else []
        except (ValueError, TypeError): argv = []
        return dict(pid=w[0], ppid=w[1], exe=w[2], argv=argv)

    def close(self) -> None:
        try: self._db.close()
        except (sqlite3.Error, AttributeError): pass


@dataclass
class DirHandle:
    """Per-open directory handle state for readdir: the lazily-built listing
    snapshot and the directory inode it was opened on."""
    inode: int
    snapshot: "list | None" = None


def _build_overlay_ops():
    """Build the MultiplexOverlayFs class. Imports pyfuse3 lazily so that importing
    this module (e.g. the --inner forwarder, or offline tests) does not require
    pyfuse3/trio. Returns the class."""
    import pyfuse3

    # Short timeouts for an untrusted, mutating mount: a box can change the merged
    # view at any moment (copy-up, whiteout, opaque), so the kernel must not cache
    # attrs/entries for long or it will serve stale (and potentially cross-state)
    # metadata. 5xx-second caching here was a correctness/safety hazard.
    ATTR_TIMEOUT = 1.0
    ENTRY_TIMEOUT = 1.0
    NEG_TIMEOUT = 1.0

    class MultiplexOverlayFs(pyfuse3.Operations):
        """One pyfuse3 Operations object serving every box. The synthetic root ('')
        lists one child per live <sid>; below that, <sid>/<rel> is the per-session
        overlay (lower=/, upper=live/<sid>/up, index in the per-box <sid>.sqlar).

        Inodes span the whole mount: ROOT_INODE is the synthetic root, and every
        other inode maps to a key "<sid>/<rel>" (rel may be empty for a session
        root). Sessions are added/removed by the OverlayMount as boxes come and go."""

        enable_writeback_cache = False

        def __init__(self, lower: str, on_event=None):
            super().__init__()
            self.lower_root = lower.rstrip("/") or "/"
            self.squash_uid = os.getuid()
            self.squash_gid = os.getgid()
            self.on_event = on_event or (lambda **ev: None)
            # session registry: sid -> dict(up=Path, index=Index, virtual={rel:bytes})
            self.sessions: dict = {}
            # inode maps. key for a path inside a session is (sid, rel).
            self._ino_to_key: dict = {pyfuse3.ROOT_INODE: None}   # None = synth root
            self._key_to_ino: dict = {}
            self._next_ino = pyfuse3.ROOT_INODE + 1
            self._lookup_count: dict = {}
            self._fd_table: dict = {}     # fh -> open fd (regular files)
            self._fh_sid: dict = {}       # fh -> sid (so teardown can close a box's fds)
            self._vfh: dict = {}          # fh -> (sid, rel, bytes) for virtual reads
            self._dir_snaps: dict = {}    # fh -> DirHandle(inode, snapshot)
            self._next_fh = 1
            # watchdog: written only by this (single) trio thread
            self._req_started = None
            self._req_label = ""
            self._req_seq = 0
            self._lock = threading.Lock()   # guards inode/fh allocation vs UI thread

        # ── session registry ────────────────────────────────────────────────
        def add_session(self, sid: str, up: Path, index: "Index",
                        passthrough: bool = False) -> None:
            with self._lock:
                self.sessions[sid] = dict(up=Path(up), index=index, virtual={},
                                          passthrough=bool(passthrough),
                                          frules=load_file_rules())

        def remove_session(self, sid: str) -> None:
            with self._lock:
                self.sessions.pop(sid, None)
                dead = [ino for ino, key in self._ino_to_key.items()
                        if key and key[0] == sid]
                for ino in dead:
                    self._ino_to_key.pop(ino, None)
                    self._lookup_count.pop(ino, None)
                self._key_to_ino = {k: i for k, i in self._key_to_ino.items()
                                    if k[0] != sid}
                # Close any still-open fds that belong to this box so its backing
                # tree can be removed without leaking descriptors. A client that
                # had the file open will get EBADF on its next read/write — the box is
                # being torn down anyway.
                dead_fhs = [fh for fh, s in self._fh_sid.items() if s == sid]
                for fh in dead_fhs:
                    self._fh_sid.pop(fh, None)
                    fd = self._fd_table.pop(fh, None)
                    if fd is not None:
                        try: os.close(fd)
                        except OSError: pass

        def add_virtual(self, sid: str, rel: str, content: bytes) -> None:
            s = self.sessions.get(sid)
            if s is not None: s["virtual"][rel.lstrip("/")] = content

        # ── inode bookkeeping ───────────────────────────────────────────────
        def _ino_for(self, sid: str, rel: str) -> int:
            key = (sid, rel)
            with self._lock:
                ino = self._key_to_ino.get(key)
                if ino is None:
                    ino = self._next_ino; self._next_ino += 1
                    self._key_to_ino[key] = ino
                    self._ino_to_key[ino] = key
                return ino

        def _key(self, inode: int):
            return self._ino_to_key.get(inode)

        # ── path helpers ─────────────────────────────────────────────────────
        def _lower_path(self, rel: str) -> str:
            return os.path.join(self.lower_root, rel) if rel else self.lower_root

        def _upper_path(self, sid: str, rel: str) -> str:
            up = self.sessions[sid]["up"]
            return str(up / rel) if rel else str(up)

        def _index(self, sid: str) -> "Index":
            return self.sessions[sid]["index"]

        # ── passthrough (direct host action, nothing captured) ───────────────
        def _passthrough(self, sid: str, rel: str) -> bool:
            """True when this op should act on the REAL host fs and record nothing in
            the overlay/sqlar — either the whole box is in direct mode (-d) or a
            file-rule marks this path 'passthrough'."""
            s = self.sessions.get(sid)
            if not s: return False
            if s.get("passthrough"): return True
            fr = s.get("frules")
            return bool(fr and fr.decide(rel) == "passthrough")

        def _host_path(self, rel: str) -> str:
            """The real host path for a passthrough op (lower root + rel)."""
            return self._lower_path(rel)

        def _passthrough_open(self, rel: str, flags: int) -> int:
            """Open the REAL host file for a passthrough write. O_NOFOLLOW on the final
            component: never dereference a box-planted symlink onto another host path."""
            host = self._host_path(rel)
            try:
                os.makedirs(os.path.dirname(host) or "/", exist_ok=True)
            except OSError:
                pass
            try:
                return os.open(host, flags | os.O_NOFOLLOW)
            except OSError as e:
                raise pyfuse3.FUSEError(e.errno or errno.EIO)

        # ── layer resolution ───────────────────────────────────────
        def _resolve_st(self, sid: str, rel: str):
            idx = self._index(sid)
            if not idx.has_overlay_state():
                try: return ("lower", self._lower_path(rel), os.lstat(self._lower_path(rel)))
                except OSError: return ("absent", None, None)
            k = idx.kind_of(rel)
            if k == "whiteout":
                return ("whiteout", None, None)
            if k is not None:
                up = self._upper_path(sid, rel)
                try: return ("upper", up, os.lstat(up))
                except OSError: pass
            if idx.hidden_by_opaque(rel):
                return ("absent", None, None)
            try: return ("lower", self._lower_path(rel), os.lstat(self._lower_path(rel)))
            except OSError: return ("absent", None, None)

        def _resolve(self, sid: str, rel: str) -> str:
            return self._resolve_st(sid, rel)[0]

        def _is_virtual(self, sid: str, rel: str) -> bool:
            s = self.sessions.get(sid)
            if not s: return False
            return rel in s["virtual"] and self._index(sid).kind_of(rel) is None

        # ── attr construction ────────────────────────────────────────────────
        def _entry(self, ino: int, st) -> "pyfuse3.EntryAttributes":
            a = pyfuse3.EntryAttributes()
            a.st_ino = ino
            a.st_mode = st.st_mode
            a.st_nlink = st.st_nlink
            a.st_uid = self.squash_uid
            a.st_gid = self.squash_gid
            a.st_rdev = getattr(st, "st_rdev", 0)
            a.st_size = st.st_size
            a.st_blksize = 512
            a.st_blocks = (st.st_size + 511) // 512
            a.st_atime_ns = int(getattr(st, "st_atime", 0) * 1e9)
            a.st_mtime_ns = int(getattr(st, "st_mtime", 0) * 1e9)
            a.st_ctime_ns = int(getattr(st, "st_ctime", 0) * 1e9)
            a.attr_timeout = ATTR_TIMEOUT
            a.entry_timeout = ENTRY_TIMEOUT
            return a

        def _synth_dir_attrs(self, ino: int) -> "pyfuse3.EntryAttributes":
            a = pyfuse3.EntryAttributes()
            a.st_ino = ino
            a.st_mode = stat_mod.S_IFDIR | 0o755
            a.st_nlink = 2
            a.st_uid = self.squash_uid
            a.st_gid = self.squash_gid
            a.st_size = 0
            a.st_blksize = 512
            a.st_blocks = 0
            now = int(time.time() * 1e9)
            a.st_atime_ns = a.st_mtime_ns = a.st_ctime_ns = now
            a.attr_timeout = ATTR_TIMEOUT
            a.entry_timeout = ENTRY_TIMEOUT
            return a

        def _virtual_attrs(self, sid: str, rel: str, ino: int) -> "pyfuse3.EntryAttributes":
            content = self.sessions[sid]["virtual"][rel]
            a = pyfuse3.EntryAttributes()
            a.st_ino = ino
            a.st_mode = stat_mod.S_IFREG | 0o644
            a.st_nlink = 1
            a.st_uid = self.squash_uid
            a.st_gid = self.squash_gid
            a.st_size = len(content)
            a.st_blksize = 512
            a.st_blocks = (len(content) + 511) // 512
            try: lst = os.lstat(self._lower_path(rel)); ts = int(lst.st_mtime * 1e9)
            except OSError: ts = int(time.time() * 1e9)
            a.st_atime_ns = a.st_mtime_ns = a.st_ctime_ns = ts
            a.attr_timeout = ATTR_TIMEOUT
            a.entry_timeout = ENTRY_TIMEOUT
            return a

        def _neg_entry(self) -> "pyfuse3.EntryAttributes":
            a = pyfuse3.EntryAttributes()
            a.st_ino = 0
            a.entry_timeout = NEG_TIMEOUT
            a.attr_timeout = NEG_TIMEOUT
            return a

        # ── watchdog ───────────────────────────────────────────────
        def _req_enter(self, label: str) -> None:
            self._req_started = time.monotonic(); self._req_label = label
            self._req_seq += 1

        def _req_exit(self) -> None:
            self._req_started = None

        def inflight_age(self):
            t = self._req_started
            return (time.monotonic() - t) if t is not None else None

        # ── child-path utility for synthetic root vs session paths ───────────
        def _child_key(self, parent_key, name: str):
            """Return (sid, rel) for a child `name` under parent_key (None = synth
            root, where children are session ids)."""
            if parent_key is None:
                return (name, "")                      # a session root
            sid, rel = parent_key
            child = (rel + "/" + name) if rel else name
            return (sid, child)

        def _parent_key(self, parent_key):
            if parent_key is None: return None
            sid, rel = parent_key
            if not rel: return None                    # session root's parent = synth
            up = rel.rsplit("/", 1)[0] if "/" in rel else ""
            return (sid, up)

        # ── FUSE: lookup ─────────────────────────────────────────────────────
        async def lookup(self, parent_inode, name, ctx=None):
            name = os.fsdecode(name)
            pkey = self._key(parent_inode)
            if name == ".":
                ckey = pkey
            elif name == "..":
                ckey = self._parent_key(pkey)
            else:
                ckey = self._child_key(pkey, name)
            if ckey is None:                            # synth root itself
                return self._synth_dir_attrs(pyfuse3.ROOT_INODE)
            sid, rel = ckey
            if pkey is None:                            # child of synth root = a session
                if sid not in self.sessions:
                    return self._neg_entry()
                ino = self._ino_for(sid, "")
                self._lookup_count[ino] = self._lookup_count.get(ino, 0) + 1
                return self._synth_dir_attrs(ino)
            if sid not in self.sessions:
                return self._neg_entry()
            if self._is_virtual(sid, rel):
                ino = self._ino_for(sid, rel)
                self._lookup_count[ino] = self._lookup_count.get(ino, 0) + 1
                return self._virtual_attrs(sid, rel, ino)
            layer, _ap, st = self._resolve_st(sid, rel)
            if layer in ("absent", "whiteout"):
                return self._neg_entry()
            ino = self._ino_for(sid, rel)
            self._lookup_count[ino] = self._lookup_count.get(ino, 0) + 1
            return self._entry(ino, st)

        async def getattr(self, inode, ctx=None):
            key = self._key(inode)
            if key is None:
                # Only the synthetic root legitimately maps to a None key. A None for
                # any other inode means it was forgotten/removed (e.g. its session was
                # torn down) — a stale inode must ENOENT, never resolve to the root's
                # attributes.
                if inode == pyfuse3.ROOT_INODE:
                    return self._synth_dir_attrs(pyfuse3.ROOT_INODE)
                raise pyfuse3.FUSEError(errno.ENOENT)
            sid, rel = key
            if sid not in self.sessions:
                raise pyfuse3.FUSEError(errno.ENOENT)
            if not rel:                                 # a session root
                return self._synth_dir_attrs(inode)
            if self._is_virtual(sid, rel):
                return self._virtual_attrs(sid, rel, inode)
            layer, _ap, st = self._resolve_st(sid, rel)
            if layer in ("absent", "whiteout"):
                raise pyfuse3.FUSEError(errno.ENOENT)
            return self._entry(inode, st)

        async def forget(self, inode_list):
            for inode, nlookup in inode_list:
                c = self._lookup_count.get(inode, 0) - nlookup
                if c <= 0:
                    self._lookup_count.pop(inode, None)
                else:
                    self._lookup_count[inode] = c

        async def setxattr(self, inode, name, value, ctx):
            raise pyfuse3.FUSEError(errno.ENOSYS)

        async def getxattr(self, inode, name, ctx):
            raise pyfuse3.FUSEError(pyfuse3.ENOATTR)

        # ── readdir ──────────────────────────────────────────────────────────
        def _scan_dir(self, sid: str, rel: str) -> list:
            """Merged listing of <sid>/<rel>: [(name, (sid, childrel) or None, attrs)].
            None key marks a virtual/synthetic-only entry where attrs are supplied."""
            idx = self._index(sid)
            names: dict = {}     # name -> (abspath_or_None, layer)
            if not idx.is_opaque(rel):
                try:
                    with os.scandir(self._lower_path(rel)) as it:
                        for de in it:
                            names[de.name] = "lower"
                except OSError: pass
            if idx.has_overlay_state():
                try:
                    with os.scandir(self._upper_path(sid, rel)) as it:
                        for de in it:
                            names[de.name] = "upper"
                except OSError: pass
                # apply index children: whiteouts remove, others ensure present
                whiteouts, present = idx.children_of(rel)
                for name in whiteouts:
                    names.pop(name, None)
                for name in present:
                    names.setdefault(name, "upper")
            # virtual files in this dir
            for vp in self.sessions[sid]["virtual"]:
                pfx = (rel + "/") if rel else ""
                if vp.startswith(pfx) and "/" not in vp[len(pfx):]:
                    names.setdefault(vp[len(pfx):], "virtual")
            out = []
            for name in sorted(names):
                childrel = (rel + "/" + name) if rel else name
                if self._is_virtual(sid, childrel):
                    ino = self._ino_for(sid, childrel)
                    out.append((name, (sid, childrel),
                                self._virtual_attrs(sid, childrel, ino)))
                    continue
                layer, _ap, st = self._resolve_st(sid, childrel)
                if layer in ("absent", "whiteout"): continue
                ino = self._ino_for(sid, childrel)
                out.append((name, (sid, childrel), self._entry(ino, st)))
            return out

        async def opendir(self, inode, ctx):
            with self._lock:
                dh = self._next_fh; self._next_fh += 1
            self._dir_snaps[dh] = DirHandle(inode=inode)
            return dh

        async def readdir(self, fh, start_id, token):
            dh = self._dir_snaps.get(fh)
            snap = dh.snapshot if dh is not None else None
            if snap is None:
                inode = dh.inode if dh is not None else None
                key = self._key(inode)
                if key is None:
                    # synthetic root: list live sessions
                    snap = []
                    for sid in sorted(self.sessions):
                        ino = self._ino_for(sid, "")
                        snap.append((sid, self._synth_dir_attrs(ino)))
                else:
                    sid, rel = key
                    if sid in self.sessions:
                        snap = [(name, attrs)
                                for name, _k, attrs in self._scan_dir(sid, rel)]
                    else:
                        snap = []
                if dh is None:
                    dh = DirHandle(inode=inode); self._dir_snaps[fh] = dh
                dh.snapshot = snap
            for i in range(start_id, len(snap)):
                name, attrs = snap[i]
                if not pyfuse3.readdir_reply(
                        token, os.fsencode(name), attrs, i + 1):
                    break

        async def releasedir(self, fh):
            self._dir_snaps.pop(fh, None)

        async def readlink(self, inode, ctx):
            key = self._key(inode)
            if key is None: raise pyfuse3.FUSEError(errno.EINVAL)
            sid, rel = key
            layer, ap, _st = self._resolve_st(sid, rel)
            if layer in ("absent", "whiteout"): raise pyfuse3.FUSEError(errno.ENOENT)
            try: return os.fsencode(os.readlink(ap))
            except OSError as e: raise pyfuse3.FUSEError(e.errno or errno.EIO)

        # ── parent-dir materialization ───────────────────────────────────────
        def _ensure_parent_dirs(self, sid: str, rel: str, wid) -> None:
            """Materialize the chain of parent dirs of rel into the upper. Each level
            is a single mkdir; opacity is recorded if it shadows a lower dir."""
            parent = rel.rsplit("/", 1)[0] if "/" in rel else ""
            if not parent: return
            idx = self._index(sid)
            parts = parent.split("/")
            cur = ""
            for p in parts:
                cur = (cur + "/" + p) if cur else p
                upath = self._upper_path(sid, cur)
                # os.path.isdir follows symlinks: a symlink in the upper pointing at a
                # host directory would be treated as "already a dir" and writes would
                # land through it onto the host. Require a real directory.
                try:
                    if stat_mod.S_ISDIR(os.lstat(upath).st_mode):
                        continue
                except OSError:
                    pass
                self._ensure_parent_dirs(sid, cur, wid)
                try:
                    os.mkdir(upath, 0o755)
                except FileExistsError:
                    pass
                except OSError as e:
                    raise pyfuse3.FUSEError(e.errno or errno.EIO)
                opaque = 0
                try:
                    if stat_mod.S_ISDIR(os.lstat(self._lower_path(cur)).st_mode):
                        # a real lower dir still showing through -> not opaque
                        opaque = 0
                except OSError:
                    pass
                idx.set_entry(cur, "dir", stat_mod.S_IFDIR | 0o755, wid,
                              "mkdir_parent", opaque=opaque)

        # ── copy-up ─────────────────────────────────────────────
        def _ensure_copyup(self, sid: str, rel: str, flags: int, ctx) -> int:
            """Materialize a lower (or absent) file into the upper; return an O_RDWR
            fd on it. Fail-closed: any copy error propagates."""
            wid = self._index(sid).writer_for(ctx.pid)
            self._ensure_parent_dirs(sid, rel, wid)
            upath = self._upper_path(sid, rel)
            if os.path.lexists(upath):
                # O_NOFOLLOW: if the upper artifact is itself a symlink (planted by
                # the sandbox to point at a host file), this raises ELOOP rather than
                # opening the target — fail closed, never dereference.
                try:
                    return os.open(upath, os.O_RDWR | os.O_NOFOLLOW)
                except OSError as e:
                    raise pyfuse3.FUSEError(e.errno or errno.EIO)
            layer, ap, st = self._resolve_st(sid, rel)
            idx = self._index(sid)
            if layer == "lower":
                # A lower symlink/dir must copy up preserving its type — never open
                # it O_RDONLY (that would follow a symlink onto its target and
                # materialize the target's bytes as a regular file). _copyup_one does
                # the type-correct copy (symlink→symlink, dir→dir); then re-open the
                # upper artifact O_NOFOLLOW. (A symlink open-for-write is unusual; the
                # caller gets an fd on the preserved artifact.)
                if not stat_mod.S_ISREG(st.st_mode):
                    self._copyup_one(sid, rel, wid)
                    try:
                        return os.open(upath, os.O_RDWR | os.O_NOFOLLOW)
                    except OSError as e:
                        raise pyfuse3.FUSEError(e.errno or errno.EIO)
                mode = stat_mod.S_IMODE(st.st_mode)
                src = os.open(ap, os.O_RDONLY | os.O_NOFOLLOW)
                try:
                    dst = os.open(upath, os.O_RDWR | os.O_CREAT | os.O_NOFOLLOW, mode)
                    try:
                        method = reflink_or_copy(src, dst)
                    except OSError as e:
                        os.close(dst)
                        try: os.unlink(upath)
                        except OSError: pass
                        raise pyfuse3.FUSEError(e.errno or errno.EIO)
                finally:
                    os.close(src)
                idx.set_entry(rel, "file", st.st_mode, wid, "copyup", detail=method)
                return dst
            else:
                # absent (or whiteout cleared) -> brand new upper file
                fd = os.open(upath, os.O_RDWR | os.O_CREAT | os.O_NOFOLLOW, 0o644)
                idx.set_entry(rel, "file", stat_mod.S_IFREG | 0o644, wid, "create")
                return fd

        # ── open / read / write / release ───────────────────────────────────
        async def open(self, inode, flags, ctx):
            key = self._key(inode)
            if key is None: raise pyfuse3.FUSEError(errno.EISDIR)
            sid, rel = key
            writable = (flags & (os.O_WRONLY | os.O_RDWR)) != 0
            if self._is_virtual(sid, rel) and not writable:
                content = self.sessions[sid]["virtual"][rel]
                with self._lock:
                    fh = self._next_fh; self._next_fh += 1
                self._vfh[fh] = (sid, rel, content)
                return pyfuse3.FileInfo(fh=fh, direct_io=False, keep_cache=False)
            self._req_enter(f"open {sid}/{rel}")
            try:
                if not writable:
                    layer, ap, _st = self._resolve_st(sid, rel)
                    if layer in ("absent", "whiteout"):
                        raise pyfuse3.FUSEError(errno.ENOENT)
                    try:
                        # O_NOFOLLOW: never dereference a symlink at the final path
                        # component on the read path either — defensive even where the
                        # resolved layer is host-owned.
                        fd = os.open(ap, os.O_RDONLY | os.O_NOFOLLOW)
                    except OSError as e:
                        raise pyfuse3.FUSEError(e.errno or errno.EIO)
                else:
                    if policy_check(sid, self._index(sid).provenance_of(ctx.pid),
                                    rel, "open_write") == "deny":
                        raise pyfuse3.FUSEError(errno.EACCES)
                    self._index(sid).writer_for(ctx.pid)   # tracing/provenance
                    if self._passthrough(sid, rel):
                        fd = self._passthrough_open(rel, flags)
                    else:
                        fd = self._ensure_copyup(sid, rel, flags, ctx)
                        self._notify(sid, rel, "modified")
                with self._lock:
                    fh = self._next_fh; self._next_fh += 1
                    self._fd_table[fh] = fd
                    self._fh_sid[fh] = sid
                return pyfuse3.FileInfo(fh=fh, direct_io=False, keep_cache=False)
            finally:
                self._req_exit()

        async def read(self, fh, off, size):
            if fh in self._vfh:
                _sid, _rel, content = self._vfh[fh]
                return content[off:off + size]
            fd = self._fd_table.get(fh)
            if fd is None: raise pyfuse3.FUSEError(errno.EBADF)
            self._req_enter("read")
            try:
                return os.pread(fd, size, off)
            except OSError as e:
                raise pyfuse3.FUSEError(e.errno or errno.EIO)
            finally:
                self._req_exit()

        async def write(self, fh, off, buf):
            fd = self._fd_table.get(fh)
            if fd is None: raise pyfuse3.FUSEError(errno.EBADF)
            self._req_enter("write")
            try:
                return os.pwrite(fd, buf, off)
            except OSError as e:
                raise pyfuse3.FUSEError(e.errno or errno.EIO)
            finally:
                self._req_exit()

        async def fsync(self, fh, datasync):
            fd = self._fd_table.get(fh)
            if fd is None: return
            try:
                if datasync: os.fdatasync(fd)
                else: os.fsync(fd)
            except OSError as e:
                raise pyfuse3.FUSEError(e.errno or errno.EIO)

        async def flush(self, fh):
            return

        async def release(self, fh):
            if fh in self._vfh:
                self._vfh.pop(fh, None); return
            self._fh_sid.pop(fh, None)
            fd = self._fd_table.pop(fh, None)
            if fd is not None:
                try: os.close(fd)
                except OSError: pass

        # ── create / mkdir / symlink ─────────────────────────────────────────
        def _mutate(self, parent_inode, name, ctx, op, host_op, upper_op):
            # THE single checked entry point for node-creating mutating handlers:
            # the security preamble (decode/key/ENOENT/writer/policy_check/EACCES/
            # _req_enter) and the passthrough-vs-overlay fork live here exactly once,
            # so no handler can skip a check. host_op/upper_op create only THIS node.
            name = os.fsdecode(name)
            pkey = self._key(parent_inode)
            if pkey is None: raise pyfuse3.FUSEError(errno.EACCES)
            sid, rel = self._child_key(pkey, name)
            if sid not in self.sessions: raise pyfuse3.FUSEError(errno.ENOENT)
            wid = self._index(sid).writer_for(ctx.pid)
            if policy_check(sid, self._index(sid).provenance_of(ctx.pid),
                            rel, op) == "deny":
                raise pyfuse3.FUSEError(errno.EACCES)
            self._req_enter(f"{op} {sid}/{rel}")
            try:
                if self._passthrough(sid, rel):
                    return host_op(sid, rel, self._host_path(rel))
                self._ensure_parent_dirs(sid, rel, wid)
                idx = self._index(sid)
                upath = self._upper_path(sid, rel)
                res = upper_op(sid, rel, upath, wid, idx)
                self._notify(sid, rel, "created")
                return res
            finally:
                self._req_exit()

        async def create(self, parent_inode, name, mode, flags, ctx):
            def host_op(sid, rel, host):
                try:
                    os.makedirs(os.path.dirname(host) or "/", exist_ok=True)
                    fd = os.open(host, flags | os.O_CREAT | os.O_NOFOLLOW,
                                 mode & 0o7777)
                except OSError as e:
                    raise pyfuse3.FUSEError(e.errno or errno.EIO)
                st = os.fstat(fd)
                ino = self._ino_for(sid, rel)
                self._lookup_count[ino] = self._lookup_count.get(ino, 0) + 1
                with self._lock:
                    nfh = self._next_fh; self._next_fh += 1
                    self._fd_table[nfh] = fd
                    self._fh_sid[nfh] = sid
                return (pyfuse3.FileInfo(fh=nfh, direct_io=False, keep_cache=False),
                        self._entry(ino, st))
            def upper_op(sid, rel, upath, wid, idx):
                try:
                    fd = os.open(upath, flags | os.O_CREAT | os.O_NOFOLLOW,
                                 mode & 0o7777)
                except OSError as e:
                    raise pyfuse3.FUSEError(e.errno or errno.EIO)
                if idx.kind_of(rel) == "whiteout":
                    idx.del_entry(rel)
                idx.set_entry(rel, "file", stat_mod.S_IFREG | (mode & 0o7777),
                              wid, "create")
                st = os.fstat(fd)
                ino = self._ino_for(sid, rel)
                self._lookup_count[ino] = self._lookup_count.get(ino, 0) + 1
                with self._lock:
                    nfh = self._next_fh; self._next_fh += 1
                    self._fd_table[nfh] = fd
                    self._fh_sid[nfh] = sid
                return (pyfuse3.FileInfo(fh=nfh, direct_io=False, keep_cache=False),
                        self._entry(ino, st))
            return self._mutate(parent_inode, name, ctx, "create", host_op, upper_op)

        async def mkdir(self, parent_inode, name, mode, ctx):
            def host_op(sid, rel, host):
                try:
                    os.makedirs(os.path.dirname(host) or "/", exist_ok=True)
                    os.mkdir(host, mode & 0o7777)
                except OSError as e:
                    raise pyfuse3.FUSEError(e.errno or errno.EIO)
                ino = self._ino_for(sid, rel)
                self._lookup_count[ino] = self._lookup_count.get(ino, 0) + 1
                return self._entry(ino, os.lstat(host))
            def upper_op(sid, rel, upath, wid, idx):
                try:
                    os.mkdir(upath, mode & 0o7777)
                except OSError as e:
                    raise pyfuse3.FUSEError(e.errno or errno.EIO)
                if idx.kind_of(rel) == "whiteout":
                    idx.del_entry(rel)
                opaque = 0
                try:
                    if stat_mod.S_ISDIR(os.lstat(self._lower_path(rel)).st_mode):
                        opaque = 1            # rm-rf'd then recreated over a lower dir
                except OSError:
                    opaque = 0
                idx.set_entry(rel, "dir", stat_mod.S_IFDIR | (mode & 0o7777), wid,
                              "mkdir", opaque=opaque)
                ino = self._ino_for(sid, rel)
                self._lookup_count[ino] = self._lookup_count.get(ino, 0) + 1
                st = os.lstat(upath)
                return self._entry(ino, st)
            return self._mutate(parent_inode, name, ctx, "mkdir", host_op, upper_op)

        async def symlink(self, parent_inode, name, target, ctx):
            target = os.fsdecode(target)
            def host_op(sid, rel, host):
                try:
                    os.makedirs(os.path.dirname(host) or "/", exist_ok=True)
                    os.symlink(target, host)
                except OSError as e:
                    raise pyfuse3.FUSEError(e.errno or errno.EIO)
                ino = self._ino_for(sid, rel)
                self._lookup_count[ino] = self._lookup_count.get(ino, 0) + 1
                return self._entry(ino, os.lstat(host))
            def upper_op(sid, rel, upath, wid, idx):
                # remove a stale upper artifact (no-follow safe: unlink/rmtree by lstat)
                try:
                    lst = os.lstat(upath)
                    if stat_mod.S_ISDIR(lst.st_mode): shutil.rmtree(upath)
                    else: os.unlink(upath)
                except FileNotFoundError:
                    pass
                except OSError as e:
                    raise pyfuse3.FUSEError(e.errno or errno.EIO)
                try:
                    os.symlink(target, upath)
                except OSError as e:
                    raise pyfuse3.FUSEError(e.errno or errno.EIO)
                if idx.kind_of(rel) == "whiteout":
                    idx.del_entry(rel)
                idx.set_entry(rel, "symlink", stat_mod.S_IFLNK | 0o777, wid, "symlink")
                ino = self._ino_for(sid, rel)
                self._lookup_count[ino] = self._lookup_count.get(ino, 0) + 1
                st = os.lstat(upath)
                return self._entry(ino, st)
            return self._mutate(parent_inode, name, ctx, "symlink", host_op, upper_op)

        # ── unlink / rmdir ───────────────────────────────────────────────────
        def _merged_children(self, sid: str, rel: str) -> list:
            return [n for n, _k, _a in self._scan_dir(sid, rel)]

        async def unlink(self, parent_inode, name, ctx):
            name = os.fsdecode(name)
            pkey = self._key(parent_inode)
            if pkey is None: raise pyfuse3.FUSEError(errno.EACCES)
            sid, rel = self._child_key(pkey, name)
            if sid not in self.sessions: raise pyfuse3.FUSEError(errno.ENOENT)
            wid = self._index(sid).writer_for(ctx.pid)
            if policy_check(sid, self._index(sid).provenance_of(ctx.pid),
                            rel, "unlink") == "deny":
                raise pyfuse3.FUSEError(errno.EACCES)
            self._req_enter(f"unlink {sid}/{rel}")
            try:
                if self._passthrough(sid, rel):
                    host = self._host_path(rel)
                    try: os.unlink(host)          # unlink never follows the final link
                    except FileNotFoundError: raise pyfuse3.FUSEError(errno.ENOENT)
                    except OSError as e: raise pyfuse3.FUSEError(e.errno or errno.EIO)
                    return
                idx = self._index(sid)
                upath = self._upper_path(sid, rel)
                if os.path.lexists(upath):
                    try: os.unlink(upath)
                    except OSError as e: raise pyfuse3.FUSEError(e.errno or errno.EIO)
                lower_exists = False
                if not idx.hidden_by_opaque(rel):
                    try: lower_exists = os.path.lexists(self._lower_path(rel))
                    except OSError: lower_exists = False
                if lower_exists:
                    idx.set_entry(rel, "whiteout", 0, wid, "unlink")
                else:
                    idx.del_entry(rel, op="unlink", writer_id=wid)
                self._notify(sid, rel, "deleted")
            finally:
                self._req_exit()

        async def rmdir(self, parent_inode, name, ctx):
            name = os.fsdecode(name)
            pkey = self._key(parent_inode)
            if pkey is None: raise pyfuse3.FUSEError(errno.EACCES)
            sid, rel = self._child_key(pkey, name)
            if sid not in self.sessions: raise pyfuse3.FUSEError(errno.ENOENT)
            wid = self._index(sid).writer_for(ctx.pid)
            if policy_check(sid, self._index(sid).provenance_of(ctx.pid),
                            rel, "rmdir") == "deny":
                raise pyfuse3.FUSEError(errno.EACCES)
            self._req_enter(f"rmdir {sid}/{rel}")
            try:
                if self._passthrough(sid, rel):
                    host = self._host_path(rel)
                    if os.path.islink(host): raise pyfuse3.FUSEError(errno.ENOTDIR)
                    try: os.rmdir(host)
                    except FileNotFoundError: raise pyfuse3.FUSEError(errno.ENOENT)
                    except OSError as e: raise pyfuse3.FUSEError(e.errno or errno.EIO)
                    return
                if self._merged_children(sid, rel):
                    raise pyfuse3.FUSEError(errno.ENOTEMPTY)
                idx = self._index(sid)
                upath = self._upper_path(sid, rel)
                if os.path.isdir(upath) and not os.path.islink(upath):
                    try: os.rmdir(upath)
                    except OSError as e: raise pyfuse3.FUSEError(e.errno or errno.EIO)
                idx.prune_subtree(rel)
                lower_is_dir = False
                if not idx.hidden_by_opaque(rel):
                    try:
                        lower_is_dir = stat_mod.S_ISDIR(
                            os.lstat(self._lower_path(rel)).st_mode)
                    except OSError: lower_is_dir = False
                if lower_is_dir:
                    idx.set_entry(rel, "whiteout", 0, wid, "rmdir")
                else:
                    idx.del_entry(rel, op="rmdir", writer_id=wid)
                self._notify(sid, rel, "deleted")
            finally:
                self._req_exit()

        # ── setattr ──────────────────────────────────────────────────────────
        async def setattr(self, inode, attr, fields, fh, ctx):
            key = self._key(inode)
            if key is None: raise pyfuse3.FUSEError(errno.EPERM)
            sid, rel = key
            if sid not in self.sessions: raise pyfuse3.FUSEError(errno.ENOENT)
            if policy_check(sid, self._index(sid).provenance_of(ctx.pid),
                            rel, "setattr") == "deny":
                raise pyfuse3.FUSEError(errno.EACCES)
            idx = self._index(sid)
            self._req_enter(f"setattr {sid}/{rel}")
            try:
                passthrough = self._passthrough(sid, rel)
                if passthrough:
                    upath = self._host_path(rel)
                    if not os.path.lexists(upath):
                        raise pyfuse3.FUSEError(errno.ENOENT)
                    wid = idx.writer_for(ctx.pid)
                else:
                    layer = self._resolve(sid, rel)
                    if layer in ("absent", "whiteout"):
                        raise pyfuse3.FUSEError(errno.ENOENT)
                    if layer == "lower":
                        fd = self._ensure_copyup(sid, rel, os.O_RDWR, ctx)
                        os.close(fd)
                    upath = self._upper_path(sid, rel)
                    wid = idx.writer_for(ctx.pid)
                is_link = stat_mod.S_ISLNK(os.lstat(upath).st_mode)
                try:
                    # size/mode operate on file content/inode: open ONE O_NOFOLLOW fd
                    # and use fchmod/ftruncate. O_NOFOLLOW makes the open of a
                    # symlink upper-artifact raise ELOOP → we never touch its target.
                    if (fields.update_size or fields.update_mode) and not is_link:
                        fd = os.open(upath, os.O_RDWR | os.O_NOFOLLOW)
                        try:
                            if fields.update_size: os.ftruncate(fd, attr.st_size)
                            if fields.update_mode:
                                os.fchmod(fd, stat_mod.S_IMODE(attr.st_mode))
                        finally:
                            os.close(fd)
                    # chown/utime have real no-follow variants (lchown / utimensat
                    # AT_SYMLINK_NOFOLLOW): they act on the link itself, never target.
                    if fields.update_uid or fields.update_gid:
                        uid = attr.st_uid if fields.update_uid else -1
                        gid = attr.st_gid if fields.update_gid else -1
                        os.chown(upath, uid, gid, follow_symlinks=False)
                    if fields.update_mtime or fields.update_atime:
                        st0 = os.lstat(upath)
                        atime = (attr.st_atime_ns / 1e9 if fields.update_atime
                                 else st0.st_atime)
                        mtime = (attr.st_mtime_ns / 1e9 if fields.update_mtime
                                 else st0.st_mtime)
                        os.utime(upath, (atime, mtime), follow_symlinks=False)
                except OSError as e:
                    raise pyfuse3.FUSEError(e.errno or errno.EIO)
                st = os.lstat(upath)
                if passthrough:
                    return self._entry(inode, st)
                if stat_mod.S_ISDIR(st.st_mode): kind = "dir"
                elif stat_mod.S_ISLNK(st.st_mode): kind = "symlink"
                else: kind = "file"
                idx.set_entry(rel, kind, st.st_mode, wid, "setattr")
                self._notify(sid, rel, "modified")
                return self._entry(inode, st)
            finally:
                self._req_exit()

        async def statfs(self, ctx):
            s = pyfuse3.StatvfsData()
            try:
                vfs = os.statvfs(str(live_home()))
                s.f_bsize = vfs.f_bsize; s.f_frsize = vfs.f_frsize
                s.f_blocks = vfs.f_blocks; s.f_bfree = vfs.f_bfree
                s.f_bavail = vfs.f_bavail; s.f_files = vfs.f_files
                s.f_ffree = vfs.f_ffree; s.f_favail = vfs.f_favail
            except OSError:
                s.f_bsize = s.f_frsize = 4096
                s.f_blocks = s.f_bfree = s.f_bavail = 1 << 20
                s.f_files = s.f_ffree = s.f_favail = 1 << 16
            s.f_namemax = 255
            return s

        # ── copy-up of one entry (for rename/link materialization) ───────────
        def _copyup_one(self, sid: str, rel: str, wid) -> None:
            upath = self._upper_path(sid, rel)
            if os.path.lexists(upath): return
            self._ensure_parent_dirs(sid, rel, wid)
            layer, ap, st = self._resolve_st(sid, rel)
            idx = self._index(sid)
            if layer == "lower":
                if stat_mod.S_ISLNK(st.st_mode):
                    os.symlink(os.readlink(ap), upath)
                    idx.set_entry(rel, "symlink", stat_mod.S_IFLNK | 0o777, wid,
                                  "copyup_symlink")
                elif stat_mod.S_ISDIR(st.st_mode):
                    os.mkdir(upath, stat_mod.S_IMODE(st.st_mode))
                    idx.set_entry(rel, "dir", st.st_mode, wid, "copyup_dir")
                else:
                    src = os.open(ap, os.O_RDONLY | os.O_NOFOLLOW)
                    try:
                        dst = os.open(upath, os.O_RDWR | os.O_CREAT | os.O_NOFOLLOW,
                                      stat_mod.S_IMODE(st.st_mode))
                        try: reflink_or_copy(src, dst)
                        finally: os.close(dst)
                    finally:
                        os.close(src)
                    idx.set_entry(rel, "file", st.st_mode, wid, "copyup")

        def _materialize_tree(self, sid: str, rel: str, wid) -> None:
            """Walk the merged view of rel and copy every entry into the upper."""
            self._copyup_one(sid, rel, wid)
            for name, _k, _a in self._scan_dir(sid, rel):
                child = (rel + "/" + name) if rel else name
                layer, _ap, st = self._resolve_st(sid, child)
                if layer in ("absent", "whiteout"): continue
                if stat_mod.S_ISDIR(st.st_mode):
                    self._materialize_tree(sid, child, wid)
                else:
                    self._copyup_one(sid, child, wid)

        async def rename(self, parent_old, name_old, parent_new, name_new,
                         flags, ctx):
            if flags & getattr(pyfuse3, "RENAME_EXCHANGE", 2):
                raise pyfuse3.FUSEError(errno.ENOSYS)
            name_old = os.fsdecode(name_old); name_new = os.fsdecode(name_new)
            pko = self._key(parent_old); pkn = self._key(parent_new)
            if pko is None or pkn is None: raise pyfuse3.FUSEError(errno.EACCES)
            sid_o, rel_o = self._child_key(pko, name_old)
            sid_n, rel_n = self._child_key(pkn, name_new)
            if sid_o != sid_n or sid_o not in self.sessions:
                raise pyfuse3.FUSEError(errno.EXDEV)
            sid = sid_o
            if policy_check(sid, self._index(sid).provenance_of(ctx.pid),
                            rel_o, "rename") == "deny":
                raise pyfuse3.FUSEError(errno.EACCES)
            idx = self._index(sid)
            wid = idx.writer_for(ctx.pid)
            # passthrough: both ends act on the real host. Both-ends-or-overlay:
            # only when BOTH paths pass through do we touch the host; if either side
            # is captured we fall through to overlay capture below. Symlink safety:
            # rename(2) operates on the names, never dereferences the final components.
            if self._passthrough(sid, rel_o) and self._passthrough(sid, rel_n):
                self._req_enter(f"rename {sid}/{rel_o}->{rel_n}")
                try:
                    ho = self._host_path(rel_o); hn = self._host_path(rel_n)
                    if not os.path.lexists(ho): raise pyfuse3.FUSEError(errno.ENOENT)
                    try:
                        os.makedirs(os.path.dirname(hn) or "/", exist_ok=True)
                        os.rename(ho, hn)
                    except OSError as e:
                        raise pyfuse3.FUSEError(e.errno or errno.EIO)
                    return
                finally:
                    self._req_exit()
            layer_o, _ap_o, st_o = self._resolve_st(sid, rel_o)
            if layer_o in ("absent", "whiteout"):
                raise pyfuse3.FUSEError(errno.ENOENT)
            layer_n = self._resolve(sid, rel_n)
            if flags & getattr(pyfuse3, "RENAME_NOREPLACE", 1):
                if layer_n not in ("absent", "whiteout"):
                    raise pyfuse3.FUSEError(errno.EEXIST)
            self._req_enter(f"rename {sid}/{rel_o}->{rel_n}")
            try:
                dst_shadows_lower = False
                try:
                    dst_shadows_lower = (not idx.hidden_by_opaque(rel_n)
                        and stat_mod.S_ISDIR(os.lstat(self._lower_path(rel_n)).st_mode))
                except OSError:
                    dst_shadows_lower = False
                is_dir = stat_mod.S_ISDIR(st_o.st_mode)
                if is_dir:
                    self._materialize_tree(sid, rel_o, wid)
                else:
                    self._copyup_one(sid, rel_o, wid)
                upo = self._upper_path(sid, rel_o); upn = self._upper_path(sid, rel_n)
                # remove existing destination upper artifact
                try:
                    lst = os.lstat(upn)
                    if stat_mod.S_ISDIR(lst.st_mode) and not stat_mod.S_ISLNK(lst.st_mode):
                        shutil.rmtree(upn)
                    else:
                        os.unlink(upn)
                except FileNotFoundError:
                    pass
                self._ensure_parent_dirs(sid, rel_n, wid)
                try:
                    os.rename(upo, upn)
                except OSError as e:
                    raise pyfuse3.FUSEError(e.errno or errno.EIO)
                # index update
                src_shadowed_lower = False
                try:
                    src_shadowed_lower = (not idx.hidden_by_opaque(rel_o)
                        and os.path.lexists(self._lower_path(rel_o)))
                except OSError:
                    src_shadowed_lower = False
                if is_dir:
                    idx.reparent(rel_o, rel_n, wid)
                    idx.set_entry(rel_n, "dir", st_o.st_mode, wid, "rename_to",
                                  opaque=1 if dst_shadows_lower else None)
                else:
                    knd = ("symlink" if stat_mod.S_ISLNK(st_o.st_mode) else "file")
                    idx.set_entry(rel_n, knd, st_o.st_mode, wid, "rename_to",
                                  opaque=1 if dst_shadows_lower else None)
                if src_shadowed_lower:
                    idx.set_entry(rel_o, "whiteout", 0, wid, "rename_from")
                else:
                    idx.del_entry(rel_o, op="rename_from", writer_id=wid)
                self._remap_inode_subtree(sid, rel_o, rel_n)
                # rename = remove-old + add-new for the live map.
                self._notify(sid, rel_o, "deleted")
                self._notify(sid, rel_n, "created")
            finally:
                self._req_exit()

        def _remap_inode_subtree(self, sid: str, rel_o: str, rel_n: str) -> None:
            with self._lock:
                oldp = rel_o + "/"; newp = rel_n + "/"
                remap = []
                for (ksid, krel), ino in list(self._key_to_ino.items()):
                    if ksid != sid: continue
                    if krel == rel_o:
                        remap.append(((ksid, krel), (ksid, rel_n), ino))
                    elif krel.startswith(oldp):
                        remap.append(((ksid, krel), (ksid, newp + krel[len(oldp):]), ino))
                for oldkey, newkey, ino in remap:
                    self._key_to_ino.pop(oldkey, None)
                    self._key_to_ino[newkey] = ino
                    self._ino_to_key[ino] = newkey

        async def link(self, inode, new_parent, new_name, ctx):
            new_name = os.fsdecode(new_name)
            key = self._key(inode); pkn = self._key(new_parent)
            if key is None or pkn is None: raise pyfuse3.FUSEError(errno.EPERM)
            sid, rel_src = key
            sid_n, rel_n = self._child_key(pkn, new_name)
            if sid != sid_n or sid not in self.sessions:
                raise pyfuse3.FUSEError(errno.EXDEV)
            layer, _ap, st = self._resolve_st(sid, rel_src)
            if layer in ("absent", "whiteout"): raise pyfuse3.FUSEError(errno.ENOENT)
            if stat_mod.S_ISDIR(st.st_mode): raise pyfuse3.FUSEError(errno.EPERM)
            wid = self._index(sid).writer_for(ctx.pid)
            if policy_check(sid, self._index(sid).provenance_of(ctx.pid),
                            rel_n, "link") == "deny":
                raise pyfuse3.FUSEError(errno.EACCES)
            self._req_enter(f"link {sid}/{rel_src}->{rel_n}")
            try:
                # Both-ends-or-overlay: hardlink on the host only when BOTH source and
                # new name pass through; if either is captured, fall through to copy-up.
                if self._passthrough(sid, rel_src) and self._passthrough(sid, rel_n):
                    hs = self._host_path(rel_src); hn = self._host_path(rel_n)
                    try:
                        os.makedirs(os.path.dirname(hn) or "/", exist_ok=True)
                        # follow_symlinks=False: hardlink the link itself, never target
                        os.link(hs, hn, follow_symlinks=False)
                    except OSError as e:
                        raise pyfuse3.FUSEError(e.errno or errno.EIO)
                    ino = self._ino_for(sid, rel_n)
                    self._lookup_count[ino] = self._lookup_count.get(ino, 0) + 1
                    return self._entry(ino, os.lstat(hn))
                self._copyup_one(sid, rel_src, wid)
                self._ensure_parent_dirs(sid, rel_n, wid)
                ups = self._upper_path(sid, rel_src); upn = self._upper_path(sid, rel_n)
                idx = self._index(sid)
                try:
                    if stat_mod.S_ISLNK(st.st_mode):
                        os.symlink(os.readlink(ups), upn)
                        idx.set_entry(rel_n, "symlink", stat_mod.S_IFLNK | 0o777, wid,
                                      "link_as_copy", detail=rel_src)
                    else:
                        src = os.open(ups, os.O_RDONLY | os.O_NOFOLLOW)
                        try:
                            dst = os.open(upn, os.O_RDWR | os.O_CREAT | os.O_NOFOLLOW,
                                          stat_mod.S_IMODE(st.st_mode))
                            try: reflink_or_copy(src, dst)
                            finally: os.close(dst)
                        finally:
                            os.close(src)
                        idx.set_entry(rel_n, "file", st.st_mode, wid, "link_as_copy",
                                      detail=rel_src)
                except OSError as e:
                    raise pyfuse3.FUSEError(e.errno or errno.EIO)
                ino = self._ino_for(sid, rel_n)
                self._lookup_count[ino] = self._lookup_count.get(ino, 0) + 1
                self._notify(sid)
                return self._entry(ino, os.lstat(upn))
            finally:
                self._req_exit()

        def _notify(self, sid: str, rel: str = None, op: str = None) -> None:
            """Live-feedback seam: tell the UI a box's overlay changed so the Changes
            view refreshes event-driven (NOT by polling). Carries the affected `rel`
            and an `op` ("created"/"modified"/"deleted") so the UI folds the change
            into its live map in O(1) — no re-walk. Called from the mutating handlers;
            the handoff itself is thread-safe (see OverlayMount)."""
            try: self.on_event(type="overlay_changed", sid=sid, rel=rel, op=op)
            except Exception: pass

    return MultiplexOverlayFs


# ════════════════════════════════════════════════════════════════════════════
#  Overlay mount manager — owns the single pyfuse3 mount on a trio thread.
#
#  The pyfuse3 serve loop runs on trio in a dedicated background thread of the UI
#  process; the Textual UI + mitmproxy run on asyncio in the main thread. The two
#  loops cannot share a thread, so the serving thread does all FUSE I/O and hands
#  events to the UI thread-safely (a thread-safe queue drained via an asyncio
#  callback). Index/RAM mutations are single-writer on the serving thread.
# ════════════════════════════════════════════════════════════════════════════

class OverlayMount:
    def __init__(self, mountpoint: Path, lower: str = "/"):
        self.mountpoint = Path(mountpoint)
        self.lower = lower
        self.ops = None
        self._thread = None
        self._started = threading.Event()
        self._start_error = None
        self._stop_trio = None       # set to a trio Event from inside the loop
        self._trio_token = None
        self.event_q: "queue.Queue" = queue.Queue()

    def _on_ops_event(self, **ev) -> None:
        # called from the trio serving thread; hand off to the UI thread-safely
        self.event_q.put(ev)

    def start(self) -> bool:
        """Mount the single overlay and start serving. Blocks until the serve loop is
        actually up (or failed). Returns True on success. Fail-closed: a mount
        failure is reported, never swallowed."""
        try:
            self.mountpoint.mkdir(parents=True, exist_ok=True)
        except OSError as e:
            self._start_error = e; return False
        make_ops = _build_overlay_ops()
        self.ops = make_ops(self.lower, on_event=self._on_ops_event)
        self._thread = threading.Thread(target=self._run, name="overlay-fuse",
                                        daemon=True)
        self._thread.start()
        self._started.wait(timeout=30)
        if self._start_error is not None:
            return False
        return self._started.is_set()

    def _run(self) -> None:
        import pyfuse3, trio
        fuse_options = set(pyfuse3.default_options)
        fuse_options.add("fsname=slopbox")
        # same uid as the mounter -> no allow_other needed; do NOT set
        # default_permissions (we report squash ownership ourselves).
        try:
            pyfuse3.init(self.ops, str(self.mountpoint), fuse_options)
        except Exception as e:
            self._start_error = e
            self._started.set()
            return

        async def _main():
            self._trio_token = trio.lowlevel.current_trio_token()
            self._stop_trio = trio.Event()
            async with trio.open_nursery() as nursery:
                nursery.start_soon(pyfuse3.main)
                # signal "serving" only after the loop is running.
                self._started.set()
                await self._stop_trio.wait()
                nursery.cancel_scope.cancel()
        try:
            trio.run(_main)
        except Exception as e:
            if self._start_error is None:
                self._start_error = e
            self._started.set()
        finally:
            try: pyfuse3.close(unmount=True)
            except Exception: pass

    def add_session(self, sid: str, up: Path, index: "Index",
                    passthrough: bool = False) -> None:
        if self.ops is not None:
            self.ops.add_session(sid, up, index, passthrough=passthrough)

    def remove_session(self, sid: str) -> None:
        if self.ops is not None:
            self.ops.remove_session(sid)

    def add_ca_spoof(self, sid: str, ca_bytes: bytes, bundle_paths) -> None:
        """Register the CA-augmented trust bundle as virtual files for this session:
        the box sees system_ca + our mitmproxy CA at every bundle path, but the
        augmented bytes are invisible to consolidate (no on-disk artifact)."""
        if self.ops is None: return
        for p in bundle_paths:
            lp = Path(p)
            try:
                if not lp.is_file(): continue
                base = lp.read_bytes()
            except OSError:
                continue
            sep = b"" if base.endswith(b"\n") else b"\n"
            self.ops.add_virtual(sid, p.lstrip("/"), base + sep + b"\n" + ca_bytes)

    def is_healthy(self) -> bool:
        """True only when the mount actually started successfully and is serving."""
        return self._started.is_set() and self._start_error is None and self.ops is not None

    def inflight_age(self):
        return self.ops.inflight_age() if self.ops else None

    # A handler wedged longer than this is treated as hung (watchdog).
    WATCHDOG_HANG_S = 30.0

    def watchdog_recover(self) -> bool:
        """Supervisor-owned recovery: if a FUSE handler has been in-flight too
        long, the single trio serve loop is frozen and any client parked in that
        request is in D-state. Lazy-unmount aborts the FUSE connection — that frees
        the parked clients (~tens of ms) and recovers the mount table. Returns True
        if a recovery was triggered.

        Note: a fuller recovery would also close the raw /dev/fuse fd to end the
        serve loop deterministically; pyfuse3 doesn't surface that fd, so the
        lazy-unmount (which the kernel turns into an ENODEV on the wedged loop) is the
        v1 mechanism. Offloading slow blocking syscalls to a thread pool to avoid
        wedging in the first place is the known later upgrade."""
        age = self.inflight_age()
        if age is None or age < self.WATCHDOG_HANG_S:
            return False
        try:
            subprocess.run(["fusermount3", "-uz", str(self.mountpoint)],
                           stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                           timeout=10)
        except (FileNotFoundError, subprocess.TimeoutExpired):
            pass
        return True

    def stop(self) -> None:
        """Stop serving and unmount. Lazy-unmount as a fallback so the mount table is
        clean even if the loop is wedged (watchdog)."""
        ev = self._stop_trio; token = self._trio_token
        if ev is not None and token is not None:
            try:
                import trio
                trio.from_thread.run_sync(ev.set, trio_token=token)
            except trio.RunFinishedError:
                # The serve loop already finished (e.g. unmounted/crashed); the
                # lazy-unmount fallback below still cleans the mount table. Log rather
                # than swallow so a premature exit is visible (LOW-4).
                print("slopbox(ui): overlay serve loop already finished at stop()",
                      file=sys.stderr)
            except Exception as e:
                print(f"slopbox(ui): overlay stop signalling failed: {e}",
                      file=sys.stderr)
        if self._thread is not None:
            self._thread.join(timeout=5)
        # lazy-unmount fallback (recovers the mount table even if wedged)
        try:
            if os.path.ismount(str(self.mountpoint)):
                subprocess.run(["fusermount3", "-uz", str(self.mountpoint)],
                               stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                               timeout=10)
        except (FileNotFoundError, subprocess.TimeoutExpired):
            pass


def _is_overlay_marker(name: str) -> bool:
    """Guard against legacy char-device whiteout / opaque-directory marker names
    (.wh..opq, .wh..wh.*) appearing in the upper. These are never created by this
    overlay model — kept as a defensive filter in upper_has_changes and cleanup_dirs."""
    return name == ".wh..opq" or name.startswith(".wh..wh.")

def upper_has_changes(up: Path) -> bool:
    """True if the overlay upper holds any real change (a created/modified file or
    a whiteout deletion), ignoring the overlay's own opaque markers."""
    for root, _dirs, files in os.walk(up, onerror=lambda _e: None):
        if any(not _is_overlay_marker(nm) for nm in files):
            return True
    return False

def is_whiteout(p: Path) -> bool:
    try:
        st = p.stat(); return stat_mod.S_ISCHR(st.st_mode) and st.st_rdev == 0
    except OSError: return False

def _is_symlink(p: Path) -> bool:
    """True if p is itself a symlink (lstat, never follows). Used to refuse writing
    THROUGH a symlink onto the host / into the upper from the UI thread (LOW-3)."""
    try:
        return stat_mod.S_ISLNK(os.lstat(p).st_mode)
    except OSError:
        return False

def remove_upper_entry(p: Path) -> None:
    """Remove one upper artifact: a file, a directory tree, or a char-device
    whiteout. No-op if nothing is there (e.g. an opacity-only deletion)."""
    try:
        if p.is_dir() and not p.is_symlink() and not is_whiteout(p):
            shutil.rmtree(p)
        elif p.exists() or p.is_symlink() or is_whiteout(p):
            p.unlink()
    except FileNotFoundError:
        pass

def cleanup_dirs(upper: Path, start: Path) -> None:
    """Walk up from `start` toward `upper`, removing directories that hold no real
    change. A dir with only opaque markers is removed only when the lower has
    nothing there (a freshly-created dir); otherwise the markers record deletions
    and the dir is kept. Dirs with files/whiteouts stop the walk."""
    d = start
    while d != upper and upper in d.parents:
        try: children = list(d.iterdir())
        except OSError: break
        if any(not _is_overlay_marker(c.name) for c in children):
            break
        if children:
            rel = d.relative_to(upper)
            if Path("/").joinpath(*rel.parts).is_dir():
                break
        parent = d.parent
        try: shutil.rmtree(d)
        except OSError: break
        d = parent

def _apply_overlay_entry(upper: Path, ap: Path, rel: str,
                         index: "Index | None" = None) -> None:
    """Write one overlay change onto the host (the same effect as the UI's Apply),
    then drop it from the overlay. A whiteout deletes; a file/symlink is copied."""
    host = Path("/") / rel
    is_deletion = (index is not None and index.kind_of(rel) == "whiteout")
    try:
        if is_deletion:
            if host.is_dir() and not host.is_symlink(): shutil.rmtree(host)
            elif host.exists() or host.is_symlink(): host.unlink()
        elif ap.is_symlink():
            tgt = os.readlink(ap)
            if host.exists() or host.is_symlink(): host.unlink()
            host.parent.mkdir(parents=True, exist_ok=True); os.symlink(tgt, host)
        elif ap.is_file():
            host.parent.mkdir(parents=True, exist_ok=True); shutil.copy2(ap, host)
        else:
            return                                       # unknown type: leave it
    except OSError:
        return
    remove_upper_entry(ap)

def _open_index_ro(shm_dir) -> "Index | None":
    """Open the session's single db for consolidate. None if absent."""
    sp = sqlar_path(Path(shm_dir).name)
    if not sp.exists(): return None
    try: return Index(Path(shm_dir))
    except sqlite3.Error: return None

def consolidate(shm_dir, session_id: str, cmd: list, index: "Index | None" = None,
                progress=None) -> None:
    """Finish a box: fill the NULL content blobs of its single sqlar from the overlay
    upper, then tear the upper down. consolidate does NOT copy rows or translate
    schemas — each entry row already exists (the FUSE layer upserted it on the
    mutating op with data=NULL); for a file/symlink we just UPDATE that SAME row's
    blob with the bytes the box wrote into the upper. Deletions/opacity are already
    rows (tombstones); opaque dirs expand into per-lower-child tombstones. Writer
    provenance per path is recorded into the `provenance` table. Afterwards the sqlar
    is self-contained and the backing tree can be freed. Idempotent and additive.

    File rules are consulted first, top-to-bottom: a matching 'apply' writes the
    change to the host and drops the row, a matching 'discard' just drops the row —
    either way it reaches neither store.

    `progress`, if given, is called as progress(done, total) after each upper entry
    is folded — the per-file deflate loop is the slow part — so a UI can render a
    fraction while consolidate runs off the loop. It is a plain callback; an off-loop
    caller must marshal any UI touch back to its own thread (never draw from here)."""
    upper = Path(shm_dir) / "up"
    if not upper.is_dir(): return
    own_index = index is None
    idx = index if index is not None else _open_index_ro(shm_dir)
    frules = load_file_rules()
    sp = sqlar_path(session_id)
    sq = _sqlar_open(sp)
    def _set_blob(rel, content: bytes, mode, mtime) -> None:
        data, sz = _sqlar_deflate(content)
        sq.execute("UPDATE sqlar SET mode=?, mtime=?, sz=?, data=? WHERE name=?",
                   (int(mode), int(mtime), sz, sqlite3.Binary(data), rel))
        if sq.execute("SELECT changes()").fetchone()[0] == 0:
            # No pre-existing row (orphaned overlay with no live index): create it.
            _sqlar_put_file(sq, rel, content, mode, mtime)
    def _prov(rel):
        return idx.writer_provenance(rel) if idx is not None else None
    def _sq_remove(rel):
        sq.execute("DELETE FROM sqlar WHERE name=?", (rel,))
        sq.execute("DELETE FROM provenance WHERE path=?", (rel,))
    moved = []
    # 1) created/modified files + symlinks in the upper (dirs are structural).
    paths = []
    for root, dirs, names in os.walk(upper, onerror=lambda _e: None):
        for nm in names: paths.append(Path(root) / nm)
        for d in dirs:
            p = Path(root) / d
            if p.is_symlink(): paths.append(p)
    ordered = sorted(set(paths)); total = len(ordered)
    for done, ap in enumerate(ordered, 1):
        rel = str(ap.relative_to(upper))
        act = frules.decide(rel)                         # apply / discard / passthrough / None
        if progress is not None:
            try: progress(done, total)
            except Exception: pass
        if act in ("discard", "passthrough"):
            _sq_remove(rel)
            remove_upper_entry(ap); cleanup_dirs(upper, ap.parent); continue
        if act == "apply":
            _apply_overlay_entry(upper, ap, rel, index=idx)
            _sq_remove(rel); cleanup_dirs(upper, ap.parent); continue
        try:
            if ap.is_symlink():
                lst = ap.lstat()
                tgt = os.readlink(ap).encode("utf-8", "surrogateescape")
                data, sz = _sqlar_deflate(tgt)
                sq.execute("UPDATE sqlar SET mode=?, mtime=?, sz=?, data=? WHERE name=?",
                           (stat_mod.S_IFLNK | 0o777, int(lst.st_mtime),
                            len(tgt), sqlite3.Binary(data), rel))
                if sq.execute("SELECT changes()").fetchone()[0] == 0:
                    _sqlar_put_symlink(sq, rel, tgt, lst.st_mtime)
                p = _prov(rel)
                if p: _sqlar_put_provenance(sq, rel, p)
            elif ap.is_file():
                st = ap.stat()
                _set_blob(rel, ap.read_bytes(), st.st_mode, st.st_mtime)
                p = _prov(rel)
                if p: _sqlar_put_provenance(sq, rel, p)
            else:
                continue                                 # dirs handled by cleanup
        except OSError:
            continue
        moved.append(ap)
    # 2) deletions (whiteouts) from the index -> tombstone rows (already present, but
    #    re-assert for the orphaned-overlay path) + provenance.
    if idx is not None:
        for rel in idx.deletions():
            act = frules.decide(rel)
            if act in ("discard", "passthrough"):
                _sq_remove(rel); continue
            host = Path("/") / rel
            if act == "apply":
                try:
                    if host.is_dir() and not host.is_symlink(): shutil.rmtree(host)
                    elif host.exists() or host.is_symlink(): host.unlink()
                except OSError: pass
                _sq_remove(rel); continue
            if host.exists() or host.is_symlink():
                _sqlar_put_tombstone(sq, rel)
                p = _prov(rel)
                if p: _sqlar_put_provenance(sq, rel, p)
            else:
                _sq_remove(rel)
        # 3) opaque dirs: expand into per-lower-child tombstones for children not
        #    re-materialized in the upper.
        for drel in idx.opaque_dirs():
            lower = Path("/") / drel
            if not lower.is_dir(): continue
            for lroot, ldirs, lfiles in os.walk(lower, onerror=lambda _e: None):
                for nm in ldirs + lfiles:
                    crel = os.path.relpath(os.path.join(lroot, nm), "/")
                    if (upper / crel).exists() or (upper / crel).is_symlink():
                        continue                          # re-materialized in upper
                    if frules.decide(crel) in ("apply", "discard", "passthrough"):
                        continue
                    _sqlar_put_tombstone(sq, crel)
    sq.commit(); sq.close()
    for ap in moved:
        remove_upper_entry(ap); cleanup_dirs(upper, ap.parent)
    if own_index and idx is not None:
        idx.close()

def _pid_alive(pid: int) -> bool:
    if not pid: return False
    try:
        os.kill(pid, 0); return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True

def rm_rf(path) -> None:
    """Remove a tree, fixing perms (backing dirs are created with restrictive modes,
    e.g. 0700, so a plain rmtree would fail on subdirectories)."""
    path = str(path)
    if not os.path.exists(path) and not os.path.islink(path):
        return
    def _fix_and_retry(func, p, _exc):
        try:
            os.chmod(p, 0o700)
            par = os.path.dirname(p)
            if par: os.chmod(par, 0o700)
        except OSError:
            pass
        try: func(p)
        except OSError: pass
    try:
        shutil.rmtree(path, onexc=_fix_and_retry)
    except TypeError:
        shutil.rmtree(path, onerror=_fix_and_retry)
    if os.path.exists(path):
        for root, dirs, files in os.walk(path, topdown=False):
            for nm in files + dirs:
                fp = os.path.join(root, nm)
                try: os.chmod(fp, 0o700)
                except OSError: pass
                try: (os.rmdir if os.path.isdir(fp) and not os.path.islink(fp)
                      else os.unlink)(fp)
                except OSError: pass
        try: os.chmod(path, 0o700); os.rmdir(path)
        except OSError: pass



@dataclass
class Session:
    session_id: str                # "YYYYmmdd-HHMMSS_PID" — the whole identity
    cmd: list
    shm_dir: str = ""              # the session backing dir: live/<sid> (up only)
    status: str = "running"
    exit_code: "int | None" = None
    conn_allowed: int = 0
    conn_denied: int = 0
    bytes_up: int = 0
    bytes_down: int = 0
    sess_rules: list = field(default_factory=list)   # ordered, session-only Rules
    live: bool = False
    has_sqlar: bool = False                           # the single db has entries
    has_flows: bool = False                           # the single db has flows
    # started time and pid are not stored — they are read back out of the name.
    @property
    def started(self) -> float: return parse_sid(self.session_id)[0]
    @property
    def pid(self) -> int: return parse_sid(self.session_id)[1]
    @property
    def stamp(self) -> str: return self.session_id.partition("_")[0]
    @property
    def upper(self) -> str: return str(Path(self.shm_dir) / "up")
    def to_dict(self) -> dict:
        d = {k: v for k, v in asdict(self).items() if k != "sess_rules"}
        d["sess_rules"] = [r.to_line() for r in self.sess_rules]
        d["upper"] = self.upper
        d["started"] = self.started; d["pid"] = self.pid; d["stamp"] = self.stamp
        return d


def discover_sessions() -> dict:
    """Find sessions purely from filesystem names: live/<sid> backing dirs (an
    un-consolidated/orphaned overlay) plus the single <sid>.sqlar under state_home.
    The command is the root process row in <sid>.sqlar (keyed by the sid's pid)."""
    out = {}
    lh = live_home()
    if lh.exists():
        for d in lh.iterdir():
            if not (d / "up").is_dir(): continue          # not a slopbox backing dir
            sid = d.name
            out[sid] = Session(
                session_id=sid, cmd=root_cmd(sid), shm_dir=str(d),
                status="running" if _pid_alive(parse_sid(sid)[1]) else "finished",
                live=False)
    sd = state_home()
    if sd.exists():
        for af in sd.glob("*.sqlar"):
            sid = af.name[:-len(".sqlar")]
            s = out.get(sid)
            if s is None:
                s = out[sid] = Session(
                    session_id=sid, cmd=root_cmd(sid),
                    shm_dir=str(live_dir(sid)), status="finished", live=False)
            s.has_sqlar = bool(sqlar_list(af))
            s.has_flows = has_flows(af)
    return out


