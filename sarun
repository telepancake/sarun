# These are pure path helpers: they must NOT create anything at import time. The
# in-slopbox `--inner` process imports this module too, and any directory it
# touched (under the slopboxed HOME) would be captured by the overlay and show up
# as a bogus "change". Real directory creation is deferred to ensure_dirs(),
# called only by the UI and the runner.
def data_home() -> Path:
    base = os.environ.get("XDG_DATA_HOME") or os.path.expanduser("~/.local/share")
    return Path(base) / "slopbox"

def config_home() -> Path:
    base = os.environ.get("XDG_CONFIG_HOME") or os.path.expanduser("~/.config")
    return Path(base) / "slopbox"

def runtime_home() -> Path:
    base = os.environ.get("XDG_RUNTIME_DIR")
    return Path(base) / "slopbox" if base else data_home()

SHM_ROOT       = Path("/dev/shm")
SHM_PREFIX     = "slopbox."
SOCK_PATH      = str(runtime_home() / "ui.sock")        # control + FD channel
MITM_CONFDIR   = data_home() / "mitmproxy"              # CA, generated once
CA_CERT        = MITM_CONFDIR / "mitmproxy-ca-cert.pem"
RULES_FILE     = config_home() / "netrules"             # allow/deny network rules
FILE_RULES_FILE = config_home() / "filerules"           # apply/discard by path glob

def ensure_dirs() -> None:
    """Create our host-side config/data/runtime directories. Called by the UI and
    the runner — never by the in-slopbox --inner process."""
    for p in (data_home(), config_home(), runtime_home(), MITM_CONFDIR, state_home()):
        try: p.mkdir(parents=True, exist_ok=True)
        except OSError: pass
    # migrate the old single "rules" file to its new name "netrules"
    old_rules = config_home() / "rules"
    if old_rules.exists() and not RULES_FILE.exists():
        try: old_rules.rename(RULES_FILE)
        except OSError: pass
    for f in (RULES_FILE, FILE_RULES_FILE):
        try: f.touch(exist_ok=True)
        except OSError: pass

INNER_PROXY_PORT = 8080   # forwarder's listen port inside the slopbox


# ════════════════════════════════════════════════════════════════════════════
#  Wire protocol (control messages: newline JSON; FD messages: SCM_RIGHTS)
# ════════════════════════════════════════════════════════════════════════════

async def aw_send(writer: asyncio.StreamWriter, **msg: Any) -> None:
    writer.write((json.dumps(msg) + "\n").encode()); await writer.drain()

async def aw_recv(reader: asyncio.StreamReader) -> "dict | None":
    try:
        line = await reader.readline()
        return json.loads(line.decode()) if line else None
    except (json.JSONDecodeError, asyncio.IncompleteReadError, OSError):
        return None

def sync_send(sock_path: str, timeout: float = 5.0, **msg: Any) -> None:
    try:
        with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as s:
            s.settimeout(timeout); s.connect(sock_path)
            s.sendall((json.dumps(msg) + "\n").encode())
    except OSError:
        pass

def ui_is_running(sock_path: str) -> bool:
    try:
        with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as s:
            s.settimeout(1.0); s.connect(sock_path); return True
    except OSError:
        return False


# ════════════════════════════════════════════════════════════════════════════
#  Inner forwarder — `slopbox --inner` (runs as pid-1-ish inside the slopbox)
# ════════════════════════════════════════════════════════════════════════════
#
# Listens on 127.0.0.1:INNER_PROXY_PORT. For each accepted connection, sends the
# connection's FD plus the session id to the UI's FD channel over a Unix socket
# that was bind-mounted into the slopbox. Then execs the real command. The
# forwarder holds no bytes; the UI drives the proxied conversation.

def run_inner(channel_path: str, session_id: str, cmd: list) -> int:
    stop = threading.Event()

    def forward_one(conn: socket.socket) -> None:
        try:
            with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as ch:
                ch.connect(channel_path)
                ch.sendmsg(
                    [json.dumps({"session_id": session_id}).encode()],
                    [(socket.SOL_SOCKET, socket.SCM_RIGHTS,
                      array.array("i", [conn.fileno()]).tobytes())],
                )
            # The UI now owns a dup of the FD; we can close ours.
        except OSError:
            pass
        finally:
            conn.close()

    def listener() -> None:
        srv = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        srv.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        try:
            srv.bind(("127.0.0.1", INNER_PROXY_PORT))
            srv.listen(64)
        except OSError as e:
            print(f"slopbox(inner): cannot listen: {e}", file=sys.stderr)
            return
        srv.settimeout(0.5)
        while not stop.is_set():
            try:
                conn, _ = srv.accept()
            except socket.timeout:
                continue
            except OSError:
                break
            threading.Thread(target=forward_one, args=(conn,), daemon=True).start()
        srv.close()

    # Only run the forwarder if a channel exists (i.e. networked + UI present).
    if channel_path and os.path.exists(os.path.dirname(channel_path) or "/"):
        threading.Thread(target=listener, daemon=True).start()

    # Run the real command as a foreground job *inside* this PID namespace. We are
    # PID 1 here, so the process-group ids we put on the controlling terminal are
    # namespace-local — which is what lets an interactive job-control shell
    # (bash/dash) save and restore the terminal's foreground group without hitting
    # "Cannot set tty process group (No such process)". The command gets its own
    # process group and the terminal handed to it; restored when it exits.
    tty_fd = next((fd for fd in (0, 1, 2) if os.isatty(fd)), None)
    old_fg = None
    if tty_fd is not None:
        try: old_fg = os.tcgetpgrp(tty_fd)
        except OSError: old_fg = None
    try:
        proc = subprocess.Popen(cmd, preexec_fn=os.setpgrp)
    except FileNotFoundError:
        print(f"slopbox(inner): command not found: {cmd[0]}", file=sys.stderr)
        return 127
    try: os.setpgid(proc.pid, proc.pid)
    except OSError: pass
    old_ttou = None
    if tty_fd is not None:
        old_ttou = signal.signal(signal.SIGTTOU, signal.SIG_IGN)
        try: os.tcsetpgrp(tty_fd, proc.pid)
        except OSError: pass
    try:
        code = proc.wait()
    except KeyboardInterrupt:
        proc.terminate()
        code = proc.wait()
    if tty_fd is not None:
        if old_fg is not None:
            try: os.tcsetpgrp(tty_fd, old_fg)
            except OSError: pass
        if old_ttou is not None:
            try: signal.signal(signal.SIGTTOU, old_ttou)
            except (OSError, ValueError): pass
    stop.set()
    return code or 0


# ════════════════════════════════════════════════════════════════════════════
#  Rules
# ════════════════════════════════════════════════════════════════════════════

RULE_KINDS = ("host", "ip", "cname", "url")


def _host_glob(pat: str, name: str) -> bool:
    """Wildcard hostname match. `*.example.com` matches example.com and any
    subdomain; otherwise standard glob (`*`, `?`)."""
    name = (name or "").rstrip(".").lower(); pat = pat.rstrip(".").lower()
    if pat.startswith("*.") and name == pat[2:]: return True
    return fnmatch.fnmatch(name, pat)


def _ip_match(pat: str, ip: str) -> bool:
    """Match an IP (v4/v6) against an address or CIDR network."""
    try:
        addr = ipaddress.ip_address(ip)
        if "/" in pat:
            return addr in ipaddress.ip_network(pat, strict=False)
        return addr == ipaddress.ip_address(pat)
    except ValueError:
        return False


@dataclass
class Rule:
    action: str            # "allow" | "deny"
    kind: str              # one of RULE_KINDS
    pattern: str

    def matches(self, host, port, url, ips, cnames) -> bool:
        k, p = self.kind, self.pattern
        if k == "host":
            # optional :port suffix (but not for bare IPv6 literals)
            if ":" in p and p.rpartition(":")[2].isdigit() and not p.startswith("["):
                h, _, pp = p.rpartition(":")
                return _host_glob(h, host) and int(pp) == port
            return _host_glob(p, host)
        if k == "ip":
            return any(_ip_match(p, ip) for ip in ips)
        if k == "cname":
            return any(_host_glob(p, c) for c in cnames)
        if k == "url":
            return bool(url) and (url == p or url.startswith(p))
        return False

    def to_line(self) -> str:
        return f"{self.action} {self.kind}:{self.pattern}"

    @staticmethod
    def parse(line: str) -> "Rule | None":
        s = line.strip()
        if not s or s.startswith("#"):
            return None
        action = "allow"
        # explicit verb, or legacy "!" deny prefix
        low = s.lower()
        if low.startswith("allow ") or low.startswith("deny "):
            verb, _, rest = s.partition(" ")
            action = verb.lower(); s = rest.strip()
        elif s.startswith("!"):
            action = "deny"; s = s[1:].strip()
        kind = "host"
        if ":" in s:
            maybe, _, rest = s.partition(":")
            if maybe.lower() in RULE_KINDS:
                kind = maybe.lower(); s = rest.strip()
        if not s:
            return None
        return Rule(action=action, kind=kind, pattern=s)


class Rules:
    """An ordered rule list, evaluated top-to-bottom — first match wins."""
    def __init__(self, path: Path):
        self.path = path; self.rules: list = []; self.load()
    def load(self) -> None:
        try: text = self.path.read_text()
        except OSError: text = ""
        self.rules = [r for r in (Rule.parse(ln) for ln in text.splitlines()) if r]
    def save(self) -> None:
        self.path.parent.mkdir(parents=True, exist_ok=True)
        self.path.write_text("".join(r.to_line() + "\n" for r in self.rules))
    def needs_dns(self) -> bool:
        return any(r.kind in ("ip", "cname") for r in self.rules)
    def decide(self, host, port, url=None, ips=(), cnames=()) -> "str | None":
        for r in self.rules:
            if r.matches(host, port, url, ips, cnames):
                return r.action
        return None
    def insert(self, rule: Rule, at_top: bool = False) -> None:
        self.rules.insert(0 if at_top else len(self.rules), rule); self.save()
    def remove_at(self, i: int) -> None:
        if 0 <= i < len(self.rules): del self.rules[i]; self.save()
    def move(self, i: int, delta: int) -> int:
        j = i + delta
        if 0 <= i < len(self.rules) and 0 <= j < len(self.rules):
            self.rules[i], self.rules[j] = self.rules[j], self.rules[i]
            self.save(); return j
        return i


# ════════════════════════════════════════════════════════════════════════════
#  File rules — apply / discard a change by path glob (first match wins)
# ════════════════════════════════════════════════════════════════════════════
#
# Patterns are extended shell globs (bash-style) over the change's absolute path,
# via wcmatch with GLOBSTAR + EXTGLOB + BRACE:
#   *            any run of non-/ characters (stays within one path segment)
#   ?            one non-/ character
#   **           crosses /, so **/ = any depth, /var/**/*.log = under /var
#   @(a|b) !(x) +(…) *(…) ?(…)   extglob groups;  {a,b}  brace alternation
# A pattern with no slash, or no leading /, matches at any depth (so *.txt, .~*,
# a, dir/**/*.txt). A leading / anchors at the filesystem root.

_GLOB_FLAGS = None

def _path_match(pat: str, rel: str) -> bool:
    global _GLOB_FLAGS
    pat = pat.strip()
    if not pat: return False
    # Lazy import: keeps a bare `import slopbox` (the in-slopbox --inner path)
    # stdlib-only — only the runner/UI that actually matches files needs wcmatch.
    from wcmatch import glob as _wg
    if _GLOB_FLAGS is None:
        _GLOB_FLAGS = _wg.GLOBSTAR | _wg.EXTGLOB | _wg.BRACE | _wg.DOTGLOB
    s = "/" + rel.lstrip("/")                    # the change's absolute path
    if "/" not in pat or not pat.startswith("/"):
        pat = "**/" + pat                        # bare name / relative → any depth
    try:
        return bool(_wg.globmatch(s, pat, flags=_GLOB_FLAGS))
    except ValueError:
        return False


@dataclass
class FileRule:
    action: str            # "apply" | "discard"
    pattern: str

    def matches(self, rel: str) -> bool:
        return _path_match(self.pattern, rel)

    def to_line(self) -> str:
        return f"{self.action} {self.pattern}"

    @staticmethod
    def parse(line: str) -> "FileRule | None":
        s = line.strip()
        if not s or s.startswith("#"):
            return None
        verb, _, rest = s.partition(" ")
        action = verb.lower(); pat = rest.strip()
        if action not in ("apply", "discard") or not pat:
            return None
        return FileRule(action=action, pattern=pat)


class FileRules:
    """An ordered apply/discard rule list, evaluated top-to-bottom — first match
    wins. Same shape as the network Rules, so the UI edits both the same way."""
    def __init__(self, path: Path):
        self.path = path; self.rules: list = []; self.load()
    def load(self) -> None:
        try: text = self.path.read_text()
        except OSError: text = ""
        self.rules = [r for r in (FileRule.parse(ln) for ln in text.splitlines()) if r]
    def save(self) -> None:
        self.path.parent.mkdir(parents=True, exist_ok=True)
        self.path.write_text("".join(r.to_line() + "\n" for r in self.rules))
    def decide(self, rel: str) -> "str | None":
        for r in self.rules:
            if r.matches(rel):
                return r.action
        return None
    def insert(self, rule: FileRule, at_top: bool = False) -> None:
        self.rules.insert(0 if at_top else len(self.rules), rule); self.save()
    def remove_at(self, i: int) -> None:
        if 0 <= i < len(self.rules): del self.rules[i]; self.save()
    def move(self, i: int, delta: int) -> int:
        j = i + delta
        if 0 <= i < len(self.rules) and 0 <= j < len(self.rules):
            self.rules[i], self.rules[j] = self.rules[j], self.rules[i]
            self.save(); return j
        return i

def load_file_rules() -> FileRules:
    return FileRules(FILE_RULES_FILE)


# ════════════════════════════════════════════════════════════════════════════
#  Session model + discovery + robust removal
# ════════════════════════════════════════════════════════════════════════════

def _is_overlay_marker(name: str) -> bool:
    """fuse-overlayfs / aufs opaque-directory and bookkeeping markers. These are
    internal to the overlay and are not user-visible changes, so we never list,
    apply, or count them."""
    return name == ".wh..opq" or name.startswith(".wh..wh.")

def ut_split(data: bytes) -> list:
    """Split bytes into lines on \\n, keeping the terminator on each line (the last
    line keeps whatever it had). b"".join(result) == data exactly, so splicing
    these line-pieces and writing the bytes back is lossless — CR/CRLF, encoding,
    BOM and a missing final newline are all preserved."""
    parts = data.split(b"\n")
    lines = [p + b"\n" for p in parts[:-1]]
    if parts[-1]:
        lines.append(parts[-1])
    return lines


# ════════════════════════════════════════════════════════════════════════════
#  Patch codec — a byte-exact unified diff (multi-file), XZ-compressed at rest,
#  meta.json kept in the file's user.slopbox.meta xattr.
# ════════════════════════════════════════════════════════════════════════════

def state_home() -> Path:
    base = os.environ.get("XDG_STATE_HOME") or os.path.expanduser("~/.local/state")
    return Path(base) / "slopbox"

def patch_path(session_id: str) -> Path:
    return state_home() / (session_id + ".patch.xz")

_NO_NL = b"\\ No newline at end of file\n"   # standard "no newline at EOF" marker

class PatchConflict(Exception):
    """A hunk's recorded context no longer matches the file it applies to."""

def _emit(out: list, prefix: bytes, line: bytes) -> None:
    # Each physical patch line ends in \n; a content line lacking its own newline
    # gets one (as terminator) plus the NO_NL marker, so parsing is unambiguous and
    # \r (CRLF) is preserved as content.
    if line.endswith(b"\n"):
        out.append(prefix + line)
    else:
        out.append(prefix + line + b"\n"); out.append(_NO_NL)

def make_patch(files: list) -> bytes:
    """files: list of dict(rel, lower, upper, created, deleted) with lower/upper as
    byte-line lists (from ut_split). Returns the unified-diff bytes."""
    import difflib
    out = []
    for f in files:
        a = b"/dev/null" if f["created"] else b"a/" + f["rel"].encode("utf-8","surrogateescape")
        b = b"/dev/null" if f["deleted"] else b"b/" + f["rel"].encode("utf-8","surrogateescape")
        out.append(b"--- " + a + b"\n"); out.append(b"+++ " + b + b"\n")
        ll, ul = f["lower"], f["upper"]
        for g in difflib.SequenceMatcher(None, ll, ul).get_grouped_opcodes(3):
            a1, a2, b1, b2 = g[0][1], g[-1][2], g[0][3], g[-1][4]
            out.append(f"@@ -{a1+1},{a2-a1} +{b1+1},{b2-b1} @@\n".encode())
            for tag, i1, i2, j1, j2 in g:
                if tag == "equal":
                    for ln in ll[i1:i2]: _emit(out, b" ", ln)
                else:
                    for ln in ll[i1:i2]: _emit(out, b"-", ln)
                    for ln in ul[j1:j2]: _emit(out, b"+", ln)
    return b"".join(out)

def parse_patch(data: bytes) -> dict:
    """Parse unified-diff bytes into an ordered {rel: filepatch} where filepatch is
    dict(rel, created, deleted, hunks=[dict(a1, b1, lines)]) and lines is the ordered
    [(op, byteline)] with op in ' '/'-'/'+'. Ordered lines let us re-serialize and
    edit hunks losslessly."""
    import re
    files = {}; cur = None; phys = ut_split(data); i = 0
    while i < len(phys):
        line = phys[i]; i += 1
        if line.startswith(b"--- "):
            aside = line[4:].rstrip(b"\n")
            bside = phys[i][4:].rstrip(b"\n") if i < len(phys) else b""; i += 1
            created = aside == b"/dev/null"; deleted = bside == b"/dev/null"
            relb = (aside if deleted else bside)[2:]   # strip "a/" or "b/"
            rel = relb.decode("utf-8","surrogateescape")
            cur = files[rel] = dict(rel=rel, created=created, deleted=deleted, hunks=[])
        elif line.startswith(b"@@") and cur is not None:
            m = re.search(rb"-(\d+)(?:,\d+)? \+(\d+)", line)
            cur["hunks"].append(dict(a1=int(m.group(1)) - 1,
                                     b1=int(m.group(2)) - 1, lines=[]))
        elif cur and cur["hunks"] and line[:1] in (b" ", b"-", b"+"):
            prefix = line[:1]; content = line[1:]
            if i < len(phys) and phys[i] == _NO_NL:
                i += 1; content = content[:-1]      # drop the terminator we added
            cur["hunks"][-1]["lines"].append((prefix.decode(), content))
    return files

def hunk_a_lines(h): return [bl for op, bl in h["lines"] if op != "+"]
def hunk_b_lines(h): return [bl for op, bl in h["lines"] if op != "-"]

def serialize_patch(files: dict) -> bytes:
    """Inverse of parse_patch: render an ordered {rel: filepatch} back to bytes."""
    out = []
    for fp in files.values():
        a = b"/dev/null" if fp["created"] else b"a/" + fp["rel"].encode("utf-8","surrogateescape")
        b = b"/dev/null" if fp["deleted"] else b"b/" + fp["rel"].encode("utf-8","surrogateescape")
        out.append(b"--- " + a + b"\n"); out.append(b"+++ " + b + b"\n")
        for h in fp["hunks"]:
            na, nb = len(hunk_a_lines(h)), len(hunk_b_lines(h))
            out.append(f"@@ -{h['a1']+1},{na} +{h['b1']+1},{nb} @@\n".encode())
            for op, line in h["lines"]:
                _emit(out, op.encode(), line)
    return b"".join(out)

def build_file_patch(rel, lower, upper, created, deleted) -> dict:
    """Parsed filepatch for one file from its lower/upper byte-line lists."""
    return parse_patch(make_patch([dict(rel=rel, lower=lower, upper=upper,
                                        created=created, deleted=deleted)]))[rel]

def apply_hunks(base_lines: list, hunks: list) -> list:
    """Apply hunks forward onto base_lines (a byte-line list). Each hunk's recorded
    context must match exactly at its position, else PatchConflict. Used for
    round-trip verification where the base is unchanged. Returns new byte-line list."""
    out = []; pos = 0
    for h in hunks:
        a1 = h["a1"]; al = hunk_a_lines(h)
        if base_lines[a1:a1 + len(al)] != al:
            raise PatchConflict(f"context mismatch at line {a1+1}")
        if a1 < pos:
            raise PatchConflict("overlapping hunks")
        out.extend(base_lines[pos:a1]); out.extend(hunk_b_lines(h)); pos = a1 + len(al)
    out.extend(base_lines[pos:])
    return out

def locate_hunk(base_lines: list, hunk: dict) -> "int | None":
    """patch(1)-style: find where a hunk's original side occurs in base_lines,
    preferring the recorded position then searching outward. None if not found. A
    pure-insert hunk (no original lines) goes at the recorded position (clamped)."""
    al = hunk_a_lines(hunk); a1 = hunk["a1"]; n = len(base_lines)
    if not al:
        return max(0, min(a1, n))
    if base_lines[a1:a1 + len(al)] == al:
        return a1
    for off in range(1, n + 1):
        for pos in (a1 - off, a1 + off):
            if 0 <= pos <= n - len(al) and base_lines[pos:pos + len(al)] == al:
                return pos
    return None

def apply_one_hunk(base_lines: list, hunk: dict) -> tuple:
    """Apply a single hunk with offset search. Returns (new_lines, offset) where
    offset is how far from the recorded position it landed (0 = exact). Raises
    PatchConflict if the context can't be found — caller leaves the file untouched."""
    pos = locate_hunk(base_lines, hunk)
    if pos is None:
        raise PatchConflict("hunk does not apply")
    al = hunk_a_lines(hunk)
    return base_lines[:pos] + hunk_b_lines(hunk) + base_lines[pos + len(al):], pos - hunk["a1"]

def write_patch_file(path: Path, data: bytes, meta: dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_bytes(lzma.compress(data, preset=6))
    try: os.setxattr(tmp, "user.slopbox.meta", json.dumps(meta).encode())
    except OSError: pass
    os.replace(tmp, path)

def read_patch_file(path: Path) -> tuple:
    """Return (data_bytes, meta_dict). meta is {} if the xattr is missing."""
    data = lzma.decompress(path.read_bytes())
    try: meta = json.loads(os.getxattr(path, "user.slopbox.meta").decode())
    except (OSError, json.JSONDecodeError): meta = {}
    return data, meta


def upper_has_changes(up: Path) -> bool:
    """True if the overlay upper holds any real change (a created/modified file or
    a whiteout deletion), ignoring the overlay's own opaque markers."""
    for root, _dirs, files in os.walk(up, onerror=lambda _e: None):
        if any(not _is_overlay_marker(nm) for nm in files):
            return True
    return False

def is_whiteout(p: Path) -> bool:
    try:
        st = p.stat(); return stat_mod.S_ISCHR(st.st_mode) and st.st_rdev == 0
    except OSError: return False

def remove_upper_entry(p: Path) -> None:
    """Remove one upper artifact: a file, a directory tree, or a char-device
    whiteout. No-op if nothing is there (e.g. an opacity-only deletion)."""
    try:
        if p.is_dir() and not p.is_symlink() and not is_whiteout(p):
            shutil.rmtree(p)
        elif p.exists() or p.is_symlink() or is_whiteout(p):
            p.unlink()
    except FileNotFoundError:
        pass

def cleanup_dirs(upper: Path, start: Path) -> None:
    """Walk up from `start` toward `upper`, removing directories that hold no real
    change. A dir with only opaque markers is removed only when the lower has
    nothing there (a freshly-created dir); otherwise the markers record deletions
    and the dir is kept. Dirs with files/whiteouts stop the walk."""
    d = start
    while d != upper and upper in d.parents:
        try: children = list(d.iterdir())
        except OSError: break
        if any(not _is_overlay_marker(c.name) for c in children):
            break
        if children:
            rel = d.relative_to(upper)
            if Path("/").joinpath(*rel.parts).is_dir():
                break
        parent = d.parent
        try: shutil.rmtree(d)
        except OSError: break
        d = parent

def _apply_overlay_entry(upper: Path, ap: Path, rel: str) -> None:
    """Write one overlay change onto the host (the same effect as the UI's Apply),
    then drop it from the overlay. A whiteout deletes; a file/symlink is copied."""
    host = Path("/") / rel
    try:
        if is_whiteout(ap):
            if host.is_dir() and not host.is_symlink(): shutil.rmtree(host)
            elif host.exists() or host.is_symlink(): host.unlink()
        elif ap.is_symlink():
            tgt = os.readlink(ap)
            if host.exists() or host.is_symlink(): host.unlink()
            host.parent.mkdir(parents=True, exist_ok=True); os.symlink(tgt, host)
        elif ap.is_file():
            host.parent.mkdir(parents=True, exist_ok=True); shutil.copy2(ap, host)
        else:
            return                                       # unknown type: leave it
    except OSError:
        return
    remove_upper_entry(ap)

def consolidate(shm_dir, session_id: str, meta: dict) -> None:
    """Move every overlay change that a patch can represent *exactly and entirely*
    into the session's patch file, then prune emptied dirs. Per file it is all or
    nothing: binary files, or anything that doesn't round-trip, stay in the overlay.
    Idempotent and additive — re-running just folds in any newly representable
    overlay change (a file is never in both the overlay and the patch).

    File rules are consulted first, top-to-bottom: a matching 'apply' writes the
    change to the host and drops it from the overlay, a matching 'discard' just
    drops it — either way it never reaches the patch. Unmatched changes fall
    through to the patch-folding above."""
    upper = Path(shm_dir) / "up"
    if not upper.is_dir(): return
    frules = load_file_rules()
    pp = patch_path(session_id)
    files = {}
    if pp.exists():
        try: files = parse_patch(read_patch_file(pp)[0])
        except Exception: files = {}
    moved = []
    paths = []
    for root, _dirs, names in os.walk(upper, onerror=lambda _e: None):
        for nm in names:
            if not _is_overlay_marker(nm): paths.append(Path(root) / nm)
    for ap in sorted(paths):
        rel = str(ap.relative_to(upper))
        act = frules.decide(rel)                         # apply / discard / None
        if act == "discard":
            remove_upper_entry(ap); cleanup_dirs(upper, ap.parent); continue
        if act == "apply":
            _apply_overlay_entry(upper, ap, rel); cleanup_dirs(upper, ap.parent)
            files.pop(rel, None); continue
        if rel in files: continue                        # already in the patch
        host = Path("/") / rel
        try:
            if is_whiteout(ap):                          # deletion
                if not host.exists() or host.is_dir(): continue
                lo = host.read_bytes()
                if b"\x00" in lo: continue
                lower, upperl, created, deleted = ut_split(lo), [], False, True
            elif ap.is_file() and not ap.is_symlink():
                ub = ap.read_bytes()
                if b"\x00" in ub: continue
                lob = host.read_bytes() if (host.exists() and not host.is_dir()) else b""
                if b"\x00" in lob: continue
                lower, upperl = ut_split(lob), ut_split(ub)
                created, deleted = not host.exists(), False
            else:
                continue
        except OSError:
            continue
        fp = build_file_patch(rel, lower, upperl, created, deleted)
        try:
            if b"".join(apply_hunks(lower, fp["hunks"])) != b"".join(upperl):
                continue                                # not exactly representable
        except PatchConflict:
            continue
        files[rel] = fp; moved.append(ap)
    if files:
        write_patch_file(pp, serialize_patch(files), meta)
    elif pp.exists():
        pp.unlink()
    for ap in moved:
        remove_upper_entry(ap); cleanup_dirs(upper, ap.parent)

def _pid_alive(pid: int) -> bool:
    if not pid: return False
    try:
        os.kill(pid, 0); return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True

def rm_rf(path) -> None:
    """Remove a tree, fixing perms (fuse-overlayfs workdir can be unwritable)."""
    path = str(path)
    if not os.path.exists(path) and not os.path.islink(path):
        return
    def _fix_and_retry(func, p, _exc):
        try:
            os.chmod(p, 0o700)
            par = os.path.dirname(p)
            if par: os.chmod(par, 0o700)
        except OSError:
            pass
        try: func(p)
        except OSError: pass
    try:
        shutil.rmtree(path, onexc=_fix_and_retry)
    except TypeError:
        shutil.rmtree(path, onerror=_fix_and_retry)
    if os.path.exists(path):
        for root, dirs, files in os.walk(path, topdown=False):
            for nm in files + dirs:
                fp = os.path.join(root, nm)
                try: os.chmod(fp, 0o700)
                except OSError: pass
                try: (os.rmdir if os.path.isdir(fp) and not os.path.islink(fp)
                      else os.unlink)(fp)
                except OSError: pass
        try: os.chmod(path, 0o700); os.rmdir(path)
        except OSError: pass

def fuse_unmount(merged: str) -> None:
    if not os.path.ismount(merged):
        return
    for tool in ("fusermount3", "fusermount"):
        try:
            subprocess.run([tool, "-u", merged], stdout=subprocess.DEVNULL,
                           stderr=subprocess.DEVNULL, timeout=10)
            if not os.path.ismount(merged):
                return
        except (FileNotFoundError, subprocess.TimeoutExpired):
            continue


@dataclass
class Session:
    session_id: str
    label: str
    cmd: list
    pid: int
    shm_dir: str
    started: float
    status: str = "running"
    exit_code: "int | None" = None
    conn_allowed: int = 0
    conn_denied: int = 0
    bytes_up: int = 0
    bytes_down: int = 0
    sess_rules: list = field(default_factory=list)   # ordered, session-only Rules
    live: bool = False
    has_patch: bool = False                           # a consolidated patch exists
    @property
    def upper(self) -> str: return str(Path(self.shm_dir) / "up")
    @property
    def merged(self) -> str: return str(Path(self.shm_dir) / "merged")
    def to_dict(self) -> dict:
        d = {k: v for k, v in asdict(self).items() if k != "sess_rules"}
        d["sess_rules"] = [r.to_line() for r in self.sess_rules]
        d["upper"] = self.upper
        return d


def write_meta(shm_dir: Path, session_id, label, cmd, pid, started) -> None:
    (shm_dir / "meta.json").write_text(json.dumps(
        dict(session_id=session_id, label=label, cmd=cmd, pid=pid, started=started)))

def read_patch_meta(path: Path) -> dict:
    """Meta from the xattr only — no need to decompress the patch."""
    try: return json.loads(os.getxattr(path, "user.slopbox.meta").decode())
    except (OSError, json.JSONDecodeError): return {}

def discover_sessions() -> dict:
    out = {}
    if SHM_ROOT.exists():
        for d in SHM_ROOT.glob(SHM_PREFIX + "*"):
            mf = d / "meta.json"
            if not mf.is_file(): continue
            try: m = json.loads(mf.read_text())
            except (json.JSONDecodeError, OSError): continue
            sid = m.get("session_id") or d.name
            pid = m.get("pid", 0)
            out[sid] = Session(
                session_id=sid, label=m.get("label", d.name), cmd=m.get("cmd", []),
                pid=pid, shm_dir=str(d), started=m.get("started", d.stat().st_mtime),
                status="running" if _pid_alive(pid) else "finished", live=False)
    sd = state_home()
    if sd.exists():
        for pf in sd.glob("*.patch.xz"):
            sid = pf.name[:-len(".patch.xz")]
            if sid in out:
                out[sid].has_patch = True
                continue
            m = read_patch_meta(pf)
            out[sid] = Session(
                session_id=m.get("session_id", sid), label=m.get("label", sid),
                cmd=m.get("cmd", []), pid=m.get("pid", 0),
                shm_dir=m.get("shm_dir", ""), started=m.get("started", pf.stat().st_mtime),
                status="finished", live=False, has_patch=True)
    return out


