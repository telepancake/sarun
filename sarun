        def _load_changes(self, sid, force=False):
            entries=self.sup.session_changes(sid)
            # Only touch the table when the set of changes actually differs, so the
            # periodic refresh keeps the pane live without blinking or losing the
            # cursor while nothing is changing.
            if not force and entries==self._ch_entries:
                return
            self._ch_entries=entries
            self._rebuild_ch(preserve=True)
            self._cbar()

        def _load_flows(self, sid, force=False):
            flows=self.sup.flows(sid)
            if not force and flows==self._nf_flows:
                return
            self._nf_flows=flows
            def row(f):
                act="✓" if f["action"]=="allow" else "✗"
                col="green" if f["action"]=="allow" else "red"
                hp=f"{f['host']}:{f['port']}" if f["port"] not in (80,443) else f["host"]
                stc="green" if 200<=f["status"]<400 else ("red" if f["status"]>=400 else "")
                return (f["id"], [
                    Text(time.strftime("%H:%M:%S", time.localtime(f["ts"]))),
                    Text(act, style=col), Text(f["method"]),
                    Text(hp, style="cyan"),
                    Text(str(f["status"] or ""), style=stc),
                    fmt_bytes(f["req_len"]), fmt_bytes(f["resp_len"])])
            self._sync_table(self.query_one("#nf-tab",DataTable), [row(f) for f in flows])
            self._update_flow_detail()

        def _update_flow_detail(self):
            d=self.query_one("#flow-detail",Static)
            sid=self._ch_sid; fid=self._sel_flow()
            if not sid or fid is None:
                d.update(Text("(no connection selected)", style="dim")); return
            f=self.sup.flow_detail(sid, fid)
            if not f:
                d.update(Text("(gone)", style="dim")); return
            def body(blob, n):
                if not blob: return Text("  (empty)\n", style="dim")
                raw=bytes(blob)
                try:
                    txt=raw.decode("utf-8")
                    t=Text(txt[:8000])
                    if len(txt)>8000 or n>len(raw): t.append(f"\n  … {fmt_bytes(n)} total\n", style="dim")
                    else: t.append("\n")
                    return t
                except UnicodeDecodeError:
                    return Text(f"  binary · {fmt_bytes(n)}\n", style="dim")
            t=Text()
            t.append(f["action"].upper()+"  ", style="green bold" if f["action"]=="allow" else "red bold")
            t.append(f["method"]+" ", style="bold")
            t.append(f["url"], style="cyan"); t.append("\n\n")
            t.append("── request headers ──\n", style="dim")
            t.append((f["req_headers"] or "").rstrip()+"\n", style="")
            t.append("── request body ──\n", style="dim"); t.append(body(f["req_body"], f["req_len"]))
            t.append("\n")
            t.append(f"── response  [{f['status']}] ──\n", style="dim")
            t.append((f["resp_headers"] or "").rstrip()+"\n", style="")
            t.append("── response body ──\n", style="dim"); t.append(body(f["resp_body"], f["resp_len"]))
            d.update(t)

