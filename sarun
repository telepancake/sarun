def ensure_ca_cert() -> Path:
    if CA_CERT.exists(): return CA_CERT
    try:
        with socket.socket() as s:
            s.bind(("127.0.0.1", 0)); tmp_port = s.getsockname()[1]
        proc = subprocess.Popen(
            ["mitmdump", "-q", "--listen-host", "127.0.0.1",
             "--listen-port", str(tmp_port), "--set", f"confdir={MITM_CONFDIR}"],
            stdin=subprocess.DEVNULL, stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL)
        for _ in range(50):
            if CA_CERT.exists(): break
            time.sleep(0.1)
        proc.terminate()
        try: proc.wait(timeout=3)
        except Exception: proc.kill()
    except FileNotFoundError:
        pass
    return CA_CERT


# Where the various distros keep the system CA bundle that OpenSSL/curl/git read
# by default. We add our mitmproxy CA to every one that exists.
SYSTEM_CA_FILES = (
    "/etc/ssl/certs/ca-certificates.crt",                   # Debian/Ubuntu/Arch
    "/etc/pki/tls/certs/ca-bundle.crt",                     # Fedora/RHEL (symlink)
    "/etc/pki/ca-trust/extracted/pem/tls-ca-bundle.pem",   # Fedora/RHEL (real)
    "/etc/ssl/cert.pem",                                    # Alpine/LibreSSL/BSD
    "/etc/ssl/ca-bundle.pem",                               # openSUSE
)

def primary_ca_path() -> "str | None":
    for f in SYSTEM_CA_FILES:
        if Path(f).is_file(): return f
    return None

# The CA-augmented trust bundle is no longer a lower overlay layer. The overlay
# engine synthesizes it as a *virtual file* at each system bundle path (see
# OverlayMount.add_ca_spoof / MultiplexOverlayFs virtual files, spec §7): the box
# sees system CA + our mitmproxy CA there, but the augmented bytes have no on-disk
# artifact in either layer, so they stay invisible to change review.


# ════════════════════════════════════════════════════════════════════════════
#  Runner — `slopbox CMD [ARGS...]`
# ════════════════════════════════════════════════════════════════════════════

def find_self() -> str: return os.path.abspath(sys.argv[0])

_BWRAP_HELP = None
def bwrap_supports(flag: str) -> bool:
    global _BWRAP_HELP
    if _BWRAP_HELP is None:
        try:
            r = subprocess.run(["bwrap", "--help"], capture_output=True,
                               text=True, timeout=5)
            _BWRAP_HELP = r.stdout + r.stderr
        except Exception:
            _BWRAP_HELP = ""
    return flag in _BWRAP_HELP

def cmd_run(cmd, no_net, session_whitelist, chdir) -> int:
    if not cmd:
        print("slopbox: no command given", file=sys.stderr); return 2

    # The UI is now the mount provider: it owns the single pyfuse3 overlay and
    # exposes this box as a subfolder under it. So the UI MUST be running — fail
    # fast and clearly otherwise. (We deliberately trade no-UI operation for live
    # feedback + per-write policy; there is no run-without-UI path.)
    if not ui_is_running(SOCK_PATH):
        print("slopbox: the UI is not running.\n"
              "  The UI owns the overlay mount that the slopbox binds as its root,\n"
              "  so a slopbox cannot run without it. Start the UI first:\n"
              "      slopbox            # (in another terminal)\n"
              f"  (expected control socket: {SOCK_PATH})", file=sys.stderr)
        return 3

    net = not no_net

    # The session id is the whole identity: timestamp + our pid. It names the
    # live/<sid> backing dir, the <mnt>/<sid> mount subfolder, and the patch
    # (<sid>.patch.xz). The only other thing kept is the command (xattr).
    sid = make_sid()

    # Register with the UI and BLOCK until it has created live/<sid>, built the
    # index, added the session to the mount, and exposed <mnt>/<sid> — only then
    # does the bwrap bind target exist. The ack carries the absolute mount path.
    ack = sync_request(SOCK_PATH, type="register", session_id=sid,
                       cmd=list(cmd), session_whitelist=session_whitelist,
                       want_net=net)
    if not ack or not ack.get("ok") or not ack.get("mount"):
        # collision on sid (same second + pid is impossible, but be safe) or the
        # UI failed to set up the overlay — retry once with a unique suffix.
        sid = sid + "." + uuid.uuid4().hex[:6]
        ack = sync_request(SOCK_PATH, type="register", session_id=sid,
                           cmd=list(cmd), session_whitelist=session_whitelist,
                           want_net=net)
        if not ack or not ack.get("ok") or not ack.get("mount"):
            print("slopbox: the UI could not set up the overlay for this session"
                  f"{(' — ' + ack['error']) if ack and ack.get('error') else ''}.",
                  file=sys.stderr)
            return 1
    box_root = ack["mount"]                      # <mnt>/<sid>
    shm_dir = ack.get("shm_dir", str(live_dir(sid)))
    can_net = net and bool(ack.get("net")) and CA_CERT.exists()

    # Diagnostics go to stderr (never stdout) and only ever before/after the
    # child runs, so the wrapped command's stdout stays clean.
    print(f"slopbox: {sid}  ({'net' if net else 'no-net'}, UI connected"
          f"{'' if can_net else ' → no network'})", file=sys.stderr)
    print(f"  overlay root: {box_root}", file=sys.stderr)

    tty_fd = next((fd for fd in (0, 1, 2) if os.isatty(fd)), None)
    old_fg_pgrp = None
    old_ttou = None
    if tty_fd is not None:
        try: old_fg_pgrp = os.tcgetpgrp(tty_fd)
        except OSError: old_fg_pgrp = None
        old_ttou = signal.signal(signal.SIGTTOU, signal.SIG_IGN)

    launched = False
    code = 1

    try:
        # the inner forwarder needs the channel socket bound in; the channel is
        # the UI socket. We bind its directory in so connect() works.
        chan = SOCK_PATH if can_net else ""

        # UNCHANGED bwrap security boundary: the ONLY difference from the old
        # fuse-overlayfs path is the bind source — this box's mount subfolder
        # instead of a per-box fuse-overlayfs `merged`. Every other flag is
        # identical (own pid/ipc/uts/net ns, all caps dropped, runs as you). The
        # bind-as-root confines the box to its subfolder; it cannot reach <mnt>/
        # or another session's <sid>. No userns, no fd-passing, no inner mount.
        args = ["bwrap",
                "--bind", str(box_root), "/",
                "--proc", "/proc", "--dev", "/dev",
                "--ro-bind-try", "/sys", "/sys",
                "--tmpfs", "/tmp", "--tmpfs", "/run",
                "--unshare-pid", "--unshare-ipc", "--unshare-uts", "--unshare-net",
                "--cap-drop", "ALL", "--die-with-parent",
                "--chdir", chdir or os.getcwd()]
        if bwrap_supports("--as-pid-1"):
            args += ["--as-pid-1"]
        if can_net:
            # bind the UI socket in (its dir) so the forwarder can reach it
            args += ["--bind", os.path.dirname(SOCK_PATH), os.path.dirname(SOCK_PATH)]
            args += ["--ro-bind", str(CA_CERT), str(CA_CERT)]
            proxy = f"http://127.0.0.1:{INNER_PROXY_PORT}"
            for var in ("http_proxy", "https_proxy", "HTTP_PROXY", "HTTPS_PROXY"):
                args += ["--setenv", var, proxy]
            # The overlay synthesizes a CA-augmented trust bundle as a *virtual*
            # file at each system bundle path (invisible to review), so point the
            # bundle-based tools at the in-overlay system bundle path; fall back to
            # the bare CA if no system bundle was found.
            primary = primary_ca_path()
            cafile = primary if primary else str(CA_CERT)
            for var in ("REQUESTS_CA_BUNDLE", "SSL_CERT_FILE",
                        "CURL_CA_BUNDLE", "GIT_SSL_CAINFO"):
                args += ["--setenv", var, cafile]
            # node merges NODE_EXTRA_CA_CERTS with its built-in roots, so it only
            # needs the addition, not the whole bundle.
            args += ["--setenv", "NODE_EXTRA_CA_CERTS", str(CA_CERT)]
        # run our own --inner, which starts the forwarder then execs cmd
        args += ["--", sys.executable, find_self(), "--inner",
                 "--channel", chan, "--sid", sid, "--", *cmd]

        proc = subprocess.Popen(args, preexec_fn=os.setpgrp)
        launched = True
        try: os.setpgid(proc.pid, proc.pid)
        except OSError: pass

        def _sig(_s, _f):
            try: os.killpg(proc.pid, signal.SIGTERM)
            except OSError:
                try: proc.terminate()
                except OSError: pass
        signal.signal(signal.SIGTERM, _sig)
        signal.signal(signal.SIGINT, _sig)

        code = proc.wait()
    finally:
        # Restore terminal foreground before we print anything else, so our own
        # output never races the child's or trips SIGTTOU.
        if tty_fd is not None and old_fg_pgrp is not None:
            try: os.tcsetpgrp(tty_fd, old_fg_pgrp)
            except OSError: pass
        if old_ttou is not None:
            try: signal.signal(signal.SIGTTOU, old_ttou)
            except (OSError, ValueError): pass

    # Tell the UI we exited. The UI runs consolidate() on live/<sid>, removes
    # <mnt>/<sid> from the live set, and deletes live/<sid>. (The runner does NOT
    # consolidate: the UI owns the index/mount and the only live index handle.)
    sync_send(SOCK_PATH, type="unregister", session_id=sid,
              status="finished" if launched else "finished",
              exit_code=(code or 0) if launched else 1)
    print(f"slopbox: {sid} exited ({code if launched else 1}). "
          f"Review changes in the UI.", file=sys.stderr)
    return (code or 0) if launched else 1


