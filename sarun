        def _decor_of(self, sid, rel):
            """Cached per-row decoration for (sid, rel), or None if not yet computed."""
            return self._ch_decor.get(sid, {}).get(rel)

        def _ch_indent(self, depth):
            # Same indent glyph/scheme as the proc pane, for visual consistency.
            return "  "*depth + ("└ " if depth else "")

        def _ch_cells(self, e, depth):
            # One REAL change row's cells from the cheap backbone + its (maybe-absent)
            # lazy decoration. The NAME column shows only the basename, indented by tree
            # depth (the full path lives in the cd-info header above the diff). An
            # undecorated changed/symlink row renders with a neutral '…' placeholder
            # rather than a guessed kind; deleted is known from the backbone.
            sigs={"created":("+","green"),"modified":("~","yellow"),"deleted":("-","red")}
            d=self._decor_of(self._ch_sid, e["path"])
            kind=d["kind"] if d else e["kind"]
            stale=bool(d and d.get("stale"))
            sym,col=sigs.get(kind,("…","dim"))
            t=Text(sym, style=col)
            if stale: t.append("!", style="reverse red")  # host is newer
            name=e["path"].rsplit("/",1)[-1]
            return [t, Text(self._ch_indent(depth)+name, style="red" if stale else ""),
                    fmt_bytes(e["size"]) if e["size"] else ""]

        def _conn_cells(self, name, depth):
            # A structural directory row (a prefix that isn't itself a change): dimmed,
            # basename + "/", cursor-skipped — display-only, never an apply target.
            return [Text(""), Text(self._ch_indent(depth)+name+"/", style="dim"), ""]

        def _build_ch_tree(self):
            # Build the change set into a DFS-ordered directory tree via the shared
            # generic core. Members keyed by full path, path tuple = path components.
            # Connector dir prefixes (not themselves changes) come back as tuple keys;
            # give them a stable "d/<joined>" string row key so the cursor can skip them.
            members={e["path"]:tuple(e["path"].split("/")) for e in self._ch_entries}
            rows=[]; conn=set()
            for key, joined, depth, connector in build_path_tree(members, lambda p:"/".join(p)):
                if connector:
                    rk="d/"+joined; conn.add(rk)
                    rows.append((rk, joined.rsplit("/",1)[-1], depth, True))
                else:
                    rows.append((key, joined.rsplit("/",1)[-1], depth, False))
            self._ch_rows=rows; self._ch_conn=conn

        def _rebuild_ch(self, preserve=False):
            # Rebuild the cached tree (set/order/labels) then feed it to _sync_table;
            # only runs when _ch_entries actually changed, so the 0.3s tick never sorts.
            self._build_ch_tree()
            ent={e["path"]:e for e in self._ch_entries}
            rows=[]
            for rk, name, depth, connector in self._ch_rows:
                if connector: rows.append((rk, self._conn_cells(name, depth)))
                else: rows.append((rk, self._ch_cells(ent[rk], depth)))
            self._sync_table(self.query_one("#cf-tab",DataTable), rows)
            self._skip_conn_ch()
            self._decorate_visible()

        def _skip_conn_ch(self):
            # Keep the cursor off dimmed connector dir rows: nudge to the next real entry.
            conn=self._ch_conn
            if not conn: return
            t=self.query_one("#cf-tab",DataTable)
            if not t.row_count: return
            try: ck=t.coordinate_to_cell_key((t.cursor_row,0)).row_key.value
            except Exception: return
            if ck not in conn: return
            keys=[rk.value for rk in t.rows]
            i=t.cursor_row
            nxt=next((j for j in range(i+1,len(keys)) if keys[j] not in conn),
                     next((j for j in range(i-1,-1,-1) if keys[j] not in conn), None))
            if nxt is not None:
                try: t.move_cursor(row=nxt, animate=False)
                except Exception: pass

        def _decorate_visible(self):
            # Viewport-scoped lazy decoration: compute is_text/stale/precise-kind ONLY
            # for the REAL rows currently scrolled into view (DataTable renders only
            # those), cache per (sid,rel), then repaint just those cells. Connector dir
            # rows need no decoration. Never iterates all n.
            sid=self._ch_sid
            if sid is None or self.view!="changes": return
            try: tbl=self.query_one("#cf-tab",DataTable)
            except Exception: return
            n=len(self._ch_rows)
            if not n: return
            top=max(0, int(tbl.scroll_offset.y))
            # Before first layout size.height is 0 — fall back to a small window, NEVER
            # n, so a huge box is never fully decorated at first paint.
            h=tbl.size.height or 40
            lo=max(0, top-2); hi=min(n, top+h+2)   # small over-scan for smoothness
            ent={e["path"]:e for e in self._ch_entries}
            cache=self._ch_decor.setdefault(sid, {})
            cols=list(tbl.columns); src=None
            for i in range(lo, hi):
                rk, name, depth, connector = self._ch_rows[i]
                if connector: continue            # structural dir row: no decoration
                e=ent.get(rk)
                if e is None: continue
                rel=e["path"]
                if rel in cache: continue
                if e["kind"]=="deleted":
                    cache[rel]=dict(is_text=False, stale=False, kind="deleted")
                else:
                    if src is None: src=self.sup.review._source(sid)
                    try: cache[rel]=self.sup.review.decorate(sid, rel, source=src)
                    except Exception: cache[rel]=dict(is_text=False, stale=False, kind=e["kind"])
                cells=self._ch_cells(e, depth)
                for ck,val in zip(cols, cells):
                    try:
                        if tbl.get_cell(rel,ck)!=val:
                            tbl.update_cell(rel,ck,val,update_width=False)
                    except Exception: pass

        def _diff_info_lines(self, d):
            k=d.get("kind")
            if k=="deleted": return [Text("DELETED", style="red bold")]
            if k=="directory": return [Text("DIRECTORY", style="cyan")]
            if k=="error": return [Text(str(d.get("error")), style="red")]
            diff=d.get("diff"); out=[]
            if diff is not None:
                for ln in diff.splitlines():
                    if ln.startswith(("+++","---")): out.append(Text(ln, style="bold"))
                    elif ln.startswith("+"): out.append(Text(ln, style="green"))
                    elif ln.startswith("-"): out.append(Text(ln, style="red"))
                    elif ln.startswith("@@"): out.append(Text(ln, style="cyan"))
                    else: out.append(Text(ln, style="dim"))
                if not diff.strip(): out.append(Text("(no textual diff)", style="dim"))
            else:
                raw=base64.b64decode(d.get("content") or b"")
                out.append(Text(f"binary · {fmt_bytes(len(raw))}", style="dim"))
                for i in range(0,min(len(raw),256),16):
                    ch=raw[i:i+16]; h=" ".join(f"{b:02x}" for b in ch)
                    a="".join(chr(b) if 0x20<=b<0x7f else "." for b in ch)
                    out.append(Text(f"{i:04x}  {h:<48}  {a}", style="dim"))
            return out

        def _update_cd_info(self, rel=None):
            # Full path + kind/size/mode shown above the diff, since the file
            # list truncates the path to keep the basename readable.
            info=self.query_one("#cd-info",Static)
            rel = rel if rel is not None else self._sel_path()
            ent = next((e for e in self._ch_entries if e["path"]==rel), None) if rel else None
            if not ent:
                info.update(Text("")); return
            mode = self.sup.review.change_mode(self._ch_sid, ent["path"])
            # The selected row is visible → use its lazy decoration for the precise
            # kind/stale (decorate on the spot if it hasn't been seen yet).
            d=self._decor_of(self._ch_sid, ent["path"])
            if d is None and ent["kind"]!="deleted":
                try: d=self._ch_decor.setdefault(self._ch_sid, {}).setdefault(
                    ent["path"], self.sup.review.decorate(self._ch_sid, ent["path"]))
                except Exception: d=None
            kind=d["kind"] if d else ent["kind"]
            stale=bool(d and d.get("stale"))
            t=Text()
            t.append("/"+ent["path"], style="bold")
            t.append("\n")
            t.append(f"{kind}", style="dim")
            if ent.get("size"): t.append(f" · {fmt_bytes(ent['size'])}", style="dim")
            if mode is not None:
                t.append(f" · {stat_mod.filemode(mode)} {oct(stat_mod.S_IMODE(mode))}", style="dim")
            if stale:
                t.append("  ⚠ host changed since capture", style="reverse red")
            info.update(t)

        def _load_diff(self, sid, rel, keep_pos=False):
            dv=self.query_one("#cd-log",DiffView)
            keep=dv.index if keep_pos else None
            res=self.sup.review.hunks(sid, rel)
            dv.clear()
            if res.get("is_text"):
                hunks=res.get("hunks") or []
                if not hunks:
                    dv.append(ListItem(Label(Text("(no textual differences)", style="dim"))))
                for h in hunks:
                    dv.append(HunkItem(h["index"], h["lines"]))
            else:
                for line in self._diff_info_lines(res.get("diff") or {}):
                    dv.append(ListItem(Label(line)))
            n=len(dv.children)
            if keep is not None and n: dv.index=min(keep, n-1)
            elif n: dv.index=0   # highlight a hunk so a/x act without an extra step

        def _hunk_op(self, index, discard):
            sid=self._ch_sid; p=self._sel_path()
            if not sid or p is None: return
            r=(self.sup.review.discard_hunk if discard
               else self.sup.review.apply_hunk)(sid, p, index)
            if not r.get("ok"): self._status(Text(r.get("error") or "hunk op failed")); return
            self._invalidate_changes(sid)   # a real edit changed the set
            self._load_changes(sid)
            if any(e["path"]==p for e in self._ch_entries):
                self._load_diff(sid, p, keep_pos=True)
            else:
                try: self.query_one("#cd-log",DiffView).clear()
                except Exception: pass
            self._cbar("hunk " + ("discarded" if discard else "applied"))
        def _hunk_apply(self, index): self._hunk_op(index, discard=False)
        def _hunk_discard(self, index): self._hunk_op(index, discard=True)

        def _status(self, t):
            try: self.query_one("#status",Static).update(t)
            except Exception: pass
        def _cbar(self, msg=""):
            n=len(self._ch_entries)
            extra=f"{n} change(s)" + (f"  ·  {msg}" if msg else "")
            try: self.query_one("#c-bar",Static).update(f"  [dim]{extra}[/]")
            except Exception: pass

        def _sel_session(self):
            t=self.query_one("#s-tab",DataTable)
            if not t.row_count: return None
            try: return self.sessions.get(
                t.coordinate_to_cell_key((t.cursor_row,0)).row_key.value)
            except Exception: return None
        def _sel_path(self):
            # The selected REAL change's full path. Connector dir rows are display-only:
            # the cursor skips them, but guard here too so apply/discard/p-jump never act
            # on a structural row.
            t=self.query_one("#cf-tab",DataTable)
            if not t.row_count: return None
            try: k=t.coordinate_to_cell_key((t.cursor_row,0)).row_key.value
            except Exception: return None
            return None if k in self._ch_conn else k

        def _load_changes(self, sid, force=False):
            entries=self._changes_for(sid)   # kicks the off-loop fold if needed
            # Mid-fold: show a placeholder row, never the partial state. _changes_for
            # already started the worker; just render the wait.
            if self._is_consolidating(sid):
                self._ch_entries=[]
                self._sync_table(self.query_one("#cf-tab",DataTable),
                                 [("consolidating",
                                   [Text(""), Text("consolidating…", style="dim"),
                                    Text("")])])
                self._ch_rows=[]; self._ch_conn=set()
                self._cbar("consolidating…")
                return
            # Only touch the table when the set of changes actually differs, so the
            # periodic refresh keeps the pane live without blinking or losing the
            # cursor while nothing is changing.
            if not force and entries==self._ch_entries:
                return
            self._ch_entries=entries
            self._rebuild_ch(preserve=True)
            self._cbar()

        def _load_flows(self, sid, force=False):
            flows=self.sup.flows(sid)
            if not force and flows==self._nf_flows:
                return
            self._nf_flows=flows
            def row(f):
                act="✓" if f["action"]=="allow" else "✗"
                col="green" if f["action"]=="allow" else "red"
                hp=f"{f['host']}:{f['port']}" if f["port"] not in (80,443) else f["host"]
                stc="green" if 200<=f["status"]<400 else ("red" if f["status"]>=400 else "")
                return (f["id"], [
                    Text(time.strftime("%H:%M:%S", time.localtime(f["ts"]))),
                    Text(act, style=col), Text(f["method"]),
                    Text(hp, style="cyan"),
                    Text(str(f["status"] or ""), style=stc),
                    fmt_bytes(f["req_len"]), fmt_bytes(f["resp_len"])])
            self._sync_table(self.query_one("#nf-tab",DataTable), [row(f) for f in flows])
            self._update_flow_detail()

        def _update_flow_detail(self):
            d=self.query_one("#flow-detail",Static)
            sid=self._ch_sid; fid=self._sel_flow()
            if not sid or fid is None:
                d.update(Text("(no connection selected)", style="dim")); return
            f=self.sup.flow_detail(sid, fid)
            if not f:
                d.update(Text("(gone)", style="dim")); return
            def body(blob, n):
                if not blob: return Text("  (empty)\n", style="dim")
                raw=bytes(blob)
                try:
                    txt=raw.decode("utf-8")
                    t=Text(txt[:8000])
                    if len(txt)>8000 or n>len(raw): t.append(f"\n  … {fmt_bytes(n)} total\n", style="dim")
                    else: t.append("\n")
                    return t
                except UnicodeDecodeError:
                    return Text(f"  binary · {fmt_bytes(n)}\n", style="dim")
            t=Text()
            t.append(f["action"].upper()+"  ", style="green bold" if f["action"]=="allow" else "red bold")
            t.append(f["method"]+" ", style="bold")
            t.append(f["url"], style="cyan"); t.append("\n\n")
            t.append("── request headers ──\n", style="dim")
            t.append((f["req_headers"] or "").rstrip()+"\n", style="")
            t.append("── request body ──\n", style="dim"); t.append(body(f["req_body"], f["req_len"]))
            t.append("\n")
            t.append(f"── response  [{f['status']}] ──\n", style="dim")
            t.append((f["resp_headers"] or "").rstrip()+"\n", style="")
            t.append("── response body ──\n", style="dim"); t.append(body(f["resp_body"], f["resp_len"]))
            d.update(t)

        def _sel_flow(self):
            t=self.query_one("#nf-tab",DataTable)
            if not t.row_count: return None
            try: return t.coordinate_to_cell_key((t.cursor_row,0)).row_key.value
            except Exception: return None

        # ── processes pane (the selected box's process table) ────────────────
        def _load_procs(self, sid, force=False):
            # LIVE box: the Index's bounded active set (htop-style), O(active set), no
            # full-table query — dead-but-not-yet-retired rows are highlighted. FINISHED
            # box: the full immutable process history, tree-built once and cached.
            # Both render as a process TREE: build_proc_tree gives DFS-ordered rows,
            # depth-indented; connector-only ancestors (added to connect the tree) are
            # dimmed and the cursor skips them. The live lookup resolves ancestors
            # outside the active set; the finished full table is self-contained.
            # Mid-fold (finished box still consolidating): the sqlar this pane reads is
            # being rewritten off the loop — show the placeholder, don't read it.
            if not self.sup.review._live(sid) and self._maybe_start_consolidate(sid):
                self._sync_table(self.query_one("#pr-tab",DataTable),
                                 [("consolidating",
                                   [Text("…"), Text(""),
                                    Text("consolidating", style="dim"), Text("")])])
                self._pr_key=None
                self._update_proc_detail()
                return
            root=parse_sid(sid)[1]
            live=self.sup.processes_live(sid)
            if live is not None:
                self._fin_procs.pop(sid, None)
                key=live
                procs=[(p, tg, pp, ex, av) for (p, tg, pp, ex, av, _al, _dd) in live]
                dead={tg for (_p, tg, _pp, _ex, _av, _al, dd) in live if dd}
                tree=build_proc_tree(procs, root,
                                     lambda tg: self.sup.proc_info(sid, tg))
            else:
                if sid not in self._fin_procs:
                    procs=self.sup.processes(sid)
                    self._fin_procs[sid]=(procs, build_proc_tree(procs, root, None))
                procs,tree=self._fin_procs[sid]
                key=procs; dead=set()
            cur=getattr(self,"_pr_key",None)
            if not force and key==cur: return
            self._pr_key=key
            self._pr_procs=[(p,tg,pp,ex,av) for (p,tg,pp,ex,av,_d,c) in tree if not c]
            self._pr_conn={("c"+str(tg)) for (_p,tg,_pp,_ex,_av,_d,c) in tree if c}
            rows=[]
            for pid, tgid, ppid, exe, argv, depth, conn in tree:
                indent="  "*depth + ("└ " if depth else "")
                nm=Text(indent+(exe.rsplit("/",1)[-1] or exe or "?")[:18], style="cyan")
                ar=Text(" ".join(argv)[:40], style="dim")
                if conn:                          # structural-only ancestor: dimmed
                    rk="c"+str(tgid)
                    tg=Text(str(tgid), style="dim"); pp=Text(str(ppid), style="dim")
                    nm.stylize("dim"); ar.stylize("dim")
                elif tgid in dead:                # htop-style: process exited, flashing out
                    rk=str(pid)
                    tg=Text(str(tgid), style="red"); pp=Text(str(ppid), style="red")
                    nm.stylize("red"); ar.stylize("red")
                else:
                    rk=str(pid); tg=str(tgid); pp=str(ppid)
                rows.append((rk, [tg, pp, nm, ar]))
            self._sync_table(self.query_one("#pr-tab",DataTable), rows)
            self._skip_conn_proc()
            self._update_proc_detail()

        def _skip_conn_proc(self):
            # Keep the cursor off dimmed connector rows: nudge to the next real member.
            conn=getattr(self,"_pr_conn",None)
            if not conn: return
            t=self.query_one("#pr-tab",DataTable)
            if not t.row_count: return
            try: ck=t.coordinate_to_cell_key((t.cursor_row,0)).row_key.value
            except Exception: return
            if ck not in conn: return
            keys=[rk.value for rk in t.rows]
            i=t.cursor_row
            nxt=next((j for j in range(i+1,len(keys)) if keys[j] not in conn),
                     next((j for j in range(i-1,-1,-1) if keys[j] not in conn), None))
            if nxt is not None:
                try: t.move_cursor(row=nxt, animate=False)
                except Exception: pass

        def _sel_proc(self):
            t=self.query_one("#pr-tab",DataTable)
            if not t.row_count: return None
            try: return int(t.coordinate_to_cell_key((t.cursor_row,0)).row_key.value)
            except Exception: return None

        def _update_proc_detail(self):
            d=self.query_one("#proc-detail",Static)
            sid=self._ch_sid; pid=self._sel_proc()
            if not sid or pid is None:
                d.update(Text("(no process selected)", style="dim")); return
            row=next((p for p in (self._pr_procs or []) if p[0]==pid), None)
            t=Text()
            if row:
                _id,tgid,ppid,exe,argv=row
                t.append(f"tgid {tgid}  ppid {ppid}\n", style="bold")
                t.append("exe   ", style="dim"); t.append((exe or "?")+"\n")
                t.append("argv  ", style="dim"); t.append(" ".join(argv)+"\n\n")
            env=self.sup.process_env(sid, pid)
            t.append("── environment ──\n", style="dim")
            if not env:
                t.append("(none captured — run with -t to record the environment)\n",
                         style="dim")
            for k in sorted(env):
                t.append(k, style="cyan"); t.append("="+env[k]+"\n")
            d.update(t)

        @on(DataTable.RowHighlighted, "#pr-tab")
        def _ph(self, ev):
            if self.view!="procs": return
            if ev.row_key and ev.row_key.value in getattr(self,"_pr_conn",()):
                self._skip_conn_proc()
            self._update_proc_detail()

        @on(DataTable.RowHighlighted, "#s-tab")
        def _sc(self, ev):
            if ev.row_key and ev.row_key.value:
                sid=ev.row_key.value
                self._ch_sid=sid
                if sid!=self._last_loaded_sid:
                    self._last_loaded_sid=sid
                    self._load_changes(sid, force=True)
                if self.view=="boxes": self._update_box_detail()

        @on(DataTable.RowSelected, "#s-tab")
        def _s_open(self, ev):
            # Enter on a slopbox → review its changes.
            if ev.row_key and ev.row_key.value:
                self._ch_sid=ev.row_key.value; self._last_loaded_sid=ev.row_key.value
                self._set_view("changes")

        @on(DataTable.RowHighlighted, "#cf-tab")
        def _cc(self, ev):
            if ev.row_key and ev.row_key.value in self._ch_conn:
                self._skip_conn_ch(); return       # nudge off the dimmed dir row
            if ev.row_key and ev.row_key.value and self._ch_sid:
                self._decorate_visible()
                self._update_cd_info(ev.row_key.value)
                self._load_diff(self._ch_sid, ev.row_key.value)

        @on(DataTable.RowHighlighted, "#nf-tab")
        def _nc(self, ev):
            if self.view=="netlog": self._update_flow_detail()

        @on(DataTable.RowSelected, "#cf-tab")
        def _f_open(self, ev):
            # Enter on a real file focuses the diff/hunk pane for it; dir rows are inert.
            if ev.row_key and ev.row_key.value and ev.row_key.value not in self._ch_conn \
               and self._ch_sid:
                self._load_diff(self._ch_sid, ev.row_key.value)
                try: self.query_one("#cd-log",DiffView).focus()
                except Exception: pass

        @on(ListView.Highlighted, "#w-list")
        def _net_hl(self, ev):
            if self.view=="net": self._update_rule_detail()

        @on(ListView.Highlighted, "#r-list")
        def _file_hl(self, ev):
            if self.view=="file": self._update_rule_detail()

        def action_back(self):
            """Esc steps back: diff → file list; any other list → slopboxes."""
            if self.view=="changes":
                try: in_diff=self.focused is self.query_one("#cd-log",DiffView)
                except Exception: in_diff=False
                if in_diff:
                    try: self.query_one("#cf-tab",DataTable).focus()
                    except Exception: pass
                    return
            if self.view!="boxes":
                self._set_view("boxes")

        def action_kill(self):
            s=self._sel_session()
            if not s or s["status"]!="running":
                self._status("no running session selected"); return
            def done(ok):
                if ok: self.sup.kill(s["session_id"])
            self.push_screen(Confirm(styled("Kill ", (s['stamp'],"bold"), "?")), done)

        def action_delete(self):
            s=self._sel_session()
            if not s: return
            if s["status"]=="running": self._status("kill it first"); return
            def done(ok):
                if ok: self.sup.delete(s["session_id"])
            self.push_screen(Confirm(styled("Delete ", (s['stamp'],"bold"), " and its overlay?")), done)

        def action_ap_allow(self): self._ap_once("allow")
        def action_ap_deny(self): self._ap_once("deny")
        def _ap_once(self, action):
            a=self._first_pending()
            if a: self.sup.policy.resolve(a["request_id"], action, "once")

        def action_ap_allow_rule(self): self._ap_rule("allow")
        def action_ap_deny_rule(self): self._ap_rule("deny")
        def _ap_rule(self, action):
            a=self._first_pending()
            if not a: return
            rid=a["request_id"]
            def done(res):
                if res:
                    scope,spec,at_top=res
                    self.sup.policy.resolve(rid, action, scope, spec, at_top)
            self.push_screen(RuleModal(action, a), done)

        def action_refresh(self):
            if self._ch_sid: self._load_changes(self._ch_sid)

        def _refresh_after(self, sid, p):
            self._invalidate_changes(sid)   # a real edit changed the set
            self._load_changes(sid)
            if p is not None and any(e["path"]==p for e in self._ch_entries):
                self._load_diff(sid, p, keep_pos=True)
            else:
                try: self.query_one("#cd-log",DiffView).clear()
                except Exception: pass

        def action_apply_one(self):
            p,sid=self._sel_path(),self._ch_sid
            if p and sid:
                r=self.sup.review.apply(sid,[p]); self._cbar(f"applied {len(r['applied'])}")
                self._refresh_after(sid, p)

        def action_apply_all(self):
            sid=self._ch_sid
            if not sid: return
            s=self.sessions.get(sid,{})
            warn="\n[yellow]still running[/]" if s.get("status")=="running" else ""
            def done(ok):
                if ok:
                    r=self.sup.review.apply(sid,None); self._cbar(f"applied {len(r['applied'])}")
                    self._refresh_after(sid, None)
            self.push_screen(Confirm(f"Apply all {len(self._ch_entries)} changes?{warn}"), done)

        def action_discard_one(self):
            p,sid=self._sel_path(),self._ch_sid
            if p and sid:
                self.sup.review.discard(sid,[p]); self._refresh_after(sid, p)

        def action_discard_all(self):
            sid=self._ch_sid
            if not sid: return
            def done(ok):
                if ok: self.sup.review.discard(sid,None); self._refresh_after(sid, None)
            self.push_screen(Confirm(f"Discard ALL {len(self._ch_entries)} changes?"), done)

    return UI


def run_ui() -> int:
    # A single UI instance only: if one is already running its control socket
    # answers, so refuse a second.
    if ui_is_running(SOCK_PATH):
        print("slopbox: the UI is already running"
              f" (control socket {SOCK_PATH}).\n"
              "  Only one UI instance may run; use the existing one.",
              file=sys.stderr)
        return 4
    ensure_dirs()
    _make_ui_app()().run()
    return 0


def cmd_patch() -> int:
    """Print the unified patch for the UI's currently-selected slopbox to stdout,
    by asking the running UI over the control socket."""
    if not ui_is_running(SOCK_PATH):
        print("slopbox: the UI is not running.", file=sys.stderr); return 3
    rep = sync_request(SOCK_PATH, type="patch")
    if not rep or not rep.get("ok"):
        print("slopbox: " + ((rep or {}).get("error") or "no patch available"),
              file=sys.stderr)
        return 1
    data = base64.b64decode(rep.get("patch") or b"")
    sys.stdout.buffer.write(data)
    return 0


_USAGE = ("slopbox                         start the UI\n"
          "       slopbox patch                   print selected box's patch (stdout)\n"
          "       slopbox [-n] [-t] [-d] [-w HOST]... [-C DIR] -- CMD [ARGS...]\n"
          "         -n  networking via mitmproxy   -t  process tracing\n"
          "         -d  direct host access (no capture)")


# ════════════════════════════════════════════════════════════════════════════
#  Entry
# ════════════════════════════════════════════════════════════════════════════

def main() -> int:
    argv = sys.argv[1:]

    # inner mode: slopbox --inner --channel PATH --sid SID -- CMD...
    if argv and argv[0] == "--inner":
        ap = argparse.ArgumentParser(prog="slopbox --inner")
        ap.add_argument("--channel", default="")
        ap.add_argument("--sid", required=True)
        ap.add_argument("cmd", nargs=argparse.REMAINDER)
        ns = ap.parse_args(argv[1:])
        cmd = ns.cmd
        if cmd and cmd[0] == "--": cmd = cmd[1:]
        return run_inner(ns.channel, ns.sid, cmd)

    if not argv:
        return run_ui()

    if argv[0] in ("-h", "--help"):
        print("usage: " + _USAGE); return 0

    if argv[0] == "patch":
        return cmd_patch()

    # The command MUST come after `--`. Flags come before it.
    if "--" not in argv:
        # A bare `slopbox ls` is the common mistake — point at the fix.
        # Don't echo back the flags as the command (that would suggest an
        # invalid `slopbox -- -t`); just show the canonical shape.
        print("slopbox: the command must come after `--`.\n"
              "  e.g.  slopbox -- CMD [ARGS...]\n"
              "  (flags go before `--`:  slopbox -t -d -- ls -la)",
              file=sys.stderr)
        return 2

    sep = argv.index("--")
    pre, cmd = argv[:sep], argv[sep + 1:]

    ap = argparse.ArgumentParser(prog="slopbox", add_help=False, usage=_USAGE)
    ap.add_argument("-w", dest="whitelist", action="append", default=[], metavar="HOST")
    ap.add_argument("-n", dest="net", action="store_true")
    ap.add_argument("-t", dest="trace", action="store_true")
    ap.add_argument("-d", dest="direct", action="store_true")
    ap.add_argument("-C", dest="chdir", default=None)
    try:
        ns = ap.parse_args(pre)
    except SystemExit:
        return 2
    if not cmd:
        print("slopbox: no command after `--`.", file=sys.stderr); return 2
    return cmd_run(cmd, ns.net, ns.trace, ns.direct, ns.whitelist, ns.chdir)


if __name__ == "__main__":
    sys.exit(main())
