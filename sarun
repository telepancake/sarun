            with Container(id="confirm-box"):
                yield Label(self.m, id="confirm-msg")
                with Horizontal(id="confirm-btns"):
                    yield Button("Yes [y]", variant="error", id="cy")
                    yield Button("No [n]", id="cn")
        def action_yes(self): self.dismiss(True)
        def action_no(self): self.dismiss(False)
        @on(Button.Pressed,"#cy")
        def _y(self): self.dismiss(True)
        @on(Button.Pressed,"#cn")
        def _n(self): self.dismiss(False)

    class RuleModal(ModalScreen):
        # Let the user write the exact rule (kind:pattern) and choose where it goes,
        # instead of the program guessing. It shows what this request can be matched
        # on — host, resolved IPs, CNAME chain, URL — so those are easy to copy.
        # Returns (scope, spec, at_top) or None.
        BINDINGS=[("escape","cancel",""),("ctrl+p","perm","")]
        def __init__(self, action, appr):
            super().__init__(); self.action=action; self.a=appr
        def compose(self):
            a=self.a
            verb="ALLOW" if self.action=="allow" else "DENY"
            col="success" if self.action=="allow" else "error"
            ips=", ".join(a.get("ips") or []) or "—"
            cnames=", ".join(a.get("cnames") or []) or "—"
            url=a.get("url") or "—"
            with Vertical(id="rule-box"):
                yield Label(f" [{col}]{verb}[/] rule", id="rule-title")
                yield Label(styled(("host  ","dim"), (a['host'],"cyan"), f":{a['port']}"))
                yield Label(styled(("ip    ","dim"), ips))
                yield Label(styled(("cname ","dim"), cnames))
                yield Label(styled(("url   ","dim"), url))
                yield Input(value=f"host:{a['host']}", id="rule-input")
                yield Label("[dim]kinds:  host:NAME[:PORT]  ·  ip:ADDR|CIDR  ·  "
                            "cname:NAME  ·  url:PREFIX[/]")
                yield Label("[dim]host & cname take [b]*[/b] wildcards — "
                            "[b]*.example.com[/b] matches example.com and any "
                            "subdomain; [b]*[/b] alone matches anything[/]")
                yield Checkbox("insert at top (checked first)", id="rule-top")
                with Horizontal(id="rule-btns"):
                    yield Button("This session [↵]", id="rb-sess", variant="primary")
                    yield Button("Permanent [^p]", id="rb-perm", variant="warning")
                    yield Button("Cancel [esc]", id="rb-cancel")
        def on_mount(self): self.query_one("#rule-input",Input).focus()
        def _spec(self): return self.query_one("#rule-input",Input).value.strip()
        def _top(self): return self.query_one("#rule-top",Checkbox).value
        def _go(self, scope):
