    class HunkItem(ListItem):
        def __init__(self, index, lines):
            super().__init__(); self.hunk_index=index; self._lines=lines
        def compose(self):
            t=Text()
            for i,(tag,txt) in enumerate(self._lines):
                if i: t.append("\n")
                if tag=="hdr": t.append(txt, style="cyan")
                elif tag=="+": t.append("+"+txt, style="green")
                elif tag=="-": t.append("-"+txt, style="red")
                else: t.append(" "+txt, style="dim")
            yield Label(t)

