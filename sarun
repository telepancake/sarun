def ensure_ca_cert() -> Path:
    if CA_CERT.exists(): return CA_CERT
    try:
        with socket.socket() as s:
            s.bind(("127.0.0.1", 0)); tmp_port = s.getsockname()[1]
        proc = subprocess.Popen(
            ["mitmdump", "-q", "--listen-host", "127.0.0.1",
             "--listen-port", str(tmp_port), "--set", f"confdir={MITM_CONFDIR}"],
            stdin=subprocess.DEVNULL, stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL)
        for _ in range(50):
            if CA_CERT.exists(): break
            time.sleep(0.1)
        proc.terminate()
        try: proc.wait(timeout=3)
        except Exception: proc.kill()
    except FileNotFoundError:
        pass
    return CA_CERT


# Where the various distros keep the system CA bundle that OpenSSL/curl/git read
# by default. We add our mitmproxy CA to every one that exists.
SYSTEM_CA_FILES = (
    "/etc/ssl/certs/ca-certificates.crt",                   # Debian/Ubuntu/Arch
    "/etc/pki/tls/certs/ca-bundle.crt",                     # Fedora/RHEL (symlink)
    "/etc/pki/ca-trust/extracted/pem/tls-ca-bundle.pem",   # Fedora/RHEL (real)
    "/etc/ssl/cert.pem",                                    # Alpine/LibreSSL/BSD
    "/etc/ssl/ca-bundle.pem",                               # openSUSE
)

def primary_ca_path() -> "str | None":
    for f in SYSTEM_CA_FILES:
        if Path(f).is_file(): return f
    return None

def build_cert_layer(dest: Path, ca_cert: Path) -> "str | None":
    """Build an overlay *lower* layer that appends our mitmproxy CA to every system
    trust bundle present on the host. Used as an extra read-only lowerdir under the
    slopbox root, so TLS verification succeeds for everything that reads the system
    store (git, curl, openssl, wget, python's ssl, …) — git in particular ignores
    CURL_CA_BUNDLE and only trusts its compiled-in bundle, which this patches.

    It is a lower layer on purpose: the modified bundles never appear in the review
    upper, so they are not mistaken for changes the program made. Returns the layer
    dir (to put first in lowerdir=…:/) or None if there was nothing to add."""
    try: ca = ca_cert.read_bytes()
    except OSError: return None
    if not ca.strip(): return None
    made = False
    for sysf in SYSTEM_CA_FILES:
        src = Path(sysf)
        try:
            if not src.is_file(): continue          # follows symlinks to the real file
            base = src.read_bytes()
        except OSError:
            continue
        out = dest / sysf.lstrip("/")
        try:
            out.parent.mkdir(parents=True, exist_ok=True)
            sep = b"" if base.endswith(b"\n") else b"\n"
            out.write_bytes(base + sep + b"\n" + ca)
            made = True
        except OSError:
            continue
    return str(dest) if made else None


