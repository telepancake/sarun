# ════════════════════════════════════════════════════════════════════════════
#  Wire protocol (control messages: newline JSON; FD messages: SCM_RIGHTS)
# ════════════════════════════════════════════════════════════════════════════

async def aw_send(writer: asyncio.StreamWriter, **msg: Any) -> None:
    writer.write((json.dumps(msg) + "\n").encode()); await writer.drain()

async def aw_recv(reader: asyncio.StreamReader) -> "dict | None":
    try:
        line = await reader.readline()
        return json.loads(line.decode()) if line else None
    except (json.JSONDecodeError, asyncio.IncompleteReadError, OSError):
        return None

def sync_send(sock_path: str, timeout: float = 5.0, **msg: Any) -> None:
    try:
        with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as s:
            s.settimeout(timeout); s.connect(sock_path)
            s.sendall((json.dumps(msg) + "\n").encode())
    except OSError:
        pass

def sync_request(sock_path: str, timeout: float = 30.0, **msg: Any) -> "dict | None":
    """Send one control message and wait for a single newline-JSON reply. Used by the
    runner to register a box and block until the UI has created live/<box_id> and
    exposed <mnt>/<box_id> (so the bwrap bind target exists). None on any failure."""
    try:
        with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as s:
            s.settimeout(timeout); s.connect(sock_path)
            s.sendall((json.dumps(msg) + "\n").encode())
            line = s.makefile("rb").readline()
            return json.loads(line.decode()) if line.strip() else None
    except (OSError, json.JSONDecodeError):
        return None

def register_request(sock_path: str, timeout: float = 30.0, **msg: Any) -> "tuple[dict | None, int]":
    """Like sync_request but carries the caller's own pidfd over SCM_RIGHTS so the
    UI can derive the runner's HOST-namespace pid from /proc/self/fdinfo without
    relying on SO_PEERCRED.  Falls back to a plain sendall (no FD) if pidfd_open is
    unavailable (Python < 3.9, kernel ENOSYS, or any OSError) — the UI then gets
    peer_pid=0 and treats this as a top-level runner.

    For nested boxes the UI sends the child overlay's dir-fd alongside the JSON reply
    (SCM_RIGHTS); the runner can then root bwrap via --bind-fd instead of --bind.

    Returns (ack_dict | None, mount_fd) where mount_fd >= 0 iff the UI sent one."""
    pidfd = -1
    try:
        pidfd = os.pidfd_open(os.getpid())
    except (OSError, AttributeError):
        pass
    try:
        with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as s:
            s.settimeout(timeout); s.connect(sock_path)
            payload = (json.dumps(msg) + "\n").encode()
            if pidfd >= 0:
                s.sendmsg([payload],
                          [(socket.SOL_SOCKET, socket.SCM_RIGHTS,
                            array.array("i", [pidfd]).tobytes())])
            else:
                s.sendall(payload)
            # Use recvmsg so we can capture an optional dir-fd the UI may piggyback on
            # the reply for nested boxes (NESTED LAUNCH mechanism).  CMSG_SPACE(4*4) is
            # enough for one fd; use a generous buffer so we never truncate.
            data, anc, _flags, _addr = s.recvmsg(65536, socket.CMSG_SPACE(4 * 4))
            mount_fd = -1
            for lvl, typ, cmsg_data in anc:
                if lvl == socket.SOL_SOCKET and typ == socket.SCM_RIGHTS:
                    a = array.array("i"); a.frombytes(cmsg_data)
                    fds = a.tolist()
                    if fds:
                        mount_fd = fds[0]
                    # close unexpected extras (shouldn't happen, defensive)
                    for extra in fds[1:]:
                        try: os.close(extra)
                        except OSError: pass
            line = data.split(b"\n", 1)[0]
            ack = json.loads(line.decode()) if line.strip() else None
            return ack, mount_fd
    except (OSError, json.JSONDecodeError):
        return None, -1
    finally:
        if pidfd >= 0:
            try: os.close(pidfd)
            except OSError: pass

def ui_is_running(sock_path: str) -> bool:
    try:
        with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as s:
            s.settimeout(1.0); s.connect(sock_path); return True
    except OSError:
        return False


#: [b]Network model[/]
#: A slopbox has [b]no real network[/] — only loopback. Outbound connections are only possible
#: when you pass [cyan]-n[/] (networking flag) AND the UI is running to gate them.
#: A tiny in-box forwarder hands each accepted connection's file descriptor to the UI over a
#: Unix socket ([cyan]SCM_RIGHTS[/]). The UI feeds it to an in-process [cyan]mitmproxy[/] instance,
#: which checks it against your allow/deny rules and — if no rule matches — asks you.
#: The real upstream fetch happens in the UI's network context; the box never touches the host network.
#: If the UI is not running, the forwarder has nowhere to send connections, so the box simply
#: has no network at all and never blocks waiting for a human.

# ════════════════════════════════════════════════════════════════════════════
#  Inner forwarder — `slopbox --inner` (runs as pid-1-ish inside the slopbox)
# ════════════════════════════════════════════════════════════════════════════
#
# Listens on 127.0.0.1:INNER_PROXY_PORT. For each accepted connection, sends the
# connection's FD to the UI's relay socket (a Unix socket bind-mounted into the
# slopbox). Then execs the real command. The forwarder holds no bytes; the UI
# drives the proxied conversation.

def run_inner(channel_path: str, cmd: list) -> int:
    stop = threading.Event()

    def _peer_pidfd(conn: socket.socket) -> int:
        """A pidfd for the connecting in-box workload process, or -1.

        We are INSIDE the box PID namespace, so we must NOT read box /proc or ship
        box-namespace pids — those are meaningless to the host-namespace UI and would
        violate the host-pid invariant. Instead we resolve the peer's (box-namespace)
        pid via SO_PEERCRED, use it ONLY as the pidfd_open() argument, and hand the
        resulting pidfd to the UI. The UI then derives the HOST pid from the pidfd's
        /proc/self/fdinfo (reported in the UI's namespace) and reads provenance there.
        Returns -1 if the peer is gone, SO_PEERCRED fails, or pidfd_open is
        unavailable (old kernel ENOSYS) — the UI then leaves the flow untagged."""
        try:
            creds = conn.getsockopt(socket.SOL_SOCKET, socket.SO_PEERCRED,
                                    struct.calcsize("3i"))
            pid, _uid, _gid = struct.unpack("3i", creds)
        except OSError:
            return -1
        if pid <= 0:
            return -1
        try:
            return os.pidfd_open(pid, 0)
        except (OSError, AttributeError):
            # AttributeError: Python < 3.9 (no os.pidfd_open).
            # OSError (e.g. ENOSYS on old kernels, ESRCH if peer already reaped).
            return -1

    def forward_one(conn: socket.socket) -> None:
        pidfd = _peer_pidfd(conn)
        try:
            with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as ch:
                ch.connect(channel_path)
                # The relay socket is per-session and bound into ONLY this box, so the
                # UI derives the session from which socket the FD arrived on. We send
                # the request socket (index 0) and, if we could open one, a pidfd for
                # the connecting workload process (index 1) over SCM_RIGHTS. No
                # process fields travel in the payload — the pidfd IS the channel, and
                # the UI resolves the HOST pid + provenance itself. No session_id is
                # ever shipped (the UI never trusts a sid from inside a box).
                fds = [conn.fileno()] if pidfd < 0 else [conn.fileno(), pidfd]
                ch.sendmsg(
                    [b"\x00"],
                    [(socket.SOL_SOCKET, socket.SCM_RIGHTS,
                      array.array("i", fds).tobytes())],
                )
            # The UI now owns dups of the fds we sent; we can close ours.
        except OSError:
            pass
        finally:
            if pidfd >= 0:
                try: os.close(pidfd)
                except OSError: pass
            conn.close()

    def listener() -> None:
        srv = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        srv.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        try:
            srv.bind(("127.0.0.1", INNER_PROXY_PORT))
            srv.listen(64)
        except OSError as e:
            print(f"slopbox(inner): cannot listen: {e}", file=sys.stderr)
            return
        srv.settimeout(0.5)
        while not stop.is_set():
            try:
                conn, _ = srv.accept()
            except socket.timeout:
                continue
            except OSError:
                break
            threading.Thread(target=forward_one, args=(conn,), daemon=True).start()
        srv.close()

    # Only run the forwarder if a channel exists (i.e. networked + UI present).
    if channel_path and os.path.exists(os.path.dirname(channel_path) or "/"):
        threading.Thread(target=listener, daemon=True).start()

    # Run the real command as a foreground job *inside* this PID namespace. We are
    # PID 1 here, so the process-group ids we put on the controlling terminal are
    # namespace-local — which is what lets an interactive job-control shell
    # (bash/dash) save and restore the terminal's foreground group without hitting
    # "Cannot set tty process group (No such process)". The command gets its own
    # process group and the terminal handed to it; restored when it exits.
    tty_fd = next((fd for fd in (0, 1, 2) if os.isatty(fd)), None)
    old_fg = None
    if tty_fd is not None:
        try: old_fg = os.tcgetpgrp(tty_fd)
        except OSError: old_fg = None
    try:
        proc = subprocess.Popen(cmd, preexec_fn=os.setpgrp)
    except FileNotFoundError:
        print(f"slopbox(inner): command not found: {cmd[0]}", file=sys.stderr)
        return 127
    try: os.setpgid(proc.pid, proc.pid)
    except OSError: pass
    old_ttou = None
    if tty_fd is not None:
        old_ttou = signal.signal(signal.SIGTTOU, signal.SIG_IGN)
        try: os.tcsetpgrp(tty_fd, proc.pid)
        except OSError: pass
    try:
        code = proc.wait()
    except KeyboardInterrupt:
        proc.terminate()
        code = proc.wait()
    if tty_fd is not None:
        if old_fg is not None:
            try: os.tcsetpgrp(tty_fd, old_fg)
            except OSError: pass
        if old_ttou is not None:
            try: signal.signal(signal.SIGTTOU, old_ttou)
            except (OSError, ValueError): pass
    stop.set()
    return code or 0


#: [b]Network allow/deny rules[/]
#: Rules are evaluated top-to-bottom; the [b]first match wins[/]. Rule kinds:
#:   [cyan]host:PATTERN[/]   match by hostname (glob: [cyan]*[/] / [cyan]?[/]; [cyan]*.example.com[/] also matches bare [cyan]example.com[/])
#:   [cyan]ip:ADDR[/]        match by resolved IP address or CIDR network (e.g. [cyan]10.0.0.0/8[/])
#:   [cyan]cname:PATTERN[/]  match any name in the DNS CNAME/alias chain
#:   [cyan]url:PREFIX[/]     match http(s) URLs by exact value or prefix
#: Add [cyan]:PORT[/] to a host pattern to restrict it to one port (e.g. [cyan]host:api.github.com:443[/]).
#: Scope when prompted: [b]once[/] (this request), [b]session[/] (until box exits), [b]permanent[/] (saved).

# ════════════════════════════════════════════════════════════════════════════
#  Rules
# ════════════════════════════════════════════════════════════════════════════

RULE_KINDS = ("host", "ip", "cname", "url")


def _host_glob(pat: str, name: str) -> bool:
    """Wildcard hostname match. `*.example.com` matches example.com and any
    subdomain; otherwise standard glob (`*`, `?`)."""
    name = (name or "").rstrip(".").lower(); pat = pat.rstrip(".").lower()
    if pat.startswith("*.") and name == pat[2:]: return True
    return fnmatch.fnmatch(name, pat)


def _ip_match(pat: str, ip: str) -> bool:
    """Match an IP (v4/v6) against an address or CIDR network."""
    try:
        addr = ipaddress.ip_address(ip)
        if "/" in pat:
            return addr in ipaddress.ip_network(pat, strict=False)
        return addr == ipaddress.ip_address(pat)
    except ValueError:
        return False


@dataclass
class Rule:
    action: str            # "allow" | "deny"
    kind: str              # one of RULE_KINDS
    pattern: str

    def matches(self, host, port, url, ips, cnames) -> bool:
        k, p = self.kind, self.pattern
        if k == "host":
            # optional :port suffix (but not for bare IPv6 literals)
            if ":" in p and p.rpartition(":")[2].isdigit() and not p.startswith("["):
                h, _, pp = p.rpartition(":")
                return _host_glob(h, host) and int(pp) == port
            return _host_glob(p, host)
        if k == "ip":
            return any(_ip_match(p, ip) for ip in ips)
        if k == "cname":
            return any(_host_glob(p, c) for c in cnames)
        if k == "url":
            return bool(url) and (url == p or url.startswith(p))
        return False

    def to_line(self) -> str:
        return f"{self.action} {self.kind}:{self.pattern}"

    @staticmethod
    def parse(line: str) -> "Rule | None":
        s = line.strip()
        if not s or s.startswith("#"):
            return None
        action = "allow"
        # explicit verb, or legacy "!" deny prefix
        low = s.lower()
        if low.startswith("allow ") or low.startswith("deny "):
            verb, _, rest = s.partition(" ")
            action = verb.lower(); s = rest.strip()
        elif s.startswith("!"):
            action = "deny"; s = s[1:].strip()
        kind = "host"
        if ":" in s:
            maybe, _, rest = s.partition(":")
            if maybe.lower() in RULE_KINDS:
                kind = maybe.lower(); s = rest.strip()
        if not s:
            return None
        return Rule(action=action, kind=kind, pattern=s)


class _RuleListBase:
    """Shared ordered-rule-list machinery for Rules and FileRules.
    Subclasses supply _elem_class (a type with parse/to_line) and decide()."""
    _elem_class: type

    def __init__(self, path: Path):
        self.path = path; self.rules: list = []; self.load()
    def load(self) -> None:
        try: text = self.path.read_text()
        except OSError: text = ""
        self.rules = [r for r in (self._elem_class.parse(ln) for ln in text.splitlines()) if r]
    def save(self) -> None:
        self.path.parent.mkdir(parents=True, exist_ok=True)
        self.path.write_text("".join(r.to_line() + "\n" for r in self.rules))
    def insert(self, rule, at_top: bool = False) -> None:
        self.rules.insert(0 if at_top else len(self.rules), rule); self.save()
    def remove_at(self, i: int) -> None:
        if 0 <= i < len(self.rules): del self.rules[i]; self.save()
    def move(self, i: int, delta: int) -> int:
        j = i + delta
        if 0 <= i < len(self.rules) and 0 <= j < len(self.rules):
            self.rules[i], self.rules[j] = self.rules[j], self.rules[i]
            self.save(); return j
        return i


class Rules(_RuleListBase):
    """An ordered rule list, evaluated top-to-bottom — first match wins."""
    _elem_class = Rule

    def needs_dns(self) -> bool:
        return any(r.kind in ("ip", "cname") for r in self.rules)
    def decide(self, host, port, url=None, ips=(), cnames=()) -> "str | None":
        for r in self.rules:
            if r.matches(host, port, url, ips, cnames):
                return r.action
        return None


#: [b]Change review — apply, discard, patch, and file rules[/]
#: After a box finishes, its changes are held in a private overlay for you to review.
#: You can act on the whole box or on individual files:
#:   [cyan]apply[/]    — write the box's changes to the real host filesystem, then remove the box
#:   [cyan]discard[/]  — drop all changes and remove the box
#:   [cyan]patch[/]    — print a unified diff of the box's changes to stdout
#:
#: [b]File rules[/] let you automate per-path decisions using glob patterns (first match wins):
#:   [cyan]apply PATTERN[/]    — automatically write matching paths to the host on review
#:   [cyan]discard PATTERN[/]  — automatically drop matching paths
#:   [cyan]passthrough PATTERN[/] — write directly to the host during capture (no capture)
#: Glob syntax: [cyan]*[/] within a segment, [cyan]**[/] across dirs, [cyan]@(a|b)[/] alternation,
#: [cyan]{a,b}[/] brace expansion. A bare name matches at any depth; a leading [cyan]/[/] anchors at root.

# ════════════════════════════════════════════════════════════════════════════
#  File rules — apply / discard a change by path glob (first match wins)
# ════════════════════════════════════════════════════════════════════════════
#
# Patterns are extended shell globs (bash-style) over the change's absolute path,
# via wcmatch with GLOBSTAR + EXTGLOB + BRACE:
#   *            any run of non-/ characters (stays within one path segment)
#   ?            one non-/ character
#   **           crosses /, so **/ = any depth, /var/**/*.log = under /var
#   @(a|b) !(x) +(…) *(…) ?(…)   extglob groups;  {a,b}  brace alternation
# A pattern with no slash, or no leading /, matches at any depth (so *.txt, .~*,
# a, dir/**/*.txt). A leading / anchors at the filesystem root.

@functools.cache
def _glob_flags() -> int:
    # Lazy import: keeps a bare `import slopbox` (the in-slopbox --inner path)
    # stdlib-only — only the runner/UI that actually matches files needs wcmatch.
    from wcmatch import glob as _wg
    return _wg.GLOBSTAR | _wg.EXTGLOB | _wg.BRACE | _wg.DOTGLOB

def _path_match(pat: str, rel: str) -> bool:
    pat = pat.strip()
    if not pat: return False
    from wcmatch import glob as _wg
    s = "/" + rel.lstrip("/")                    # the change's absolute path
    if "/" not in pat or not pat.startswith("/"):
        pat = "**/" + pat                        # bare name / relative → any depth
    try:
        return bool(_wg.globmatch(s, pat, flags=_glob_flags()))
    except ValueError:
        return False


FILE_ACTIONS = ("apply", "discard", "passthrough")

@dataclass
class FileRule:
    action: str            # "apply" | "discard" | "passthrough"
    pattern: str

    def matches(self, rel: str) -> bool:
        return _path_match(self.pattern, rel)

    def to_line(self) -> str:
        return f"{self.action} {self.pattern}"

    @staticmethod
    def parse(line: str) -> "FileRule | None":
        s = line.strip()
        if not s or s.startswith("#"):
            return None
        verb, _, rest = s.partition(" ")
        action = verb.lower(); pat = rest.strip()
        if action not in FILE_ACTIONS or not pat:
            return None
        return FileRule(action=action, pattern=pat)


class FileRules(_RuleListBase):
    """An ordered apply/discard rule list, evaluated top-to-bottom — first match
    wins. Same shape as the network Rules, so the UI edits both the same way."""
    _elem_class = FileRule

    def decide(self, rel: str) -> "str | None":
        for r in self.rules:
            if r.matches(rel):
                return r.action
        return None

def load_file_rules() -> FileRules:
    return FileRules(file_rules_file())


# ════════════════════════════════════════════════════════════════════════════
#  Patch codec & tree utilities
# ════════════════════════════════════════════════════════════════════════════
# Patch codec: byte-exact unified diff (multi-file), computed ON DEMAND from the
# single sqlar (no patch file at rest). Used to render text diffs in the Changes
# view, to apply/discard individual hunks, and to print via `slopbox patch`.
# Tree utilities: build_path_tree/build_proc_tree/nearest_surviving_row — generic
# stateless tree assembly shared by the file and process panes.

def ut_split(data: bytes) -> list:
    """Split bytes into lines on \\n, keeping the terminator on each line (the last
    line keeps whatever it had). b"".join(result) == data exactly, so splicing
    these line-pieces and writing the bytes back is lossless — CR/CRLF, encoding,
    BOM and a missing final newline are all preserved."""
    parts = data.split(b"\n")
    lines = [p + b"\n" for p in parts[:-1]]
    if parts[-1]:
        lines.append(parts[-1])
    return lines


_PROC_TREE_DEPTH = 64   # defensive cap on a root→self walk (cycles / runaway chains)

def build_path_tree(members, payload_of):
    """Generic stateless TREE core shared by the proc and file panes. `members` maps
    key -> path-tuple for the REAL rows. Every ancestor PREFIX of a member's path that
    isn't itself a member is unioned in as a structural CONNECTOR, so the tree is fully
    connected; sorting all rows by their path tuple yields DFS order (a parent/prefix
    immediately precedes its subtree, siblings ordered by the tuple). `payload_of(path)`
    resolves the per-row payload for any node (member or connector) — the caller keys it
    however it likes (proc: last tuple element = tgid; file: the joined path).

    Returns [(key, payload, depth, connector)] in DFS order, where depth=len(path)-1 and
    `connector`=True for a purely-structural prefix added by the union. Order-independent:
    output is a pure function of the member set + payload_of."""
    paths = {}                                # path-tuple -> key  (member or connector)
    is_member = {}                            # path-tuple -> bool
    for key, path in members.items():
        path = tuple(path)
        paths[path] = key; is_member[path] = True
        for i in range(1, len(path)):         # union in every ancestor prefix
            pre = path[:i]
            if pre not in paths:
                paths.setdefault(pre, pre); is_member.setdefault(pre, False)
    for path in list(paths):
        is_member.setdefault(path, False)
    rows = []
    for path in sorted(paths):                # lexicographic path → DFS order
        connector = not is_member[path]
        rows.append((paths[path], payload_of(path), len(path) - 1, connector))
    return rows

def build_proc_tree(procs, roots, lookup):
    """Stateless process-TREE assembly: turn a flat viewing list into DFS-ordered,
    depth-indented rows that stay correct under any scroll/paging with NO global tree
    state. For each member compute its root→self pid path by walking the ppid chain up
    until it reaches a member of `roots` (the box's hierarchy roots — a re-run box has
    several, so the result is a FOREST; defensive: visited-guard, stop at a root /
    ppid<=1 / a missing ancestor, cap depth). UNION in every ancestor met while walking
    — even ones not in `procs` — so the tree is fully connected; the generic core
    (build_path_tree) then sorts by path tuple to yield DFS order (parent immediately
    before its subtree, siblings by pid).

    `procs` is [(id, tgid, ppid, exe, argv-list)]; `roots` is a set of root tgids;
    `lookup(tgid)->(ppid,exe,argv)|None` resolves connector ancestors not present in
    `procs` (same builder for live/finished). Returns [(id, tgid, ppid, exe, argv,
    depth, connector)] in DFS order, where depth=len(path)-1 and `connector`=True for a
    purely-structural ancestor (added by the union, not a member of `procs`).
    Order-independent: output is a pure function of the (roots, lookup, set-of-procs)."""
    roots = set(roots or ())
    members = {}                              # tgid -> (id, ppid, exe, argv)
    for pid, tgid, ppid, exe, argv in procs:
        members[tgid] = (pid, ppid, exe or "", list(argv))
    nodes = {}                                # tgid -> (ppid, exe, argv)
    for tgid, (_id, ppid, exe, argv) in members.items():
        nodes[tgid] = (ppid, exe, argv)

    def info(tgid):
        if tgid in nodes: return nodes[tgid]
        m = members.get(tgid)
        if m is not None: return m[1], m[2], m[3]
        got = lookup(tgid) if lookup else None
        return got                            # (ppid,exe,argv) or None

    def path_of(tgid):
        path = []; seen = set()
        cur = tgid
        for _ in range(_PROC_TREE_DEPTH):
            if cur in seen: break             # cycle guard
            seen.add(cur); path.append(cur)
            if cur in roots: break            # reached a box root
            got = info(cur)
            if got is None: break             # missing ancestor: stop, link what we have
            ppid = got[0]
            if ppid <= 1: break               # init / unknown parent
            nodes.setdefault(ppid, info(ppid) or (0, "", []))
            cur = ppid
        path.reverse()
        return tuple(path)

    member_paths = {tgid: path_of(tgid) for tgid in list(members)}

    def payload_of(path):
        tgid = path[-1]                       # last pid-path element identifies the proc
        ppid, exe, argv = nodes.get(tgid) or (info(tgid) or (0, "", []))
        connector = tgid not in members
        pid = members[tgid][0] if not connector else tgid
        return pid, tgid, ppid, exe, argv

    rows = build_path_tree(member_paths, payload_of)
    return [(pid, tgid, ppid, exe, argv, depth, connector)
            for (_tgid, (pid, tgid, ppid, exe, argv), depth, connector) in rows]

def nearest_surviving_row(vanished_tgid, ppid_of, present):
    """When the cursored proc `vanished_tgid` is gone, find the row key of its NEAREST
    surviving ANCESTOR: walk ppid_of (tgid->ppid, covering prior+new rows incl
    connectors) up from its parent to the first tgid present in `present` (tgid->row
    key). None if no ancestor survives (caller falls back to the root). O(depth)."""
    seen = set(); cur = ppid_of.get(vanished_tgid)
    for _ in range(_PROC_TREE_DEPTH):
        if cur is None or cur in seen: break
        if cur in present: return present[cur]
        seen.add(cur); cur = ppid_of.get(cur)
    return None

_NO_NL = b"\\ No newline at end of file\n"   # standard "no newline at EOF" marker

class PatchConflict(Exception):
    """A hunk's recorded context no longer matches the file it applies to."""

def _emit(out: list, prefix: bytes, line: bytes) -> None:
    # Each physical patch line ends in \n; a content line lacking its own newline
    # gets one (as terminator) plus the NO_NL marker, so parsing is unambiguous and
    # \r (CRLF) is preserved as content.
    if line.endswith(b"\n"):
        out.append(prefix + line)
    else:
        out.append(prefix + line + b"\n"); out.append(_NO_NL)

def make_patch(files: list) -> bytes:
    """files: list of dict(rel, lower, upper, created, deleted) with lower/upper as
    byte-line lists (from ut_split). Returns the unified-diff bytes."""
    out = []
    for f in files:
        a = b"/dev/null" if f["created"] else b"a/" + f["rel"].encode("utf-8","surrogateescape")
        b = b"/dev/null" if f["deleted"] else b"b/" + f["rel"].encode("utf-8","surrogateescape")
        out.append(b"--- " + a + b"\n"); out.append(b"+++ " + b + b"\n")
        ll, ul = f["lower"], f["upper"]
        for g in difflib.SequenceMatcher(None, ll, ul).get_grouped_opcodes(3):
            a1, a2, b1, b2 = g[0][1], g[-1][2], g[0][3], g[-1][4]
            out.append(f"@@ -{a1+1},{a2-a1} +{b1+1},{b2-b1} @@\n".encode())
            for tag, i1, i2, j1, j2 in g:
                if tag == "equal":
                    for ln in ll[i1:i2]: _emit(out, b" ", ln)
                else:
                    for ln in ll[i1:i2]: _emit(out, b"-", ln)
                    for ln in ul[j1:j2]: _emit(out, b"+", ln)
    return b"".join(out)

def parse_patch(data: bytes) -> dict:
    """Parse unified-diff bytes into an ordered {rel: filepatch} where filepatch is
    dict(rel, created, deleted, hunks=[dict(a1, b1, lines)]) and lines is the ordered
    [(op, byteline)] with op in ' '/'-'/'+'. Ordered lines let us re-serialize and
    edit hunks losslessly."""
    files = {}; cur = None; phys = ut_split(data); i = 0
    while i < len(phys):
        line = phys[i]; i += 1
        if line.startswith(b"--- "):
            aside = line[4:].rstrip(b"\n")
            bside = phys[i][4:].rstrip(b"\n") if i < len(phys) else b""; i += 1
            created = aside == b"/dev/null"; deleted = bside == b"/dev/null"
            relb = (aside if deleted else bside)[2:]   # strip "a/" or "b/"
            rel = relb.decode("utf-8","surrogateescape")
            cur = files[rel] = dict(rel=rel, created=created, deleted=deleted, hunks=[])
        elif line.startswith(b"@@") and cur is not None:
            m = re.search(rb"-(\d+)(?:,\d+)? \+(\d+)", line)
            if m is None:
                raise ValueError(f"parse_patch: malformed @@ header: {line!r}")
            cur["hunks"].append(dict(a1=int(m.group(1)) - 1,
                                     b1=int(m.group(2)) - 1, lines=[]))
        elif cur and cur["hunks"] and line[:1] in (b" ", b"-", b"+"):
            prefix = line[:1]; content = line[1:]
            if i < len(phys) and phys[i] == _NO_NL:
                i += 1; content = content[:-1]      # drop the terminator we added
            cur["hunks"][-1]["lines"].append((prefix.decode(), content))
    return files

def hunk_a_lines(h): return [bl for op, bl in h["lines"] if op != "+"]
def hunk_b_lines(h): return [bl for op, bl in h["lines"] if op != "-"]

def serialize_patch(files: dict) -> bytes:
    """Inverse of parse_patch: render an ordered {rel: filepatch} back to bytes."""
    out = []
    for fp in files.values():
        a = b"/dev/null" if fp["created"] else b"a/" + fp["rel"].encode("utf-8","surrogateescape")
        b = b"/dev/null" if fp["deleted"] else b"b/" + fp["rel"].encode("utf-8","surrogateescape")
        out.append(b"--- " + a + b"\n"); out.append(b"+++ " + b + b"\n")
        for h in fp["hunks"]:
            na, nb = len(hunk_a_lines(h)), len(hunk_b_lines(h))
            out.append(f"@@ -{h['a1']+1},{na} +{h['b1']+1},{nb} @@\n".encode())
            for op, line in h["lines"]:
                _emit(out, op.encode(), line)
    return b"".join(out)

def build_file_patch(rel, lower, upper, created, deleted) -> dict:
    """Parsed filepatch for one file from its lower/upper byte-line lists."""
    return parse_patch(make_patch([dict(rel=rel, lower=lower, upper=upper,
                                        created=created, deleted=deleted)]))[rel]

# ════════════════════════════════════════════════════════════════════════════
#  Sqlar — the single per-box database (index + at-rest archive)
# ════════════════════════════════════════════════════════════════════════════
# ONE database file per box, at sqlar_path(box_id). It is BOTH the live index
# (consulted on every FUSE op, mirrored in RAM for the hot path) AND the at-rest
# archive. Schema:
#   sqlar(name, mode, mtime, sz, data, opaque, writer, last_writer)
#       every file/dir/symlink/whiteout entry. `mtime` is integer NANOSECONDS
#       (st_mtime_ns). `data` is the zlib-deflated blob (NULL for a resident file
#       whose bytes live in the pool). A char-device mode with NULL data is a
#       deletion tombstone. `opaque`=1 marks an opaque directory. `writer`/
#       `last_writer` are process.id FKs for the first/most-recent writer.
#   provenance(path, pid, ppid, exe, argv) — per-path writer provenance.
#   process(id, tgid, ppid, exe, argv, env_id, root) — one row per traced tgid;
#       `root`=1 marks a hierarchy root. A re-run adds another root → FOREST.
#   env(id, hash, env) — unique environment json, deduped by hash.
#   meta(key, value) — small per-box strings (e.g. the box's display `name`).
#   flows(...) — every gated request/response for the box.
#
# `up/` is the box-backing sentinel only. Regular-file bytes live in pool blobs;
# dirs and symlinks have no on-disk artifact — their rows are the truth, served
# from the in-RAM Index mirror.
# ════════════════════════════════════════════════════════════════════════════

def sqlar_path(box_id) -> Path:
    # The box's single db, named by its stable integer id: <box_id>.sqlar.
    return state_home() / (str(box_id) + ".sqlar")

_SQLAR_SCHEMA_VERSION = 2  # bump when DDL or migration list changes

def _sqlar_open(path) -> "sqlite3.Connection":
    path = Path(path); path.parent.mkdir(parents=True, exist_ok=True)
    # 0700: the single db holds writer provenance (pid/exe/argv/env).
    old = os.umask(0o077)
    try:
        conn = sqlite3.connect(str(path))
    finally:
        os.umask(old)
    try: os.chmod(str(path), 0o600)
    except OSError: pass
    conn.execute("PRAGMA busy_timeout=3000")
    # Gate the one-time DDL + migrations behind user_version so repeated opens
    # (the common case) skip straight to returning the connection.
    ver = conn.execute("PRAGMA user_version").fetchone()[0]
    if ver < _SQLAR_SCHEMA_VERSION:
        conn.executescript(
            "CREATE TABLE IF NOT EXISTS sqlar"
            "(name TEXT PRIMARY KEY, mode INT, mtime INT, sz INT, data BLOB,"
            " opaque INT DEFAULT 0, writer INT, last_writer INT);"
            "CREATE TABLE IF NOT EXISTS provenance"
            "(path TEXT PRIMARY KEY, pid INT, ppid INT, exe TEXT, argv TEXT);"
            "CREATE TABLE IF NOT EXISTS env"
            "(id INTEGER PRIMARY KEY AUTOINCREMENT, hash TEXT UNIQUE, env TEXT);"
            "CREATE TABLE IF NOT EXISTS process"
            "(id INTEGER PRIMARY KEY AUTOINCREMENT, tgid INT UNIQUE, ppid INT,"
            " exe TEXT, argv TEXT, env_id INT, root INT DEFAULT 0);"
            "CREATE TABLE IF NOT EXISTS meta(key TEXT PRIMARY KEY, value TEXT);"
            "CREATE TABLE IF NOT EXISTS flows("
            " id INTEGER PRIMARY KEY AUTOINCREMENT, ts REAL, action TEXT,"
            " method TEXT, scheme TEXT, host TEXT, port INT, url TEXT, status INT,"
            " process_id INT, req_headers TEXT, req_len INT, req_body BLOB,"
            " resp_headers TEXT, resp_len INT, resp_body BLOB);")
        # Migrate boxes created by an older schema: add columns introduced later.
        # The one DDL above is authoritative for fresh DBs; these top up existing files.
        _ensure_columns(conn, "sqlar", {"last_writer": "INT"})
        _ensure_columns(conn, "process", {"root": "INT DEFAULT 0"})
        conn.execute(f"PRAGMA user_version = {_SQLAR_SCHEMA_VERSION}")
        conn.commit()
    return conn

_IDENT_RE = re.compile(r'^[A-Za-z_][A-Za-z0-9_]*$')

def _ensure_columns(conn, table: str, cols: dict) -> None:
    """Add any missing `cols` (name -> SQL decl) to `table` in place. CREATE TABLE
    IF NOT EXISTS never alters an existing table, so a db written by an older schema
    keeps its old column set until this tops it up.

    `table` and each column `name` are validated against a strict identifier regex
    before interpolation into DDL, guarding against accidental injection if a future
    migration introduces a non-literal value."""
    if not _IDENT_RE.match(table):
        raise ValueError(f"_ensure_columns: invalid table identifier: {table!r}")
    have = {r[1] for r in conn.execute(f"PRAGMA table_info({table})")}
    for name, decl in cols.items():
        if not _IDENT_RE.match(name):
            raise ValueError(f"_ensure_columns: invalid column identifier: {name!r}")
        if name not in have:
            conn.execute(f"ALTER TABLE {table} ADD COLUMN {name} {decl}")

def _sqlar_deflate(content: bytes):
    comp = zlib.compress(content, 6)
    return (comp, len(content)) if len(comp) < len(content) else (content, len(content))

def _sqlar_put_file(conn, name, content: bytes, mode, mtime_ns) -> None:
    """`mtime_ns` is integer nanoseconds (st_mtime_ns); stored as-is."""
    data, sz = _sqlar_deflate(content)
    conn.execute("INSERT INTO sqlar(name,mode,mtime,sz,data) VALUES(?,?,?,?,?)"
                 " ON CONFLICT(name) DO UPDATE SET mode=excluded.mode,"
                 " mtime=excluded.mtime, sz=excluded.sz, data=excluded.data",
                 (name, int(mode), int(mtime_ns), sz, sqlite3.Binary(data)))

def _sqlar_put_provenance(conn, name, prov: dict) -> None:
    conn.execute("INSERT OR REPLACE INTO provenance VALUES(?,?,?,?,?)",
                 (name, int(prov.get("pid") or 0), int(prov.get("ppid") or 0),
                  prov.get("exe") or "", json.dumps(prov.get("argv") or [])))

def _sqlar_put_symlink(conn, name, target: bytes, mtime_ns) -> None:
    """`mtime_ns` is integer nanoseconds (st_mtime_ns); stored as-is."""
    conn.execute("INSERT INTO sqlar(name,mode,mtime,sz,data) VALUES(?,?,?,?,?)"
                 " ON CONFLICT(name) DO UPDATE SET mode=excluded.mode,"
                 " mtime=excluded.mtime, sz=excluded.sz, data=excluded.data",
                 (name, stat_mod.S_IFLNK | 0o777, int(mtime_ns), len(target),
                  sqlite3.Binary(target)))

def _sqlar_put_tombstone(conn, name) -> None:
    conn.execute("INSERT INTO sqlar(name,mode,mtime,sz,data) VALUES(?,?,?,?,?)"
                 " ON CONFLICT(name) DO UPDATE SET mode=excluded.mode,"
                 " mtime=excluded.mtime, sz=excluded.sz, data=excluded.data",
                 (name, stat_mod.S_IFCHR, 0, 0, None))

def sqlar_list(path) -> list:
    """[(name, mode, mtime, sz)] sorted by name; [] if there is no archive.
    mtime is integer NANOSECONDS (st_mtime_ns)."""
    path = Path(path)
    if not path.exists(): return []
    conn = _sqlar_open(path)
    try: return conn.execute("SELECT name,mode,mtime,sz FROM sqlar "
                             "ORDER BY name").fetchall()
    except sqlite3.Error: return []
    finally: conn.close()

def sqlar_mode(path, name) -> "int | None":
    path = Path(path)
    if not path.exists(): return None
    conn = _sqlar_open(path)
    try:
        row = conn.execute("SELECT mode FROM sqlar WHERE name=?", (name,)).fetchone()
    except sqlite3.Error: row = None
    finally: conn.close()
    return row[0] if row else None

def sqlar_mtime(path, name) -> "int | None":
    """Stored mtime as integer NANOSECONDS (st_mtime_ns), or None if missing."""
    path = Path(path)
    if not path.exists(): return None
    conn = _sqlar_open(path)
    try:
        row = conn.execute("SELECT mtime FROM sqlar WHERE name=?", (name,)).fetchone()
    except sqlite3.Error: row = None
    finally: conn.close()
    return row[0] if row else None

def sqlar_nonempty(path) -> bool:
    """True if the sqlar has at least one entry — cheaper than fetching all rows."""
    path = Path(path)
    if not path.exists(): return False
    conn = _sqlar_open(path)
    try:
        row = conn.execute("SELECT 1 FROM sqlar LIMIT 1").fetchone()
    except sqlite3.Error: row = None
    finally: conn.close()
    return row is not None

def sqlar_mode_mtime(path, name) -> "tuple[int, int] | tuple[None, None]":
    """Fetch mode AND mtime in a single SELECT — use at call sites that need both."""
    path = Path(path)
    if not path.exists(): return None, None
    conn = _sqlar_open(path)
    try:
        row = conn.execute("SELECT mode, mtime FROM sqlar WHERE name=?",
                           (name,)).fetchone()
    except sqlite3.Error: row = None
    finally: conn.close()
    return (row[0], row[1]) if row else (None, None)

def box_id_of_sqlar(path) -> "int | None":
    """The box_id for a <box_id>.sqlar path: its filename stem (box_id IS the identity)."""
    try: return int(Path(path).stem)
    except (ValueError, TypeError): return None

def sqlar_content(path, name) -> "bytes | None":
    """Decompressed bytes for one entry (the symlink target for a symlink); None if
    missing or a tombstone. Reads EITHER rest form: an evicted/folded row (bytes
    compressed in `data`) or a permanently-resident row (data NULL; bytes in the pool
    blob at blob_path(box_id, rowid) — the uncompressed file on disk)."""
    path = Path(path)
    if not path.exists(): return None
    conn = _sqlar_open(path)
    try:
        row = conn.execute("SELECT rowid,sz,data FROM sqlar WHERE name=?",
                           (name,)).fetchone()
    except sqlite3.Error: row = None
    finally: conn.close()
    if not row: return None
    rowid, sz, data = row
    if data is not None:
        data = bytes(data)
        return data if len(data) == sz else zlib.decompress(data)
    # Resident: bytes live in the pool blob (the permanent file rest form). Locate it
    # by the box's stable id (the sqlar filename stem) + the row's stable rowid.
    bid = box_id_of_sqlar(path)
    if bid is None: return None
    try:
        bp = blob_path(bid, rowid)
    except (ValueError, TypeError):
        return None
    try:
        return bp.read_bytes() if bp.exists() else None
    except OSError:
        return None

def sqlar_remove(path, name) -> int:
    """Drop one entry; unlink the archive when it empties of entries. Returns
    entries left."""
    path = Path(path)
    if not path.exists(): return 0
    conn = _sqlar_open(path)
    try:
        conn.execute("DELETE FROM sqlar WHERE name=?", (name,))
        conn.execute("DELETE FROM provenance WHERE path=?", (name,)); conn.commit()
        left = conn.execute("SELECT EXISTS(SELECT 1 FROM sqlar)").fetchone()[0]
        flows = conn.execute("SELECT EXISTS(SELECT 1 FROM flows)").fetchone()[0]
    except sqlite3.Error as e:
        print(f"slopbox: sqlar_remove {path} {name}: {e}", file=sys.stderr)
        left = 1; flows = 1
    finally: conn.close()
    if left == 0 and flows == 0:
        try: path.unlink()
        except OSError: pass
    return left

def _drop_sqlar_row_and_blob(path, box_id, rel) -> None:
    """Drop one sqlar row AND any permanent pool blob backing it. The row is removed
    FIRST: a failed removal must never leave a resident row whose blob is gone (a
    zombie reading as an empty file); a crash between the two only orphans the blob,
    which sweep_orphan_pools reclaims. `box_id` may be None (no blob check).
    Uses a single connection for both the rowid read and the delete."""
    path = Path(path)
    rel = rel.lstrip("/")
    if not path.exists(): return
    conn = _sqlar_open(path)
    bp = None
    try:
        try:
            row = conn.execute("SELECT rowid,data FROM sqlar WHERE name=?",
                               (rel,)).fetchone()
        except sqlite3.Error: row = None
        if box_id is not None and row is not None and row[1] is None:
            try: bp = blob_path(int(box_id), row[0])
            except (ValueError, TypeError): bp = None
        # Delete the row (and its provenance), then check emptiness — mirrors sqlar_remove
        try:
            conn.execute("DELETE FROM sqlar WHERE name=?", (name := rel,))
            conn.execute("DELETE FROM provenance WHERE path=?", (name,)); conn.commit()
            left = conn.execute("SELECT EXISTS(SELECT 1 FROM sqlar)").fetchone()[0]
            flows = conn.execute("SELECT EXISTS(SELECT 1 FROM flows)").fetchone()[0]
        except sqlite3.Error: left = 1; flows = 1
    finally: conn.close()
    if left == 0 and flows == 0:
        try: path.unlink()
        except OSError: pass
    if bp is not None:
        try:
            if bp.exists(): bp.unlink()
        except OSError: pass


# ════════════════════════════════════════════════════════════════════════════
#  Network log
# ════════════════════════════════════════════════════════════════════════════
# Every gated request/response, written live by the in-process mitmproxy into the
# `flows` table of the box's sqlar db. No separate file. Each flow carries the
# process-table id (process_id) of the in-box process that opened the connection.

_FLOW_BODY_CAP = 1 << 20    # store at most 1 MiB of each body (but record true size)
_PROC_RETIRE_S = 4.0        # live proc pane: keep a dead tgid (highlighted) this long
_ACTIVE_CAP    = 4096       # active set hard cap (bounds RAM when the pane is unwatched)
_DNS_CACHE_CAP = 4096       # bounded LRU cap for NetworkPolicy._dns_cache

def _hdr_text(items) -> str:
    out = []
    for k, v in (items or []):
        if isinstance(k, bytes): k = k.decode("latin-1", "replace")
        if isinstance(v, bytes): v = v.decode("latin-1", "replace")
        out.append(f"{k}: {v}")
    return "\n".join(out)

def flows_add(path, fl: dict) -> None:
    rb = fl.get("req_body") or b""; pb = fl.get("resp_body") or b""
    conn = _sqlar_open(path)
    try:
        conn.execute(
            "INSERT INTO flows(ts,action,method,scheme,host,port,url,status,process_id,"
            "req_headers,req_len,req_body,resp_headers,resp_len,resp_body)"
            " VALUES(?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)",
            (fl.get("ts", time.time()), fl.get("action", ""), fl.get("method", ""),
             fl.get("scheme", ""), fl.get("host", ""), fl.get("port", 0),
             fl.get("url", ""), fl.get("status", 0), fl.get("process_id"),
             _hdr_text(fl.get("req_headers")), len(rb), sqlite3.Binary(rb[:_FLOW_BODY_CAP]),
             _hdr_text(fl.get("resp_headers")), len(pb), sqlite3.Binary(pb[:_FLOW_BODY_CAP])))
        conn.commit()
    finally:
        conn.close()

def flows_list(path) -> list:
    path = Path(path)
    if not path.exists(): return []
    conn = _sqlar_open(path); conn.row_factory = sqlite3.Row
    try:
        return [dict(r) for r in conn.execute(
            "SELECT id,ts,action,method,host,port,url,status,process_id,req_len,resp_len"
            " FROM flows ORDER BY id").fetchall()]
    except sqlite3.Error:
        return []
    finally:
        conn.close()

def flows_get(path, fid) -> "dict | None":
    path = Path(path)
    if not path.exists(): return None
    conn = _sqlar_open(path); conn.row_factory = sqlite3.Row
    try:
        r = conn.execute("SELECT * FROM flows WHERE id=?", (fid,)).fetchone()
        return dict(r) if r else None
    except sqlite3.Error:
        return None
    finally:
        conn.close()


def has_flows(path) -> bool:
    path = Path(path)
    if not path.exists(): return False
    conn = _sqlar_open(path)
    try: return bool(conn.execute("SELECT EXISTS(SELECT 1 FROM flows)").fetchone()[0])
    except sqlite3.Error: return False
    finally: conn.close()


# ════════════════════════════════════════════════════════════════════════════
#  Session model & box metadata helpers
# ════════════════════════════════════════════════════════════════════════════
# process_list, sqlar_meta_get/set, _all_box_ids, mint_box_id, as_box_id,
# sweep_orphan_pools, process_roots, sqlar_writer_id, process_env, root_cmd —
# box-id/meta/process helpers used by Supervisor, the CLI commands, and the UI.
def process_list(path) -> list:
    """[(id, tgid, ppid, exe, argv-list)] for the box's process table."""
    path = Path(path)
    if not path.exists(): return []
    conn = _sqlar_open(path)
    try:
        rows = conn.execute("SELECT id,tgid,ppid,exe,argv FROM process "
                            "ORDER BY id").fetchall()
    except sqlite3.Error: return []
    finally: conn.close()
    out = []
    for pid, tgid, ppid, exe, argv in rows:
        try: av = json.loads(argv) if argv else []
        except (ValueError, TypeError): av = []
        out.append((pid, tgid, ppid, exe or "", av))
    return out

def sqlar_meta_get(path, key: str) -> "str | None":
    """Read one small per-box meta string (e.g. the box's display `name`) from a
    sqlar on disk. None if absent."""
    path = Path(path)
    if not path.exists(): return None
    conn = _sqlar_open(path)
    try:
        row = conn.execute("SELECT value FROM meta WHERE key=?", (key,)).fetchone()
    except sqlite3.Error: row = None
    finally: conn.close()
    return row[0] if row else None

def sqlar_meta_set(path, key: str, value: str) -> None:
    conn = _sqlar_open(path)
    try:
        conn.execute("INSERT INTO meta(key,value) VALUES(?,?)"
                     " ON CONFLICT(key) DO UPDATE SET value=excluded.value",
                     (key, str(value)))
        conn.commit()
    finally: conn.close()

def _all_box_ids() -> set:
    """The set of integer box_ids that currently exist on disk: every <n>.sqlar stem
    plus every live/<n> backing dir. box_id IS the on-disk identity (file/dir stem),
    so this is a pure scan — no meta read needed."""
    out: set = set()
    sh = state_home()
    if sh.exists():
        for p in sh.glob("*.sqlar"):
            try: out.add(int(p.stem))
            except ValueError: pass
    lh = live_home()
    if lh.exists():
        for d in lh.iterdir():
            try: out.add(int(d.name))
            except ValueError: pass
    return out

def mint_box_id() -> int:
    """Mint a fresh, never-before-used box_id: max(existing on disk)+1.

    INVARIANT: exactly ONE process (the UI's Supervisor) ever calls this function.
    The scan-then-assign is therefore race-free without a cross-process lock.
    If that invariant were violated (e.g. two UI instances), collisions could occur.
    Cross-process locking is intentionally out of scope; the ChannelServer already
    prevents a second UI instance from starting (run_ui() checks ui_is_running()
    before launching). Called EAGERLY at box creation so a path is always derivable
    from the id."""
    return max(_all_box_ids(), default=0) + 1

def as_box_id(box_id) -> int:
    """box_id IS the identity now (the sqlar/backing stem), so this is the identity
    cast itself. Kept as a one-liner so the many call sites that pass a box's key and
    want its int read unchanged."""
    return int(box_id)

def sweep_orphan_pools() -> None:
    """Drop pool dirs whose box is gone: any blob/<box_id> with no surviving sqlar
    claiming that id (the box's sqlar was deleted/applied). Runs at UI startup beside
    the overlay-orphan sweep; cheap when the pool is empty."""
    root = pool_home()
    if not root.exists(): return
    live = set(_all_box_ids())
    for d in root.iterdir():
        if not d.is_dir(): continue
        try: bid = int(d.name)
        except ValueError: continue
        if bid not in live:
            rm_rf(d)

def process_roots(path) -> set:
    """The box's hierarchy-root tgids (process.root=1) read from a sqlar on disk —
    the finished-box counterpart to Index.roots()."""
    path = Path(path)
    if not path.exists(): return set()
    conn = _sqlar_open(path)
    try:
        return {r[0] for r in conn.execute("SELECT tgid FROM process WHERE root=1")}
    except sqlite3.Error: return set()
    finally: conn.close()

def sqlar_writer_id(path, rel) -> "int | None":
    """The process-table row id that LAST wrote `rel` (the sqlar `last_writer` tag),
    or None. Finished-box path: read straight from the consolidated single sqlar."""
    path = Path(path)
    if not path.exists(): return None
    conn = _sqlar_open(path)
    try:
        row = conn.execute("SELECT last_writer FROM sqlar WHERE name=?",
                            (rel,)).fetchone()
    except sqlite3.Error: row = None
    finally: conn.close()
    return row[0] if row and row[0] is not None else None

def process_env(path, proc_id) -> dict:
    """The deduped environment for one process row (resolved via env_id)."""
    path = Path(path)
    if not path.exists(): return {}
    conn = _sqlar_open(path)
    try:
        row = conn.execute(
            "SELECT env.env FROM process JOIN env ON process.env_id=env.id"
            " WHERE process.id=?", (proc_id,)).fetchone()
    except sqlite3.Error: row = None
    finally: conn.close()
    if not row or not row[0]: return {}
    try: return json.loads(row[0])
    except (ValueError, TypeError): return {}

def root_cmd(sid: str) -> list:
    """The box's command: argv of its FIRST root process row (process.root=1, lowest
    id) in <sid>.sqlar. [] if no such row exists. The persisted single source of truth,
    surviving after the runner exits; a re-run box has several roots — this is the
    original launch's command."""
    path = sqlar_path(sid)
    if not path.exists(): return []
    conn = _sqlar_open(path)
    try:
        row = conn.execute("SELECT argv FROM process WHERE root=1"
                           " ORDER BY id LIMIT 1").fetchone()
    except sqlite3.Error: row = None
    finally: conn.close()
    if not row or not row[0]: return []
    try: return list(json.loads(row[0]))
    except (ValueError, TypeError): return []


#: [b]Filesystem / overlay model[/]
#: Each slopbox sees a [b]copy-on-write overlay[/] of the host filesystem ([cyan]/[/]) as its root.
#: Reads fall through to the real host unless the box has written that path.
#: Writes are captured in the box's private overlay — the host is [b]never touched[/] until you
#: explicitly [cyan]apply[/] changes. Every write is recorded in a per-box [cyan].sqlar[/] database
#: (an SQLite archive) so the UI can show exactly what changed and let you review diffs.
#: A box's identity is its stable integer [cyan]box_id[/] — renaming a box changes only its
#: display label, never its backing data or id.

# ════════════════════════════════════════════════════════════════════════════
#  Overlay engine — pyfuse3 copy-on-write overlay, multiplexed per box
# ════════════════════════════════════════════════════════════════════════════
# ONE pyfuse3 mount (see OverlayMount). Its synthetic root lists one subfolder
# <box_id> per live box; <mnt>/<box_id>/… is a merged overlay of lower=/ plus
# that box's private state (files in pool, dirs/symlinks in Index rows). Inode
# numbers span the whole mount; each inode carries its (sid, rel) so one
# Operations object serves every box.
# No user namespaces, no /dev/fuse fd-passing, no inner mount/pivot_root —
# so the mount nests cleanly inside containers (toolbox etc.) with nothing
# beyond fusermount3. bwrap binds the <box_id> subfolder as the box's root.

# Selected env keys captured per writer (provenance).
_PROV_ENV_KEYS = ("USER", "PWD", "SSH_CONNECTION", "TERM", "_")

FICLONE = 0x40049409   # _IOW(0x94, 9, int) — btrfs/xfs reflink ioctl

# ── fd-based mount primitives (Linux 5.2+, x86-64) ──────────────────────────
# Used by the NESTED LAUNCH mechanism: the UI creates an open_tree "mount fd" for
# the child overlay and ships it via SCM_RIGHTS to the nested runner.  The runner
# calls move_mount to graft it at a known path inside the parent box, then passes
# that path to bwrap -- avoiding any path resolution of the sibling overlay tree.
import ctypes as _ctypes
_LIBC: "_ctypes.CDLL | None" = None

def _libc() -> "_ctypes.CDLL":
    global _LIBC
    if _LIBC is None:
        _LIBC = _ctypes.CDLL("libc.so.6", use_errno=True)
        _libc_init_sigs(_LIBC)
    return _LIBC

def _libc_init_sigs(lib) -> None:
    """Set argtypes/restype on each named libc wrapper once (not every call)."""
    for name, restype, argtypes in (
        ("open_tree",  _ctypes.c_int,
         (_ctypes.c_int, _ctypes.c_char_p, _ctypes.c_uint)),
        ("move_mount", _ctypes.c_int,
         (_ctypes.c_int, _ctypes.c_char_p, _ctypes.c_int,
          _ctypes.c_char_p, _ctypes.c_uint)),
        ("umount2",    _ctypes.c_int,
         (_ctypes.c_char_p, _ctypes.c_int)),
    ):
        fn = getattr(lib, name, None)
        if fn is not None:
            fn.restype = restype
            fn.argtypes = argtypes

# open_tree/move_mount/umount2 are reached through glibc's NAMED wrappers when present
# (glibc >= 2.36 for the first two; umount2 forever) — those resolve the correct per-arch
# syscall number for us. Only on older glibc do we fall back to raw syscall() with numbers
# from the asm-generic table (shared by x86-64/arm64/riscv64 — the new mount-API syscalls
# were assigned the same numbers there).
_OPEN_TREE_NR  = {"x86_64": 428, "aarch64": 428, "riscv64": 428}
_MOVE_MOUNT_NR = {"x86_64": 429, "aarch64": 429, "riscv64": 429}

_OPEN_TREE_CLONE  = 1
_AT_EMPTY_PATH    = 0x1000
_AT_FDCWD         = -100
_MOVE_MOUNT_F_EMPTY_PATH = 0x00000004
_MNT_DETACH       = 0x00000002


def _open_tree_fd(dir_fd: int) -> int:
    """open_tree(dir_fd, "", OPEN_TREE_CLONE | AT_EMPTY_PATH) → mount-fd.

    Returns a *mount fd* that can be passed via SCM_RIGHTS and grafted elsewhere
    with move_mount.  The fd does NOT carry a path — it represents the filesystem
    subtree rooted at dir_fd regardless of whether that path is accessible in the
    caller's mount namespace.  Returns -1 on failure (old kernel, EPERM, etc.)."""
    try:
        libc = _libc()
        fn = getattr(libc, "open_tree", None)
        if fn is not None:                                  # arch-correct named wrapper
            fd = fn(dir_fd, b"", _OPEN_TREE_CLONE | _AT_EMPTY_PATH)
        else:                                               # pre-2.36 glibc fallback
            nr = _OPEN_TREE_NR.get(os.uname().machine)
            if nr is None:
                return -1
            fd = libc.syscall(_ctypes.c_long(nr), _ctypes.c_int(dir_fd),
                              _ctypes.c_char_p(b""),
                              _ctypes.c_uint(_OPEN_TREE_CLONE | _AT_EMPTY_PATH))
        return int(fd) if int(fd) >= 0 else -1
    except Exception:
        return -1


def _move_mount(tree_fd: int, dest: str) -> int:
    """move_mount(tree_fd, "", AT_FDCWD, dest, MOVE_MOUNT_F_EMPTY_PATH).

    Grafts the subtree represented by tree_fd (obtained via _open_tree_fd) at
    dest.  dest must be an existing empty directory in the current mount namespace.
    Returns 0 on success, errno (>0) on failure."""
    try:
        libc = _libc()
        fn = getattr(libc, "move_mount", None)
        if fn is not None:                                  # arch-correct named wrapper
            ret = fn(tree_fd, b"", _AT_FDCWD, dest.encode(),
                     _MOVE_MOUNT_F_EMPTY_PATH)
        else:                                               # pre-2.36 glibc fallback
            nr = _MOVE_MOUNT_NR.get(os.uname().machine)
            if nr is None:
                return errno.ENOSYS
            ret = libc.syscall(_ctypes.c_long(nr), _ctypes.c_int(tree_fd),
                               _ctypes.c_char_p(b""), _ctypes.c_int(_AT_FDCWD),
                               _ctypes.c_char_p(dest.encode()),
                               _ctypes.c_uint(_MOVE_MOUNT_F_EMPTY_PATH))
        return 0 if int(ret) >= 0 else _ctypes.get_errno()
    except Exception:
        return errno.ENOSYS


def _lazy_umount(path: str) -> None:
    """MNT_DETACH umount via the umount2(2) named wrapper (arch-correct), best-effort."""
    try:
        libc = _libc()
        fn = getattr(libc, "umount2", None)
        if fn is None:
            return
        fn(path.encode(), _MNT_DETACH)
    except Exception:
        pass


# ── provenance & policy ──────────────────────────────────────────────────────
def _proc_status_field(pid: int, field: str) -> "int | None":
    """One integer field (e.g. Tgid, PPid) from /proc/<pid>/status. None if gone."""
    try:
        with open(f"/proc/{pid}/status", "rb") as f:
            for ln in f:
                if ln.startswith(field.encode() + b":"):
                    return int(ln.split()[1])
    except (OSError, ValueError, IndexError):
        pass
    return None

def tgid_of(pid: int) -> int:
    """Resolve a FUSE ctx.pid (a thread id) to its thread-group id via
    /proc/<pid>/status Tgid; falls back to pid itself if unreadable."""
    t = _proc_status_field(pid, "Tgid")
    return t if t is not None else int(pid)


def _parse_proc_stat(pid: int) -> "tuple[int, int]":
    """Parse /proc/<pid>/stat and return (ppid, start_time).  Both fields are 0 on
    any error.  The comm field may contain spaces and parentheses, so the split is
    anchored after the last ')' (rfind) — the same dance used by both callers."""
    try:
        with open(f"/proc/{pid}/stat", "rb") as f:
            st = f.read()
        rp = st.rfind(b")")
        rest = st[rp + 2:].split() if rp >= 0 else []
        ppid = int(rest[1]) if len(rest) >= 2 else 0
        start_time = int(rest[19]) if len(rest) >= 20 else 0
        return ppid, start_time
    except (OSError, ValueError):
        return 0, 0


def _proc_start_time(pid: int) -> int:
    """The process's start time (field 22 of /proc/<pid>/stat, jiffies since boot).
    0 if unreadable. Cheap and stable for a live process; used to detect PID reuse so
    a provenance cache entry is not reused across two different processes (LOW-1)."""
    return _parse_proc_stat(pid)[1]


def read_provenance(pid: int, full_env: bool = False) -> dict:
    """Best-effort writer provenance from host /proc/<pid>. Read SYNCHRONOUSLY from
    the write handler while the caller is still blocked (and thus still in /proc).
    Every field is best-effort — a vanished pid yields zeros/empties, never raises
    (/proc reads are the one place best-effort OSError is acceptable). full_env
    captures the whole environment (for the process table when tracing is on);
    otherwise only the small _PROV_ENV_KEYS subset is kept."""
    info = dict(pid=int(pid), ppid=0, exe="", argv=[], env={}, start_time=0)
    base = f"/proc/{pid}"
    try:
        with open(f"{base}/cmdline", "rb") as f:
            raw = f.read()
        info["argv"] = [p.decode("utf-8", "surrogateescape")
                        for p in raw.split(b"\x00") if p]
    except OSError: pass
    try: info["exe"] = os.readlink(f"{base}/exe")
    except OSError: pass
    # Parse /proc/<pid>/stat via the shared helper (comm may contain spaces/parens).
    ppid, start_time = _parse_proc_stat(pid)
    info["ppid"] = ppid; info["start_time"] = start_time
    try:
        with open(f"{base}/environ", "rb") as f:
            env_raw = f.read()
        env = {}
        for kv in env_raw.split(b"\x00"):
            if b"=" not in kv: continue
            k, _, v = kv.partition(b"=")
            ks = k.decode("utf-8", "surrogateescape")
            if full_env or ks in _PROV_ENV_KEYS:
                env[ks] = v.decode("utf-8", "surrogateescape")
        info["env"] = env
    except OSError: pass
    return info


def policy_check(box_id: str, prov: dict, path: str, op: str) -> str:
    """THE policy hook. Called once per mutating overlay op (create/write/unlink/
    rename/setattr/…) with the box id, the writer's provenance (pid/exe/argv),
    the overlay-relative path, and the operation name. Returns "allow" or "deny".

    For v1 this always allows. It exists as the single, obvious seam where
    per-write policy — a file-rules check, or an interactive UI prompt exactly
    like the network-approval flow — would attach. It runs ON the trio serving
    thread while the writer is blocked, so a future prompt would hand off to the
    UI thread and await, just like Supervisor.approval_request does for connections."""
    return "allow"


# ── copy helpers ─────────────────────────────────────────────────────────────
def reflink_or_copy(src_fd: int, dst_fd: int) -> str:
    """Clone src into dst. Tries FICLONE (O(1) on btrfs/xfs/bcachefs); on any of the
    not-supported errnos falls back to copy_file_range, then to a 1 MiB read/write
    loop (always correct). Returns 'reflink' or 'copy'. Never silently no-ops — a
    failure to materialize content is a correctness bug."""
    try:
        fcntl.ioctl(dst_fd, FICLONE, src_fd)
        return "reflink"
    except OSError as e:
        if e.errno not in (errno.ENOTSUP, errno.EOPNOTSUPP, errno.EXDEV,
                           errno.EINVAL, errno.EPERM):
            raise
    # plain copy
    os.lseek(src_fd, 0, os.SEEK_SET); os.lseek(dst_fd, 0, os.SEEK_SET)
    try:
        st = os.fstat(src_fd); remaining = st.st_size
        while remaining > 0:
            n = os.copy_file_range(src_fd, dst_fd, remaining)
            if n == 0: break
            remaining -= n
        if remaining == 0:
            os.lseek(dst_fd, 0, os.SEEK_SET); os.lseek(src_fd, 0, os.SEEK_SET)
            return "copy"
    except (OSError, AttributeError):
        pass
    os.lseek(src_fd, 0, os.SEEK_SET); os.lseek(dst_fd, 0, os.SEEK_SET)
    os.ftruncate(dst_fd, 0)
    while True:
        chunk = os.read(src_fd, 1 << 20)
        if not chunk: break
        off = 0
        while off < len(chunk):
            off += os.write(dst_fd, chunk[off:])
    os.lseek(dst_fd, 0, os.SEEK_SET); os.lseek(src_fd, 0, os.SEEK_SET)
    return "copy"


def _kind_of_mode(mode: int) -> str:
    if stat_mod.S_ISCHR(mode): return "whiteout"
    if stat_mod.S_ISDIR(mode): return "dir"
    if stat_mod.S_ISLNK(mode): return "symlink"
    return "file"


# ── Index (in-RAM mirror + per-box sqlar write-through) ─────────────────────
class Index:
    """The single per-instance database (sqlar_path(sid)) + a write-through RAM
    mirror. There is exactly ONE sqlite file per box; this class is the set of
    operations on it that the FUSE layer needs — there is no separate index.db.

    On every mutating FUSE op the entry row is upserted into the `sqlar` table
    right then (data = NULL for files: the bytes are in the overlay upper and the
    NULL blob is filled in during consolidate()). The hot read paths
    (lookup/getattr/readdir) touch ONLY the RAM mirror; the db is written on
    mutation and read for provenance / process detail. Opened
    check_same_thread=False — the serve loop owns all mutations (under
    self._lock); the UI thread reads concurrently and relies on the lock for
    SQLite safety and GIL-protected dict reads for the RAM mirror.

    A box's process tracing (when -t is on) records each unique tgid into the
    `process` table here, deduping its environment via the `env` table; the
    process row id tags both modified file entries (the `writer` column) and
    network flows."""

    def __init__(self, backing: Path):
        self.backing = Path(backing)
        # The single db: state_home/<box_id>.sqlar. The box_id is the backing dir name.
        self.db_path = sqlar_path(self.backing.name)
        # Create the parent dir + the one schema (the single source of the schema).
        _sqlar_open(self.db_path).close()
        self._db = sqlite3.connect(str(self.db_path), check_same_thread=False)
        self._db.execute("PRAGMA journal_mode=WAL")
        self._db.execute("PRAGMA synchronous=NORMAL")
        self._proc_cache: dict = {}       # (tgid) -> process.id (this process only)
        self._prov_cache: dict = {}       # host pid -> provenance dict (hot-path cache)
        self._prov_by_proc: dict = {}     # process.id -> provenance dict
        # Live "active set": tgid -> last-seen monotonic, stamped every time the FUSE
        # serve thread or the relay path records/sees a tgid (in-memory only, NOT
        # persisted — the persistent `process` table keeps the full history). Reads
        # come from the UI thread; the dict is GIL-atomic like the other RAM mirrors.
        self._active: dict = {}           # tgid -> last-seen monotonic
        self._dead_since: dict = {}       # tgid -> first monotonic kill(0) saw it dead
        self._tracing = False             # -t: record the process table
        # The box's hierarchy ROOTS: the tgids of every `slopbox -- cmd` launch (one
        # per run; a re-run adds another). Newly-inserted process rows bubble up their
        # PPid chain until they reach a root, so the table stays one connected FOREST.
        # Authoritative source is the `process.root` column (loaded here, kept in sync
        # by process_from_prov); the sid's pid is no longer consulted as the boundary.
        self._roots: set = set()
        self._whiteouts: set = set()
        self._kinds: dict = {}
        self._opaque: set = set()
        self._targets: dict = {}          # rel -> symlink target bytes (RAM mirror)
        self._lock = threading.Lock()     # serialize SQLite + mirror mutations
        self._load_mirror()
        # Stable pool id == the box's identity == the backing dir / sqlar stem.
        self.box_id = int(self.backing.name)

    def set_tracing(self, on: bool) -> None:
        self._tracing = bool(on)

    def _load_mirror(self) -> None:
        for path, mode, opaque, sz, data in self._db.execute(
                "SELECT name, mode, opaque, sz, data FROM sqlar"):
            kind = _kind_of_mode(mode)
            if kind == "whiteout":
                self._whiteouts.add(path)
            else:
                self._kinds[path] = kind
            if kind == "symlink" and data is not None:
                blob = bytes(data)
                self._targets[path] = (blob if len(blob) == sz
                                       else zlib.decompress(blob))
            if opaque:
                self._opaque.add(path)
        # Hierarchy roots recorded by earlier runs (PPid-bubbling boundary).
        for (tgid,) in self._db.execute(
                "SELECT tgid FROM process WHERE root=1"):
            self._roots.add(tgid)

    @staticmethod
    def _row_mode(kind, mode) -> int:
        if kind == "whiteout": return stat_mod.S_IFCHR
        return int(mode)

    # ── fast RAM accessors (hot path) ───────────────────────────────────────
    def has_overlay_state(self) -> bool:
        return bool(self._whiteouts or self._kinds or self._opaque)

    def kind_of(self, rel: str) -> "str | None":
        if rel in self._whiteouts: return "whiteout"
        return self._kinds.get(rel)

    def symlink_target(self, rel: str) -> "bytes | None":
        """The symlink target bytes for `rel`, or None if rel is not a symlink in the
        mirror. Served straight from RAM (no disk readlink)."""
        if self._kinds.get(rel) != "symlink": return None
        return self._targets.get(rel)

    def is_opaque(self, rel: str) -> bool:
        return rel in self._opaque

    def hidden_by_opaque(self, rel: str) -> bool:
        if not self._opaque: return False
        parts = rel.split("/") if rel else []
        for i in range(len(parts)):
            anc = "/".join(parts[:i])
            if anc in self._opaque: return True
        return False

    def all_kinds(self) -> tuple:
        """Snapshot of every path with a (non-whiteout) index kind. UI-thread read of
        the RAM mirror; GIL-atomic like the other accessors."""
        return tuple(self._kinds.keys())

    def children_of(self, rel: str) -> tuple:
        """Index entries that are DIRECT children of dir `rel`, for the merged
        readdir scan: (whiteouts, present). `whiteouts` is the set of child names
        that whiteout a lower entry (remove from the listing); `present` is the
        set of child names that have an index kind (ensure present in the
        listing). Names only — caller resolves each via kind_of/_resolve_st."""
        prefix = (rel + "/") if rel else ""
        whiteouts, present = set(), set()
        for wp in self._whiteouts:
            if wp.startswith(prefix) and "/" not in wp[len(prefix):]:
                whiteouts.add(wp[len(prefix):])
        for kp in self._kinds:
            if kp.startswith(prefix) and kp != rel and "/" not in kp[len(prefix):]:
                present.add(kp[len(prefix):])
        return whiteouts, present

    # ── provenance / process table ──────────────────────────────────────────
    def _prov_key(self, pid: int) -> tuple:
        """Cache key that survives PID reuse: (pid, /proc start_time)."""
        return (pid, _proc_start_time(pid))

    def _touch_active(self, tgid: int) -> None:
        """Re-stamp a tgid in the active set (last-seen monotonic) and keep the set
        bounded: when it crosses the cap, drop the oldest-seen dead entries so RAM
        stays bounded even if the proc pane is never opened to drive retirement.
        Serve/relay-thread write; GIL-atomic dict ops (Index threading contract)."""
        now = time.monotonic()
        self._active[tgid] = now
        if len(self._active) > _ACTIVE_CAP:
            overflow = len(self._active) - _ACTIVE_CAP
            for t, _seen in _heapq.nsmallest(
                    overflow + 16, self._active.items(), key=lambda kv: kv[1]):
                if len(self._active) <= _ACTIVE_CAP: break
                if t == tgid or _pid_alive(t): continue
                self._active.pop(t, None); self._dead_since.pop(t, None)

    def writer_for(self, pid: int) -> int:
        """Resolve the FUSE ctx.pid (a TID) to its tgid and return that tgid's
        process-table row id, inserting it (and its deduped env) on first sight.
        Always returns an id even if /proc is gone. The id tags the file entry."""
        tgid = tgid_of(pid)
        self._touch_active(tgid)                 # active-set: re-stamp on every sight
        cached = self._proc_cache.get(tgid)
        if cached is not None: return cached
        # When tracing, capture the FULL environment for the process table; the
        # subset-cached provenance_of() is enough otherwise. Resolve the parent to
        # its tgid and hand off to the single insert/dedup path (which also bubbles
        # the PPid chain up to the box root so the table stays one connected tree).
        prov = read_provenance(pid, full_env=True) if self._tracing \
            else self.provenance_of(pid)
        ppid_tgid = tgid_of(prov["ppid"]) if prov.get("ppid") else 0
        return self.process_from_prov(dict(tgid=tgid, ppid=ppid_tgid,
                                           exe=prov["exe"], argv=prov["argv"],
                                           env=prov.get("env") or {})) or tgid

    def process_from_prov(self, prov: dict, root: bool = False) -> "int | None":
        """Insert/dedup a process row from a provenance dict (tgid/ppid/exe/argv/env,
        all HOST-namespace — resolved by RelayServer from the --inner pidfd via host
        /proc, consistent with the FUSE path) and return its row id. Returns None if no
        tgid was supplied. Same process-table + env-crc32 dedup as writer_for. `root`
        marks this tgid as a hierarchy root (a `slopbox -- cmd` launch) — the PPid
        bubbling boundary; it is also remembered in the RAM `_roots` mirror."""
        tgid = int(prov.get("tgid") or 0)
        if not tgid: return None
        self._touch_active(tgid)                  # active-set: re-stamp on every sight
        if root:
            self._roots.add(tgid)
        cached = self._proc_cache.get(tgid)
        if cached is not None:
            if root:                              # promote an already-recorded row
                with self._lock:
                    self._db.execute("UPDATE process SET root=1 WHERE tgid=?", (tgid,))
                    self._db.commit()
            return cached
        ppid_tgid = int(prov.get("ppid") or 0)
        exe = prov.get("exe") or ""
        argv = prov.get("argv") or []
        env = prov.get("env") or {}
        with self._lock:
            eid = None
            if self._tracing:
                env_json = json.dumps(env, sort_keys=True)
                env_hash = hashlib.sha256(env_json.encode()).hexdigest()
                self._db.execute("INSERT OR IGNORE INTO env(hash,env) VALUES(?,?)",
                                 (env_hash, env_json))
                eid = self._db.execute("SELECT id FROM env WHERE hash=?",
                                       (env_hash,)).fetchone()[0]
            cur = self._db.execute(
                "INSERT OR IGNORE INTO process(tgid,ppid,exe,argv,env_id,root)"
                " VALUES(?,?,?,?,?,?)",
                (tgid, ppid_tgid, exe, json.dumps(argv), eid, 1 if root else 0))
            inserted = cur.rowcount > 0   # newly recorded vs. already present
            pid_row = self._db.execute("SELECT id FROM process WHERE tgid=?",
                                       (tgid,)).fetchone()[0]
            self._db.commit()
        self._proc_cache[tgid] = pid_row
        self._prov_by_proc[pid_row] = dict(pid=tgid, ppid=ppid_tgid, exe=exe, argv=argv)
        # A root is its own boundary; never bubble above it into the runner's ancestry.
        # Pass through depth/seen-set if present (injected by _bubble_parent to carry
        # the cap across the mutual recursion).
        if inserted and not root:
            self._bubble_parent(tgid, ppid_tgid,
                                _depth=int(prov.get("_bubble_depth") or 0),
                                _seen=prov.get("_bubble_seen") or None)
        return pid_row

    def _bubble_parent(self, tgid: int, ppid: int,
                       _depth: int = 0, _seen: "set | None" = None) -> None:
        """Record this row's parent (and so its whole PPid chain) so the per-box
        process table forms ONE tree rooted at the sid's host pid. Runs only when a
        row was genuinely new — the dedup short-circuit of process_from_prov stops
        the recursion at the first ancestor already present (the root row, recorded
        at register, is always present). Best-effort: a failed ancestor /proc read links
        a minimal row and stops, never raises.
        STOPS at: a root tgid (boundary — never walk above a `slopbox -- cmd` launch
        into the runner's own host ancestry), ppid<=1 (init), any already-recorded
        parent, or a depth/cycle cap (64 levels / seen-set, matching _lower_has /
        display_path) so a pathological or cyclic process tree cannot overflow the stack."""
        if _depth >= 64: return                  # depth cap — same limit as _lower_has
        if _seen is None: _seen = set()
        if tgid in _seen: return                 # cycle guard
        _seen.add(tgid)
        if tgid in self._roots: return           # a root row is the boundary
        if ppid <= 1: return                     # reached init; no system procs
        if ppid in self._proc_cache: return      # parent already linked (roots always are)
        try:
            pprov = read_provenance(ppid, full_env=self._tracing)
        except OSError:
            pprov = dict(ppid=0, exe="", argv=[], env={})
        # A live parent yields its own ppid (walk continues up); a vanished parent
        # yields ppid 0 — a minimal row is still linked (tgid=ppid), then the next
        # frame stops at ppid<=1 since the grandparent is unreachable.
        parent = dict(tgid=tgid_of(ppid) or ppid,
                      ppid=tgid_of(pprov.get("ppid")) if pprov.get("ppid") else 0,
                      exe=pprov.get("exe") or "", argv=pprov.get("argv") or [],
                      env=pprov.get("env") or {},
                      _bubble_depth=_depth + 1, _bubble_seen=_seen)
        self.process_from_prov(parent)           # recurses up; dedup ends the walk

    def proc_info(self, tgid: int) -> "tuple | None":
        """(ppid, exe, argv-list) for ANY recorded tgid, in or out of the active set —
        the tree builder uses it to resolve connector ancestors. RAM-only read of the
        GIL-atomic caches (Index threading contract): _proc_cache maps tgid→row id and
        _prov_by_proc maps row id→provenance. None if the tgid was never recorded."""
        pid_row = self._proc_cache.get(tgid)
        prov = self._prov_by_proc.get(pid_row) if pid_row is not None else None
        if prov is None: return None
        return prov["ppid"], prov["exe"] or "", list(prov["argv"])

    def roots(self) -> set:
        """The box's hierarchy-root tgids (the PPid-bubbling / tree-walk boundary).
        GIL-atomic read of the RAM mirror (Index threading contract)."""
        return set(self._roots)

    def live_processes(self) -> list:
        """htop-style live view of the box's ACTIVE SET: the recently-seen tgids only,
        decorated from the in-memory caches (NO full-table scan, cost O(active set)).
        Returns [(id, tgid, ppid, exe, argv-list, alive, dead)] where `alive` is a
        kill(0) liveness probe over just the active set and `dead` flags a row that
        kill(0) reports gone but is still inside its retirement grace window. A tgid
        first seen dead is stamped and kept (highlighted) for _PROC_RETIRE_S, then
        pruned from the active set — the persistent `process` table is untouched.
        UI-thread read of the GIL-atomic active-set/cache dicts (Index contract)."""
        now = time.monotonic()
        out = []
        for tgid in list(self._active):
            alive = _pid_alive(tgid)
            if alive:
                self._dead_since.pop(tgid, None)
            else:
                first = self._dead_since.get(tgid)
                if first is None:
                    self._dead_since[tgid] = first = now
                if now - first >= _PROC_RETIRE_S:    # retire: drop from the live pane
                    self._active.pop(tgid, None)
                    self._dead_since.pop(tgid, None)
                    continue
            pid_row = self._proc_cache.get(tgid)
            prov = self._prov_by_proc.get(pid_row) if pid_row is not None else None
            if prov is not None:
                ppid, exe, argv = prov["ppid"], prov["exe"], prov["argv"]
            else:
                ppid, exe, argv = 0, "", []
            out.append((pid_row if pid_row is not None else tgid, tgid, ppid,
                        exe or "", list(argv), alive, not alive))
        out.sort(key=lambda r: r[1])
        return out

    def add_flow(self, fl: dict) -> None:
        """Append one completed flow to the box's single sqlar via THIS handle — the
        one writer (under self._lock), so a flow write never opens a second handle to
        the WAL db and never races the serve thread into SQLITE_BUSY."""
        rb = fl.get("req_body") or b""; pb = fl.get("resp_body") or b""
        with self._lock:
            self._db.execute(
                "INSERT INTO flows(ts,action,method,scheme,host,port,url,status,process_id,"
                "req_headers,req_len,req_body,resp_headers,resp_len,resp_body)"
                " VALUES(?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)",
                (fl.get("ts", time.time()), fl.get("action", ""), fl.get("method", ""),
                 fl.get("scheme", ""), fl.get("host", ""), fl.get("port", 0),
                 fl.get("url", ""), fl.get("status", 0), fl.get("process_id"),
                 _hdr_text(fl.get("req_headers")), len(rb),
                 sqlite3.Binary(rb[:_FLOW_BODY_CAP]),
                 _hdr_text(fl.get("resp_headers")), len(pb),
                 sqlite3.Binary(pb[:_FLOW_BODY_CAP])))
            self._db.commit()

    def provenance_of(self, pid: int) -> dict:
        """Provenance for a pid, cached per (pid, start_time) for this process."""
        key = self._prov_key(pid)
        cached = self._prov_cache.get(key)
        if cached is not None: return cached
        prov = read_provenance(pid)
        self._prov_cache[key] = prov
        return prov

    # ── mutations (write-through; upsert into the single sqlar) ──────────────
    def _upsert(self, path, mode, writer_id, opaque) -> None:
        """Upsert one entry row with data=NULL (filled at consolidate). opaque None
        means leave as-is on update; writer_id None means leave as-is on update.
        `writer` records the FIRST process to touch the path (set once); `last_writer`
        records the MOST RECENT (advanced on every named write)."""
        # opaque=None → NULL here so the ON CONFLICT clause can distinguish
        # "leave as-is" (NULL → COALESCE keeps existing) from "set to 0" (0).
        # COALESCE(?,0) in the INSERT VALUES defaults a fresh row to 0 when opaque
        # is None (NULL), matching the original behaviour.
        op = int(opaque) if opaque is not None else None
        self._db.execute(
            "INSERT INTO sqlar(name,mode,mtime,sz,data,opaque,writer,last_writer)"
            " VALUES(?,?,0,0,NULL,COALESCE(?,0),?,?)"
            " ON CONFLICT(name) DO UPDATE SET"
            "  mode=excluded.mode,"
            "  opaque=COALESCE(excluded.opaque, sqlar.opaque),"
            "  writer=COALESCE(sqlar.writer, excluded.writer),"
            "  last_writer=COALESCE(excluded.last_writer, sqlar.last_writer)",
            (path, int(mode), op, writer_id, writer_id))

    def set_entry(self, path, kind, mode, writer_id, op,
                  detail: str = "", opaque=None, target=None,
                  mtime_ns=None) -> None:
        with self._lock:
            self._upsert(path, self._row_mode(kind, mode), writer_id, opaque)
            if kind == "symlink" and target is not None:
                # Put the target into the row IMMEDIATELY (deflated, sz=len) so the
                # row is the single source of truth — no fold-at-consolidate desync.
                tgt = target if isinstance(target, (bytes, bytearray)) else \
                    str(target).encode("utf-8", "surrogateescape")
                data, sz = _sqlar_deflate(bytes(tgt))
                m = int(mtime_ns) if mtime_ns is not None else 0
                self._db.execute(
                    "UPDATE sqlar SET sz=?, data=?, mtime=? WHERE name=?",
                    (sz, sqlite3.Binary(data), m, path))
            elif mtime_ns is not None:
                # Dir (or any non-symlink) row: record mtime so the synthesized stat
                # served from the mirror carries a stable timestamp.
                self._db.execute("UPDATE sqlar SET mtime=? WHERE name=?",
                                 (int(mtime_ns), path))
            self._db.commit()
            # RAM mirror — mutate under the SAME lock.
            if kind == "whiteout":
                self._whiteouts.add(path); self._kinds.pop(path, None)
                self._targets.pop(path, None)
            else:
                self._kinds[path] = kind; self._whiteouts.discard(path)
                if kind == "symlink":
                    if target is not None:
                        self._targets[path] = bytes(tgt)
                else:
                    self._targets.pop(path, None)
            if opaque is not None:
                if opaque: self._opaque.add(path)
                else: self._opaque.discard(path)

    def del_entry(self, path, op: str = "del", writer_id=None) -> None:
        with self._lock:
            self._db.execute("DELETE FROM sqlar WHERE name=?", (path,))
            self._db.commit()
            self._whiteouts.discard(path); self._kinds.pop(path, None)
            self._opaque.discard(path); self._targets.pop(path, None)

    def row_id(self, rel: str) -> "int | None":
        """The sqlar rowid for `rel` — names the blob in the pool."""
        with self._lock:
            row = self._db.execute(
                "SELECT rowid FROM sqlar WHERE name=?", (rel,)).fetchone()
        return row[0] if row else None

    def rename_row(self, old: str, new: str, writer_id=None) -> None:
        """Single-row in-place rename: preserves rowid (and thus blob address).
        Deletes any pre-existing row at `new`, then renames `old`->>`new` in-place.
        Updates the RAM mirror accordingly."""
        with self._lock:
            # drop any pre-existing entry at the destination
            self._db.execute("DELETE FROM sqlar WHERE name=?", (new,))
            # rename in-place (rowid preserved)
            if writer_id is not None:
                self._db.execute(
                    "UPDATE sqlar SET name=?, last_writer=? WHERE name=?",
                    (new, writer_id, old))
            else:
                self._db.execute(
                    "UPDATE sqlar SET name=? WHERE name=?", (new, old))
            self._db.commit()
            # mirror: move old -> new, dropping any prior new
            for s in (self._whiteouts, self._opaque):
                had = new in s; s.discard(new)
                if old in s: s.discard(old); s.add(new)
                elif had: pass  # old not present; new was, now gone — correct
            kind = self._kinds.pop(new, None)  # drop any pre-existing new kind
            old_kind = self._kinds.pop(old, None)
            if old_kind is not None:
                self._kinds[new] = old_kind
            # move the symlink target alongside the kind (drop any pre-existing new)
            self._targets.pop(new, None)
            old_tgt = self._targets.pop(old, None)
            if old_tgt is not None:
                self._targets[new] = old_tgt

    def prune_subtree(self, prefix: str) -> None:
        pref = prefix + "/"
        pref_hi = pref[:-1] + chr(ord(pref[-1]) + 1)  # prefix range upper bound
        with self._lock:
            # Free the pool blobs of any file rows under the prefix before dropping the
            # rows — otherwise the bytes leak (the row that named them is gone).
            for rid, mode in self._db.execute(
                    "SELECT rowid, mode FROM sqlar WHERE name >= ? AND name < ?",
                    (pref, pref_hi)).fetchall():
                if stat_mod.S_ISREG(mode):
                    try: blob_path(self.box_id, rid).unlink()
                    except OSError: pass
            self._db.execute("DELETE FROM sqlar WHERE name >= ? AND name < ?",
                             (pref, pref_hi))
            self._db.commit()
            for s in (self._whiteouts, self._opaque):
                for p in [p for p in s if p.startswith(pref)]: s.discard(p)
            for p in [p for p in self._kinds if p.startswith(pref)]:
                self._kinds.pop(p, None)
            for p in [p for p in self._targets if p.startswith(pref)]:
                self._targets.pop(p, None)

    def reparent(self, old: str, new: str, writer_id) -> None:
        """Rename the whole subtree old/ -> new/ IN PLACE (UPDATE name, keep rowids).
        Rowid stability is required so file blobs (addressed by box_id+rowid) never
        move on disk across a directory rename."""
        oldp = old + "/"; newp = new + "/"
        oldp_hi = oldp[:-1] + chr(ord(oldp[-1]) + 1)  # prefix range upper bound
        with self._lock:
            rows = self._db.execute(
                "SELECT rowid, name, mode, opaque FROM sqlar"
                " WHERE name >= ? AND name < ?",
                (oldp, oldp_hi)).fetchall()
            for rowid, path, mode, opaque in rows:
                np = newp + path[len(oldp):]
                # drop any pre-existing row at the destination (keep source rowid)
                self._db.execute("DELETE FROM sqlar WHERE name=? AND rowid!=?",
                                 (np, rowid))
                self._db.execute("UPDATE sqlar SET name=? WHERE rowid=?", (np, rowid))
            self._db.commit()
            for _rowid, path, mode, opaque in rows:
                np = newp + path[len(oldp):]
                kind = _kind_of_mode(mode)
                self._whiteouts.discard(path); self._kinds.pop(path, None)
                self._opaque.discard(path)
                # symlink target moves with the row (rowid + data preserved on disk);
                # carry the RAM mirror over too.
                old_tgt = self._targets.pop(path, None)
                self._targets.pop(np, None)
                # also drop any pre-existing mirror entry at the new name
                self._whiteouts.discard(np); self._kinds.pop(np, None)
                self._opaque.discard(np)
                if kind == "symlink" and old_tgt is not None:
                    self._targets[np] = old_tgt
                if kind == "whiteout": self._whiteouts.add(np)
                else: self._kinds[np] = kind
                if opaque: self._opaque.add(np)

    # ── consolidate accessors ────────────────────────────────────
    def deletions(self) -> list:
        with self._lock:
            snap = list(self._whiteouts)
        return sorted(snap)

    def opaque_dirs(self) -> list:
        with self._lock:
            snap = list(self._opaque)
        return sorted(snap)

    def writer_id_for(self, path: str) -> "int | None":
        """The process-table row id that LAST wrote `path` (the sqlar `last_writer`
        tag), or None. Keys the proc pane → used to focus the writer when jumping to
        procs. UI-thread read of the single sqlar handle: take _lock so it never races
        the serve thread's writes on the shared connection (Index threading contract)."""
        try:
            with self._lock:
                row = self._db.execute(
                    "SELECT last_writer FROM sqlar WHERE name=?", (path,)).fetchone()
        except sqlite3.Error: return None
        return row[0] if row and row[0] is not None else None

    def writer_provenance(self, path: str) -> "dict | None":
        # No lock: consolidate-only precondition — called post-teardown with the box
        # dead and the serve thread stopped, so there is no concurrent writer.
        cur = self._db.execute(
            "SELECT last_writer FROM sqlar WHERE name=?", (path,)).fetchone()
        if not cur or cur[0] is None: return None
        cached = self._prov_by_proc.get(cur[0])
        if cached is not None: return dict(cached)
        w = self._db.execute(
            "SELECT tgid,ppid,exe,argv FROM process WHERE id=?", (cur[0],)).fetchone()
        if not w: return None
        try: argv = json.loads(w[3]) if w[3] else []
        except (ValueError, TypeError): argv = []
        return dict(pid=w[0], ppid=w[1], exe=w[2], argv=argv)

    def row_mtime(self, rel: str) -> int:
        """The row's stored mtime (integer ns), or 0 if missing. Used on the hot read
        path to synthesize dir/symlink stat without an on-disk lstat."""
        with self._lock:
            row = self._db.execute(
                "SELECT mtime FROM sqlar WHERE name=?", (rel,)).fetchone()
        return int(row[0]) if row and row[0] is not None else 0

    def row_mode_mtime(self, rel: str):
        """(mode, mtime_ns) for the row, or (None, 0). Hot read path: synthesize a
        dir/symlink stat from the row without touching disk."""
        with self._lock:
            row = self._db.execute(
                "SELECT mode, mtime FROM sqlar WHERE name=?", (rel,)).fetchone()
        if not row: return (None, 0)
        return (int(row[0]), int(row[1]) if row[1] is not None else 0)

    def file_row(self, rel: str):
        """Return (rowid, mode, sz, mtime, data) for a file row, or None.
        Used on the hot read path to serve evicted (data NOT NULL) files."""
        with self._lock:
            row = self._db.execute(
                "SELECT rowid, mode, sz, mtime, data FROM sqlar WHERE name=?",
                (rel,)).fetchone()
        return row  # None or (rowid, mode, sz, mtime, data)

    def mark_resident(self, rel: str) -> None:
        """After a fault-in: NULL the row's data+sz to restore the live invariant
        (blob in pool, row empty). Called only after the blob is safely written."""
        with self._lock:
            self._db.execute(
                "UPDATE sqlar SET data=NULL, sz=0 WHERE name=?", (rel,))
            self._db.commit()

    def set_blob(self, rel: str, data: bytes, sz: int, mode: int,
                 mtime_ns: int, writer_id) -> None:
        """Write an evicted-row (data NOT NULL) for `rel` — called from the FUSE
        layer's write-buffer release path to deflate a buffered file straight into
        the sqlar row, bypassing a pool blob.  Reuses _upsert so the RAM mirror
        (_kinds) and row shape stay consistent with what set_entry/consolidate expect.
        `data` is already deflated (raw-or-zlib per _sqlar_deflate); `sz` is the
        uncompressed length."""
        with self._lock:
            # _upsert ensures the row exists + updates mode/writer mirror.
            self._upsert(rel, mode, writer_id, None)
            self._db.execute(
                "UPDATE sqlar SET data=?, sz=?, mtime=?, mode=? WHERE name=?",
                (sqlite3.Binary(data), sz, int(mtime_ns), int(mode), rel))
            self._db.commit()
            # RAM mirror: ensure kind is "file" (whiteout cleared by _upsert logic).
            self._kinds[rel] = "file"
            self._whiteouts.discard(rel); self._targets.pop(rel, None)

    def close(self) -> None:
        try: self._db.close()
        except (sqlite3.Error, AttributeError): pass


@dataclass
class DirHandle:
    """Per-open directory handle state for readdir: the lazily-built listing
    snapshot and the directory inode it was opened on."""
    inode: int
    snapshot: "list | None" = None


# ── MultiplexOverlayFs (pyfuse3 FUSE operations) ────────────────────────────
def _build_overlay_ops():
    """Build the MultiplexOverlayFs class. Imports pyfuse3 lazily so that importing
    this module (e.g. the --inner forwarder, or offline tests) does not require
    pyfuse3/trio. Returns the class."""
    import pyfuse3

    # Short timeouts for an untrusted, mutating mount: a box can change the merged
    # view at any moment (copy-up, whiteout, opaque), so the kernel must not cache
    # attrs/entries for long or it will serve stale (and potentially cross-state)
    # metadata. 5xx-second caching here was a correctness/safety hazard.
    ATTR_TIMEOUT = 1.0
    ENTRY_TIMEOUT = 1.0
    NEG_TIMEOUT = 1.0

    class MultiplexOverlayFs(pyfuse3.Operations):
        """One pyfuse3 Operations object serving every box. The synthetic root ('')
        lists one child per live <sid>; below that, <sid>/<rel> is the per-session
        overlay (lower=/, upper=live/<sid>/up, index in the per-box <sid>.sqlar).

        Inodes span the whole mount: ROOT_INODE is the synthetic root, and every
        other inode maps to a key "<sid>/<rel>" (rel may be empty for a session
        root). Sessions are added/removed by the OverlayMount as boxes come and go."""

        enable_writeback_cache = False

        def __init__(self, lower: str, on_event=None):
            super().__init__()
            self.lower_root = lower.rstrip("/") or "/"
            self.squash_uid = os.getuid()
            self.squash_gid = os.getgid()
            self.on_event = on_event or (lambda **ev: None)
            # session registry: sid -> dict(up=Path, index=Index, virtual={rel:bytes})
            self.sessions: dict = {}
            # inode maps. key for a path inside a session is (sid, rel).
            self._ino_to_key: dict = {pyfuse3.ROOT_INODE: None}   # None = synth root
            self._key_to_ino: dict = {}
            self._next_ino = pyfuse3.ROOT_INODE + 1
            self._lookup_count: dict = {}
            self._fd_table: dict = {}     # fh -> open fd (regular files)
            self._fh_sid: dict = {}       # fh -> sid (so teardown can close a box's fds)
            self._vfh: dict = {}          # fh -> (sid, rel, bytes) for virtual reads
            self._dir_snaps: dict = {}    # fh -> DirHandle(inode, snapshot)
            self._next_fh = 1
            # ── Tier-0 write buffer: hold small file bytes in RAM instead of
            #    materializing a pool blob.  Spills to a pool blob (Tier 1) at
            #    WBUF_SPILL; deflates into the sqlar row on release (Tier 2).
            WBUF_SPILL = 1 << 20          # 1 MiB spill threshold
            self._WBUF_SPILL = WBUF_SPILL
            self._wbuf: dict = {}         # fh -> dict(sid, rel, data:bytearray, dirty,
                                          #            mode, mtime_ns, wid, spilled_fd)
            self._wbuf_key: dict = {}     # (sid, rel) -> fh  (reverse for stat path)
            # watchdog: written only by this (single) trio thread
            self._req_started = None
            self._req_label = ""
            self._req_seq = 0
            self._lock = threading.Lock()   # guards inode/fh allocation vs UI thread
            # Lazily-attached read-only base sessions: finished parents whose sqlar
            # exists on disk but who are NOT live.  Keyed by their sid, same as the
            # normal sessions dict (they share it).  _base_children maps each base sid
            # to the set of live child sids that keep it alive; when the set empties the
            # base is detached and its Index closed.
            self._base_sessions: dict = {}    # sid -> True (membership flag)
            self._base_children: dict = {}    # base_sid -> set of child sids

        # ── session registry ────────────────────────────────────────────────
        def add_session(self, sid: str, up: Path, index: "Index",
                        passthrough: bool = False, parent: "str | None" = None) -> None:
            # `parent`: the box key str(parent_box_id) of the box this one was launched
            # INSIDE (nested `./slopbox`). When set, everything beneath this box's own
            # upper is not the real host but the parent box's merged view (see
            # _lower_resolve) — reads, listings, copy-up sources, and opacity all chain
            # through the parent, down to the real host at the root box.
            with self._lock:
                self.sessions[sid] = dict(up=Path(up), index=index, virtual={},
                                          passthrough=bool(passthrough),
                                          parent=parent or None,
                                          frules=load_file_rules())
            # Persist the parent pointer in the sqlar meta so that _attach_base_session
            # can resolve grandparents for chains of finished boxes.
            if parent:
                try:
                    sqlar_meta_set(sqlar_path(sid), "parent_box_id", str(parent))
                except Exception:
                    pass

        def set_parent(self, sid: str, parent: "str | None") -> None:
            """Re-point a live session's parent box key (dissolve re-parenting). The
            inode key (box_id, rel) is unchanged — only the lower-chain target moves."""
            s = self.sessions.get(sid)
            if s is not None:
                s["parent"] = parent or None
            if parent:
                try: sqlar_meta_set(sqlar_path(sid), "parent_box_id", str(parent))
                except Exception: pass

        def remove_session(self, sid: str) -> None:
            with self._lock:
                self.sessions.pop(sid, None)
                dead = [ino for ino, key in self._ino_to_key.items()
                        if key and key[0] == sid]
                for ino in dead:
                    self._ino_to_key.pop(ino, None)
                    self._lookup_count.pop(ino, None)
                self._key_to_ino = {k: i for k, i in self._key_to_ino.items()
                                    if k[0] != sid}
                # Close any still-open fds that belong to this box so its backing
                # tree can be removed without leaking descriptors. A client that
                # had the file open will get EBADF on its next read/write — the box is
                # being torn down anyway.
                dead_fhs = [fh for fh, s in self._fh_sid.items() if s == sid]
                for fh in dead_fhs:
                    self._fh_sid.pop(fh, None)
                    fd = self._fd_table.pop(fh, None)
                    if fd is not None:
                        try: os.close(fd)
                        except OSError: pass
                # Drop write-buffer entries for this sid (guard against leaks).
                dead_wfhs = [fh for fh, wb in self._wbuf.items() if wb["sid"] == sid]
                for fh in dead_wfhs:
                    wb = self._wbuf.pop(fh, None)
                    if wb is not None:
                        self._wbuf_key.pop((wb["sid"], wb["rel"]), None)
                        sfd = wb.get("spilled_fd", -1)
                        if sfd >= 0:
                            try: os.close(sfd)
                            except OSError: pass
            # Remove this child from any base-session child-set; detach bases that are
            # now unreferenced (child-set empty and base is not also a live session).
            for psid, children in list(self._base_children.items()):
                children.discard(sid)
                if not children and psid in self._base_sessions:
                    self._detach_base_session(psid)

        # ── base-session lifecycle (finished parents used as read-only lower) ──
        def _attach_base_session(self, parent_sid: str) -> None:
            """Idempotent. Attach a finished parent box (sqlar on disk, NOT live) as a
            read-only base session so _lower_resolve/evicted-read paths serve its
            accepted state as the child's lower layer.

            Create the Index from the backing dir (regular-file rows stay evicted; the
            FUSE fault-in path inflates them on demand) and add the session entry —
            identical shape to a live session, but passthrough=False and marked in
            _base_sessions.  A base session is NEVER written to: copy-up always targets
            the live child's own overlay."""
            if parent_sid in self.sessions:
                return   # already present (live or already attached base)
            sp = sqlar_path(parent_sid)
            if not sp.exists():
                return   # no sqlar → nothing to attach
            ld = live_dir(parent_sid)
            # Ensure the backing dir and the up/ sentinel exist so Index.__init__ can
            # locate shm_dir even if the original live/<box_id> was already cleaned up.
            ld.mkdir(parents=True, exist_ok=True)
            (ld / "up").mkdir(parents=True, exist_ok=True)
            try:
                idx = Index(ld)
            except Exception:
                return
            # Read the grandparent pointer from meta so chains of finished boxes resolve.
            grandparent = sqlar_meta_get(sp, "parent_box_id")
            if grandparent and not valid_box_id(grandparent):
                grandparent = None
            self.sessions[parent_sid] = dict(
                up=ld / "up", index=idx, virtual={},
                passthrough=False,
                parent=grandparent or None,
                frules=load_file_rules())
            self._base_sessions[parent_sid] = True
            # If the grandparent is also finished (not live), attach it recursively so
            # multi-level chains resolve.  Guard against cycles with a depth cap.
            if grandparent and grandparent not in self.sessions:
                if sqlar_path(grandparent).exists():
                    self._attach_base_session(grandparent)

        def _detach_base_session(self, psid: str) -> None:
            """Remove a base session when its child-set empties.  Closes its Index and
            drops it from sessions/_base_sessions.  No-op if the sid is still live."""
            if psid not in self._base_sessions:
                return
            self._base_sessions.pop(psid, None)
            self._base_children.pop(psid, None)
            s = self.sessions.pop(psid, None)
            if s is not None:
                try: s["index"].close()
                except Exception: pass
            # Clean up inode maps for the detached base (avoids stale entries).
            dead = [ino for ino, key in self._ino_to_key.items()
                    if key and key[0] == psid]
            for ino in dead:
                self._ino_to_key.pop(ino, None)
                self._lookup_count.pop(ino, None)
            self._key_to_ino = {k: i for k, i in self._key_to_ino.items()
                                if k[0] != psid}
            # Purge the transient backing the attach created (live/<box_id> with the up/
            # sentinel). It is fully reconstructable from the box's <box_id>.sqlar (which
            # we never touch), so dropping it just reclaims scratch space; a later
            # re-attach rebuilds it. Copy-ups read a base read-only, so there are no
            # faulted-in pool blobs to lose.
            try:
                rm_rf(live_dir(psid))
            except Exception:
                pass

        def add_virtual(self, sid: str, rel: str, content: bytes) -> None:
            s = self.sessions.get(sid)
            if s is not None: s["virtual"][rel.lstrip("/")] = content

        # ── inode bookkeeping ───────────────────────────────────────────────
        def _ino_for(self, sid: str, rel: str) -> int:
            key = (sid, rel)
            with self._lock:
                ino = self._key_to_ino.get(key)
                if ino is None:
                    ino = self._next_ino; self._next_ino += 1
                    self._key_to_ino[key] = ino
                    self._ino_to_key[ino] = key
                return ino

        def _key(self, inode: int):
            return self._ino_to_key.get(inode)

        # ── path helpers ─────────────────────────────────────────────────────
        def _lower_path(self, rel: str) -> str:
            return os.path.join(self.lower_root, rel) if rel else self.lower_root

        def _upper_path(self, sid: str, rel: str) -> str:
            up = self.sessions[sid]["up"]
            return str(up / rel) if rel else str(up)

        def _index(self, sid: str) -> "Index":
            return self.sessions[sid]["index"]

        # ── base layer (the real host, or — nested — the parent box's view) ──
        # A box launched inside another box declares its parent sid (add_session).
        # The layer BENEATH this box's own upper is then the parent box's merged
        # overlay view rather than the real host: reads, directory listings, copy-up
        # sources and opacity/existence checks all resolve through the parent, which
        # layers over its own parent, recursively, until the root box bottoms out on
        # the real host. The recursion is finite (each hop is a distinct live sid).
        def _parent(self, sid: str) -> "str | None":
            s = self.sessions.get(sid)
            p = s.get("parent") if s else None
            if not p:
                return None
            if p in self.sessions:
                return p
            # Finished parent: sqlar exists but the session is no longer live.
            # Lazily attach it as a read-only base session so the evicted-read and
            # directory-listing paths can serve the parent's accepted state.
            if sqlar_path(p).exists():
                self._attach_base_session(p)
                # Register this child as keeping the base alive (idempotent set-add).
                self._base_children.setdefault(p, set()).add(sid)
                if p in self.sessions:
                    return p
            return None

        def _lower_resolve(self, sid: str, rel: str):
            """(layer, abspath, st) for the layer beneath this box's own upper — the
            parent box's merged view if nested, else the real host. The returned path
            is a real on-disk file (host file, or a file in some ancestor's upper), so
            callers can lstat/open/copy it directly."""
            p = self._parent(sid)
            if p is not None:
                return self._resolve_st(p, rel)
            host = self._lower_path(rel)
            try: return ("lower", host, os.lstat(host))
            except OSError: return ("absent", None, None)

        def _lower_exists(self, sid: str, rel: str) -> bool:
            return self._lower_resolve(sid, rel)[0] not in ("absent", "whiteout")

        def _lower_is_dir(self, sid: str, rel: str) -> bool:
            _l, _ap, st = self._lower_resolve(sid, rel)
            return bool(st and stat_mod.S_ISDIR(st.st_mode))

        def _lower_names(self, sid: str, rel: str) -> dict:
            """{name: 'lower'} for the entries the layer beneath this box's own upper
            shows under dir `rel`: the parent box's merged listing if nested, else the
            real host directory."""
            p = self._parent(sid)
            if p is not None:
                return {n: "lower" for n, _k, _a in self._scan_dir(p, rel)}
            out = {}
            try:
                with os.scandir(self._lower_path(rel)) as it:
                    for de in it: out[de.name] = "lower"
            except OSError: pass
            return out

        # ── passthrough (direct host action, nothing captured) ───────────────
        def _passthrough(self, sid: str, rel: str) -> bool:
            """True when this op should act on the REAL host fs and record nothing in
            the overlay/sqlar — either the whole box is in direct mode (-d) or a
            file-rule marks this path 'passthrough'."""
            s = self.sessions.get(sid)
            if not s: return False
            if s.get("passthrough"): return True
            fr = s.get("frules")
            return bool(fr and fr.decide(rel) == "passthrough")

        def _host_path(self, rel: str) -> str:
            """The real host path for a passthrough op (lower root + rel)."""
            return self._lower_path(rel)

        def _passthrough_open(self, rel: str, flags: int) -> int:
            """Open the REAL host file for a passthrough write. O_NOFOLLOW on the final
            component: never dereference a box-planted symlink onto another host path."""
            host = self._host_path(rel)
            try:
                os.makedirs(os.path.dirname(host) or "/", exist_ok=True)
            except OSError:
                pass
            try:
                return os.open(host, flags | os.O_NOFOLLOW)
            except OSError as e:
                raise pyfuse3.FUSEError(e.errno or errno.EIO)

        # ── pool-backed artifact path helpers ────────────────────────────────
        def _backing_path(self, sid: str, rel: str) -> "str | None":
            """The on-disk artifact for rel in OUR upper: a regular file's pool blob.
            Dirs and symlinks have NO on-disk artifact (served from the mirror/row),
            so they — like everything else — return None."""
            idx = self._index(sid)
            if idx.kind_of(rel) == "file":
                rid = idx.row_id(rel)
                if rid is None: return None
                return str(blob_path(idx.box_id, rid))
            return None

        def _new_file_blob(self, sid: str, rel: str, mode, wid, op: str,
                           detail: str = "") -> str:
            """Ensure the FILE row for rel exists; return the blob path string.
            Clears a stale whiteout entry first. The blob shard dir is created."""
            idx = self._index(sid)
            if idx.kind_of(rel) == "whiteout":
                idx.del_entry(rel)
            idx.set_entry(rel, "file", mode, wid, op, detail=detail)
            rid = idx.row_id(rel)
            bp = blob_path(idx.box_id, rid)
            bp.parent.mkdir(parents=True, exist_ok=True)
            return str(bp)

        # ── Tier-0 write buffer helpers ──────────────────────────────────────

        def _should_buffer_write(self, sid: str, rel: str, flags: int,
                                 idx: "Index") -> bool:
            """Return True iff this open-for-write should use the RAM write buffer
            instead of the disk copy-up path.  False when: passthrough session (always
            goes through _write_open); the path is not a regular file; the file is
            already open-buffered by another handle (no double-buffer); the existing
            file is >= WBUF_SPILL (large files stay on disk)."""
            if self._passthrough(sid, rel):
                return False
            # already buffered by another fh (rare: concurrent opens of the same rel)
            if (sid, rel) in self._wbuf_key:
                return False
            k = idx.kind_of(rel)
            # non-file overlay kinds (dir, symlink, whiteout) go to disk path
            if k is not None and k != "file":
                return False
            # existing regular file whose on-disk size is already large: disk path
            if k == "file":
                row = idx.file_row(rel)
                if row is not None:
                    _rowid, _mode, sz, _mtime, data = row
                    if data is not None:
                        # evicted: sz is the uncompressed size
                        if sz >= self._WBUF_SPILL:
                            return False
                    else:
                        # resident: check blob size
                        rid = idx.row_id(rel)
                        if rid is not None:
                            bp = blob_path(idx.box_id, rid)
                            try:
                                if os.path.getsize(str(bp)) >= self._WBUF_SPILL:
                                    return False
                            except OSError:
                                pass
            # lower (host) file: check host size if it exists
            if k is None:
                layer, ap, st = self._lower_resolve(sid, rel)
                if layer in ("lower", "upper") and st is not None:
                    if st.st_size >= self._WBUF_SPILL:
                        return False
            return True

        def _create_write_buffer(self, sid: str, rel: str, idx: "Index",
                                 flags: int, ctx) -> dict:
            """Allocate and seed the write-buffer dict for fh.
            Seeds the bytearray from: O_TRUNC → empty; evicted row → decompress;
            resident blob → read file; else → empty.
            Marks the file in the index so it is visible while buffered."""
            wid = idx.writer_for(ctx.pid)
            # ── seed current bytes ──────────────────────────────────
            if flags & os.O_TRUNC:
                data = bytearray()
            else:
                data = None
                k = idx.kind_of(rel)
                if k == "file":
                    row = idx.file_row(rel)
                    if row is not None:
                        _rowid, _mode, _sz, _mtime, rowdata = row
                        if rowdata is not None:
                            # evicted: decompress into bytearray
                            blob = bytes(rowdata)
                            content = blob if len(blob) == _sz else zlib.decompress(blob)
                            data = bytearray(content)
                        else:
                            # resident: read pool blob
                            rid = idx.row_id(rel)
                            if rid is not None:
                                bp = blob_path(idx.box_id, rid)
                                try:
                                    data = bytearray(bp.read_bytes())
                                except OSError:
                                    data = bytearray()
                if data is None:
                    # No own-overlay entry: seed from the lower layer (host or parent box).
                    layer, ap, _st = self._lower_resolve(sid, rel)
                    if layer in ("lower", "upper") and ap is not None:
                        try:
                            with open(ap, "rb") as f:
                                data = bytearray(f.read())
                        except OSError:
                            data = bytearray()
                    elif layer in ("lower", "upper"):
                        # ap is None: the lower file is EVICTED in an ancestor box — read
                        # its row bytes (read-only) so a buffered copy-up isn't empty.
                        eb = self._evicted_bytes(sid, rel)
                        data = bytearray(eb) if eb is not None else bytearray()
                    else:
                        data = bytearray()
            # ── mode for this file ──────────────────────────────────
            row = idx.file_row(rel)
            if row is not None:
                mode = row[1]
            else:
                layer, _ap, st = self._lower_resolve(sid, rel)
                if st is not None:
                    mode = st.st_mode
                else:
                    mode = stat_mod.S_IFREG | 0o644
            # ── mark visible in the index immediately ───────────────
            # Clears a whiteout if present so kind_of(rel)=="file" while buffered.
            if idx.kind_of(rel) == "whiteout":
                idx.del_entry(rel)
            idx.set_entry(rel, "file", mode, wid,
                          "create" if idx.kind_of(rel) is None else "open_write")
            return dict(sid=sid, rel=rel, data=data, dirty=False,
                        mode=mode, mtime_ns=time.time_ns(), wid=wid, spilled_fd=-1)

        def _spill_write_buffer(self, fh: int) -> None:
            """Materialize the write buffer's bytearray to a pool blob (Tier 1).
            Called when len(data) > WBUF_SPILL.  After spilling the bytearray is
            cleared to free RAM; subsequent writes go directly to the spilled_fd."""
            wb = self._wbuf[fh]
            sid, rel = wb["sid"], wb["rel"]
            idx = self._index(sid)
            # _new_file_blob ensures the row exists and returns the blob path.
            bp_str = self._new_file_blob(sid, rel, wb["mode"], wb["wid"], "spill")
            fd = os.open(bp_str,
                         os.O_RDWR | os.O_CREAT | os.O_TRUNC | os.O_NOFOLLOW,
                         stat_mod.S_IMODE(wb["mode"]) or 0o644)
            try:
                os.write(fd, bytes(wb["data"]))
            except OSError:
                os.close(fd)
                raise
            wb["spilled_fd"] = fd
            wb["data"] = bytearray()   # free RAM; writes now go to spilled_fd

        def _buffer_stat(self, sid: str, rel: str):
            """Return a _row_stat for an open write-buffer entry, or None.
            Reports the LIVE size/mtime so getattr/lookup/_scan_dir see consistent
            sizes even while a write is in progress (coherence seam)."""
            fh = self._wbuf_key.get((sid, rel))
            if fh is None:
                return None
            wb = self._wbuf.get(fh)
            if wb is None:
                return None
            sfd = wb.get("spilled_fd", -1)
            if sfd >= 0:
                try:
                    sz = os.fstat(sfd).st_size
                except OSError:
                    sz = len(wb["data"])
            else:
                sz = len(wb["data"])
            return self._row_stat(wb["mode"], sz, wb["mtime_ns"])

        # ── layer resolution ───────────────────────────────────────
        @staticmethod
        def _row_stat(mode: int, sz: int, mtime_ns: int):
            """Fake stat-like object for an evicted file (blob absent, bytes in row).
            path is None; _entry() only reads the fields below."""
            return SimpleNamespace(
                st_mode=mode, st_nlink=1, st_size=sz,
                st_atime_ns=mtime_ns, st_mtime_ns=mtime_ns, st_ctime_ns=mtime_ns,
                st_rdev=0, st_blocks=(sz + 511) // 512, st_blksize=512)

        @staticmethod
        def _synth_link_stat(size: int, mtime_ns: int):
            """Synthetic stat for a symlink served from the mirror (no on-disk lstat).
            mode S_IFLNK|0777, st_size == len(target). _entry() reads only these."""
            return SimpleNamespace(
                st_mode=stat_mod.S_IFLNK | 0o777, st_nlink=1, st_size=size,
                st_atime_ns=mtime_ns, st_mtime_ns=mtime_ns, st_ctime_ns=mtime_ns,
                st_rdev=0, st_blocks=0, st_blksize=512)

        @staticmethod
        def _synth_dir_stat(mode: int, mtime_ns: int):
            """Synthetic stat for a dir served from the mirror (no on-disk lstat).
            Mirrors _synth_dir_attrs: nlink 2, size 0."""
            m = stat_mod.S_IFDIR | (stat_mod.S_IMODE(mode) or 0o755)
            ts = mtime_ns if mtime_ns else time.time_ns()
            return SimpleNamespace(
                st_mode=m, st_nlink=2, st_size=0,
                st_atime_ns=ts, st_mtime_ns=ts, st_ctime_ns=ts,
                st_rdev=0, st_blocks=0, st_blksize=512)

        def _resolve_st(self, sid: str, rel: str):
            # Coherence seam: an open write buffer is the authoritative source for
            # size/mtime while a write is in progress — check before index/blob/lower.
            bst = self._buffer_stat(sid, rel)
            if bst is not None:
                return ("upper", None, bst)
            idx = self._index(sid)
            if not idx.has_overlay_state():
                return self._lower_resolve(sid, rel)
            k = idx.kind_of(rel)
            if k == "whiteout":
                return ("whiteout", None, None)
            if k == "file":
                # File is resident if its pool blob exists; evicted if blob absent
                # but the row carries data; absent otherwise.
                rid = idx.row_id(rel)
                if rid is not None:
                    bp = blob_path(idx.box_id, rid)
                    if bp.exists():
                        try: return ("upper", str(bp), os.lstat(str(bp)))
                        except OSError: pass
                    # blob absent: check for evicted row (data NOT NULL)
                    row = idx.file_row(rel)
                    if row is not None:
                        _rowid, mode, sz, mtime_ns, data = row
                        if data is not None:
                            # evicted: path=None, stat from row
                            return ("upper", None, self._row_stat(mode, sz, mtime_ns))
            elif k == "symlink":
                # Served from the mirror: synthetic S_IFLNK stat, size == len(target),
                # row mtime. No on-disk lstat (the artifact may not exist).
                tgt = idx.symlink_target(rel) or b""
                return ("upper", None,
                        self._synth_link_stat(len(tgt), idx.row_mtime(rel)))
            elif k == "dir":
                # Served from the mirror: synthetic dir stat from the row mode/mtime.
                mode, mtime_ns = idx.row_mode_mtime(rel)
                return ("upper", None,
                        self._synth_dir_stat(mode if mode is not None else 0o755,
                                             mtime_ns))
            if idx.hidden_by_opaque(rel):
                return ("absent", None, None)
            return self._lower_resolve(sid, rel)

        def _resolve(self, sid: str, rel: str) -> str:
            return self._resolve_st(sid, rel)[0]

        def _is_virtual(self, sid: str, rel: str) -> bool:
            s = self.sessions.get(sid)
            if not s: return False
            return rel in s["virtual"] and self._index(sid).kind_of(rel) is None

        # ── attr construction ────────────────────────────────────────────────
        def _entry(self, ino: int, st) -> "pyfuse3.EntryAttributes":
            a = pyfuse3.EntryAttributes()
            a.st_ino = ino
            a.st_mode = st.st_mode
            a.st_nlink = st.st_nlink
            a.st_uid = self.squash_uid
            a.st_gid = self.squash_gid
            a.st_rdev = getattr(st, "st_rdev", 0)
            a.st_size = st.st_size
            a.st_blksize = 512
            a.st_blocks = (st.st_size + 511) // 512
            a.st_atime_ns = getattr(st, "st_atime_ns", 0)
            a.st_mtime_ns = getattr(st, "st_mtime_ns", 0)
            a.st_ctime_ns = getattr(st, "st_ctime_ns", 0)
            a.attr_timeout = ATTR_TIMEOUT
            a.entry_timeout = ENTRY_TIMEOUT
            return a

        def _synth_dir_attrs(self, ino: int) -> "pyfuse3.EntryAttributes":
            a = pyfuse3.EntryAttributes()
            a.st_ino = ino
            a.st_mode = stat_mod.S_IFDIR | 0o755
            a.st_nlink = 2
            a.st_uid = self.squash_uid
            a.st_gid = self.squash_gid
            a.st_size = 0
            a.st_blksize = 512
            a.st_blocks = 0
            now = time.time_ns()
            a.st_atime_ns = a.st_mtime_ns = a.st_ctime_ns = now
            a.attr_timeout = ATTR_TIMEOUT
            a.entry_timeout = ENTRY_TIMEOUT
            return a

        def _virtual_attrs(self, sid: str, rel: str, ino: int) -> "pyfuse3.EntryAttributes":
            content = self.sessions[sid]["virtual"][rel]
            a = pyfuse3.EntryAttributes()
            a.st_ino = ino
            a.st_mode = stat_mod.S_IFREG | 0o644
            a.st_nlink = 1
            a.st_uid = self.squash_uid
            a.st_gid = self.squash_gid
            a.st_size = len(content)
            a.st_blksize = 512
            a.st_blocks = (len(content) + 511) // 512
            try: lst = os.lstat(self._lower_path(rel)); ts = lst.st_mtime_ns
            except OSError: ts = time.time_ns()
            a.st_atime_ns = a.st_mtime_ns = a.st_ctime_ns = ts
            a.attr_timeout = ATTR_TIMEOUT
            a.entry_timeout = ENTRY_TIMEOUT
            return a

        def _neg_entry(self) -> "pyfuse3.EntryAttributes":
            a = pyfuse3.EntryAttributes()
            a.st_ino = 0
            a.entry_timeout = NEG_TIMEOUT
            a.attr_timeout = NEG_TIMEOUT
            return a

        # ── watchdog ───────────────────────────────────────────────
        def _req_enter(self, label: str) -> None:
            self._req_started = time.monotonic(); self._req_label = label
            self._req_seq += 1

        def _req_exit(self) -> None:
            self._req_started = None

        def inflight_age(self):
            t = self._req_started
            return (time.monotonic() - t) if t is not None else None

        # ── child-path utility for synthetic root vs session paths ───────────
        def _child_key(self, parent_key, name: str):
            """Return (sid, rel) for a child `name` under parent_key (None = synth
            root, where children are session ids)."""
            if parent_key is None:
                return (name, "")                      # a session root
            sid, rel = parent_key
            child = (rel + "/" + name) if rel else name
            return (sid, child)

        def _parent_key(self, parent_key):
            if parent_key is None: return None
            sid, rel = parent_key
            if not rel: return None                    # session root's parent = synth
            up = rel.rsplit("/", 1)[0] if "/" in rel else ""
            return (sid, up)

        # ── FUSE: lookup ─────────────────────────────────────────────────────
        async def lookup(self, parent_inode, name, ctx=None):
            name = os.fsdecode(name)
            pkey = self._key(parent_inode)
            if name == ".":
                ckey = pkey
            elif name == "..":
                ckey = self._parent_key(pkey)
            else:
                ckey = self._child_key(pkey, name)
            if ckey is None:                            # synth root itself
                return self._synth_dir_attrs(pyfuse3.ROOT_INODE)
            sid, rel = ckey
            if pkey is None:                            # child of synth root = a session
                if sid not in self.sessions:
                    return self._neg_entry()
                ino = self._ino_for(sid, "")
                self._lookup_count[ino] = self._lookup_count.get(ino, 0) + 1
                return self._synth_dir_attrs(ino)
            if sid not in self.sessions:
                return self._neg_entry()
            if self._is_virtual(sid, rel):
                ino = self._ino_for(sid, rel)
                self._lookup_count[ino] = self._lookup_count.get(ino, 0) + 1
                return self._virtual_attrs(sid, rel, ino)
            layer, _ap, st = self._resolve_st(sid, rel)
            if layer in ("absent", "whiteout"):
                return self._neg_entry()
            ino = self._ino_for(sid, rel)
            self._lookup_count[ino] = self._lookup_count.get(ino, 0) + 1
            return self._entry(ino, st)

        async def getattr(self, inode, ctx=None):
            key = self._key(inode)
            if key is None:
                # Only the synthetic root legitimately maps to a None key. A None for
                # any other inode means it was forgotten/removed (e.g. its session was
                # torn down) — a stale inode must ENOENT, never resolve to the root's
                # attributes.
                if inode == pyfuse3.ROOT_INODE:
                    return self._synth_dir_attrs(pyfuse3.ROOT_INODE)
                raise pyfuse3.FUSEError(errno.ENOENT)
            sid, rel = key
            if sid not in self.sessions:
                raise pyfuse3.FUSEError(errno.ENOENT)
            if not rel:                                 # a session root
                return self._synth_dir_attrs(inode)
            if self._is_virtual(sid, rel):
                return self._virtual_attrs(sid, rel, inode)
            layer, _ap, st = self._resolve_st(sid, rel)
            if layer in ("absent", "whiteout"):
                raise pyfuse3.FUSEError(errno.ENOENT)
            return self._entry(inode, st)

        async def forget(self, inode_list):
            for inode, nlookup in inode_list:
                c = self._lookup_count.get(inode, 0) - nlookup
                if c <= 0:
                    self._lookup_count.pop(inode, None)
                else:
                    self._lookup_count[inode] = c

        async def setxattr(self, inode, name, value, ctx):
            raise pyfuse3.FUSEError(errno.ENOSYS)

        async def getxattr(self, inode, name, ctx):
            raise pyfuse3.FUSEError(pyfuse3.ENOATTR)

        # ── readdir ──────────────────────────────────────────────────────────
        def _scan_dir(self, sid: str, rel: str) -> list:
            """Merged listing of <sid>/<rel>: [(name, (sid, childrel) or None, attrs)].
            None key marks a virtual/synthetic-only entry where attrs are supplied."""
            idx = self._index(sid)
            names: dict = {}     # name -> layer
            if not idx.is_opaque(rel):
                for nm in self._lower_names(sid, rel):
                    names[nm] = "lower"
            if idx.has_overlay_state():
                # Overlay children come from the Index mirror (files in the pool, dirs/
                # symlinks in the rows) — NOT os.scandir(upper): no dir/symlink artifacts
                # live on disk. whiteouts remove a lower name; others ensure present.
                whiteouts, present = idx.children_of(rel)
                for name in whiteouts:
                    names.pop(name, None)
                for name in present:
                    names.setdefault(name, "upper")
            # virtual files in this dir
            for vp in self.sessions[sid]["virtual"]:
                pfx = (rel + "/") if rel else ""
                if vp.startswith(pfx) and "/" not in vp[len(pfx):]:
                    names.setdefault(vp[len(pfx):], "virtual")
            out = []
            for name in sorted(names):
                childrel = (rel + "/" + name) if rel else name
                if self._is_virtual(sid, childrel):
                    ino = self._ino_for(sid, childrel)
                    out.append((name, (sid, childrel),
                                self._virtual_attrs(sid, childrel, ino)))
                    continue
                layer, _ap, st = self._resolve_st(sid, childrel)
                if layer in ("absent", "whiteout"): continue
                ino = self._ino_for(sid, childrel)
                out.append((name, (sid, childrel), self._entry(ino, st)))
            return out

        async def opendir(self, inode, ctx):
            with self._lock:
                dh = self._next_fh; self._next_fh += 1
            self._dir_snaps[dh] = DirHandle(inode=inode)
            return dh

        async def readdir(self, fh, start_id, token):
            dh = self._dir_snaps.get(fh)
            snap = dh.snapshot if dh is not None else None
            if snap is None:
                inode = dh.inode if dh is not None else None
                key = self._key(inode)
                if key is None:
                    # synthetic root: list live sessions
                    snap = []
                    for sid in sorted(self.sessions):
                        ino = self._ino_for(sid, "")
                        snap.append((sid, self._synth_dir_attrs(ino)))
                else:
                    sid, rel = key
                    if sid in self.sessions:
                        snap = [(name, attrs)
                                for name, _k, attrs in self._scan_dir(sid, rel)]
                    else:
                        snap = []
                if dh is None:
                    dh = DirHandle(inode=inode); self._dir_snaps[fh] = dh
                dh.snapshot = snap
            for i in range(start_id, len(snap)):
                name, attrs = snap[i]
                if not pyfuse3.readdir_reply(
                        token, os.fsencode(name), attrs, i + 1):
                    break

        async def releasedir(self, fh):
            self._dir_snaps.pop(fh, None)

        async def readlink(self, inode, ctx):
            key = self._key(inode)
            if key is None: raise pyfuse3.FUSEError(errno.EINVAL)
            sid, rel = key
            layer, ap, _st = self._resolve_st(sid, rel)
            if layer in ("absent", "whiteout"): raise pyfuse3.FUSEError(errno.ENOENT)
            # Overlay symlink: served straight from the mirror (target in the row).
            tgt = self._index(sid).symlink_target(rel)
            if tgt is not None:
                return bytes(tgt)
            # Lower (host / ancestor) symlink: resolved path is a real on-disk link.
            if ap is None: raise pyfuse3.FUSEError(errno.ENOENT)
            try: return os.fsencode(os.readlink(ap))
            except OSError as e: raise pyfuse3.FUSEError(e.errno or errno.EIO)

        # ── parent-dir materialization ───────────────────────────────────────
        def _ensure_parent_dirs(self, sid: str, rel: str, wid) -> None:
            """Record the chain of parent dirs of rel as dir ROWS in the mirror — no
            on-disk artifact (dirs are served from the index, not from up/). Each level
            already tracked as a dir is left untouched (opacity preserved)."""
            parent = rel.rsplit("/", 1)[0] if "/" in rel else ""
            if not parent: return
            idx = self._index(sid)
            parts = parent.split("/")
            cur = ""
            for p in parts:
                cur = (cur + "/" + p) if cur else p
                if idx.kind_of(cur) == "dir":
                    continue
                # Record this level as a dir row. A freshly-recorded parent never
                # carries opacity (it shows the lower through); a dir explicitly
                # recreated over a lower dir gets opacity recorded by mkdir/rename.
                idx.set_entry(cur, "dir", stat_mod.S_IFDIR | 0o755, wid,
                              "mkdir_parent", opaque=0)

        def _readlink_source(self, sid: str, rel: str, ap: "str | None") -> "str | None":
            """The symlink target for a copy-up source. ap is non-None for a host/lower
            link (os.readlink). For an overlay link (ancestor's mirror) ap is None —
            walk the parent chain for the owning session's row target. None if neither."""
            if ap is not None:
                try: return os.readlink(ap)
                except OSError: return None
            cur = sid; seen: set = set()
            while cur and cur not in seen:
                seen.add(cur)
                tgt = self._index(cur).symlink_target(rel)
                if tgt is not None:
                    return tgt.decode("utf-8", "surrogateescape")
                p = self._parent(cur)
                if p is None: break
                cur = p
            return None

        # ── fault-in: inflate an evicted row back to a pool blob ────────────
        def _owning_evicted_sid(self, sid: str, rel: str) -> "str | None":
            """Walk the parent chain upward to find the session whose index has an
            evicted file row (data NOT NULL, no pool blob) for rel.  Used by copy-up
            and ensure-copyup when _resolve_st returns ap=None for a regular file
            from an ancestor session (finished parent attached as a base)."""
            cur = sid
            seen: set = set()
            while cur and cur not in seen:
                seen.add(cur)
                idx = self._index(cur)
                if idx.kind_of(rel) == "file":
                    row = idx.file_row(rel)
                    if row is not None and row[4] is not None:
                        return cur
                p = self._parent(cur)
                if p is None:
                    break
                cur = p
            return None

        def _evicted_bytes(self, sid: str, rel: str) -> "bytes | None":
            """Decompressed content of an evicted file (bytes in a sqlar row, no blob),
            read from the OWNING session's row WITHOUT mutating it. The owning session
            may be this box or an ancestor; an ancestor attached as a base is read-only,
            so a copy-up/seed reads its bytes here rather than faulting it in (which
            would NULL its row and move its only copy into a throwaway pool blob)."""
            owning = self._owning_evicted_sid(sid, rel)
            if owning is None:
                return None
            row = self._index(owning).file_row(rel)
            if row is None or row[4] is None:
                return None
            blob = bytes(row[4]); sz = row[2]
            return blob if len(blob) == sz else zlib.decompress(blob)

        def _fault_in(self, sid: str, rel: str) -> None:
            """Idempotent. If the file's row has data and no blob: decompress the
            row bytes, write the blob, chmod+mtime, then NULL the row (resident).
            No-op if already resident (blob exists) or data already NULL."""
            idx = self._index(sid)
            row = idx.file_row(rel)
            if row is None: return
            rowid, mode, sz, mtime_ns, data = row
            if data is None: return                      # already resident (NULL)
            bp = blob_path(idx.box_id, rowid)
            if bp.exists(): return                       # blob already present
            blob = bytes(data)
            content = blob if len(blob) == sz else zlib.decompress(blob)
            bp.parent.mkdir(parents=True, exist_ok=True)
            bp.write_bytes(content)
            try: os.chmod(bp, stat_mod.S_IMODE(mode))
            except OSError: pass
            _restore_host_mtime_ns(bp, mtime_ns, is_symlink=False)
            idx.mark_resident(rel)                       # NULL data in row

        # ── copy-up ─────────────────────────────────────────────
        def _ensure_copyup(self, sid: str, rel: str, flags: int, ctx) -> int:
            """Materialize a lower (or absent) file into the pool; return an O_RDWR
            fd on the blob. Regular files go to the pool blob (flat, no host-path
            layout); dirs/symlinks are mirrored via _copyup_one (row-only, no on-disk
            artifact). Fail-closed: any copy error propagates."""
            idx = self._index(sid)
            wid = idx.writer_for(ctx.pid)
            # FIRST: if already a file in the index with a blob, just open it.
            if idx.kind_of(rel) == "file":
                rid = idx.row_id(rel)
                if rid is not None:
                    bp = blob_path(idx.box_id, rid)
                    if bp.exists():
                        try:
                            return os.open(str(bp), os.O_RDWR | os.O_NOFOLLOW)
                        except OSError as e:
                            raise pyfuse3.FUSEError(e.errno or errno.EIO)
                    # evicted (blob absent, data in row): fault in then open blob
                    row = idx.file_row(rel)
                    if row is not None and row[4] is not None:
                        try:
                            self._fault_in(sid, rel)
                            return os.open(str(bp), os.O_RDWR | os.O_NOFOLLOW)
                        except OSError as e:
                            raise pyfuse3.FUSEError(e.errno or errno.EIO)
            # Resolve the source from lower/upper layers.
            layer, ap, st = self._resolve_st(sid, rel)
            if layer in ("lower", "upper"):
                # A lower symlink/dir is copied up preserving its type — into the
                # mirror row, NOT an on-disk artifact (_copyup_one records the dir/
                # symlink row). There is no fd to hand back: opening a symlink/dir for
                # write is degenerate (the kernel resolves symlinks before open, and a
                # dir open-for-write is EISDIR). Record the row, then refuse the fd.
                if not stat_mod.S_ISREG(st.st_mode):
                    self._ensure_parent_dirs(sid, rel, wid)
                    self._copyup_one(sid, rel, wid)
                    raise pyfuse3.FUSEError(
                        errno.EISDIR if stat_mod.S_ISDIR(st.st_mode) else errno.EINVAL)
                # ap is None when the file is evicted in an ancestor (base) session.
                # Copy its row bytes into the child's OWN blob without faulting in /
                # mutating the read-only base (that would null the finished box's row).
                if ap is None:
                    data = self._evicted_bytes(sid, rel)
                    if data is None:
                        raise pyfuse3.FUSEError(errno.EIO)
                    bp_str = self._new_file_blob(sid, rel, st.st_mode, wid, "copyup")
                    dst = os.open(bp_str, os.O_RDWR | os.O_CREAT | os.O_NOFOLLOW,
                                  stat_mod.S_IMODE(st.st_mode))
                    try:
                        os.write(dst, data)
                    except OSError as e:
                        try: os.close(dst)
                        except OSError: pass
                        raise pyfuse3.FUSEError(e.errno or errno.EIO)
                    return dst
                src = os.open(ap, os.O_RDONLY | os.O_NOFOLLOW)
                try:
                    bp_str = self._new_file_blob(sid, rel, st.st_mode, wid, "copyup")
                    mode = stat_mod.S_IMODE(st.st_mode)
                    dst = os.open(bp_str, os.O_RDWR | os.O_CREAT | os.O_NOFOLLOW, mode)
                    try:
                        reflink_or_copy(src, dst)
                    except OSError as e:
                        os.close(dst)
                        try: os.unlink(bp_str)
                        except OSError: pass
                        raise pyfuse3.FUSEError(e.errno or errno.EIO)
                finally:
                    os.close(src)
                return dst
            else:
                # absent (or whiteout cleared) -> brand new pool blob
                bp_str = self._new_file_blob(sid, rel, stat_mod.S_IFREG | 0o644,
                                             wid, "create")
                return os.open(bp_str, os.O_RDWR | os.O_CREAT | os.O_NOFOLLOW, 0o644)

        # ── open / read / write / release ───────────────────────────────────
        def _write_open(self, sid: str, rel: str, flags: int, ctx) -> int:
            """Open a file for writing, honoring the kick-up chain.
            Passthrough + parent  → recurse into parent's overlay (captured there).
            Passthrough + no parent → real host (_passthrough_open), unchanged.
            Non-passthrough       → copy-up into this box's own pool blob."""
            # Base sessions are strictly read-only: never write into a finished parent.
            if sid in self._base_sessions:
                raise pyfuse3.FUSEError(errno.EROFS)
            if self._passthrough(sid, rel):
                p = self._parent(sid)
                if p is not None:
                    return self._write_open(p, rel, flags, ctx)   # KICK UP
                return self._passthrough_open(rel, flags)          # ROOT: real host
            fd = self._ensure_copyup(sid, rel, flags, ctx)
            # Honor O_TRUNC on the overlay path. With FUSE atomic_o_trunc the
            # kernel passes O_TRUNC to open() (and sends NO separate
            # setattr(size=0)), so the handler must truncate itself — else a
            # rewrite-shorter (e.g. `>` over an existing upper file, as
            # config.status does when it reuses a sed fragment) keeps the old
            # tail bytes past the new length and the file reads back corrupt.
            if flags & os.O_TRUNC:
                try: os.ftruncate(fd, 0)
                except OSError as e:
                    os.close(fd)
                    raise pyfuse3.FUSEError(e.errno or errno.EIO)
            self._notify(sid, rel, "modified")
            return fd

        async def open(self, inode, flags, ctx):
            key = self._key(inode)
            if key is None: raise pyfuse3.FUSEError(errno.EISDIR)
            sid, rel = key
            writable = (flags & (os.O_WRONLY | os.O_RDWR)) != 0
            if self._is_virtual(sid, rel) and not writable:
                content = self.sessions[sid]["virtual"][rel]
                with self._lock:
                    fh = self._next_fh; self._next_fh += 1
                self._vfh[fh] = (sid, rel, content)
                return pyfuse3.FileInfo(fh=fh, direct_io=False, keep_cache=False)
            self._req_enter(f"open {sid}/{rel}")
            try:
                if not writable:
                    layer, ap, _st = self._resolve_st(sid, rel)
                    if layer in ("absent", "whiteout"):
                        raise pyfuse3.FUSEError(errno.ENOENT)
                    # Evicted file: path is None, bytes live in the row.  The row
                    # may belong to this session or to an ancestor (finished parent
                    # attached as a base).  Find the owning session, then serve via
                    # _vfh — no materialization to disk on a read-only open.
                    if ap is None:
                        owning = self._owning_evicted_sid(sid, rel)
                        evict_idx = (self._index(owning) if owning
                                     else self._index(sid))
                        row = evict_idx.file_row(rel)
                        if row is None or row[4] is None:
                            raise pyfuse3.FUSEError(errno.EIO)
                        _rowid, _mode, sz, _mtime, data = row
                        blob = bytes(data)
                        content = blob if len(blob) == sz else zlib.decompress(blob)
                        with self._lock:
                            fh = self._next_fh; self._next_fh += 1
                        self._vfh[fh] = (sid, rel, content)
                        return pyfuse3.FileInfo(fh=fh, direct_io=False, keep_cache=False)
                    try:
                        # O_NOFOLLOW: never dereference a symlink at the final path
                        # component on the read path either — defensive even where the
                        # resolved layer is host-owned.
                        fd = os.open(ap, os.O_RDONLY | os.O_NOFOLLOW)
                    except OSError as e:
                        raise pyfuse3.FUSEError(e.errno or errno.EIO)
                else:
                    # Base sessions are strictly read-only (finished parent).
                    if sid in self._base_sessions:
                        raise pyfuse3.FUSEError(errno.EROFS)
                    if policy_check(sid, self._index(sid).provenance_of(ctx.pid),
                                    rel, "open_write") == "deny":
                        raise pyfuse3.FUSEError(errno.EACCES)
                    idx = self._index(sid)
                    if self._should_buffer_write(sid, rel, flags, idx):
                        # Tier-0: hold bytes in RAM; deflate into sqlar row on release.
                        wb = self._create_write_buffer(sid, rel, idx, flags, ctx)
                        with self._lock:
                            fh = self._next_fh; self._next_fh += 1
                        self._wbuf[fh] = wb
                        self._wbuf_key[(sid, rel)] = fh
                        self._notify(sid, rel, "modified")
                        return pyfuse3.FileInfo(fh=fh, direct_io=False, keep_cache=False)
                    # Tier-1 / existing: disk copy-up path.
                    idx.writer_for(ctx.pid)   # tracing/provenance
                    fd = self._write_open(sid, rel, flags, ctx)
                with self._lock:
                    fh = self._next_fh; self._next_fh += 1
                    self._fd_table[fh] = fd
                    self._fh_sid[fh] = sid
                return pyfuse3.FileInfo(fh=fh, direct_io=False, keep_cache=False)
            finally:
                self._req_exit()

        async def read(self, fh, off, size):
            if fh in self._vfh:
                _sid, _rel, content = self._vfh[fh]
                return content[off:off + size]
            # Tier-0 read: serve from the RAM write buffer.
            wb = self._wbuf.get(fh)
            if wb is not None:
                sfd = wb.get("spilled_fd", -1)
                if sfd >= 0:
                    # spilled: read from the pool blob fd
                    self._req_enter("read")
                    try:
                        return os.pread(sfd, size, off)
                    except OSError as e:
                        raise pyfuse3.FUSEError(e.errno or errno.EIO)
                    finally:
                        self._req_exit()
                return bytes(wb["data"])[off:off + size]
            fd = self._fd_table.get(fh)
            if fd is None: raise pyfuse3.FUSEError(errno.EBADF)
            self._req_enter("read")
            try:
                return os.pread(fd, size, off)
            except OSError as e:
                raise pyfuse3.FUSEError(e.errno or errno.EIO)
            finally:
                self._req_exit()

        async def write(self, fh, off, buf):
            # Tier-0 write: splice into the RAM bytearray.
            wb = self._wbuf.get(fh)
            if wb is not None:
                end = off + len(buf)
                sfd = wb.get("spilled_fd", -1)
                if sfd >= 0:
                    # already spilled: write through to the blob fd
                    self._req_enter("write")
                    try:
                        written = os.pwrite(sfd, buf, off)
                    except OSError as e:
                        raise pyfuse3.FUSEError(e.errno or errno.EIO)
                    finally:
                        self._req_exit()
                    wb["dirty"] = True; wb["mtime_ns"] = time.time_ns()
                    return written
                # in-RAM path: extend bytearray as needed, splice in
                if end > len(wb["data"]):
                    wb["data"].extend(bytes(end - len(wb["data"])))
                wb["data"][off:end] = buf
                wb["dirty"] = True; wb["mtime_ns"] = time.time_ns()
                # spill if over threshold
                if len(wb["data"]) > self._WBUF_SPILL:
                    try:
                        self._spill_write_buffer(fh)
                    except OSError as e:
                        raise pyfuse3.FUSEError(e.errno or errno.EIO)
                return len(buf)
            fd = self._fd_table.get(fh)
            if fd is None: raise pyfuse3.FUSEError(errno.EBADF)
            self._req_enter("write")
            try:
                return os.pwrite(fd, buf, off)
            except OSError as e:
                raise pyfuse3.FUSEError(e.errno or errno.EIO)
            finally:
                self._req_exit()

        async def fsync(self, fh, datasync):
            # Tier-0 RAM: no-op (durable on release); spilled: fsync the blob fd.
            wb = self._wbuf.get(fh)
            if wb is not None:
                sfd = wb.get("spilled_fd", -1)
                if sfd >= 0:
                    try:
                        if datasync: os.fdatasync(sfd)
                        else: os.fsync(sfd)
                    except OSError as e:
                        raise pyfuse3.FUSEError(e.errno or errno.EIO)
                return
            fd = self._fd_table.get(fh)
            if fd is None: return
            try:
                if datasync: os.fdatasync(fd)
                else: os.fsync(fd)
            except OSError as e:
                raise pyfuse3.FUSEError(e.errno or errno.EIO)

        async def flush(self, fh):
            return

        async def release(self, fh):
            if fh in self._vfh:
                self._vfh.pop(fh, None); return
            # Tier-0 release: deflate into sqlar row (RAM) or close blob fd (spilled).
            wb = self._wbuf.pop(fh, None)
            if wb is not None:
                self._wbuf_key.pop((wb["sid"], wb["rel"]), None)
                sid, rel = wb["sid"], wb["rel"]
                sfd = wb.get("spilled_fd", -1)
                if sfd >= 0:
                    # spilled: blob file is resident; just close the fd.
                    # consolidate will deflate it into the row later.
                    try: os.close(sfd)
                    except OSError: pass
                else:
                    # RAM path: deflate into an evicted sqlar row.
                    # Also delete any stale resident pool blob so _resolve_st won't
                    # serve the old bytes instead of the new row data.
                    idx = self._index(sid)
                    rid = idx.row_id(rel)
                    if rid is not None:
                        bp = blob_path(idx.box_id, rid)
                        if bp.exists():
                            try: os.unlink(str(bp))
                            except OSError: pass
                    data_bytes = bytes(wb["data"])
                    deflated, sz = _sqlar_deflate(data_bytes)
                    idx.set_blob(rel, deflated, sz, wb["mode"],
                                 wb["mtime_ns"], wb["wid"])
                self._notify(sid, rel, "modified")
                return
            self._fh_sid.pop(fh, None)
            fd = self._fd_table.pop(fh, None)
            if fd is not None:
                try: os.close(fd)
                except OSError: pass

        # ── create / mkdir / symlink ─────────────────────────────────────────
        def _mutate_at(self, sid: str, rel: str, ctx, op, host_op, upper_op):
            """Passthrough-vs-overlay fork for _mutate, with kick-up recursion.
            Passthrough + parent  → recurse into parent's overlay (captured there).
            Passthrough + no parent → host_op on real host, unchanged.
            Non-passthrough       → upper_op records into this sid's own overlay."""
            if self._passthrough(sid, rel):
                p = self._parent(sid)
                if p is not None:
                    return self._mutate_at(p, rel, ctx, op, host_op, upper_op)  # KICK UP
                return host_op(sid, rel, self._host_path(rel))  # ROOT: real host
            wid = self._index(sid).writer_for(ctx.pid)
            self._ensure_parent_dirs(sid, rel, wid)
            idx = self._index(sid)
            upath = self._upper_path(sid, rel)
            res = upper_op(sid, rel, upath, wid, idx)
            self._notify(sid, rel, "created")
            return res

        def _mutate(self, parent_inode, name, ctx, op, host_op, upper_op):
            # THE single checked entry point for node-creating mutating handlers:
            # the security preamble (decode/key/ENOENT/writer/policy_check/EACCES/
            # _req_enter) and the passthrough-vs-overlay fork live here exactly once,
            # so no handler can skip a check. host_op/upper_op create only THIS node.
            name = os.fsdecode(name)
            pkey = self._key(parent_inode)
            if pkey is None: raise pyfuse3.FUSEError(errno.EACCES)
            sid, rel = self._child_key(pkey, name)
            if sid not in self.sessions: raise pyfuse3.FUSEError(errno.ENOENT)
            wid = self._index(sid).writer_for(ctx.pid)
            if policy_check(sid, self._index(sid).provenance_of(ctx.pid),
                            rel, op) == "deny":
                raise pyfuse3.FUSEError(errno.EACCES)
            self._req_enter(f"{op} {sid}/{rel}")
            try:
                return self._mutate_at(sid, rel, ctx, op, host_op, upper_op)
            finally:
                self._req_exit()

        async def create(self, parent_inode, name, mode, flags, ctx):
            def host_op(sid, rel, host):
                try:
                    os.makedirs(os.path.dirname(host) or "/", exist_ok=True)
                    fd = os.open(host, flags | os.O_CREAT | os.O_NOFOLLOW,
                                 mode & 0o7777)
                except OSError as e:
                    raise pyfuse3.FUSEError(e.errno or errno.EIO)
                st = os.fstat(fd)
                ino = self._ino_for(sid, rel)
                self._lookup_count[ino] = self._lookup_count.get(ino, 0) + 1
                with self._lock:
                    nfh = self._next_fh; self._next_fh += 1
                    self._fd_table[nfh] = fd
                    self._fh_sid[nfh] = sid
                return (pyfuse3.FileInfo(fh=nfh, direct_io=False, keep_cache=False),
                        self._entry(ino, st))
            def upper_op(sid, rel, upath, wid, idx):
                # Tier-0: a new/small file buffers in RAM and deflates into the sqlar
                # row on release — the common case (create()+write()+close, e.g. nearly
                # everything ./configure writes) never materializes a pool file.
                if self._should_buffer_write(sid, rel, flags, idx):
                    wb = self._create_write_buffer(sid, rel, idx, flags, ctx)
                    m = stat_mod.S_IFREG | (mode & 0o7777)
                    if wb["mode"] != m:            # honor the explicit create() mode
                        wb["mode"] = m
                        idx.set_entry(rel, "file", m, wb["wid"], "create")
                    with self._lock:
                        nfh = self._next_fh; self._next_fh += 1
                    self._wbuf[nfh] = wb
                    self._wbuf_key[(sid, rel)] = nfh
                    ino = self._ino_for(sid, rel)
                    self._lookup_count[ino] = self._lookup_count.get(ino, 0) + 1
                    return (pyfuse3.FileInfo(fh=nfh, direct_io=False, keep_cache=False),
                            self._entry(ino, self._buffer_stat(sid, rel)))
                # Tier-1: large / forced-to-disk — pool blob + fd, as before.
                # File bytes go to the pool blob, not up/<rel>. _new_file_blob
                # handles whiteout removal and index set_entry.
                try:
                    bp = self._new_file_blob(sid, rel, stat_mod.S_IFREG | (mode & 0o7777),
                                             wid, "create")
                    fd = os.open(bp, flags | os.O_CREAT | os.O_NOFOLLOW,
                                 mode & 0o7777)
                except OSError as e:
                    raise pyfuse3.FUSEError(e.errno or errno.EIO)
                st = os.fstat(fd)
                ino = self._ino_for(sid, rel)
                self._lookup_count[ino] = self._lookup_count.get(ino, 0) + 1
                with self._lock:
                    nfh = self._next_fh; self._next_fh += 1
                    self._fd_table[nfh] = fd
                    self._fh_sid[nfh] = sid
                return (pyfuse3.FileInfo(fh=nfh, direct_io=False, keep_cache=False),
                        self._entry(ino, st))
            return self._mutate(parent_inode, name, ctx, "create", host_op, upper_op)

        async def mkdir(self, parent_inode, name, mode, ctx):
            def host_op(sid, rel, host):
                try:
                    os.makedirs(os.path.dirname(host) or "/", exist_ok=True)
                    os.mkdir(host, mode & 0o7777)
                except OSError as e:
                    raise pyfuse3.FUSEError(e.errno or errno.EIO)
                ino = self._ino_for(sid, rel)
                self._lookup_count[ino] = self._lookup_count.get(ino, 0) + 1
                return self._entry(ino, os.lstat(host))
            def upper_op(sid, rel, upath, wid, idx):
                if idx.kind_of(rel) == "whiteout":
                    idx.del_entry(rel)
                opaque = 1 if self._lower_is_dir(sid, rel) else 0   # recreated over lower dir
                dmode = stat_mod.S_IFDIR | (mode & 0o7777)
                idx.set_entry(rel, "dir", dmode, wid, "mkdir", opaque=opaque,
                              mtime_ns=time.time_ns())
                ino = self._ino_for(sid, rel)
                self._lookup_count[ino] = self._lookup_count.get(ino, 0) + 1
                st = self._synth_dir_stat(dmode, idx.row_mtime(rel))
                return self._entry(ino, st)
            return self._mutate(parent_inode, name, ctx, "mkdir", host_op, upper_op)

        async def symlink(self, parent_inode, name, target, ctx):
            target = os.fsdecode(target)
            def host_op(sid, rel, host):
                try:
                    os.makedirs(os.path.dirname(host) or "/", exist_ok=True)
                    os.symlink(target, host)
                except OSError as e:
                    raise pyfuse3.FUSEError(e.errno or errno.EIO)
                ino = self._ino_for(sid, rel)
                self._lookup_count[ino] = self._lookup_count.get(ino, 0) + 1
                return self._entry(ino, os.lstat(host))
            def upper_op(sid, rel, upath, wid, idx):
                # Symlink lives ONLY in the row (target + mode + mtime) — no on-disk
                # artifact. A prior dir/symlink/file row at rel is overwritten by the
                # symlink row; a pre-existing FILE row's pool blob is dropped first.
                if idx.kind_of(rel) == "file":
                    rid = idx.row_id(rel)
                    if rid is not None:
                        try: blob_path(idx.box_id, rid).unlink()
                        except OSError: pass
                if idx.kind_of(rel) == "whiteout":
                    idx.del_entry(rel)
                mt = time.time_ns()
                tgt = target.encode("utf-8", "surrogateescape")
                idx.set_entry(rel, "symlink", stat_mod.S_IFLNK | 0o777, wid, "symlink",
                              target=tgt, mtime_ns=mt)
                ino = self._ino_for(sid, rel)
                self._lookup_count[ino] = self._lookup_count.get(ino, 0) + 1
                st = self._synth_link_stat(len(tgt), idx.row_mtime(rel))
                return self._entry(ino, st)
            return self._mutate(parent_inode, name, ctx, "symlink", host_op, upper_op)

        # ── unlink / rmdir ───────────────────────────────────────────────────
        def _merged_children(self, sid: str, rel: str) -> list:
            return [n for n, _k, _a in self._scan_dir(sid, rel)]

        def _unlink_overlay(self, sid: str, rel: str, wid) -> None:
            """Overlay (captured) unlink for sid. Removes the backing artifact and
            updates the index. Used directly and as the kick-up target."""
            idx = self._index(sid)
            bp = self._backing_path(sid, rel)
            if bp is not None and os.path.lexists(bp):
                try: os.unlink(bp)
                except OSError as e: raise pyfuse3.FUSEError(e.errno or errno.EIO)
            lower_exists = (not idx.hidden_by_opaque(rel)
                            and self._lower_exists(sid, rel))
            if lower_exists:
                idx.set_entry(rel, "whiteout", 0, wid, "unlink")
            else:
                idx.del_entry(rel, op="unlink", writer_id=wid)
            self._notify(sid, rel, "deleted")

        async def unlink(self, parent_inode, name, ctx):
            name = os.fsdecode(name)
            pkey = self._key(parent_inode)
            if pkey is None: raise pyfuse3.FUSEError(errno.EACCES)
            sid, rel = self._child_key(pkey, name)
            if sid not in self.sessions: raise pyfuse3.FUSEError(errno.ENOENT)
            wid = self._index(sid).writer_for(ctx.pid)
            if policy_check(sid, self._index(sid).provenance_of(ctx.pid),
                            rel, "unlink") == "deny":
                raise pyfuse3.FUSEError(errno.EACCES)
            self._req_enter(f"unlink {sid}/{rel}")
            try:
                if self._passthrough(sid, rel):
                    p = self._parent(sid)
                    if p is not None:
                        # KICK UP: captured delete in the parent's overlay.
                        pwid = self._index(p).writer_for(ctx.pid)
                        self._unlink_overlay(p, rel, pwid)
                        return
                    host = self._host_path(rel)
                    try: os.unlink(host)          # unlink never follows the final link
                    except FileNotFoundError: raise pyfuse3.FUSEError(errno.ENOENT)
                    except OSError as e: raise pyfuse3.FUSEError(e.errno or errno.EIO)
                    return
                self._unlink_overlay(sid, rel, wid)
            finally:
                self._req_exit()

        def _rmdir_overlay(self, sid: str, rel: str, wid) -> None:
            """Overlay (captured) rmdir for sid. Used directly and as kick-up target."""
            if self._merged_children(sid, rel):
                raise pyfuse3.FUSEError(errno.ENOTEMPTY)
            idx = self._index(sid)
            # Dir lives only in the mirror — no on-disk artifact to rmdir.
            idx.prune_subtree(rel)
            lower_is_dir = (not idx.hidden_by_opaque(rel)
                            and self._lower_is_dir(sid, rel))
            if lower_is_dir:
                idx.set_entry(rel, "whiteout", 0, wid, "rmdir")
            else:
                idx.del_entry(rel, op="rmdir", writer_id=wid)
            self._notify(sid, rel, "deleted")

        async def rmdir(self, parent_inode, name, ctx):
            name = os.fsdecode(name)
            pkey = self._key(parent_inode)
            if pkey is None: raise pyfuse3.FUSEError(errno.EACCES)
            sid, rel = self._child_key(pkey, name)
            if sid not in self.sessions: raise pyfuse3.FUSEError(errno.ENOENT)
            wid = self._index(sid).writer_for(ctx.pid)
            if policy_check(sid, self._index(sid).provenance_of(ctx.pid),
                            rel, "rmdir") == "deny":
                raise pyfuse3.FUSEError(errno.EACCES)
            self._req_enter(f"rmdir {sid}/{rel}")
            try:
                if self._passthrough(sid, rel):
                    p = self._parent(sid)
                    if p is not None:
                        # KICK UP: captured rmdir in the parent's overlay.
                        pwid = self._index(p).writer_for(ctx.pid)
                        self._rmdir_overlay(p, rel, pwid)
                        return
                    host = self._host_path(rel)
                    if os.path.islink(host): raise pyfuse3.FUSEError(errno.ENOTDIR)
                    try: os.rmdir(host)
                    except FileNotFoundError: raise pyfuse3.FUSEError(errno.ENOENT)
                    except OSError as e: raise pyfuse3.FUSEError(e.errno or errno.EIO)
                    return
                self._rmdir_overlay(sid, rel, wid)
            finally:
                self._req_exit()

        # ── setattr ──────────────────────────────────────────────────────────
        def _setattr_overlay(self, sid: str, rel: str, inode: int,
                             attr, fields, ctx) -> "pyfuse3.EntryAttributes":
            """Overlay (captured) setattr body for sid. Copy-up if needed, apply
            attr changes to the backing artifact, update index. Returns EntryAttributes
            using `inode` (the caller's FUSE inode) so the kernel cache is correct."""
            idx = self._index(sid)
            wid = idx.writer_for(ctx.pid)
            # Buffered file: apply size/mode/mtime directly to the buffer, no disk op.
            fh = self._wbuf_key.get((sid, rel))
            if fh is not None:
                wb = self._wbuf.get(fh)
                if wb is not None:
                    if fields.update_size:
                        new_sz = attr.st_size
                        cur = wb["data"]
                        if new_sz < len(cur):
                            del cur[new_sz:]
                        elif new_sz > len(cur):
                            cur.extend(bytes(new_sz - len(cur)))
                        wb["dirty"] = True
                    if fields.update_mode:
                        wb["mode"] = (wb["mode"] & ~0o7777) | stat_mod.S_IMODE(attr.st_mode)
                        wb["dirty"] = True
                    if fields.update_mtime:
                        wb["mtime_ns"] = attr.st_mtime_ns
                    bst = self._buffer_stat(sid, rel)
                    self._notify(sid, rel, "modified")
                    return self._entry(inode, bst)
            layer = self._resolve(sid, rel)
            if layer in ("absent", "whiteout"):
                raise pyfuse3.FUSEError(errno.ENOENT)
            if layer == "lower":
                # Copy up the lower entry first (file→blob, dir/symlink→mirror row).
                if stat_mod.S_ISREG(self._resolve_st(sid, rel)[2].st_mode):
                    fd = self._ensure_copyup(sid, rel, os.O_RDWR, ctx)
                    os.close(fd)
                else:
                    self._ensure_parent_dirs(sid, rel, wid)
                    self._copyup_one(sid, rel, wid)
            else:
                if idx.kind_of(rel) == "file":
                    bp_str = self._backing_path(sid, rel)
                    if bp_str is not None and not os.path.exists(bp_str):
                        self._fault_in(sid, rel)
            # Dir / symlink: no on-disk artifact — apply to the mirror row only. uid/gid
            # is squashed, so chown is an accepted no-op; mode/mtime update the row.
            k = idx.kind_of(rel)
            if k in ("dir", "symlink"):
                cur_mode, cur_mt = idx.row_mode_mtime(rel)
                if cur_mode is None:
                    cur_mode = (stat_mod.S_IFDIR | 0o755 if k == "dir"
                                else stat_mod.S_IFLNK | 0o777)
                new_mode = cur_mode
                if fields.update_mode:
                    new_mode = (cur_mode & ~0o7777) | stat_mod.S_IMODE(attr.st_mode)
                new_mt = (attr.st_mtime_ns if fields.update_mtime else cur_mt)
                # symlink: keep its target row data (set_entry target=None preserves it).
                idx.set_entry(rel, k, new_mode, wid, "setattr", mtime_ns=new_mt)
                if k == "dir":
                    st = self._synth_dir_stat(new_mode, idx.row_mtime(rel))
                else:
                    tgt = idx.symlink_target(rel) or b""
                    st = self._synth_link_stat(len(tgt), idx.row_mtime(rel))
                self._notify(sid, rel, "modified")
                return self._entry(inode, st)
            # Dir/symlink returned early above; only regular files reach here.
            upath = self._backing_path(sid, rel) or self._upper_path(sid, rel)
            try:
                if fields.update_size or fields.update_mode:
                    fd = os.open(upath, os.O_RDWR | os.O_NOFOLLOW)
                    try:
                        if fields.update_size: os.ftruncate(fd, attr.st_size)
                        if fields.update_mode:
                            os.fchmod(fd, stat_mod.S_IMODE(attr.st_mode))
                    finally:
                        os.close(fd)
                if fields.update_uid or fields.update_gid:
                    uid = attr.st_uid if fields.update_uid else -1
                    gid = attr.st_gid if fields.update_gid else -1
                    os.chown(upath, uid, gid, follow_symlinks=False)
                if fields.update_mtime or fields.update_atime:
                    st0 = os.lstat(upath)
                    atime_ns = (attr.st_atime_ns if fields.update_atime
                                else st0.st_atime_ns)
                    mtime_ns = (attr.st_mtime_ns if fields.update_mtime
                                else st0.st_mtime_ns)
                    os.utime(upath, ns=(atime_ns, mtime_ns), follow_symlinks=False)
            except OSError as e:
                raise pyfuse3.FUSEError(e.errno or errno.EIO)
            st = os.lstat(upath)
            idx.set_entry(rel, "file", st.st_mode, wid, "setattr")
            self._notify(sid, rel, "modified")
            return self._entry(inode, st)

        async def setattr(self, inode, attr, fields, fh, ctx):
            key = self._key(inode)
            if key is None: raise pyfuse3.FUSEError(errno.EPERM)
            sid, rel = key
            if sid not in self.sessions: raise pyfuse3.FUSEError(errno.ENOENT)
            if policy_check(sid, self._index(sid).provenance_of(ctx.pid),
                            rel, "setattr") == "deny":
                raise pyfuse3.FUSEError(errno.EACCES)
            self._req_enter(f"setattr {sid}/{rel}")
            try:
                if self._passthrough(sid, rel):
                    p = self._parent(sid)
                    if p is not None:
                        # KICK UP: captured setattr in the parent's overlay.
                        return self._setattr_overlay(p, rel, inode, attr, fields, ctx)
                    upath = self._host_path(rel)
                    if not os.path.lexists(upath):
                        raise pyfuse3.FUSEError(errno.ENOENT)
                    is_link = stat_mod.S_ISLNK(os.lstat(upath).st_mode)
                    try:
                        if (fields.update_size or fields.update_mode) and not is_link:
                            fd = os.open(upath, os.O_RDWR | os.O_NOFOLLOW)
                            try:
                                if fields.update_size: os.ftruncate(fd, attr.st_size)
                                if fields.update_mode:
                                    os.fchmod(fd, stat_mod.S_IMODE(attr.st_mode))
                            finally:
                                os.close(fd)
                        # chown/utime have real no-follow variants (lchown / utimensat
                        # AT_SYMLINK_NOFOLLOW): they act on the link itself, never target.
                        if fields.update_uid or fields.update_gid:
                            uid = attr.st_uid if fields.update_uid else -1
                            gid = attr.st_gid if fields.update_gid else -1
                            os.chown(upath, uid, gid, follow_symlinks=False)
                        if fields.update_mtime or fields.update_atime:
                            st0 = os.lstat(upath)
                            atime_ns = (attr.st_atime_ns if fields.update_atime
                                        else st0.st_atime_ns)
                            mtime_ns = (attr.st_mtime_ns if fields.update_mtime
                                        else st0.st_mtime_ns)
                            os.utime(upath, ns=(atime_ns, mtime_ns), follow_symlinks=False)
                    except OSError as e:
                        raise pyfuse3.FUSEError(e.errno or errno.EIO)
                    return self._entry(inode, os.lstat(upath))
                return self._setattr_overlay(sid, rel, inode, attr, fields, ctx)
            finally:
                self._req_exit()

        async def statfs(self, ctx):
            s = pyfuse3.StatvfsData()
            try:
                vfs = os.statvfs(str(live_home()))
                s.f_bsize = vfs.f_bsize; s.f_frsize = vfs.f_frsize
                s.f_blocks = vfs.f_blocks; s.f_bfree = vfs.f_bfree
                s.f_bavail = vfs.f_bavail; s.f_files = vfs.f_files
                s.f_ffree = vfs.f_ffree; s.f_favail = vfs.f_favail
            except OSError:
                s.f_bsize = s.f_frsize = 4096
                s.f_blocks = s.f_bfree = s.f_bavail = 1 << 20
                s.f_files = s.f_ffree = s.f_favail = 1 << 16
            s.f_namemax = 255
            return s

        # ── copy-up of one entry (for rename/link materialization) ───────────
        def _copyup_one(self, sid: str, rel: str, wid) -> None:
            """Copy one entry into the overlay. Dirs and symlinks are mirrored into the
            Index row only (no on-disk artifact). Regular files go into the pool blob
            (flat, rowid-addressed). The early-return guard uses the correct backing
            per type."""
            idx = self._index(sid)
            # For files: the blob is the backing; for dirs/symlinks: up/<rel>.
            k = idx.kind_of(rel)
            if k == "file":
                rid = idx.row_id(rel)
                if rid is not None:
                    bp = blob_path(idx.box_id, rid)
                    if bp.exists():
                        return   # already resident (blob present)
                    # evicted own file: fault in (inflate row -> blob); no re-copy
                    row = idx.file_row(rel)
                    if row is not None and row[4] is not None:
                        self._fault_in(sid, rel)
                        return
            elif idx.kind_of(rel) in ("dir", "symlink"):
                return   # already recorded in this box's mirror
            self._ensure_parent_dirs(sid, rel, wid)
            layer, ap, st = self._resolve_st(sid, rel)
            if layer in ("lower", "upper"):     # host, or (nested) an ancestor's upper
                if stat_mod.S_ISLNK(st.st_mode):
                    # Record the symlink as a row only (no on-disk artifact). The target
                    # comes from the owning mirror (overlay link) or os.readlink (host).
                    tgt = self._readlink_source(sid, rel, ap)
                    if tgt is None: return
                    idx.set_entry(rel, "symlink", stat_mod.S_IFLNK | 0o777, wid,
                                  "copyup_symlink",
                                  target=tgt.encode("utf-8", "surrogateescape"),
                                  mtime_ns=getattr(st, "st_mtime_ns", 0))
                elif stat_mod.S_ISDIR(st.st_mode):
                    idx.set_entry(rel, "dir", st.st_mode, wid, "copyup_dir",
                                  mtime_ns=getattr(st, "st_mtime_ns", 0))
                else:
                    # ap is None when the source is an evicted row in an ancestor (base)
                    # session.  Write its row bytes into the child's blob WITHOUT
                    # mutating the read-only base (no fault-in / row-null).
                    if ap is None:
                        data = self._evicted_bytes(sid, rel)
                        if data is None:
                            return   # can't resolve source; skip silently
                        bp_str = self._new_file_blob(sid, rel, st.st_mode, wid, "copyup")
                        try:
                            dst = os.open(bp_str, os.O_RDWR | os.O_CREAT | os.O_NOFOLLOW,
                                          stat_mod.S_IMODE(st.st_mode))
                            try: os.write(dst, data)
                            finally: os.close(dst)
                        except OSError:
                            pass
                        return
                    # ap is a real on-disk path (lower or resident upper): copy to blob.
                    src = os.open(ap, os.O_RDONLY | os.O_NOFOLLOW)
                    try:
                        bp_str = self._new_file_blob(sid, rel, st.st_mode, wid, "copyup")
                        dst = os.open(bp_str, os.O_RDWR | os.O_CREAT | os.O_NOFOLLOW,
                                      stat_mod.S_IMODE(st.st_mode))
                        try: reflink_or_copy(src, dst)
                        finally: os.close(dst)
                    finally:
                        os.close(src)
                    # set_entry already done by _new_file_blob

        def _materialize_tree(self, sid: str, rel: str, wid) -> None:
            """Walk the merged view of rel and copy every entry into the upper."""
            self._copyup_one(sid, rel, wid)
            for name, _k, _a in self._scan_dir(sid, rel):
                child = (rel + "/" + name) if rel else name
                layer, _ap, st = self._resolve_st(sid, child)
                if layer in ("absent", "whiteout"): continue
                if stat_mod.S_ISDIR(st.st_mode):
                    self._materialize_tree(sid, child, wid)
                else:
                    self._copyup_one(sid, child, wid)

        def _rename_overlay(self, sid: str, rel_o: str, rel_n: str,
                            flags: int, st_o, ctx) -> None:
            """Overlay (captured) rename body for sid. Used directly and as kick-up
            target. Caller holds _req_enter; st_o is lstat of the source."""
            idx = self._index(sid)
            wid = idx.writer_for(ctx.pid)
            layer_n = self._resolve(sid, rel_n)
            if flags & getattr(pyfuse3, "RENAME_NOREPLACE", 1):
                if layer_n not in ("absent", "whiteout"):
                    raise pyfuse3.FUSEError(errno.EEXIST)
            dst_shadows_lower = (not idx.hidden_by_opaque(rel_n)
                                 and self._lower_is_dir(sid, rel_n))
            is_dir = stat_mod.S_ISDIR(st_o.st_mode)
            is_reg = stat_mod.S_ISREG(st_o.st_mode)
            src_shadowed_lower = (not idx.hidden_by_opaque(rel_o)
                                  and self._lower_exists(sid, rel_o))
            if is_dir:
                self._materialize_tree(sid, rel_o, wid)
            else:
                self._copyup_one(sid, rel_o, wid)
            # Remove any existing destination FILE pool blob (dirs/symlinks carry no
            # on-disk artifact; their rows are replaced by reparent/rename_row below).
            if idx.kind_of(rel_n) == "file":
                dst_bp = self._backing_path(sid, rel_n)
                if dst_bp and os.path.lexists(dst_bp):
                    try: os.unlink(dst_bp)
                    except OSError: pass
            self._ensure_parent_dirs(sid, rel_n, wid)
            if is_dir:
                # Move the dir subtree in the mirror (rows). File blobs stay put,
                # addressed by rowid which reparent preserves — no on-disk rename.
                # Drop the destination's prior overlay subtree (rows + their pool
                # blobs) before moving the source over it — else those entries
                # survive as ghosts with orphaned bytes.
                idx.prune_subtree(rel_n)
                idx.reparent(rel_o, rel_n, wid)
                idx.set_entry(rel_n, "dir", st_o.st_mode, wid, "rename_to",
                              opaque=1 if dst_shadows_lower else None)
                if src_shadowed_lower:
                    idx.set_entry(rel_o, "whiteout", 0, wid, "rename_from")
                else:
                    idx.del_entry(rel_o, op="rename_from", writer_id=wid)
            elif is_reg:
                # Regular file: NO os.rename — blob stays at its rowid address.
                # rename_row moves the index entry in place (keeps rowid+blob).
                idx.rename_row(rel_o, rel_n, wid)
                if dst_shadows_lower:
                    # UPSERT to set opaque without changing rowid/kind.
                    idx.set_entry(rel_n, "file", st_o.st_mode, wid, "rename_to",
                                  opaque=1)
                if src_shadowed_lower:
                    idx.set_entry(rel_o, "whiteout", 0, wid, "rename_from")
                # rename_row already removed rel_o from the index; if src was NOT
                # lower-shadowed, nothing more to do (del_entry already implicit).
            else:
                # Symlink: move the row in place (target data preserved by rename_row).
                # _copyup_one above recorded rel_o's symlink row in this box's mirror.
                idx.rename_row(rel_o, rel_n, wid)
                if dst_shadows_lower:
                    idx.set_entry(rel_n, "symlink", st_o.st_mode, wid, "rename_to",
                                  opaque=1)
                if src_shadowed_lower:
                    idx.set_entry(rel_o, "whiteout", 0, wid, "rename_from")
            self._remap_inode_subtree(sid, rel_o, rel_n)
            # rename = remove-old + add-new for the live map.
            self._notify(sid, rel_o, "deleted")
            self._notify(sid, rel_n, "created")

        async def rename(self, parent_old, name_old, parent_new, name_new,
                         flags, ctx):
            if flags & getattr(pyfuse3, "RENAME_EXCHANGE", 2):
                raise pyfuse3.FUSEError(errno.ENOSYS)
            name_old = os.fsdecode(name_old); name_new = os.fsdecode(name_new)
            pko = self._key(parent_old); pkn = self._key(parent_new)
            if pko is None or pkn is None: raise pyfuse3.FUSEError(errno.EACCES)
            sid_o, rel_o = self._child_key(pko, name_old)
            sid_n, rel_n = self._child_key(pkn, name_new)
            if sid_o != sid_n or sid_o not in self.sessions:
                raise pyfuse3.FUSEError(errno.EXDEV)
            sid = sid_o
            if policy_check(sid, self._index(sid).provenance_of(ctx.pid),
                            rel_o, "rename") == "deny":
                raise pyfuse3.FUSEError(errno.EACCES)
            # passthrough: both ends act on the real host. Both-ends-or-overlay:
            # only when BOTH paths pass through do we touch the host; if either side
            # is captured we fall through to overlay capture below. Symlink safety:
            # rename(2) operates on the names, never dereferences the final components.
            if self._passthrough(sid, rel_o) and self._passthrough(sid, rel_n):
                p = self._parent(sid)
                if p is not None:
                    # KICK UP: rename as a captured op in the parent's overlay.
                    # Resolve st_o through the parent (since the file lives there).
                    layer_o, _ap_o, st_o = self._resolve_st(p, rel_o)
                    if layer_o in ("absent", "whiteout"):
                        raise pyfuse3.FUSEError(errno.ENOENT)
                    self._req_enter(f"rename {sid}/{rel_o}->{rel_n}")
                    try:
                        self._rename_overlay(p, rel_o, rel_n, flags, st_o, ctx)
                        return
                    finally:
                        self._req_exit()
                self._req_enter(f"rename {sid}/{rel_o}->{rel_n}")
                try:
                    ho = self._host_path(rel_o); hn = self._host_path(rel_n)
                    if not os.path.lexists(ho): raise pyfuse3.FUSEError(errno.ENOENT)
                    try:
                        os.makedirs(os.path.dirname(hn) or "/", exist_ok=True)
                        os.rename(ho, hn)
                    except OSError as e:
                        raise pyfuse3.FUSEError(e.errno or errno.EIO)
                    return
                finally:
                    self._req_exit()
            layer_o, _ap_o, st_o = self._resolve_st(sid, rel_o)
            if layer_o in ("absent", "whiteout"):
                raise pyfuse3.FUSEError(errno.ENOENT)
            self._req_enter(f"rename {sid}/{rel_o}->{rel_n}")
            try:
                self._rename_overlay(sid, rel_o, rel_n, flags, st_o, ctx)
            finally:
                self._req_exit()

        def _remap_inode_subtree(self, sid: str, rel_o: str, rel_n: str) -> None:
            with self._lock:
                oldp = rel_o + "/"; newp = rel_n + "/"
                remap = []
                for (ksid, krel), ino in list(self._key_to_ino.items()):
                    if ksid != sid: continue
                    if krel == rel_o:
                        remap.append(((ksid, krel), (ksid, rel_n), ino))
                    elif krel.startswith(oldp):
                        remap.append(((ksid, krel), (ksid, newp + krel[len(oldp):]), ino))
                for oldkey, newkey, ino in remap:
                    self._key_to_ino.pop(oldkey, None)
                    self._key_to_ino[newkey] = ino
                    self._ino_to_key[ino] = newkey

        def _link_overlay(self, sid: str, rel_src: str, rel_n: str,
                          st, ino: int, ctx) -> "pyfuse3.EntryAttributes":
            """Overlay (captured) link body for sid. Used directly and as kick-up
            target. ino is the FUSE inode for rel_n (from the caller's session)."""
            idx = self._index(sid)
            wid = idx.writer_for(ctx.pid)
            self._copyup_one(sid, rel_src, wid)
            self._ensure_parent_dirs(sid, rel_n, wid)
            try:
                if stat_mod.S_ISLNK(st.st_mode):
                    # link-as-copy of a symlink: copy the target into a new row (no
                    # on-disk artifact). _copyup_one above recorded rel_src's target
                    # into this box's mirror; fall back to the source resolution.
                    tgt_b = idx.symlink_target(rel_src)
                    if tgt_b is None:
                        _l, ap_s, _s = self._resolve_st(sid, rel_src)
                        tgt_s = self._readlink_source(sid, rel_src, ap_s)
                        tgt_b = (tgt_s.encode("utf-8", "surrogateescape")
                                 if tgt_s is not None else b"")
                    idx.set_entry(rel_n, "symlink", stat_mod.S_IFLNK | 0o777, wid,
                                  "link_as_copy", detail=rel_src,
                                  target=tgt_b,
                                  mtime_ns=getattr(st, "st_mtime_ns", 0))
                else:
                    src_bp = self._backing_path(sid, rel_src)
                    if src_bp is None:
                        # No pool blob backs the source (e.g. an open write-buffered
                        # file not yet spilled): nothing to reflink-copy from here.
                        raise pyfuse3.FUSEError(errno.EIO)
                    dst_bp = self._new_file_blob(sid, rel_n, st.st_mode, wid,
                                                 "link_as_copy", detail=rel_src)
                    src = os.open(src_bp, os.O_RDONLY | os.O_NOFOLLOW)
                    try:
                        dst = os.open(dst_bp, os.O_RDWR | os.O_CREAT | os.O_NOFOLLOW,
                                      stat_mod.S_IMODE(st.st_mode))
                        try: reflink_or_copy(src, dst)
                        finally: os.close(dst)
                    finally:
                        os.close(src)
            except OSError as e:
                raise pyfuse3.FUSEError(e.errno or errno.EIO)
            self._lookup_count[ino] = self._lookup_count.get(ino, 0) + 1
            self._notify(sid, rel_n, "created")
            # Symlink dst has no on-disk artifact: stat it via the mirror.
            _l, _ap, st_n = self._resolve_st(sid, rel_n)
            return self._entry(ino, st_n)

        async def link(self, inode, new_parent, new_name, ctx):
            new_name = os.fsdecode(new_name)
            key = self._key(inode); pkn = self._key(new_parent)
            if key is None or pkn is None: raise pyfuse3.FUSEError(errno.EPERM)
            sid, rel_src = key
            sid_n, rel_n = self._child_key(pkn, new_name)
            if sid != sid_n or sid not in self.sessions:
                raise pyfuse3.FUSEError(errno.EXDEV)
            layer, _ap, st = self._resolve_st(sid, rel_src)
            if layer in ("absent", "whiteout"): raise pyfuse3.FUSEError(errno.ENOENT)
            if stat_mod.S_ISDIR(st.st_mode): raise pyfuse3.FUSEError(errno.EPERM)
            wid = self._index(sid).writer_for(ctx.pid)
            if policy_check(sid, self._index(sid).provenance_of(ctx.pid),
                            rel_n, "link") == "deny":
                raise pyfuse3.FUSEError(errno.EACCES)
            self._req_enter(f"link {sid}/{rel_src}->{rel_n}")
            try:
                # Both-ends-or-overlay: hardlink on the host only when BOTH source and
                # new name pass through; if either is captured, fall through to copy-up.
                if self._passthrough(sid, rel_src) and self._passthrough(sid, rel_n):
                    p = self._parent(sid)
                    if p is not None:
                        # KICK UP: link-as-copy in the parent's overlay.
                        # Resolve st through the parent (source lives there).
                        player, _pap, pst = self._resolve_st(p, rel_src)
                        if player in ("absent", "whiteout"):
                            raise pyfuse3.FUSEError(errno.ENOENT)
                        ino = self._ino_for(sid, rel_n)
                        return self._link_overlay(p, rel_src, rel_n, pst, ino, ctx)
                    hs = self._host_path(rel_src); hn = self._host_path(rel_n)
                    try:
                        os.makedirs(os.path.dirname(hn) or "/", exist_ok=True)
                        # follow_symlinks=False: hardlink the link itself, never target
                        os.link(hs, hn, follow_symlinks=False)
                    except OSError as e:
                        raise pyfuse3.FUSEError(e.errno or errno.EIO)
                    ino = self._ino_for(sid, rel_n)
                    self._lookup_count[ino] = self._lookup_count.get(ino, 0) + 1
                    return self._entry(ino, os.lstat(hn))
                ino = self._ino_for(sid, rel_n)
                return self._link_overlay(sid, rel_src, rel_n, st, ino, ctx)
            finally:
                self._req_exit()

        def flush_wbuf(self, force: bool = False) -> None:
            """Snapshot all dirty RAM-backed write buffers to their sqlar rows.

            WHY: if the process dies with files still open, in-RAM bytes are lost.
            This method snapshots each dirty buffer into the evicted sqlar row using
            the same deflate path as release() — crash-resilient durability without
            closing the file or resetting the buffer (the bytearray stays the live
            authoritative copy; reads still serve from it, not from the row snapshot).

            Called periodically by the trio serve task (_periodic_flush) and once on
            exit in OverlayMount.stop() before the FUSE session is torn down.

            MUST be called on the serve (trio) thread only — _wbuf is NOT thread-safe.
            force=True snapshots even non-dirty buffers (used on exit so nothing is missed).
            Spilled buffers (spilled_fd >= 0) are already on disk; skip them."""
            for fh, wb in list(self._wbuf.items()):
                try:
                    if wb.get("spilled_fd", -1) >= 0:
                        continue   # already on disk in the pool blob; not at risk
                    if not force and not wb.get("dirty", False):
                        continue   # unchanged since last snapshot; skip
                    sid, rel = wb["sid"], wb["rel"]
                    idx = self._index(sid)
                    # Delete any stale pool blob so _resolve_st won't serve old bytes.
                    rid = idx.row_id(rel)
                    if rid is not None:
                        bp = blob_path(idx.box_id, rid)
                        if bp.exists():
                            try: os.unlink(str(bp))
                            except OSError: pass
                    data_bytes = bytes(wb["data"])
                    deflated, sz = _sqlar_deflate(data_bytes)
                    # Mirror release()'s exact call — sets data NOT NULL in the row.
                    idx.set_blob(rel, deflated, sz, wb["mode"],
                                 wb["mtime_ns"], wb["wid"])
                    # Mark clean so unchanged buffers are skipped on the next cycle.
                    # write() already sets dirty=True on any subsequent write, so this is safe.
                    wb["dirty"] = False
                except Exception:
                    pass   # one bad entry must not abort the rest

        def _notify(self, sid: str, rel: str = None, op: str = None) -> None:
            """Live-feedback seam: tell the UI a box's overlay changed so the Changes
            view refreshes event-driven (NOT by polling). Carries the affected `rel`
            and an `op` ("created"/"modified"/"deleted") so the UI folds the change
            into its live map in O(1) — no re-walk. Called from the mutating handlers;
            the handoff itself is thread-safe (see OverlayMount)."""
            try: self.on_event(type="overlay_changed", sid=sid, rel=rel, op=op)
            except Exception: pass

    return MultiplexOverlayFs


# ════════════════════════════════════════════════════════════════════════════
#  Overlay mount manager — OverlayMount (trio thread) + Session model & discovery
# ════════════════════════════════════════════════════════════════════════════
# pyfuse3 serve loop runs on trio in a dedicated background thread; Textual UI +
# mitmproxy run on asyncio in the main thread. The two loops cannot share a thread:
# the serving thread does all FUSE I/O and hands events to the UI thread-safely (a
# thread-safe queue drained via asyncio). Index/RAM mutations are single-writer on
# the serving thread.
# Session model & discovery: Session dataclass, discover_sessions(), liveness
# helpers (_pid_alive/_pidfd_alive/_box_running), and rm_rf() follow OverlayMount.

class OverlayMount:
    def __init__(self, mountpoint: Path, lower: str = "/"):
        self.mountpoint = Path(mountpoint)
        self.lower = lower
        self.ops = None
        self._thread = None
        self._started = threading.Event()
        self._start_error = None
        self._stop_trio = None       # set to a trio Event from inside the loop
        self._trio_token = None
        self.event_q: "queue.Queue" = queue.Queue()

    def _on_ops_event(self, **ev) -> None:
        # called from the trio serving thread; hand off to the UI thread-safely
        self.event_q.put(ev)

    def start(self) -> bool:
        """Mount the single overlay and start serving. Blocks until the serve loop is
        actually up (or failed). Returns True on success. Fail-closed: a mount
        failure is reported, never swallowed."""
        # Fail fast with an actionable message if the FUSE device is missing,
        # rather than letting pyfuse3/fusermount3 die with a cryptic error.
        if not os.path.exists("/dev/fuse"):
            self._start_error = RuntimeError(
                "FUSE device /dev/fuse missing; toolbox provides it, plain "
                "podman needs `--device /dev/fuse`")
            return False
        try:
            self.mountpoint.mkdir(parents=True, exist_ok=True)
        except OSError as e:
            self._start_error = e; return False
        make_ops = _build_overlay_ops()
        self.ops = make_ops(self.lower, on_event=self._on_ops_event)
        self._thread = threading.Thread(target=self._run, name="overlay-fuse",
                                        daemon=True)
        self._thread.start()
        self._started.wait(timeout=30)
        if self._start_error is not None:
            return False
        if not self._started.is_set():
            self._start_error = TimeoutError("overlay mount did not come up in 30s")
            return False
        return True

    def _run(self) -> None:
        import pyfuse3, trio
        fuse_options = set(pyfuse3.default_options)
        fuse_options.add("fsname=slopbox")
        # same uid as the mounter -> no allow_other needed; do NOT set
        # default_permissions (we report squash ownership ourselves).
        try:
            pyfuse3.init(self.ops, str(self.mountpoint), fuse_options)
        except Exception as e:
            self._start_error = e
            self._started.set()
            return

        ops = self.ops

        async def _periodic_flush():
            """Snapshot dirty RAM write buffers every 5 s — runs on the serve thread
            so _wbuf access is safe (no locks needed, same thread as all FUSE ops).
            Cancelled cleanly when the nursery scope is cancelled on stop()."""
            while True:
                await trio.sleep(5)
                try:
                    ops.flush_wbuf()
                except Exception as _e:
                    print(f"[overlay] periodic flush error: {_e}", file=sys.stderr)

        async def _main():
            self._trio_token = trio.lowlevel.current_trio_token()
            self._stop_trio = trio.Event()
            async with trio.open_nursery() as nursery:
                nursery.start_soon(pyfuse3.main)
                nursery.start_soon(_periodic_flush)
                # signal "serving" only after the loop is running.
                self._started.set()
                await self._stop_trio.wait()
                nursery.cancel_scope.cancel()
        try:
            trio.run(_main)
        except Exception as e:
            if self._start_error is None:
                self._start_error = e
            self._started.set()
        finally:
            try: pyfuse3.close(unmount=True)
            except Exception: pass

    def add_session(self, sid: str, up: Path, index: "Index",
                    passthrough: bool = False, parent: "str | None" = None) -> None:
        if self.ops is not None:
            self.ops.add_session(sid, up, index, passthrough=passthrough,
                                 parent=parent)

    def remove_session(self, sid: str) -> None:
        if self.ops is not None:
            self.ops.remove_session(sid)

    def set_parent(self, sid: str, parent: "str | None") -> None:
        if self.ops is not None:
            self.ops.set_parent(sid, parent)

    def add_ca_spoof(self, sid: str, ca_bytes: bytes, bundle_paths) -> None:
        """Register the CA-augmented trust bundle as virtual files for this session:
        the box sees system_ca + our mitmproxy CA at every bundle path, but the
        augmented bytes are invisible to consolidate (no on-disk artifact)."""
        if self.ops is None: return
        for p in bundle_paths:
            lp = Path(p)
            try:
                if not lp.is_file(): continue
                base = lp.read_bytes()
            except OSError:
                continue
            sep = b"" if base.endswith(b"\n") else b"\n"
            self.ops.add_virtual(sid, p.lstrip("/"), base + sep + b"\n" + ca_bytes)

    def is_healthy(self) -> bool:
        """True only when the mount actually started successfully and is serving."""
        return self._started.is_set() and self._start_error is None and self.ops is not None

    def inflight_age(self):
        return self.ops.inflight_age() if self.ops else None

    # A handler wedged longer than this is treated as hung (watchdog).
    WATCHDOG_HANG_S = 30.0

    def watchdog_recover(self) -> bool:
        """Supervisor-owned recovery: if a FUSE handler has been in-flight too
        long, the single trio serve loop is frozen and any client parked in that
        request is in D-state. Lazy-unmount aborts the FUSE connection — that frees
        the parked clients (~tens of ms) and recovers the mount table. Returns True
        if a recovery was triggered.

        Note: a fuller recovery would also close the raw /dev/fuse fd to end the
        serve loop deterministically; pyfuse3 doesn't surface that fd, so the
        lazy-unmount (which the kernel turns into an ENODEV on the wedged loop) is the
        v1 mechanism. Offloading slow blocking syscalls to a thread pool to avoid
        wedging in the first place is the known later upgrade."""
        age = self.inflight_age()
        if age is None or age < self.WATCHDOG_HANG_S:
            return False
        try:
            subprocess.run(["fusermount3", "-uz", str(self.mountpoint)],
                           stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                           timeout=10)
        except (FileNotFoundError, subprocess.TimeoutExpired):
            pass
        return True

    def stop(self) -> None:
        """Stop serving and unmount. Lazy-unmount as a fallback so the mount table is
        clean even if the loop is wedged (watchdog)."""
        ev = self._stop_trio; token = self._trio_token
        if ev is not None and token is not None:
            try:
                import trio
                # Force-flush all dirty RAM buffers on the serve thread BEFORE stopping,
                # so open files' bytes reach the sqlar row even if the UI/process dies.
                # run_sync schedules the call on the trio event loop (serve thread) and
                # blocks the UI thread until it completes — safe because flush_wbuf is
                # synchronous and _wbuf is only mutated by the serve thread.
                if self.ops is not None:
                    try:
                        trio.from_thread.run_sync(self.ops.flush_wbuf,
                                                  True,   # force=True
                                                  trio_token=token)
                    except Exception:
                        pass   # best-effort; proceed with shutdown regardless
                trio.from_thread.run_sync(ev.set, trio_token=token)
            except trio.RunFinishedError:
                # The serve loop already finished (e.g. unmounted/crashed); the
                # lazy-unmount fallback below still cleans the mount table. Log rather
                # than swallow so a premature exit is visible (LOW-4).
                print("slopbox(ui): overlay serve loop already finished at stop()",
                      file=sys.stderr)
            except Exception as e:
                print(f"slopbox(ui): overlay stop signalling failed: {e}",
                      file=sys.stderr)
        if self._thread is not None:
            self._thread.join(timeout=5)
        # lazy-unmount fallback (recovers the mount table even if wedged)
        try:
            if os.path.ismount(str(self.mountpoint)):
                subprocess.run(["fusermount3", "-uz", str(self.mountpoint)],
                               stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                               timeout=10)
        except (FileNotFoundError, subprocess.TimeoutExpired):
            pass


# ── consolidate / unconsolidate ──────────────────────────────────────────────
def _is_overlay_marker(name: str) -> bool:
    """Guard against legacy char-device whiteout / opaque-directory marker names
    (.wh..opq, .wh..wh.*) appearing in the upper. These are never created by this
    overlay model — kept as a defensive filter in upper_has_changes and cleanup_dirs."""
    return name == ".wh..opq" or name.startswith(".wh..wh.")

def upper_has_changes(up: Path) -> bool:
    """True if the overlay upper holds a STRAY on-disk artifact (a leftover file).
    Under the no-mirror invariant up/ holds no change artifacts at all — files live
    in the content pool, dirs/symlinks live in the sqlar rows — so this normally
    returns False and the box's reviewable state is gauged from its sqlar
    (sqlar_list/has_flows) by every caller. Kept as a defensive stray-artifact
    detector (and to recognize a pre-invariant orphan tree)."""
    for root, _dirs, files in os.walk(up, onerror=lambda _e: None):
        if any(not _is_overlay_marker(nm) for nm in files):
            return True
    return False

def is_whiteout(p: Path) -> bool:
    try:
        st = p.stat(); return stat_mod.S_ISCHR(st.st_mode) and st.st_rdev == 0
    except OSError: return False

def _is_symlink(p: Path) -> bool:
    """True if p is itself a symlink (lstat, never follows). Used to refuse writing
    THROUGH a symlink onto the host / into the upper from the UI thread (LOW-3)."""
    return Path(p).is_symlink()

def _restore_host_mtime_ns(host, mtime_ns, is_symlink: bool) -> None:
    """Set host's mtime to exactly `mtime_ns` integer nanoseconds (atime too). For a
    symlink, utime the link itself (follow_symlinks=False). Best-effort/no-op if
    mtime_ns is None or the platform can't utime a symlink."""
    if mtime_ns is None: return
    n = int(mtime_ns)
    try:
        os.utime(host, ns=(n, n), follow_symlinks=not is_symlink)
    except (OSError, NotImplementedError):
        pass

def remove_upper_entry(p: Path) -> None:
    """Remove one upper artifact: a file, a directory tree, or a char-device
    whiteout. No-op if nothing is there (e.g. an opacity-only deletion)."""
    try:
        if p.is_dir() and not p.is_symlink() and not is_whiteout(p):
            shutil.rmtree(p)
        elif p.exists() or p.is_symlink() or is_whiteout(p):
            p.unlink()
    except FileNotFoundError:
        pass

def cleanup_dirs(upper: Path, start: Path) -> None:
    """Walk up from `start` toward `upper`, removing directories that hold no real
    change. A dir with only opaque markers is removed only when the lower has
    nothing there (a freshly-created dir); otherwise the markers record deletions
    and the dir is kept. Dirs with files/whiteouts stop the walk."""
    d = start
    while d != upper and upper in d.parents:
        try: children = list(d.iterdir())
        except OSError: break
        if any(not _is_overlay_marker(c.name) for c in children):
            break
        if children:
            rel = d.relative_to(upper)
            if Path("/").joinpath(*rel.parts).is_dir():
                break
        parent = d.parent
        try: shutil.rmtree(d)
        except OSError: break
        d = parent

def _open_index_ro(shm_dir) -> "Index | None":
    """Open the session's single db for consolidate. None if absent."""
    sp = sqlar_path(Path(shm_dir).name)
    if not sp.exists(): return None
    try: return Index(Path(shm_dir))
    except sqlite3.Error: return None

def consolidate(shm_dir, session_id: str, index: "Index | None" = None,
                progress=None) -> None:
    """Settle a box's overlay into its single sqlar at rest — PLACEMENT ONLY, no file
    rules. Symlinks/dirs already carry their truth in the row (target/mode/mtime written
    at creation — no fold walk); each regular file picks a per-file rest form by size
    (small → folded sqlar blob; large → kept as a PERMANENT pool file, the row left
    resident with data NULL); deletions/opacity become tombstone rows. Writer
    provenance per path is recorded. Afterwards the sqlar (plus any kept pool files) is
    the box's complete at-rest form and the backing tree can be freed. Idempotent.

    Apply/discard of file rules is NOT done here — those run on box DELETE or on an
    explicit UI action (ChangeReview.apply/discard), never on box stop. So consolidate
    runs at stop purely to make the box reviewable; nothing reaches the host.

    `progress`, if given, is called as progress(done, total) after each upper entry is
    folded so a UI can render a fraction while consolidate runs off the loop."""
    upper = Path(shm_dir) / "up"
    if not upper.is_dir(): return
    own_index = index is None
    idx = index if index is not None else _open_index_ro(shm_dir)
    sp = sqlar_path(session_id)
    # Pool id for this box: needed to locate blob files.
    box_id = as_box_id(session_id)
    sq = _sqlar_open(sp)
    def _set_blob(rel, content: bytes, mode, mtime_ns) -> None:
        data, sz = _sqlar_deflate(content)
        sq.execute("UPDATE sqlar SET mode=?, mtime=?, sz=?, data=? WHERE name=?",
                   (int(mode), int(mtime_ns), sz, sqlite3.Binary(data), rel))
        if sq.execute("SELECT changes()").fetchone()[0] == 0:
            # No pre-existing row (orphaned overlay with no live index): create it.
            _sqlar_put_file(sq, rel, content, mode, mtime_ns)
    def _prov(rel):
        return idx.writer_provenance(rel) if idx is not None else None
    moved = []
    blob_paths_to_evict = []
    try:
        # 1) symlinks/dirs need NO fold walk: their rows already carry the truth — the
        #    symlink target was written into the row at creation (set_entry target=...),
        #    dir rows hold mode/mtime, and neither has an on-disk artifact. (A stray file
        #    artifact under up/ is unexpected but still folded gracefully below.) The walk
        #    here only catches such strays; the symlink-fold path is gone.
        paths = []
        for root, dirs, names in os.walk(upper, onerror=lambda _e: None):
            for nm in names: paths.append(Path(root) / nm)
        ordered = sorted(set(paths)); total_upper = len(ordered)
        for done, ap in enumerate(ordered, 1):
            rel = str(ap.relative_to(upper))
            if progress is not None:
                try: progress(done, total_upper)
                except Exception: pass
            try:
                if ap.is_file() and not ap.is_symlink():
                    # Regular files no longer live in up/; a file here is unexpected
                    # but handle it gracefully (fold it in, then remove).
                    st = ap.stat()
                    _set_blob(rel, ap.read_bytes(), st.st_mode, st.st_mtime_ns)
                    p = _prov(rel)
                    if p: _sqlar_put_provenance(sq, rel, p)
                else:
                    continue                                 # dirs handled by cleanup
            except OSError:
                continue
            moved.append(ap)
        # 1b) regular-file rows: bytes live in pool blobs (data IS NULL). Place by size:
        #     a large file stays a PERMANENT pool file (row resident: data NULL, blob kept
        #     on disk — record its real size/mode/mtime so offline readers report correct
        #     metadata); a small file folds into the sqlar blob and its pool file is evicted.
        file_rows = sq.execute(
            "SELECT rowid, name, mode FROM sqlar WHERE data IS NULL").fetchall()
        for rowid, rel, mode in file_rows:
            if not stat_mod.S_ISREG(mode): continue         # dir/symlink/tombstone rows
            bp = blob_path(box_id, rowid)
            if not bp.exists(): continue                     # no blob (not yet written)
            try:
                bst = os.stat(bp)
                mtime_ns = bst.st_mtime_ns
                content = bp.read_bytes()
            except OSError:
                continue
            if len(content) >= POOL_RESIDENT_MIN:
                sq.execute("UPDATE sqlar SET mode=?, mtime=?, sz=?, data=NULL WHERE name=?",
                           (int(mode), int(mtime_ns), len(content), rel))
                if sq.execute("SELECT changes()").fetchone()[0] == 0:
                    # Orphaned overlay with no live-index row: create a resident row.
                    sq.execute("INSERT INTO sqlar(name,mode,mtime,sz,data) VALUES(?,?,?,?,NULL)",
                               (rel, int(mode), int(mtime_ns), len(content)))
                # blob NOT evicted: it IS the rest form.
            else:
                _set_blob(rel, content, mode, mtime_ns)
                blob_paths_to_evict.append(bp)
            p = _prov(rel)
            if p: _sqlar_put_provenance(sq, rel, p)
        # 2) deletions (whiteouts) from the index -> tombstone rows (already present, but
        #    re-assert for the orphaned-overlay path) + provenance.
        if idx is not None:
            for rel in idx.deletions():
                host = Path("/") / rel
                if host.exists() or host.is_symlink():
                    _sqlar_put_tombstone(sq, rel)
                    p = _prov(rel)
                    if p: _sqlar_put_provenance(sq, rel, p)
                else:
                    sq.execute("DELETE FROM sqlar WHERE name=?", (rel,))
                    sq.execute("DELETE FROM provenance WHERE path=?", (rel,))
            # 3) opaque dirs: expand into per-lower-child tombstones for children not
            #    re-materialized in the upper or the pool.
            for drel in idx.opaque_dirs():
                lower = Path("/") / drel
                if not lower.is_dir(): continue
                for lroot, ldirs, lfiles in os.walk(lower, onerror=lambda _e: None):
                    for nm in ldirs + lfiles:
                        crel = os.path.relpath(os.path.join(lroot, nm), "/")
                        # Re-materialized children live in the ROW now (dirs/symlinks have
                        # no upper artifact; files keep a pool blob or an evicted row). A
                        # non-tombstone row of ANY kind means the child was re-created.
                        row = sq.execute("SELECT rowid, mode, data FROM sqlar WHERE name=?",
                                         (crel,)).fetchone()
                        if row and not stat_mod.S_ISCHR(row[1]):
                            if stat_mod.S_ISREG(row[1]):
                                if blob_path(box_id, row[0]).exists() or row[2] is not None:
                                    continue                  # file present in pool or row
                                # regular row with neither blob nor data: fall through to
                                # tombstone (the bytes are gone).
                            else:
                                continue                      # dir/symlink re-created
                        _sqlar_put_tombstone(sq, crel)
        sq.commit()
    finally:
        sq.close()
    for ap in moved:
        remove_upper_entry(ap); cleanup_dirs(upper, ap.parent)
    for bp in blob_paths_to_evict:
        try: bp.unlink()
        except OSError: pass
    if own_index and idx is not None:
        idx.close()

def unconsolidate(shm_dir) -> None:
    """Ensure the empty `up/` discovery sentinel exists inside `shm_dir`. The Index
    mirror (dirs, symlinks) and pool blobs (regular files) are the authoritative
    state — nothing is rebuilt on disk. Idempotent."""
    upper = Path(shm_dir) / "up"
    upper.mkdir(parents=True, exist_ok=True)

def _pid_alive(pid: int) -> bool:
    if not pid: return False
    try:
        os.kill(pid, 0); return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True

def _pidfd_alive(pidfd: int) -> bool:
    """True while the process the pidfd refers to is still running. A pidfd becomes
    readable once its process exits (Linux >=5.3), so 'not readable' == alive. Wrap-
    immune: the pidfd names one exact process incarnation, never a reused pid."""
    if pidfd is None or pidfd < 0:
        return False
    try:
        r, _, _ = select.select([pidfd], [], [], 0)
    except (OSError, ValueError):
        return False
    return not r

def _box_running(s) -> bool:
    """True iff box `s` has a live runner root right now — the wrap-immune liveness
    that Session.status uses. PID-reuse-safe: never trusts s.pid (a reused pid could
    make a finished box look alive and be read or freed as if it were running)."""
    return bool(s and s.live and s.run_pidfd >= 0 and _pidfd_alive(s.run_pidfd))

def rm_rf(path) -> None:
    """Remove a tree, fixing perms (backing dirs are created with restrictive modes,
    e.g. 0700, so a plain rmtree would fail on subdirectories)."""
    path = str(path)
    if not os.path.exists(path) and not os.path.islink(path):
        return
    def _fix_and_retry(func, p, _exc):
        try:
            os.chmod(p, 0o700)
            par = os.path.dirname(p)
            if par: os.chmod(par, 0o700)
        except OSError:
            pass
        try: func(p)
        except OSError: pass
    try:
        shutil.rmtree(path, onexc=_fix_and_retry)
    except TypeError:
        shutil.rmtree(path, onerror=_fix_and_retry)
    if os.path.exists(path):
        for root, dirs, files in os.walk(path, topdown=False):
            for nm in files + dirs:
                fp = os.path.join(root, nm)
                try: os.chmod(fp, 0o700)
                except OSError: pass
                try: (os.rmdir if os.path.isdir(fp) and not os.path.islink(fp)
                      else os.unlink)(fp)
                except OSError: pass
        try: os.chmod(path, 0o700); os.rmdir(path)
        except OSError: pass



@dataclass
class Session:
    session_id: str                # the box's internal key, str(box_id) — its identity
    cmd: list
    shm_dir: str = ""              # the session backing dir: live/<box_id> (up only)
    # status is DERIVED (see .status): a box is "running" iff it currently has a live
    # runner root (kernel-derived liveness via the held pidfd). These flags only record
    # WHY a stopped box stopped — they never make a box appear running.
    killed: bool = False           # the box was killed (vs exiting on its own)
    errored: bool = False          # bwrap never launched (nothing was written)
    exit_code: "int | None" = None
    conn_allowed: int = 0
    conn_denied: int = 0
    bytes_up: int = 0
    bytes_down: int = 0
    sess_rules: list = field(default_factory=list)   # ordered, session-only Rules
    live: bool = False
    has_sqlar: bool = False                           # the single db has entries
    has_flows: bool = False                           # the single db has flows
    box_id: int = 0              # the box's stable integer id (== int(session_id))
    name: str = ""              # the box's mutable user-facing NAME label
    run_pid: int = 0              # the live runner's host pid (set at register)
    run_pidfd: int = -1           # held pidfd of the live runner; liveness handle, closed at teardown
    parent_box_id: "int | None" = None  # parent's box_id (kernel-derived); None for top-level
    # started time comes from the box's on-disk ctime (the id is numeric and carries no
    # timestamp); pid is the live runner's host pid.
    @property
    def started(self) -> float:
        return box_ctime(self.box_id or self.session_id)
    @property
    def pid(self) -> int:
        return self.run_pid
    @property
    def upper(self) -> str: return str(Path(self.shm_dir) / "up")
    @property
    def status(self) -> str:
        # Box status is a property of its running roots, NOT a stored flag flipped on
        # stop: a box is "running" iff it has a live runner root right now (kernel-
        # derived liveness via the held pidfd — wrap-immune). With no running root the
        # box is stopped, and the flags say why. A box discovered from disk (no held
        # pidfd this UI run) is, by definition, not running.
        if _box_running(self):
            return "running"
        if self.killed:
            return "killed"
        if self.errored:
            return "error"
        return "finished"
    def to_dict(self) -> dict:
        d = {k: v for k, v in asdict(self).items() if k != "sess_rules"}
        d["sess_rules"] = [r.to_line() for r in self.sess_rules]
        d["upper"] = self.upper
        d["status"] = self.status
        d["started"] = self.started; d["pid"] = self.pid
        # session_id stays == str(box_id) (the internal key); `name` is the mutable label.
        # The derived dotted display `path` is injected at the Supervisor _emit boundary.
        return d


def _parent_box_id_of(af) -> "int | None":
    v = sqlar_meta_get(af, "parent_box_id")
    try: return int(v) if v else None
    except (ValueError, TypeError): return None

def discover_sessions() -> dict:
    """Find sessions purely from the on-disk box_id identity: live/<box_id> backing
    dirs (an un-consolidated/orphaned overlay) plus the single <box_id>.sqlar under
    state_home. The key is str(box_id). The NAME label and parent_box_id pointer come
    from the sqlar meta; the command is the root process row in the sqlar."""
    out = {}
    lh = live_home()
    if lh.exists():
        for d in lh.iterdir():
            if not (d / "up").is_dir(): continue          # not a slopbox backing dir
            sid = d.name
            if not BOX_ID_RE.match(sid): continue            # not a box_id-named dir
            # No held pidfd for a disk-discovered box (its runner, if any, belonged to a
            # prior UI run we don't own), so .status derives to "finished" — correct: a
            # box this UI isn't running can't be "running".
            out[sid] = Session(
                session_id=sid, box_id=int(sid), cmd=root_cmd(sid), shm_dir=str(d),
                live=False)
    sd = state_home()
    if sd.exists():
        for af in sd.glob("*.sqlar"):
            sid = af.name[:-len(".sqlar")]
            if not BOX_ID_RE.match(sid): continue            # not a box_id-named sqlar
            s = out.get(sid)
            if s is None:
                s = out[sid] = Session(
                    session_id=sid, box_id=int(sid), cmd=root_cmd(sid),
                    shm_dir=str(live_dir(sid)), live=False)
            s.has_sqlar = sqlar_nonempty(af)
            s.has_flows = has_flows(af)
            # The NAME label and parent pointer come from meta. Empty/missing parent meta
            # means a top-level box (parent None). Without the parent pointer a nested box
            # would come back top-level and apply/promote would target the host.
            s.name = sqlar_meta_get(af, "name") or ""
            s.parent_box_id = _parent_box_id_of(af)
    return out


