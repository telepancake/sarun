# These are pure path helpers: they must NOT create anything at import time. The
# in-slopbox `--inner` process imports this module too, and any directory it
# touched (under the slopboxed HOME) would be captured by the overlay and show up
# as a bogus "change". Real directory creation is deferred to ensure_dirs(),
# called only by the UI and the runner.
def data_home() -> Path:
    base = os.environ.get("XDG_DATA_HOME") or os.path.expanduser("~/.local/share")
    return Path(base) / "slopbox"

def config_home() -> Path:
    base = os.environ.get("XDG_CONFIG_HOME") or os.path.expanduser("~/.config")
    return Path(base) / "slopbox"

def runtime_home() -> Path:
    base = os.environ.get("XDG_RUNTIME_DIR")
    return Path(base) / "slopbox" if base else data_home()

def live_home() -> Path:
    """Per-session overlay backing: live/<sid>/{up,index.db}. Holds provenance, so
    it is created mode 0700. Replaces the old /dev/shm/slopbox.<sid> overlay dirs."""
    return runtime_home() / "live"

def live_dir(session_id: str) -> Path:
    return live_home() / session_id

def mnt_point() -> Path:
    """The single pyfuse3 mountpoint the UI owns; box subfolders live under it as
    <mnt>/<sid>. Empty at rest."""
    return runtime_home() / "mnt"

SOCK_PATH      = str(runtime_home() / "ui.sock")        # control + FD channel
MITM_CONFDIR   = data_home() / "mitmproxy"              # CA, generated once
CA_CERT        = MITM_CONFDIR / "mitmproxy-ca-cert.pem"
RULES_FILE     = config_home() / "netrules"             # allow/deny network rules
FILE_RULES_FILE = config_home() / "filerules"           # apply/discard by path glob

def ensure_dirs() -> None:
    """Create our host-side config/data/runtime directories. Called by the UI and
    the runner — never by the in-slopbox --inner process."""
    for p in (data_home(), config_home(), runtime_home(), MITM_CONFDIR, state_home()):
        try: p.mkdir(parents=True, exist_ok=True)
        except OSError: pass
    # live/ holds provenance (pid/exe/argv of writers) — restrict it (R8).
    try: live_home().mkdir(parents=True, mode=0o700, exist_ok=True)
    except OSError: pass
    try: os.chmod(live_home(), 0o700)
    except OSError: pass
    try: mnt_point().mkdir(parents=True, exist_ok=True)
    except OSError: pass
    # migrate the old single "rules" file to its new name "netrules"
    old_rules = config_home() / "rules"
    if old_rules.exists() and not RULES_FILE.exists():
        try: old_rules.rename(RULES_FILE)
        except OSError: pass
    for f in (RULES_FILE, FILE_RULES_FILE):
        try: f.touch(exist_ok=True)
        except OSError: pass

INNER_PROXY_PORT = 8080   # forwarder's listen port inside the slopbox


# ════════════════════════════════════════════════════════════════════════════
#  Wire protocol (control messages: newline JSON; FD messages: SCM_RIGHTS)
# ════════════════════════════════════════════════════════════════════════════

async def aw_send(writer: asyncio.StreamWriter, **msg: Any) -> None:
    writer.write((json.dumps(msg) + "\n").encode()); await writer.drain()

async def aw_recv(reader: asyncio.StreamReader) -> "dict | None":
    try:
        line = await reader.readline()
        return json.loads(line.decode()) if line else None
    except (json.JSONDecodeError, asyncio.IncompleteReadError, OSError):
        return None

def sync_send(sock_path: str, timeout: float = 5.0, **msg: Any) -> None:
    try:
        with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as s:
            s.settimeout(timeout); s.connect(sock_path)
            s.sendall((json.dumps(msg) + "\n").encode())
    except OSError:
        pass

def sync_request(sock_path: str, timeout: float = 30.0, **msg: Any) -> "dict | None":
    """Send one control message and wait for a single newline-JSON reply. Used by the
    runner to register a session and block until the UI has created live/<sid> and
    exposed <mnt>/<sid> (so the bwrap bind target exists). None on any failure."""
    try:
        with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as s:
            s.settimeout(timeout); s.connect(sock_path)
            s.sendall((json.dumps(msg) + "\n").encode())
            buf = b""
            while b"\n" not in buf:
                chunk = s.recv(4096)
                if not chunk: break
                buf += chunk
            line = buf.split(b"\n", 1)[0]
            return json.loads(line.decode()) if line.strip() else None
    except (OSError, json.JSONDecodeError):
        return None

def ui_is_running(sock_path: str) -> bool:
    try:
        with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as s:
            s.settimeout(1.0); s.connect(sock_path); return True
    except OSError:
        return False


# ════════════════════════════════════════════════════════════════════════════
#  Inner forwarder — `slopbox --inner` (runs as pid-1-ish inside the slopbox)
# ════════════════════════════════════════════════════════════════════════════
#
# Listens on 127.0.0.1:INNER_PROXY_PORT. For each accepted connection, sends the
# connection's FD plus the session id to the UI's FD channel over a Unix socket
# that was bind-mounted into the slopbox. Then execs the real command. The
# forwarder holds no bytes; the UI drives the proxied conversation.

def run_inner(channel_path: str, session_id: str, cmd: list) -> int:
    stop = threading.Event()

    def forward_one(conn: socket.socket) -> None:
        try:
            with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as ch:
                ch.connect(channel_path)
                ch.sendmsg(
                    [json.dumps({"session_id": session_id}).encode()],
                    [(socket.SOL_SOCKET, socket.SCM_RIGHTS,
                      array.array("i", [conn.fileno()]).tobytes())],
                )
            # The UI now owns a dup of the FD; we can close ours.
        except OSError:
            pass
        finally:
            conn.close()

    def listener() -> None:
        srv = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        srv.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        try:
            srv.bind(("127.0.0.1", INNER_PROXY_PORT))
            srv.listen(64)
        except OSError as e:
            print(f"slopbox(inner): cannot listen: {e}", file=sys.stderr)
            return
        srv.settimeout(0.5)
        while not stop.is_set():
            try:
                conn, _ = srv.accept()
            except socket.timeout:
                continue
            except OSError:
                break
            threading.Thread(target=forward_one, args=(conn,), daemon=True).start()
        srv.close()

    # Only run the forwarder if a channel exists (i.e. networked + UI present).
    if channel_path and os.path.exists(os.path.dirname(channel_path) or "/"):
        threading.Thread(target=listener, daemon=True).start()

    # Run the real command as a foreground job *inside* this PID namespace. We are
    # PID 1 here, so the process-group ids we put on the controlling terminal are
    # namespace-local — which is what lets an interactive job-control shell
    # (bash/dash) save and restore the terminal's foreground group without hitting
    # "Cannot set tty process group (No such process)". The command gets its own
    # process group and the terminal handed to it; restored when it exits.
    tty_fd = next((fd for fd in (0, 1, 2) if os.isatty(fd)), None)
    old_fg = None
    if tty_fd is not None:
        try: old_fg = os.tcgetpgrp(tty_fd)
        except OSError: old_fg = None
    try:
        proc = subprocess.Popen(cmd, preexec_fn=os.setpgrp)
    except FileNotFoundError:
        print(f"slopbox(inner): command not found: {cmd[0]}", file=sys.stderr)
        return 127
    try: os.setpgid(proc.pid, proc.pid)
    except OSError: pass
    old_ttou = None
    if tty_fd is not None:
        old_ttou = signal.signal(signal.SIGTTOU, signal.SIG_IGN)
        try: os.tcsetpgrp(tty_fd, proc.pid)
        except OSError: pass
    try:
        code = proc.wait()
    except KeyboardInterrupt:
        proc.terminate()
        code = proc.wait()
    if tty_fd is not None:
        if old_fg is not None:
            try: os.tcsetpgrp(tty_fd, old_fg)
            except OSError: pass
        if old_ttou is not None:
            try: signal.signal(signal.SIGTTOU, old_ttou)
            except (OSError, ValueError): pass
    stop.set()
    return code or 0


