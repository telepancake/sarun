        def _refresh_file_rules(self):
            lv=self.query_one("#r-list",ListView)
            idx=lv.index; lv.clear()
            for r in self.frules_store.rules:
                col="red" if r.action=="discard" else "green"
                sign="−" if r.action=="discard" else "+"
                lv.append(ListItem(Label(Text(f"{sign} {r.action} {r.pattern}", style=col))))
            n=len(self.frules_store.rules)
            if idx is not None and n: lv.index=min(idx, n-1)

        def _file_rules_changed(self):
            # A new/changed rule should get a chance to act on whatever is still in
            # the overlays, so let those sessions consolidate again on next view.
            self.sup._consolidated.clear()
            self._refresh_file_rules()

        def _file_rule_add(self):
            def done(line):
                if not line: return
                r=FileRule.parse(line)
                if not r:
                    self._status("invalid file rule — use: apply|discard <glob>"); return
                self.frules_store.insert(r); self._file_rules_changed()
                try: self.query_one("#r-list",ListView).index=len(self.frules_store.rules)-1
                except Exception: pass
            self.push_screen(FileRuleLineModal("discard "), done)

        def _file_rule_edit_at(self, i):
            rules=self.frules_store.rules
            if i is None or not (0<=i<len(rules)): return
            def done(line):
                if line is None: return
                r=FileRule.parse(line)
                if not r: self._status("invalid file rule — keeping the old one"); return
                rules[i]=r; self.frules_store.save(); self._file_rules_changed()
                try: self.query_one("#r-list",ListView).index=i
                except Exception: pass
            self.push_screen(FileRuleLineModal(rules[i].to_line()), done)

        def _file_rule_del(self, i):
            self.frules_store.remove_at(i); self._file_rules_changed()
        def _file_rule_move(self, i, d):
            j=self.frules_store.move(i, d); self._file_rules_changed()
