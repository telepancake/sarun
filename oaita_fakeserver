#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = []
# ///
"""
oaita_fakeserver — a zero-dependency, OpenAI-compatible FAKE API server.

A reusable test double for the OpenAI HTTP API. Tests (and later the real
`oaita` client) drive it for exact, network-free control over what the
"model" returns. It is pure stdlib — no `openai`, no `httpx`, no anything —
yet it speaks the wire format the official `openai` SDK parses without error:
proper `chat.completion` JSON for non-streaming calls and a valid
Server-Sent-Events stream of `chat.completion.chunk` objects for streaming.

Two ways to consume it:

  • imported by a test —
        loader = importlib.machinery.SourceFileLoader(
            "oaita_fakeserver", "/path/to/oaita_fakeserver")
        m = loader.load_module()
        with m.FakeOpenAIServer() as srv:
            srv.enqueue("hi there")
            base_url = srv.base_url            # point the openai SDK here
            ...
            assert srv.requests[-1].model == "test-model"

  • run directly — `./oaita_fakeserver` runs a built-in self-smoke that
    exercises every code path with `urllib` (no third-party deps) and prints
    `ALL PASS` / `N FAILURE(S)`.

Design contract: the server gives EXACT control. A test ENQUEUEs canned
responses (`CannedChat` / `CannedError` / `CannedRaw`, or a bare str/dict) and
the server pops them FIFO; every received request is CAPTURED as a
`CapturedRequest` for later assertions. If a chat request arrives with an empty
queue and no `default`, the server answers 500 with a loud "nothing enqueued"
error — so a test that forgot to enqueue fails obviously rather than silently.

Sections:
    1 · Imports & small helpers
    2 · Canned-response value types (CannedChat / CannedError / CannedRaw)
    3 · Request capture (CapturedRequest)
    4 · The HTTP request handler
    5 · The server (FakeOpenAIServer)
    6 · __main__ self-smoke
"""

from __future__ import annotations

# ════════════════════════════════════════════════════════════════════════════
#  1 · Imports & small helpers
# ════════════════════════════════════════════════════════════════════════════
import json
import sys
import threading
import time
from dataclasses import dataclass, field
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from urllib.parse import urlparse, parse_qs

# Compact JSON: no superfluous whitespace, matching what real API servers emit.
_JSON = dict(separators=(",", ":"), ensure_ascii=False)


def _dumps(obj) -> str:
    return json.dumps(obj, **_JSON)


_counter_lock = threading.Lock()
_counter = 0


def _gen_id(prefix: str = "chatcmpl") -> str:
    """Stable-ish, monotonically-unique id like the real `chatcmpl-...`."""
    global _counter
    with _counter_lock:
        _counter += 1
        n = _counter
    return f"{prefix}-fake{int(time.time()*1000):x}{n:04x}"


def _default_usage() -> dict:
    return {"prompt_tokens": 9, "completion_tokens": 12, "total_tokens": 21}


def _split_content(content: str, n: int) -> list[str]:
    """Split `content` into up to `n` non-empty contiguous pieces (chars)."""
    if not content:
        return []
    n = max(1, int(n))
    if n >= len(content):
        # One piece per char (still non-empty), capped at len(content).
        return list(content)
    size, rem = divmod(len(content), n)
    pieces, i = [], 0
    for k in range(n):
        # Spread the remainder across the first `rem` pieces.
        step = size + (1 if k < rem else 0)
        pieces.append(content[i:i + step])
        i += step
    return [p for p in pieces if p]


